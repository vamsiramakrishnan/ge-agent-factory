{
  "name": "ge-agent-factory",
  "private": true,
  "version": "0.1.0",
  "description": "Gemini Enterprise transformation deck and use-case demo factory",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "ge": "tools/ge.mjs"
  },
  "scripts": {
    "setup": "bun run tools/setup-harness.mjs",
    "ge": "bun tools/ge.mjs",
    "dev": "bun scripts/dev-help.mjs",
    "start": "bun scripts/dev-help.mjs",
    "build": "bun scripts/dev-help.mjs",
    "preview": "bun scripts/dev-help.mjs",
    "dev:console": "bun run --filter ./apps/console dev",
    "dev:presentation": "bun run --filter ./apps/presentation dev",
    "dev:generator": "bun run --filter ./apps/ge-demo-generator dev",
    "build:console": "bun run --filter ./apps/console build",
    "build:presentation": "bun run --filter ./apps/presentation build",
    "start:console": "PORT=8261 bun run --filter ./apps/console start",
    "start:presentation": "PORT=8251 bun run --filter ./apps/presentation start",
    "preview:console": "bun run --filter ./apps/console preview",
    "preview:presentation": "bun run --filter ./apps/presentation preview",
    "lint": "bun run --filter '*' lint",
    "catalog": "bun apps/ge-demo-generator/scripts/sync-use-cases-from-slides.mjs",
    "test": "bun test apps tools packages",
    "test:py": "python3 -m pytest apps/ge-demo-generator/mcp-service/tests packages/simulator-runtime -q",
    "ci": "bun run source:hygiene && bun run lint && bun run test",
    "generator:dev": "bun run --filter ./apps/ge-demo-generator dev",
    "generator:sync": "bun run apps/ge-demo-generator/scripts/sync-use-cases-from-slides.mjs",
    "generator:sync-registry-db": "node apps/ge-demo-generator/scripts/sync-agent-spec-registry-db.mjs",
    "generator:audit": "bun run apps/ge-demo-generator/scripts/audit-usecase-specs.mjs",
    "generator:emit-baselines": "bun run apps/ge-demo-generator/scripts/emit-baseline-specs.mjs",
    "generator:inventory-systems": "node apps/ge-demo-generator/scripts/inventory-upstream-systems.mjs",
    "generator:simulator-coverage": "node apps/ge-demo-generator/scripts/plan-simulator-coverage.mjs",
    "generator:materialize-simulators": "node apps/ge-demo-generator/scripts/materialize-simulator-seeds.mjs",
    "generator:download-openapi-specs": "node apps/ge-demo-generator/scripts/download-openapi-specs.mjs",
    "generator:tools-from-openapi": "node apps/ge-demo-generator/scripts/generate-tools-from-openapi.mjs",
    "generator:validate-simulators": "node apps/ge-demo-generator/scripts/validate-simulator-pack.mjs",
    "generator:test-simulators": "python3 -m pytest apps/ge-demo-generator/mcp-service/tests/test_simulator_conformance.py",
    "source:hygiene": "node tools/source-hygiene.mjs",
    "generator:new-simulator": "node apps/ge-demo-generator/scripts/scaffold-simulator-pack.mjs"
  },
  "dependencies": {
    "@ge/agent-resolver": "workspace:*",
    "@ge/run-ledger": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "citty": "^0.2.2",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  }
}
