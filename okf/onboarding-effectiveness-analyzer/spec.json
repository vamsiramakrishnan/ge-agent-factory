  "department": "hr",
  "sourcePath": "../presentation/src/components/slides/use-cases/hr/OnboardingEffectivenessAnalyzer.tsx",
  "subtitle": "A-213 • Onboarding & Integration",
  "persona": "HR Ops Lead",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-2",
  "systems": [
    "Workday",
    "LMS",
    "Survey Platform",
    "Google BigQuery"
  ],
  "kpis": [
    {
      "label": "Measurement depth",
      "before": "Completion rate only",
      "after": "Multi-signal"
    },
    {
      "label": "Attrition prediction",
      "before": "None",
      "after": "30-day forecast"
    },
    {
      "label": "Cohort benchmarking",
      "before": "Annual",
      "after": "Real-time"
    }
  ],
  "statusQuo": [
    "Onboarding effectiveness measured solely by task completion rates with no link to productivity or retention outcomes.",
    "No cohort-level benchmarking to identify which onboarding paths produce the best new hire performance.",
    "Feedback loops between onboarding experience and program design are broken — surveys collected but rarely actioned."
  ],
  "agentification": [
    "Multi-signal effectiveness scoring combining survey sentiment, early performance metrics, and engagement data.",
    "Cohort benchmarking that compares onboarding outcomes across roles, locations, and hiring channels.",
    "Predictive early attrition flags that identify at-risk new hires and recommend targeted intervention actions."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "New hire performance data, retention status, role details"
      },
      {
        "system": "BigQuery",
        "description": "Onboarding analytics warehouse, cohort benchmarks"
      },
      {
        "system": "Looker",
        "description": "Onboarding effectiveness dashboards, cohort comparisons"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Multi-signal effectiveness scoring, attrition prediction"
      }
    ],
    "pipeline": [
      {
        "label": "Signal Aggregation",
        "description": "Collect survey responses, completion metrics, early performance signals, and engagement data from Workday. Aggregate into BigQuery analytics warehouse."
      },
      {
        "label": "Effectiveness Scoring",
        "description": "Multi-signal effectiveness scoring combining sentiment, early performance, and engagement. Cohort benchmarking across roles, locations, and hiring channels."
      },
      {
        "label": "Early Warning & Dashboards",
        "description": "Predictive early attrition flags for at-risk new hires. Real-time dashboards published to Looker with recommended intervention actions."
      }
    ]
  },
