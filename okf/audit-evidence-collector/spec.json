    "anomalies": [
      {
        "id": "audit-evidence-collector-baseline-gap",
        "description": "Seed a realistic gap where Evidence collection time sits between 3-4 weeks per audit and 2-3 days, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "tickets",
          "change_requests"
        ],
        "discoveryPath": [
          "Inspect ServiceNow GRC records for the affected entities",
          "Compare against Google Drive historical baseline",
          "Generate a citation-backed recommendation"
        ],
