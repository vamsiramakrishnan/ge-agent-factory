  "department": "it",
  "sourcePath": "../presentation/src/components/slides/use-cases/it/AuditEvidenceCollector.tsx",
  "subtitle": "A-4502 • IT Governance & Compliance",
  "persona": "Compliance & GRC Lead",
  "layer": "Layer 2: Agent Designer",
  "triggerType": "event",
  "domainId": "domain-45",
  "systems": [
    "ServiceNow GRC",
    "Google Drive",
    "Jira",
    "Slack",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Evidence collection time",
      "before": "3-4 weeks per audit",
      "after": "2-3 days"
    },
    {
      "label": "Evidence completeness",
      "before": "70% on first pass",
      "after": "92% auto-collected"
    },
    {
      "label": "Audit prep labor hours",
      "before": "200+ hours",
      "after": "40 hours"
    }
  ],
  "statusQuo": [
    "Audit evidence collection is a 3-4 week scramble involving 15+ people across the organization.",
    "Evidence scattered across Google Drive, Jira, Slack, and email — each request requires detective work.",
    "Auditors receive incomplete packages on first submission, triggering follow-up requests and delays."
  ],
  "agentification": [
    "Gemini interprets auditor requests in audit language and maps them to specific internal evidence sources.",
    "Auto-collects evidence from Jira, Google Drive, Slack, and ServiceNow — eliminating manual artifact hunting.",
    "Identifies gaps before submission, reducing follow-up requests and audit cycle time."
  ],
  "architecture": {
    "connections": [
      {
        "system": "ServiceNow GRC",
        "description": "Audit requests, control framework, evidence requirements"
      },
      {
        "system": "Google Drive",
        "description": "Policy documents, meeting minutes, approval records"
      },
      {
        "system": "Jira",
        "description": "Change tickets, approval workflows, remediation tracking"
      },
      {
        "system": "Slack",
        "description": "Communication records, approval threads, incident responses"
      },
      {
        "system": "BigQuery",
        "description": "Evidence collection analytics, coverage tracking, freshness scoring"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Request interpretation, evidence gap identification"
      }
    ],
    "pipeline": [
      {
        "label": "Request Interpretation",
        "description": "Parse the auditor's evidence request — often written in audit language. Map to specific internal systems, data types, and time periods. Identify which controls the request relates to."
      },
      {
        "label": "Multi-System Collection",
        "description": "Auto-collect evidence from mapped sources: change tickets from Jira, policy documents from Google Drive, approval threads from Slack, incident records from ServiceNow. Validate freshness and completeness."
      },
      {
        "label": "Gap Analysis",
        "description": "Analyze collected evidence for completeness against the audit request. Identify missing artifacts, stale documents, and weak evidence that may not satisfy the auditor."
      },
      {
        "label": "Package Assembly",
        "description": "Organize evidence in audit-ready format with table of contents, cross-references to controls, and narrative context. Flag gaps requiring manual collection."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Audit Evidence Collector so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
