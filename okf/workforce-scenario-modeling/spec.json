  "kpis": [
    {
      "label": "Scenarios per cycle",
      "before": "2-3",
      "after": "50+"
    },
    {
      "label": "Forecast accuracy",
      "before": "60%",
      "after": "92%"
    },
    {
      "label": "Planning cycle",
      "before": "8 weeks",
      "after": "2 days"
    }
  ],
  "statusQuo": [
    "Demand forecasting done in siloed spreadsheets with manual assumptions.",
    "Gap analysis compares static snapshots, often outdated by the time of review.",
    "Limited to 2-3 scenarios per cycle due to manual effort."
  ],
  "agentification": [
    "Gemini runs multi-scenario models with real-time business signals.",
    "Interactive 'what-if' analysis for attrition, hiring ramp, and contractor mix.",
    "Automated supply-side strategies (Build vs Buy vs Bot)."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Headcount, org hierarchy, attrition history"
      },
      {
        "system": "SAP BPC",
        "description": "Financial plans, cost center budgets, FTE targets"
      },
      {
        "system": "Anaplan",
        "description": "Workforce planning models, scenario parameters"
      },
      {
        "system": "BigQuery",
        "description": "Unified workforce data lake, trend analytics"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Multi-scenario demand modeling, gap reasoning"
      }
    ],
    "pipeline": [
      {
        "label": "Data Aggregation",
        "description": "Ingest headcount, attrition, and financial plan data from Workday, SAP BPC, and Anaplan. Normalize into a unified workforce data model in BigQuery."
      },
      {
        "label": "Demand Forecasting",
        "description": "Run multi-variable demand models using revenue forecasts, attrition projections, and business signals. Generate 50+ scenario variations with confidence intervals."
      },
      {
        "label": "Gap Analysis & Strategy",
        "description": "Gemini reasons about skills, headcount, and location gaps across scenarios. Generates Build vs Buy vs Bot recommendations with cost-benefit trade-offs."
      }
    ]
  },
