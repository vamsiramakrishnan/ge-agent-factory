{
  "id": "itsm-analytics-dashboard",
  "title": "ITSM Analytics Dashboard",
  "department": "it",
  "sourcePath": "../presentation/src/components/slides/use-cases/it/ITSMAnalyticsDashboard.tsx",
  "subtitle": "IT5-08 • IT Service Management",
  "persona": "IT Service Desk Manager",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-42",
  "systems": [
    "ServiceNow",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Report creation time",
      "before": "4-6 hours manual",
      "after": "Automated weekly"
    },
    {
      "label": "Anomaly explanation",
      "before": "Requires investigation",
      "after": "Auto-contextualized"
    },
    {
      "label": "Metric coverage",
      "before": "5 core KPIs",
      "after": "25+ metrics with trends"
    }
  ],
  "statusQuo": [
    "Weekly ITSM report manually assembled from ServiceNow exports, taking 4-6 hours per week.",
    "Volume anomalies (rollout spikes, outage-related tickets) require manual investigation to explain.",
    "Report covers only 5 core KPIs due to time constraints in manual data gathering."
  ],
  "agentification": [
    "Gemini generates the weekly report automatically with trend commentary and anomaly explanations.",
    "LLM separates signal from noise — 'volume up 15% from MFA rollout, underlying demand flat.'",
    "Comprehensive 25+ metric coverage with drill-down capability replaces 5-KPI spreadsheet."
  ],
  "architecture": {
    "connections": [
      {
        "system": "ServiceNow",
        "description": "Ticket data, SLA metrics, CSAT surveys, agent performance"
      },
      {
        "system": "BigQuery",
        "description": "ITSM analytics warehouse, trend computations"
      },
      {
        "system": "Looker",
        "description": "Dashboard visualizations, metric presentations"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Trend narrative generation, anomaly explanation"
      }
    ],
    "pipeline": [
      {
        "label": "Metric Aggregation",
        "description": "Pull ITSM metrics from ServiceNow across all processes — incident volume, request fulfillment time, change failure rates, problem resolution, and CSAT scores."
      },
      {
        "label": "Trend Computation & Anomaly Detection",
        "description": "Compute week-over-week trends, detect volume anomalies (e.g., MFA rollout spike), and calculate performance metrics including first-contact resolution and agent productivity."
      },
      {
        "label": "Report Narrative Generation",
        "description": "Gemini generates human-readable weekly report explaining trends, calling out anomalies, and recommending actions. Separates signal from noise — 'ticket volume up 15% due to MFA rollout, underlying volume flat.'"
      },
      {
        "label": "Dashboard & Distribution",
        "description": "Report published to Looker dashboard with drill-down capability. Summary distributed to IT leadership via email."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for ITSM Analytics Dashboard so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
