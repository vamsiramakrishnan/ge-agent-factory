  "id": "asc-606-contract-analyzer",
  "title": "ASC 606 Contract Analyzer",
  "department": "finance",
  "sourcePath": "../presentation/src/components/slides/use-cases/finance/ASC606ContractAnalyzer.tsx",
  "subtitle": "A-2705 • Revenue & Cost Accounting",
  "persona": "Controller",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event",
  "domainId": "domain-27",
  "systems": [
    "SAP S/4HANA SD",
    "Contract Repository",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Contract analysis time",
      "before": "1-2 days",
      "after": "2-3 hours"
    },
    {
      "label": "Consistency across analysts",
      "before": "Variable treatment",
      "after": "Standardized with precedent matching"
    },
    {
      "label": "Audit readiness",
      "before": "Memos created ad-hoc",
      "after": "Auto-generated with cited guidance"
    }
  ],
  "statusQuo": [
    "Revenue accountants manually read contracts and apply ASC 606 — inconsistent treatment across analysts.",
    "Accounting memos written from scratch each time without leveraging precedent analyses.",
    "Novel contract terms identified during audit, not at inception, creating restatement risk."
  ],
  "agentification": [
    "Gemini reads complex contract language and applies the 5-step ASC 606 model with cited guidance.",
    "Precedent matching ensures consistent treatment across similar contracts.",
    "Novel terms flagged proactively at contract inception, not discovered during audit."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA SD",
        "description": "Sales orders, contract master, pricing conditions"
      },
      {
        "system": "Contract Repository",
        "description": "Signed contracts, SOWs, amendments, side letters"
      },
      {
        "system": "BigQuery",
        "description": "Historical contract analyses, SSP data, precedent treatments"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Contract language interpretation, ASC 606 application, memo drafting"
      }
    ],
    "pipeline": [
      {
        "label": "Contract Extraction",
        "description": "Parse contract documents using NLP to extract deliverables, pricing, payment terms, modification clauses, MFN provisions, and termination rights."
      },
      {
        "label": "Precedent Matching",
        "description": "Compare extracted terms against historical contract analyses to identify similar treatments. Flag novel terms without precedent for enhanced review."
      },
      {
        "label": "ASC 606 Application",
        "description": "Gemini applies the 5-step model: (1) identify the contract, (2) identify performance obligations — is implementation distinct? (3) determine transaction price — does MFN create variable consideration? (4) allocate on relative SSP, (5) determine recognition pattern."
      },
      {
        "label": "Memo Generation",
        "description": "Generate accounting memo documenting the analysis, conclusions, and cited guidance. Route to Controller for review and archive to contract file."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for ASC 606 Contract Analyzer so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
