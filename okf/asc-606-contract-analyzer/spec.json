      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "contract_extraction",
            "label": "Contract Extraction",
            "description": "Parse contract documents using NLP to extract deliverables, pricing, payment terms, modification clauses, MFN provisions, and termination rights.",
            "tools": [
              "query_contract_repository_contract_repository_records",
              "lookup_asc_606_contract_analyzer_controls_playbook"
            ]
          },
          {
            "id": "precedent_matching",
            "label": "Precedent Matching",
