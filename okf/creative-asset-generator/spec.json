      "evidenceRequirements": [
        {
          "claim": "Asset creation time moved from 2-3 days toward 2 hours",
          "mustCite": [
            "figma.assets",
            "canva.assets"
          ],
          "sourceSystemIds": [
            "figma",
            "canva"
