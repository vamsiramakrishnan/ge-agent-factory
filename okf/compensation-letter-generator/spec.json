      "label": "Generation time",
      "before": "2 weeks for all",
      "after": "1 click"
    },
    {
      "label": "Personalization errors",
      "before": "5%",
      "after": "0%"
    },
    {
      "label": "Languages",
      "before": "1",
      "after": "15+"
    }
  ],
  "statusQuo": [
    "Comp letters manually generated from templates with error-prone mail merge.",
    "Personalization errors undermine the impact of positive pay changes.",
    "Distribution delays mean employees hear about raises through the grapevine."
  ],
  "agentification": [
    "Auto-generates personalized total compensation statements with visual breakdowns.",
    "Multi-language support with culturally appropriate formatting by region.",
    "Secure digital distribution with read-receipt tracking and manager talking points."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Individual comp changes, base/bonus/equity breakdown, benefits elections"
      },
      {
        "system": "Google Docs",
        "description": "Personalized compensation letter output with visual breakdowns"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Letter personalization, multi-language translation, visual formatting"
      }
    ],
    "pipeline": [
      {
        "label": "Compensation Data Pull",
        "description": "Extract individual comp changes including base salary, bonus targets, equity grants, and benefits from Workday at comp cycle close."
      },
      {
        "label": "Letter Personalization",
        "description": "Gemini generates personalized total compensation statements with visual breakdowns, contextual messaging, and manager talking points for each employee."
      },
      {
        "label": "Multi-Language & Delivery",
        "description": "Auto-translate letters for global workforce with culturally appropriate formatting. Encrypt and distribute via employee portal with read-receipt tracking."
      }
    ]
  },
