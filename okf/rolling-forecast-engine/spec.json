            "tools": [
              "query_sap_s_4hana_fi_co_gl_entries",
              "query_anaplan_budget_lines",
              "lookup_rolling_forecast_engine_controls_playbook",
              "action_sap_s_4hana_fi_co_generate"
            ]
          },
          {
            "id": "time_series_forecasting",
            "label": "Time-Series Forecasting",
            "description": "Run Prophet/ARIMA models on revenue and expense lines. Apply seasonal decomposition, trend extrapolation, and generate confidence intervals for each forecast line.",
            "tools": [
              "query_anaplan_budget_lines",
              "lookup_rolling_forecast_engine_controls_playbook",
              "action_sap_s_4hana_fi_co_generate"
            ]
