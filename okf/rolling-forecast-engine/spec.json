              "lookup_rolling_forecast_engine_controls_playbook"
            ]
          },
          {
            "id": "delivery_distribution",
            "label": "Delivery & Distribution",
            "description": "Distribute updated forecast projections to stakeholders with variance commentary and assumption change log.",
            "tools": [
              "lookup_rolling_forecast_engine_controls_playbook"
            ]
          }
        ]
      },
