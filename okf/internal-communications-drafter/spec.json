    "pipeline": [
      {
        "label": "Context Assembly",
        "description": "Parse communication request to understand announcement type (reorg, product launch, policy change), affected teams, and urgency. Pull organizational context from Salesforce and communication history."
      },
      {
        "label": "Engagement Optimization",
        "description": "Analyze historical read rates and click-through by communication type, audience segment, and distribution channel to optimize timing and format."
      },
      {
        "label": "Audience-Aware Drafting",
        "description": "Gemini drafts internal communications that inform and align — not just announcements but narratives explaining the 'why' tailored to each audience. Engineering cares about reporting lines, marketing about campaign ownership, sales about territory alignment."
      },
      {
        "label": "Distribution & Tracking",
        "description": "After VP Marketing approval, distribute via optimal channels (email, Slack, intranet). Track read rates, click-through, and feedback responses."
      }
    ]
