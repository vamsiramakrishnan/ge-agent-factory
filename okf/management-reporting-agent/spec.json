          "description": "Look up sections of the Management Reporting Agent Controls Playbook to cite in narrative output, escalation rationale, and audit evidence.",
          "requiredInputs": [
            "section_anchor"
          ],
          "produces": [
            "document_section",
            "citation_anchor"
          ],
