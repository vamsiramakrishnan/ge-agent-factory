{
  "id": "budget-allocator-forecaster",
  "title": "Budget Allocator & Forecaster",
  "department": "marketing",
  "sourcePath": "../presentation/src/components/slides/use-cases/marketing/BudgetAllocatorForecaster.tsx",
  "subtitle": "A-2902 \\u2022 Marketing Strategy",
  "persona": "VP Marketing",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-29",
  "systems": [
    "Anaplan",
    "HubSpot",
    "Google Ads",
    "BigQuery",
    "Looker"
  ],
  "kpis": [
    {
      "label": "Budget cycle time",
      "before": "2 weeks",
      "after": "2 days"
    },
    {
      "label": "Forecast accuracy",
      "before": "\\u00b125%",
      "after": "\\u00b18%"
    },
    {
      "label": "Reallocation frequency",
      "before": "Quarterly",
      "after": "Monthly"
    }
  ],
  "statusQuo": [
    "Budget allocation based on prior year spend with minor adjustments, not data-driven optimization.",
    "Variance analysis requires manual pull from 5+ ad platforms and spreadsheet reconciliation.",
    "Channel underperformance diagnosed weeks after the fact with limited root cause visibility."
  ],
  "agentification": [
    "Gemini interprets why channels underperform by reading campaign notes, creative change logs, and market context beyond the numbers.",
    "Marketing mix modeling with Monte Carlo simulation enables scenario-based budget optimization with confidence intervals.",
    "Generates reallocation recommendations with business rationale, enabling monthly rather than quarterly budget adjustments."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Google Ads",
        "description": "Campaign spend actuals, CPC trends, conversion data"
      },
      {
        "system": "Meta Ads Manager",
        "description": "Social ad spend, audience performance, creative metrics"
      },
      {
        "system": "HubSpot",
        "description": "MAP spend tracking, email campaign costs, lead source data"
      },
      {
        "system": "Anaplan",
        "description": "Financial planning models, budget templates, scenario inputs"
      },
      {
        "system": "BigQuery",
        "description": "Unified spend cube, marketing mix models, scenario simulations"
      },
      {
        "system": "Looker",
        "description": "Budget vs. actual dashboards, channel ROI visualizations"
      }
    ],
    "pipeline": [
      {
        "label": "Spend Aggregation",
        "description": "Pull spend actuals from Google Ads, Meta Ads, LinkedIn Ads, and HubSpot. Aggregate budget vs. actual by channel and campaign in BigQuery."
      },
      {
        "label": "ROI Forecasting & Simulation",
        "description": "Run marketing mix modeling with diminishing returns curve fitting per channel. Monte Carlo simulation on budget reallocation scenarios to estimate impact on pipeline."
      },
      {
        "label": "Variance Interpretation",
        "description": "Gemini reads campaign notes, creative change logs, and competitive context to explain why channels underperform forecasts. Generates budget reallocation recommendations with business rationale."
      },
      {
        "label": "Dashboard & Delivery",
        "description": "Budget performance dashboards updated in Looker. Variance alerts and reallocation proposals sent to VP Marketing for approval."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Budget Allocator & Forecaster so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
