      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "spend_aggregation",
            "label": "Spend Aggregation",
            "description": "Pull spend actuals from Google Ads, Meta Ads, LinkedIn Ads, and HubSpot. Aggregate budget vs. actual by channel and campaign in BigQuery.",
            "tools": [
              "query_anaplan_budget_lines",
              "query_hubspot_contacts",
              "query_google_ads_campaigns",
              "query_bigquery_analytics_events",
              "lookup_budget_allocator_forecaster_playbook"
            ]
          },
          {
            "id": "roi_forecasting_simulation",
            "label": "ROI Forecasting & Simulation",
            "description": "Run marketing mix modeling with diminishing returns curve fitting per channel. Monte Carlo simulation on budget reallocation scenarios to estimate impact on pipeline.",
            "tools": [
              "query_anaplan_budget_lines",
              "lookup_budget_allocator_forecaster_playbook"
            ]
          },
          {
            "id": "variance_interpretation",
            "label": "Variance Interpretation",
            "description": "Gemini reads campaign notes, creative change logs, and competitive context to explain why channels underperform forecasts. Generates budget reallocation recommendations with business rationale.",
            "tools": [
              "query_anaplan_budget_lines",
              "query_google_ads_campaigns",
              "lookup_budget_allocator_forecaster_playbook",
              "action_anaplan_recommend"
            ]
          },
          {
            "id": "dashboard_delivery",
            "label": "Dashboard & Delivery",
            "description": "Budget performance dashboards updated in Looker. Variance alerts and reallocation proposals sent to VP Marketing for approval.",
            "tools": [
              "query_anaplan_budget_lines",
              "lookup_budget_allocator_forecaster_playbook"
            ]
          }
        ]
