    {
      "label": "Contract analysis time",
      "before": "2-3 days",
      "after": "2-4 hours"
    },
    {
      "label": "Revenue misstatement risk",
      "before": "Material risk",
      "after": "Near-zero"
    },
    {
      "label": "ASC 606 compliance",
      "before": "Manual judgment",
      "after": "Systematic with cited guidance"
    }
  ],
  "statusQuo": [
    "Revenue recognition analysis performed manually by accountants reading contract terms.",
    "SSP estimates rely on spreadsheets with stale data that drift from actual pricing.",
    "Complex bundled contracts lead to inconsistent treatment across accounting teams."
  ],
  "agentification": [
    "Gemini reads complex contract language and applies the ASC 606 5-step model with cited guidance.",
    "ML-based SSP estimation uses current transaction data, not stale spreadsheets.",
    "Automated accounting memos with cited standards ensure consistent treatment across all contracts."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA SD/FI",
        "description": "Sales orders, billing documents, contract master data"
      },
      {
        "system": "RevPro/Zuora",
        "description": "Subscription contracts, billing schedules, SSP data"
      },
      {
        "system": "BigQuery",
        "description": "Historical SSP data, contract analytics, revenue trends"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Contract term interpretation, performance obligation identification, accounting memo generation"
      }
    ],
    "pipeline": [
      {
        "label": "Contract Extraction",
        "description": "Parse contract documents to extract performance obligations, pricing terms, variable consideration, and modification clauses. Match against billing system data."
      },
      {
        "label": "SSP & Allocation",
        "description": "Estimate standalone selling prices using historical transaction data. Apply relative SSP allocation across performance obligations."
      },
      {
        "label": "ASC 606 Reasoning",
        "description": "Gemini interprets complex contract terms: Is implementation distinct from the license? Does the MFN clause create variable consideration? Does the modification represent a separate contract or a catch-up adjustment?"
      },
      {
        "label": "Posting & Documentation",
        "description": "Generate journal entries per the recognition schedule. Create accounting memo with cited ASC 606 guidance for Controller review."
      }
    ]
  },
