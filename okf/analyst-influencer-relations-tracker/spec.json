      "before": "4-6 hours",
      "after": "45 minutes"
    },
    {
      "label": "Coverage tracking",
      "before": "Ad-hoc Google alerts",
      "after": "Continuous multi-source"
    },
    {
      "label": "Analyst engagement cadence",
      "before": "Reactive",
      "after": "Proactive quarterly rhythm"
    }
  ],
  "statusQuo": [
    "Analyst relationships managed in spreadsheets with no systematic engagement tracking.",
    "Briefing preparation is a scramble — reviewing analyst's recent work the night before.",
    "Coverage tracking limited to ad-hoc Google Alerts with no sentiment or influence scoring."
  ],
  "agentification": [
    "Gemini prepares briefing materials that anticipate questions based on each analyst's recent publications and perspectives.",
    "LLM synthesizes coverage patterns to identify which analysts are becoming more or less favorable.",
    "Maintains proactive engagement rhythm with relationship health tracking across all analyst and influencer contacts."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce CRM",
        "description": "Analyst and media contact records, engagement history, interaction tracking"
      },
      {
        "system": "Cision",
        "description": "Media monitoring, analyst coverage tracking, journalist database"
      },
      {
        "system": "LinkedIn",
        "description": "Analyst thought leadership monitoring, content engagement signals"
      },
      {
        "system": "Google Workspace",
        "description": "Briefing documents, analyst notes, engagement calendar"
      },
      {
        "system": "BigQuery",
        "description": "Coverage analytics, influence scoring, engagement history"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Briefing material generation, question anticipation, coverage analysis"
      }
    ],
    "pipeline": [
      {
        "label": "Coverage Aggregation",
        "description": "Monitor analyst publications via Cision, LinkedIn posts, and industry reports. Track mentions of company, competitors, and relevant market themes. Maintain contact database with engagement history."
      },
      {
        "label": "Influence & Sentiment Scoring",
        "description": "Score analyst influence based on publication reach, citation frequency, and audience relevance. Track coverage sentiment trends and briefing effectiveness metrics."
      },
      {
        "label": "Briefing Intelligence",
        "description": "Gemini prepares analyst briefing materials by analyzing the analyst's recent publications and known perspectives. Anticipates questions and prepares proactive talking points."
      },
      {
        "label": "Engagement Management",
        "description": "Maintain engagement calendar with scheduled briefings, follow-up tasks, and coverage reporting. Route analyst inquiries for timely response."
      }
    ]
  },
