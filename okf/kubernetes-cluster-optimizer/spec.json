      "before": "35%",
      "after": "70%+"
    },
    {
      "label": "Monthly infrastructure savings",
      "before": "N/A",
      "after": "$3K+ per cluster"
    }
  ],
  "statusQuo": [
    "Pod resource requests set during initial deployment and never adjusted — most are 2-3x over-provisioned.",
    "Developers set generous limits 'just in case,' leading to poor bin-packing and wasted node capacity.",
    "Right-sizing requires manual analysis of each pod's actual usage — never happens at scale."
  ],
  "agentification": [
    "Gemini explains optimization opportunities with concrete savings — number of nodes to consolidate and dollar impact.",
    "Pod right-sizing based on p95/p99 actual usage replaces developer guesswork with data-driven resource allocation.",
    "GitOps-integrated PRs make right-sizing as easy as reviewing and merging a pull request."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Kubernetes",
        "description": "Pod specs, resource requests/limits, node capacity, scheduling data"
      },
      {
        "system": "Datadog",
        "description": "Actual CPU/memory usage by pod, node-level utilization"
      },
      {
        "system": "BigQuery",
        "description": "Historical usage patterns, right-sizing models, savings tracking"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Optimization reasoning, consolidation narrative, cost impact analysis"
      }
    ],
    "pipeline": [
      {
        "label": "Cluster Resource Analysis",
        "description": "Analyze Kubernetes cluster resource allocation — pod requests vs. actual usage from Datadog. Map node utilization, scheduling efficiency, and over-provisioning patterns across all clusters."
      },
      {
        "label": "Right-Sizing & Bin-Packing",
        "description": "Calculate optimal pod requests/limits based on p95 actual usage. Run bin-packing analysis to determine optimal node count. Recommend HPA tuning based on traffic patterns."
      },
      {
        "label": "Optimization Narrative",
        "description": "Gemini explains: 'Cluster prod-east has 40% memory over-provisioned — pods request 2Gi but use 1.1Gi at p99. Reducing requests to 1.5Gi would consolidate from 12 nodes to 8, saving $3,400/month.'"
      },
      {
        "label": "GitOps Application",
        "description": "Right-sizing recommendations applied via GitOps workflow — PRs generated with updated resource specs. Before/after comparison tracked in BigQuery."
      }
    ]
  },
