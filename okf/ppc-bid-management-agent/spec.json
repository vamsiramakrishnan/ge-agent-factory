    "Google Ads",
    "Microsoft Ads",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "ROAS improvement",
      "before": "Manual bids",
      "after": "+28% ROAS"
    },
    {
      "label": "Bid adjustment frequency",
      "before": "Weekly manual",
      "after": "Daily automated"
    },
    {
      "label": "Budget pacing accuracy",
      "before": "±15% variance",
      "after": "±3% variance"
    }
  ],
  "statusQuo": [
    "Bids adjusted weekly based on manual spreadsheet analysis and gut feel.",
    "Competitive dynamics in search auctions diagnosed reactively after CPC spikes.",
    "Budget pacing checked manually with frequent over/under-spend."
  ],
  "agentification": [
    "Daily automated bid optimization with quality score prediction and dayparting models.",
    "Gemini interprets competitive auction dynamics and explains CPC changes in context.",
    "Real-time budget pacing with automatic reallocation across high-performing campaigns."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Google Ads",
        "description": "Campaign performance, bid data, quality scores, auction insights"
      },
      {
        "system": "Microsoft Ads",
        "description": "Campaign metrics, bid modifiers, audience performance"
      },
      {
        "system": "BigQuery",
        "description": "Historical bid performance, ROAS tracking, optimization models"
      },
      {
        "system": "Looker",
        "description": "PPC performance dashboards, pacing alerts"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Competitive dynamics interpretation, budget rationale generation"
      }
    ],
    "pipeline": [
      {
        "label": "Performance Aggregation",
        "description": "Pull campaign-level and keyword-level performance from Google Ads and Microsoft Ads. Aggregate in BigQuery with historical bid data and budget pacing."
      },
      {
        "label": "Bid Optimization Modeling",
        "description": "Quality score prediction, dayparting analysis, device bid modifiers, and geographic performance modeling. Automated bidding optimization using historical conversion data."
      },
      {
        "label": "Competitive Interpretation",
        "description": "Gemini interprets competitive dynamics — why CPC increased, whether it's new entrants or existing competitors changing strategy. Generates budget reallocation recommendations with business rationale."
      },
      {
        "label": "Execution & Dashboards",
        "description": "Push bid adjustments back to ad platforms. Budget changes over 15% routed for specialist approval. Feed Looker dashboards with updated performance data."
      }
    ]
  },
