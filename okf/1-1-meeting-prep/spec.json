  "statusQuo": [
    "1:1 agendas created ad-hoc or not at all; lack of consistency.",
    "Managers manually gather context from multiple siloed systems.",
    "Talking points based on memory rather than objective data signals."
  ],
  "agentification": [
    "Auto-generated agendas with goal progress and recent feedback.",
    "Suggested coaching topics based on real-time performance signals.",
    "Integrated recognition and milestone reminders for managers."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Employee profile, recent performance data, tenure milestones"
      },
      {
        "system": "Lattice",
        "description": "OKR progress, recent feedback, check-in history"
      },
      {
        "system": "Google Calendar",
        "description": "Upcoming 1:1 meetings, scheduling context"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Context synthesis, talking point generation, coaching prompts"
      }
    ],
    "pipeline": [
      {
        "label": "Meeting Detection",
        "description": "Monitor Google Calendar for upcoming 1:1 meetings. Trigger context assembly 24 hours before each scheduled session."
      },
      {
        "label": "Context Assembly",
        "description": "Gather OKR progress from Lattice, recent feedback, sentiment signals, and performance data from Workday. Build comprehensive employee context."
      },
      {
        "label": "Agenda Generation",
        "description": "Gemini generates personalized talking points, coaching prompts, and recognition reminders based on assembled context and recent developments."
      }
    ]
  },
