  "kpis": [
    {
      "label": "Self-service resolution rate",
      "before": "15%",
      "after": "65%"
    },
    {
      "label": "Average resolution time",
      "before": "4 hours (with human)",
      "after": "3 minutes (bot)"
    },
    {
      "label": "Help desk ticket volume",
      "before": "500/week",
      "after": "200/week"
    }
  ],
  "statusQuo": [
    "Every IT issue — even simple password resets — requires a ServiceNow ticket and human agent interaction.",
    "Average resolution time is 4 hours because tickets queue behind higher priority items.",
    "Users lose productivity waiting for simple fixes that could be self-service."
  ],
  "agentification": [
    "Gemini understands IT issues in natural language and resolves common requests automatically.",
    "LLM executes automated fixes for password resets, access requests, and VPN issues directly.",
    "65% self-service resolution rate reduces help desk ticket volume by 60% and average resolution to 3 minutes."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Slack",
        "description": "Chat interface for IT support requests"
      },
      {
        "system": "ServiceNow",
        "description": "Ticket creation, KB articles, service catalog"
      },
      {
        "system": "Okta",
        "description": "Password resets, access status checks, group management"
      },
      {
        "system": "Google Workspace",
        "description": "Account settings, permission checks, calendar access"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Natural language understanding, troubleshooting reasoning"
      }
    ],
    "pipeline": [
      {
        "label": "Intent Understanding",
        "description": "Parse the user's natural language request to understand the issue type, urgency, and affected systems. Classify as password/access/VPN/hardware/software/other."
      },
      {
        "label": "Knowledge Retrieval",
        "description": "Search ServiceNow KB and Confluence for matching resolution articles. Rank by relevance and recency. Check for known outages or recent changes that might explain the issue."
      },
      {
        "label": "Resolution Execution",
        "description": "For common issues (password reset, access request, VPN troubleshooting), execute automated fixes directly. For complex issues, provide step-by-step guided troubleshooting with screenshots."
      },
      {
        "label": "Escalation & Learning",
        "description": "If self-service fails, create ServiceNow ticket with full conversation context for human agent. Log resolution patterns to improve future auto-resolution."
      }
    ]
  },
