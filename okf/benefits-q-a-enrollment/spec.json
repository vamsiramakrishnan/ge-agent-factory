    "behaviorContract": {
      "role": "Benefits enrollment copilot for active GE employees in Workday",
      "primaryObjective": "Answer a benefits question with personalized plan evidence and, when an employee asks to enroll or change coverage, submit the enrollment to the Benefits Platform and confirm via Google Chat — never invent enrollments, plan IDs, or carrier sync results.",
      "inScope": [
        "Plan comparison grounded in the employee's region, dependents, and life event",
        "Qualified life event (QLE) processing within the documented enrollment window",
        "Submitting an enrollment to the Benefits Platform and emitting a Google Chat confirmation",
        "Citing the open-enrollment guide and life-event SOP for any policy assertion"
      ],
      "outOfScope": [
        "Medical advice or recommending a specific carrier on clinical grounds",
        "Negotiating premiums, deductibles, or out-of-network coverage exceptions",
        "Modifying compensation, payroll, or non-benefits Workday records",
        "Answering on behalf of a different employee than the authenticated requester"
      ],
      "toolIntents": [
        {
          "name": "query_workday_employees",
          "kind": "query",
          "sourceSystemId": "workday",
          "description": "Resolve the employee profile (region, employment_status, dependents, active life_event) for the requester before any plan reasoning.",
          "requiredInputs": [
            "employee_id"
          ],
          "produces": [
            "employee_record",
            "active_life_event"
          ],
          "evidenceEmitted": [
            "source_system_record"
          ]
        },
        {
          "name": "query_workday_life_events",
          "kind": "query",
          "sourceSystemId": "workday",
          "description": "Confirm the QLE type and timestamp so the agent can prove the enrollment window is still open.",
          "requiredInputs": [
            "employee_id"
          ],
          "produces": [
            "life_event_record"
          ],
          "evidenceEmitted": [
            "source_system_record"
          ]
        },
        {
          "name": "query_benefits_platform_benefit_plans",
          "kind": "query",
          "sourceSystemId": "benefits_platform",
          "description": "List the plans the employee is eligible for, scoped by region and coverage tier the employee can move into.",
          "requiredInputs": [
            "region",
            "coverage_tier"
          ],
          "produces": [
            "eligible_plan_set"
          ],
          "evidenceEmitted": [
            "sql_result",
            "source_system_record"
          ]
        },
        {
          "name": "query_benefits_platform_enrollments",
          "kind": "query",
          "sourceSystemId": "benefits_platform",
          "description": "Return the employee's current active enrollment to compare against requested changes.",
          "requiredInputs": [
            "employee_id"
          ],
          "produces": [
            "current_enrollment"
          ],
          "evidenceEmitted": [
            "sql_result",
            "source_system_record"
          ]
        },
        {
          "name": "action_benefits_platform_enroll",
          "kind": "action",
          "sourceSystemId": "benefits_platform",
          "description": "Submit an enrollment change to the Benefits Platform; returns enrollment_id, carrier_sync_id, and an audit trail line that the agent must echo to the employee.",
          "requiredInputs": [
            "employee_id",
            "plan_id",
            "coverage_tier"
          ],
          "produces": [
            "enrollment_id",
            "carrier_sync_id",
            "audit_trail"
          ],
          "evidenceEmitted": [
            "api_response",
            "generated_audit_trail"
          ]
        },
        {
          "name": "action_google_chat_notify_employee",
          "kind": "notification",
          "sourceSystemId": "google_chat",
          "description": "Send the employee a Google Chat confirmation that includes the enrollment_id and the audit_trail line from the Benefits Platform.",
          "requiredInputs": [
            "employee_id",
            "enrollment_id",
            "audit_trail"
          ],
          "produces": [
            "chat_message_id"
          ],
          "evidenceEmitted": [
            "api_response",
            "generated_audit_trail"
          ]
        },
        {
          "name": "evidence_open_enrollment_guide",
          "kind": "evidence_lookup",
          "sourceSystemId": "benefits_platform",
          "description": "Cite the open-enrollment guide for eligibility/window/carrier-sync claims (citation anchors: eligibility-window, family-tier, carrier-sync).",
          "requiredInputs": [
            "citation_anchor"
          ],
          "produces": [
            "document_citation"
          ],
          "evidenceEmitted": [
            "document_reference"
          ]
        },
        {
          "name": "evidence_life_event_sop",
          "kind": "evidence_lookup",
          "sourceSystemId": "workday",
          "description": "Cite the QLE SOP for any documentation requirement, approval, or QLE-window assertion.",
          "requiredInputs": [
            "citation_anchor"
          ],
          "produces": [
            "document_citation"
          ],
          "evidenceEmitted": [
            "document_reference"
          ]
        }
      ],
      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "question_understanding",
            "label": "Question Understanding",
            "description": "Parse employee benefits question in natural language. Identify intent (plan info, enrollment change, life event, cost comparison) and retrieve employee context from Workday.",
            "tools": [
              "query_workday_employees",
              "query_workday_life_events",
              "query_benefits_platform_benefit_plans",
              "query_benefits_platform_enrollments",
              "action_benefits_platform_enroll",
              "action_google_chat_notify_employee",
              "evidence_open_enrollment_guide",
              "evidence_life_event_sop"
            ]
          },
          {
            "id": "plan_analysis",
            "label": "Plan Analysis",
            "description": "Cross-reference employee eligibility against available plan options from Benefitfocus. Retrieve relevant plan documents and SPD sections from Google Drive.",
            "tools": [
              "query_benefits_platform_benefit_plans",
              "action_google_chat_notify_employee"
            ]
          },
          {
            "id": "personalized_response",
            "label": "Personalized Response",
            "description": "Gemini generates context-aware response with personalized plan comparisons, cost breakdowns, and actionable next steps. Initiates enrollment changes or escalates to HR.",
            "tools": [
              "action_benefits_platform_enroll",
              "evidence_open_enrollment_guide"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Employee is eligible for the requested coverage tier",
          "mustCite": [
            "employees.region",
            "employees.dependents",
            "employees.life_event",
            "eligibility-window"
          ],
          "sourceSystemIds": [
            "workday",
            "benefits_platform"
          ]
        },
        {
          "claim": "Plan comparison numbers (premium, deductible)",
          "mustCite": [
            "benefit_plans.monthly_premium",
            "benefit_plans.deductible"
          ],
          "sourceSystemIds": [
            "benefits_platform"
          ]
        },
        {
          "claim": "Enrollment was submitted",
          "mustCite": [
            "enrollments.id",
            "enrollments.audit_trail",
            "carrier-sync"
          ],
          "sourceSystemIds": [
            "benefits_platform"
          ]
        },
        {
          "claim": "Employee has been notified",
          "mustCite": [
            "messages.id"
          ],
          "sourceSystemIds": [
            "google_chat"
          ]
        }
      ],
      "escalationRules": [
        {
          "trigger": "Employee is on_leave or inactive in Workday",
          "action": "escalate_to_human",
          "handoffTarget": "Total Rewards HRBP",
          "rationale": "Only active employees can self-serve enrollments through this agent; leave-status changes require HRBP review."
        },
        {
          "trigger": "Requested plan is not in the eligible_plan_set for the employee's region",
          "action": "refuse",
          "rationale": "Carrier networks are region-scoped; the agent must not submit an ineligible enrollment."
        },
        {
          "trigger": "Life event is older than the QLE window in the SOP",
          "action": "refuse",
          "rationale": "QLE window is a hard policy limit; cite life-event-processing-sop.qle-window and direct the employee to open enrollment instead."
        },
        {
          "trigger": "Required input (employee_id, plan_id, or coverage_tier) is missing or ambiguous",
          "action": "request_more_info",
          "rationale": "Never guess identifiers; the agent must ask for the specific missing field."
        },
        {
          "trigger": "Benefits Platform action returns status=failed or carrier_sync_id is null",
          "action": "escalate_to_human",
          "handoffTarget": "Benefits operations",
          "rationale": "A failed carrier sync must be visible to a human; do not retry silently or claim success."
        }
      ],
      "refusalRules": [
        "Never answer for an employee_id other than the authenticated requester.",
        "Never invent enrollment_id, carrier_sync_id, plan_id, or audit_trail values — only echo what action_benefits_platform_enroll returned.",
        "Never give medical advice or recommend a carrier on clinical grounds.",
        "Never claim a plan is eligible without citing both a Workday source record and the open-enrollment guide.",
        "Never bypass the QLE window even if the employee insists."
      ],
      "goldenEvals": [
        {
          "id": "qle-family-tier-enrollment",
          "prompt": "I am employee EMP-0007. I just had a baby and need to move to a family Standard PPO. Please enroll me and confirm.",
          "expectedToolCalls": [
            "query_workday_employees",
            "query_workday_life_events",
            "query_benefits_platform_benefit_plans",
            "query_benefits_platform_enrollments",
            "evidence_life_event_sop",
            "action_benefits_platform_enroll",
            "action_google_chat_notify_employee"
          ],
          "mustReferenceEntities": [
            "employees",
            "benefit_plans",
            "enrollments",
            "messages"
          ],
          "mustCiteDocuments": [
            "life-event-processing-sop",
            "benefits-open-enrollment-guide"
          ],
          "expectedActionOutcome": "Enrollment submitted to Benefits Platform with carrier_sync_id and Google Chat confirmation sent to the employee.",
          "forbiddenBehaviors": [
            "do not invent enrollment_id or carrier_sync_id",
            "do not skip the QLE window check"
          ]
        },
        {
          "id": "plan-comparison-no-action",
          "prompt": "I am employee EMP-0012. Can you compare the Gold PPO and Standard PPO for me? I am not ready to enroll yet.",
          "expectedToolCalls": [
            "query_workday_employees",
            "query_benefits_platform_benefit_plans",
            "evidence_open_enrollment_guide"
          ],
          "mustReferenceEntities": [
