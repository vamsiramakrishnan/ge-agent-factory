  "statusQuo": [
    "HiPo development plans are generic templates rarely revisited.",
    "Stretch assignments managed informally with no systematic matching.",
    "Readiness assessment remains subjective and inconsistent across leaders."
  ],
  "agentification": [
    "Personalized development journey design based on competency gap analysis.",
    "Automated stretch assignment matching to open opportunities and projects.",
    "Milestone-based readiness tracking with objective progression metrics."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Employee competency profiles, career aspirations, role requirements"
      },
      {
        "system": "Cornerstone",
        "description": "Learning catalog, course completions, skill certifications"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Gap analysis, journey design, assignment matching"
      }
    ],
    "pipeline": [
      {
        "label": "Gap Analysis",
        "description": "Assess individual competency gaps against target role requirements from Workday. Cross-reference with learning history from Cornerstone."
      },
      {
        "label": "Journey Design",
        "description": "Gemini designs personalized development journeys combining learning paths, stretch assignments, mentoring, and experiential opportunities."
      },
      {
        "label": "Milestone Tracking",
        "description": "Track progress against development milestones with readiness score updates. Match stretch assignments and mentors based on evolving needs."
      }
    ]
  },
