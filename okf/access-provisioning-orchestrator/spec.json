    {
      "label": "Day-one readiness",
      "before": "60% have all access",
      "after": "95% fully provisioned"
    },
    {
      "label": "Provisioning time",
      "before": "2-3 days",
      "after": "< 4 hours"
    },
    {
      "label": "Access-related tickets",
      "before": "35 per week",
      "after": "5 per week"
    }
  ],
  "statusQuo": [
    "New hire access provisioned manually via ServiceNow tickets — average 2-3 days, often incomplete on day one.",
    "Role-based access templates are static and miss team-specific tools, requiring follow-up requests.",
    "Termination access revocation is inconsistent — former employees retain access for days or weeks."
  ],
  "agentification": [
    "Gemini receives HR events and automatically provisions access using role templates enhanced by peer analysis.",
    "LLM resolves edge cases — recognizing that an ML team data engineer needs different access than a platform DE.",
    "Sub-4-hour provisioning ensures 95% day-one readiness with complete audit trail."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "HR events — new hire, role change, termination, department transfer"
      },
      {
        "system": "Okta",
        "description": "Identity management, group assignments, SSO provisioning"
      },
      {
        "system": "Google Workspace",
        "description": "Email, calendar, Drive, Workspace group memberships"
      },
      {
        "system": "ServiceNow",
        "description": "Access request tickets, approval workflows, audit trail"
      },
      {
        "system": "BigQuery",
        "description": "Access pattern analytics, role template optimization"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Edge case reasoning, role-access matching"
      }
    ],
    "pipeline": [
      {
        "label": "Event Processing",
        "description": "Receive HR lifecycle event from Workday — new hire (with role, department, team, start date), role change (old/new role), or termination. Determine access action type."
      },
      {
        "label": "Role-Based Access Matching",
        "description": "Match the employee's role and department against access templates. Analyze access patterns of peers in the same team to identify common tools beyond the template."
      },
      {
        "label": "Edge Case Resolution",
        "description": "Gemini handles cases that don't fit standard templates — a 'Senior Data Engineer' on the ML team needs Vertex AI access not in the standard DE template. Identifies and resolves access gaps before day one."
      },
      {
        "label": "Multi-System Provisioning",
        "description": "Provision access across Okta, Google Workspace, and all connected applications. Create ServiceNow ticket for audit trail. Request manager approval for elevated permissions."
      }
    ]
  },
