    "anomalies": [
      {
        "id": "orphaned-access-after-termination",
        "description": "Access remains provisioned 7+ days after HR termination event, indicating revocation failure.",
        "affectedEntities": [
          "access_provisions",
          "employees",
          "hr_events"
        ],
        "discoveryPath": [
          "Find hr_events with event_type=termination",
          "Join access_provisions with status=provisioned",
          "Check provisioned_at > termination_date + 7 days",
          "Flag as anomaly"
        ],
        "expectedEvidence": [
          "Termination HR event",
          "Access provision record",
          "Missing revocation ticket"
        ],
        "expectedRecommendation": "Immediately revoke access and create compliance audit ticket."
      }
    ],
