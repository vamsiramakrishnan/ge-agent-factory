    {
      "label": "IR prep time",
      "before": "2-3 weeks",
      "after": "3-5 days"
    },
    {
      "label": "Q&A coverage",
      "before": "10-15 anticipated questions",
      "after": "40+ with prepared responses"
    },
    {
      "label": "Consensus analysis",
      "before": "Manual spreadsheet",
      "after": "Automated with variance ranking"
    }
  ],
  "statusQuo": [
    "Investor relations preparation takes weeks of manual compilation from multiple data sources.",
    "Analyst Q&A preparation limited to 10-15 obvious questions without systematic coverage.",
    "Consensus analysis done manually in spreadsheets, missing real-time estimate revisions."
  ],
  "agentification": [
    "Automated compilation of results, consensus estimates, and peer data in days instead of weeks.",
    "Gemini anticipates 40+ analyst questions with prepared talking points based on variance patterns.",
    "Real-time consensus tracking identifies estimate revisions and prepares proactive messaging."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Bloomberg",
        "description": "Analyst estimates, market data, peer valuations"
      },
      {
        "system": "S&P Capital IQ",
        "description": "Consensus estimates, peer financials, industry data"
      },
      {
        "system": "BigQuery",
        "description": "Internal financial results, KPIs, guidance tracking"
      },
      {
        "system": "Google Slides",
        "description": "Earnings presentation output"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Analyst question anticipation, talking point generation, script drafting"
      }
    ],
    "pipeline": [
      {
        "label": "Data Assembly",
        "description": "Compile quarterly results from BigQuery. Pull analyst consensus estimates from Bloomberg and Capital IQ. Gather peer results for competitive context."
      },
      {
        "label": "Variance Analysis",
        "description": "Compare results vs. consensus on every major line item. Rank variances by magnitude and analyst sensitivity. Analyze performance vs. prior guidance."
      },
      {
        "label": "Q&A Preparation",
        "description": "Gemini anticipates analyst questions: 'Given the 3% revenue miss, analysts will ask about pipeline and guidance. Prepare: pipeline is $150M (up 20%), miss was timing-driven, guidance maintained.' Drafts earnings script and talking points."
      },
      {
        "label": "Presentation Assembly",
        "description": "Generate earnings presentation in Google Slides with results, peer comparisons, guidance update, and supporting appendix materials."
      }
    ]
  },
