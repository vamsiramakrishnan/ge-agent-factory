      "label": "Data freshness",
      "before": "Quarterly",
      "after": "Real-time"
    },
    {
      "label": "Markets monitored",
      "before": "5",
      "after": "200+"
    },
    {
      "label": "Talent risk alerts",
      "before": "0",
      "after": "Continuous"
    }
  ],
  "statusQuo": [
    "Manual research of industry labor reports and competitor hiring.",
    "Internal skills inventory is a point-in-time snapshot.",
    "Talent supply risks discovered reactively during hiring."
  ],
  "agentification": [
    "Continuous crawling of external market data joined with internal skills.",
    "Real-time surfacing of talent supply risks by role and geography.",
    "Predictive benchmarking of salary and availability trends."
  ],
  "architecture": {
    "connections": [
      {
        "system": "LinkedIn Talent Insights",
        "description": "Talent pool sizes, hiring trends, skill availability"
      },
      {
        "system": "Lightcast",
        "description": "Job posting volumes, salary benchmarks, skill demand signals"
      },
      {
        "system": "BLS Data",
        "description": "Labor force statistics, unemployment rates, wage indices"
      },
      {
        "system": "BigQuery",
        "description": "Aggregated market intelligence data lake, trend models"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Market synthesis, talent risk scoring, intelligence brief generation"
      }
    ],
    "pipeline": [
      {
        "label": "Market Data Ingestion",
        "description": "Continuous crawling of LinkedIn Talent Insights, Lightcast job postings, and BLS labor statistics. Data normalized and stored in BigQuery market intelligence lake."
      },
      {
        "label": "Talent Supply Risk Modeling",
        "description": "Time-series analysis on talent supply trends. Risk scoring by role, location, and skill cluster using historical patterns and predictive models."
      },
      {
        "label": "Intelligence Brief Generation",
        "description": "Gemini synthesizes market data into actionable intelligence briefs for HR leaders. Highlights competitive positioning, emerging skill shortages, and salary pressure points."
      }
    ]
  },
