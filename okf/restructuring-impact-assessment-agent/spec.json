  "department": "hr",
  "sourcePath": "../presentation/src/components/slides/use-cases/hr/RestructuringImpactAssessment.tsx",
  "subtitle": "A-106 • Organization Design & Restructuring",
  "persona": "CHRO",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event",
  "domainId": "domain-1",
  "systems": [
    "Workday",
    "SAP SuccessFactors",
    "Skills DB",
    "Google BigQuery"
  ],
  "kpis": [
    {
      "label": "Assessment time",
      "before": "6 weeks",
      "after": "48 hours"
    },
    {
      "label": "Role mapping accuracy",
      "before": "70%",
      "after": "95%"
    },
    {
      "label": "Compliance coverage",
      "before": "Partial",
      "after": "100%"
    }
  ],
  "statusQuo": [
    "Impact assessments conducted manually in spreadsheets with incomplete role mapping across business units.",
    "RIF analysis lacks data-driven rigor — decisions often based on tenure or cost rather than skills and business need.",
    "Redeployment and reskilling options are afterthoughts, evaluated too late in the restructuring timeline."
  ],
  "agentification": [
    "Automated role-to-role mapping using an enterprise skills taxonomy to identify transferability and overlap.",
    "Multi-scenario impact modeling across RIF, redeployment, and reskilling pathways with cost and timeline projections.",
    "Compliance-checked recommendations ensuring adherence to labor regulations, WARN Act requirements, and internal policies."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Employee profiles, roles, skills, compensation data"
      },
      {
        "system": "SAP BPC",
        "description": "Budget impact modeling, cost center realignment"
      },
      {
        "system": "BigQuery",
        "description": "Skills taxonomy, role mapping analytics, compliance data"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Role mapping reasoning, impact narrative generation"
      }
    ],
    "pipeline": [
      {
        "label": "Scenario & Role Mapping",
        "description": "Ingest restructuring scenario parameters from Workday. Map current roles to proposed structure using enterprise skills taxonomy in BigQuery."
      },
      {
        "label": "Impact Quantification",
        "description": "Multi-scenario modeling across RIF, redeployment, and reskilling pathways. Cost projections, timeline estimates, and headcount impact calculated."
      },
      {
        "label": "Compliance & Narrative",
        "description": "Gemini validates WARN Act compliance, adverse impact analysis, and severance requirements. Generates executive impact report with recommendations."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Restructuring Impact Assessment Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
