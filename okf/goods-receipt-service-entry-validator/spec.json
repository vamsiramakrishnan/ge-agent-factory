  "systems": [
    "SAP S/4HANA MM (MIGO)",
    "WMS",
    "IoT/RFID"
  ],
  "kpis": [
    {
      "label": "GR discrepancy detection",
      "before": "Manual spot checks",
      "after": "100% automated"
    },
    {
      "label": "Service validation time",
      "before": "3-5 days",
      "after": "Same day"
    },
    {
      "label": "False GR confirmations",
      "before": "12% undetected",
      "after": "<2%"
    }
  ],
  "statusQuo": [
    "Warehouse staff confirms receipt in SAP without verifying quantities against PO — discrepancies caught only at invoice.",
    "Service entry sheets rubber-stamped without validating whether SOW deliverables were actually completed.",
    "No correlation between IoT/RFID data at the dock and ERP goods receipt postings."
  ],
  "agentification": [
    "IoT/RFID data automatically cross-referenced against PO quantities with anomaly detection on variances.",
    "LLM validates service entry sheets against actual SOW — confirms that 'section 4.2 deliverables' (documents, reviews, sign-offs) were met.",
    "Interprets subjective completion criteria in service contracts and flags incomplete deliverables before payment is triggered."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA MM",
        "description": "Goods receipt posting (MIGO), PO data, delivery schedules, inspection triggers"
      },
      {
        "system": "WMS",
        "description": "Warehouse management receipt data, bin locations, packing slip scans"
      },
      {
        "system": "IoT/RFID",
        "description": "Dock-level barcode/RFID scans, real-time quantity counts, pallet tracking"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Service entry sheet validation — reads SOW deliverables and validates completion against subjective criteria"
      }
    ],
    "pipeline": [
      {
        "label": "Receipt Data Ingestion",
        "description": "Receive goods receipt data from warehouse MIGO posting or IoT/RFID sensors at the dock. Correlate physical count data with delivery documentation."
      },
      {
        "label": "Quantity & Quality Matching",
        "description": "Cross-reference received quantities against PO. Detect anomalies in quantities, delivery timing, and packaging. Recommend quality inspection sampling based on supplier history."
      },
      {
        "label": "Service Entry Validation",
        "description": "For services, LLM reads service entry sheets stating 'completed phase 2 design review deliverables as per SOW section 4.2' and validates against the actual SOW to confirm that section 4.2 deliverables (specific documents, reviews, sign-offs) were actually met. Interprets subjective completion criteria."
      },
      {
        "label": "Receipt Confirmation & Downstream Trigger",
        "description": "Confirm validated goods receipt or service entry in ERP, triggering three-way match eligibility for invoice processing."
      }
    ]
  },
  "generationSpec": {
