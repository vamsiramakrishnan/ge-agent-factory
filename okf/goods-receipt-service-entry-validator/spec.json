      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "receipt_data_ingestion",
            "label": "Receipt Data Ingestion",
            "description": "Receive goods receipt data from warehouse MIGO posting or IoT/RFID sensors at the dock. Correlate physical count data with delivery documentation.",
            "tools": [
              "query_sap_s_4hana_mm_migo_purchase_orders",
              "query_iot_rfid_iot_rfid_records",
              "lookup_goods_receipt_service_entry_validator_policy_guide",
              "action_sap_s_4hana_mm_migo_trigger"
            ]
          },
          {
