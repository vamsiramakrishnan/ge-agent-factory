      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Goods Receipt & Service Entry Validator so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
