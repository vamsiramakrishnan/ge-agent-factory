    "dbt",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Quality coverage",
      "before": "40% of tables checked",
      "after": "95% of tables checked"
    },
    {
      "label": "Degradation detection",
      "before": "Reported by consumers",
      "after": "Proactive daily alerts"
    },
    {
      "label": "Root cause identification",
      "before": "Hours of investigation",
      "after": "Auto-hypothesized"
    }
  ],
  "statusQuo": [
    "Data quality issues discovered by downstream consumers, not proactive monitoring.",
    "Quality checks cover only 40% of tables, leaving most of the data warehouse unmonitored.",
    "Root cause investigation for quality drops requires hours of manual upstream tracing."
  ],
  "agentification": [
    "Gemini explains quality degradations with root cause hypotheses tied to upstream system changes.",
    "LLM correlates quality drops with recent data pipeline or application changes automatically.",
    "Daily proactive monitoring replaces reactive consumer complaints, catching issues before they propagate."
  ],
  "architecture": {
    "connections": [
      {
        "system": "dbt",
        "description": "Schema tests, data quality assertions, freshness checks"
      },
      {
        "system": "BigQuery",
        "description": "Data profiling, quality metric computation, trend storage"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Quality issue contextualization, root cause hypotheses"
      },
      {
        "system": "Looker",
        "description": "Quality scorecard visualization, trend dashboards"
      }
    ],
    "pipeline": [
      {
        "label": "Quality Rule Execution",
        "description": "Run data quality checks using dbt tests and custom BigQuery assertions. Check completeness (null rates), accuracy (referential integrity), consistency (cross-table agreement), and timeliness (freshness)."
      },
      {
        "label": "Score Computation & Trending",
        "description": "Calculate domain-level quality scores from individual check results. Detect week-over-week degradation trends and correlate with upstream system changes or data volume shifts."
      },
      {
        "label": "Root Cause Contextualization",
        "description": "Gemini explains quality degradations with business context — 'email completeness dropped from 98% to 91% after the new registration flow made email optional.' Provides remediation recommendations."
      },
      {
        "label": "Scorecard Publication",
        "description": "Quality scorecard published to Looker dashboard with drill-down by domain and dimension. Alert notifications sent for domains falling below threshold."
      }
    ]
  },
