    {
      "label": "Backup coverage gaps",
      "before": "Found in DR drills",
      "after": "Daily detection"
    },
    {
      "label": "RPO/RTO compliance",
      "before": "Quarterly audit",
      "after": "Continuous monitoring"
    },
    {
      "label": "DR readiness score",
      "before": "Unknown",
      "after": "Daily scored by tier"
    }
  ],
  "statusQuo": [
    "Backup coverage gaps discovered during annual DR drills — by then the gap has existed for months.",
    "RPO/RTO compliance measured quarterly via manual audit, not continuously monitored.",
    "New systems and migrations often miss backup configuration, creating unprotected data."
  ],
  "agentification": [
    "Gemini identifies backup coverage gaps immediately — catching systems dropped from backup jobs during migrations.",
    "Continuous RPO/RTO compliance scoring replaces quarterly audits with daily validated readiness.",
    "Storage growth forecasting prevents backup infrastructure from running out of capacity unexpectedly."
  ],
  "architecture": {
    "connections": [
      {
        "system": "AWS Backup",
        "description": "Backup job status, restore points, cross-region copies"
      },
      {
        "system": "GCP Cloud Storage",
        "description": "Object storage backups, lifecycle policies, cross-region status"
      },
      {
        "system": "Terraform",
        "description": "Infrastructure declarations for backup policy validation"
      },
      {
        "system": "BigQuery",
        "description": "Backup history, RPO/RTO compliance tracking, storage growth"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "DR readiness narrative, coverage gap identification, compliance reasoning"
      }
    ],
    "pipeline": [
      {
        "label": "Backup Status Collection",
        "description": "Verify backup completion across AWS Backup and GCP Cloud Storage. Check cross-region replication status. Validate backup retention meets policy requirements by system tier."
      },
      {
        "label": "RPO/RTO Compliance Scoring",
        "description": "Track backup success rates over time. Benchmark restore times against RTO targets. Score RPO compliance based on backup frequency vs. data change rate. Forecast storage growth."
      },
      {
        "label": "DR Readiness Narrative",
        "description": "Gemini generates report: 'All tier-1 systems meet RPO targets. The user-uploads S3 bucket hasn't been in the cross-region backup since March migration — violates 4-hour RPO. Adding to backup job immediately.'"
      },
      {
        "label": "Report & Remediation",
        "description": "DR compliance report published with coverage gap alerts. Non-compliant systems flagged with auto-generated remediation actions. Quarterly DR drill schedule maintained."
      }
    ]
  },
