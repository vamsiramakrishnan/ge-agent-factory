  "kpis": [
    {
      "label": "Forecast accuracy",
      "before": "55-65%",
      "after": "88%"
    },
    {
      "label": "Demand signal sources",
      "before": "ERP only",
      "after": "ERP + NLP signals"
    },
    {
      "label": "Aggregation time",
      "before": "3 days manual",
      "after": "Real-time"
    }
  ],
  "statusQuo": [
    "Demand forecasting relies solely on ERP consumption history, missing informal BU signals.",
    "Manual aggregation across plants takes days.",
    "No way to incorporate qualitative signals like 'new product line in Q3.'"
  ],
  "agentification": [
    "Prophet/ARIMA time-series forecasting with automated seasonality decomposition.",
    "LLM parses unstructured emails from stakeholders — 'project delayed to next year' becomes a demand adjustment.",
    "Resolves conflicting signals from multiple business units."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA MM/PP",
        "description": "Requisition history, consumption data, production plans"
      },
      {
        "system": "Oracle ERP",
        "description": "Cross-system consumption and purchase order history"
      },
      {
        "system": "Coupa",
        "description": "Requisition history and demand signals from procurement platform"
      },
      {
        "system": "BigQuery",
        "description": "Time-series storage, forecast models, aggregated demand cube"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "NLP parsing of unstructured demand signals from stakeholder emails"
      }
    ],
    "pipeline": [
      {
        "label": "ERP Data Extraction",
        "description": "Extract requisition history and consumption data from SAP S/4HANA, Oracle ERP, and Coupa. Aggregate across BUs and plants into a unified demand history."
      },
      {
        "label": "Time-Series Forecasting",
        "description": "Prophet/ARIMA models with automated seasonality decomposition and confidence intervals on historical consumption by material group."
      },
      {
        "label": "NLP Signal Parsing & Adjustment",
        "description": "Gemini parses unstructured demand signals — stakeholder emails saying 'new production line in Q3' or 'project delayed to next year' — and translates them into demand adjustments. Resolves conflicting signals from multiple BUs."
      }
    ]
  },
