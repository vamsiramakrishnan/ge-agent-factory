{
  "id": "concentration-risk-analyzer",
  "title": "Concentration Risk Analyzer",
  "department": "procurement",
  "sourcePath": "../presentation/src/components/slides/use-cases/procurement/ConcentrationRiskAnalyzer.tsx",
  "subtitle": "A-1607 • Supplier Risk",
  "persona": "CPO",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-16",
  "systems": [
    "Spend Data",
    "Supplier Master",
    "Contract Data",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Categories with concentration analysis",
      "before": "Top 10 manual",
      "after": "All categories automated"
    },
    {
      "label": "Revenue impact modeling",
      "before": "Not quantified",
      "after": "Per-supplier $ impact"
    },
    {
      "label": "Diversification lead time visibility",
      "before": "Unknown",
      "after": "Qualification timeline mapped"
    }
  ],
  "statusQuo": [
    "Concentration risk assessed only for top categories — tail categories with hidden sole-source exposure go unmonitored.",
    "HHI scores presented as numbers without business impact context — CPO can't prioritize action.",
    "No modeling of what it would take to diversify — qualification timelines and certification barriers unknown."
  ],
  "agentification": [
    "HHI calculation across all categories with what-if simulation — single supplier failure impact modeled against revenue and production.",
    "LLM translates concentration metrics into business narratives: 'HHI of 0.85 = effectively single-sourced, $12M/week at risk, 9-month qualification for alternate.'",
    "Reasons about whether concentration is an acceptable trade-off (patented component) vs. addressable risk (lazy sourcing), recommending safety stock vs. diversification accordingly."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Spend Data",
        "description": "Category spend volumes, supplier allocation percentages, PO history"
      },
      {
        "system": "Supplier Master",
        "description": "Supplier entity data, geographic locations, capability classifications"
      },
      {
        "system": "Contract Data",
        "description": "Contract terms, sole-source agreements, qualification requirements"
      },
      {
        "system": "BigQuery",
        "description": "HHI calculation, graph analytics, what-if simulation engine, diversification modeling"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Business risk narrative generation, concentration trade-off reasoning"
      }
    ],
    "pipeline": [
      {
        "label": "Data Assembly & Mapping",
        "description": "Pull spend data, supplier master, and contract data across all categories and geographies. Map supplier-category-geography-BU relationships for concentration analysis."
      },
      {
        "label": "Concentration Analytics & Simulation",
        "description": "Calculate HHI (Herfindahl-Hirschman Index) by category. Run what-if simulations modeling the impact of single-supplier failure on revenue and production. Diversification scenario modeling with qualification timeline estimates."
      },
      {
        "label": "Business Risk Narrative",
        "description": "Gemini translates concentration metrics into business risk narratives: 'Category X has HHI of 0.85 — effectively single-sourced. If Supplier A experiences a 30-day disruption, estimated production impact is $12M/week across 3 product lines. Alternate qualification would take 9 months due to aerospace certification.' Reasons about whether concentration is an acceptable strategic trade-off vs. addressable risk."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Concentration Risk Analyzer so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
