          ]
        }
      ],
      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "data_assembly_mapping",
            "label": "Data Assembly & Mapping",
            "description": "Pull spend data, supplier master, and contract data across all categories and geographies. Map supplier-category-geography-BU relationships for concentration analysis.",
            "tools": [
              "query_spend_data_spend_data_records",
              "query_supplier_master_supplier_master_records",
              "query_contract_data_contract_data_records",
              "lookup_concentration_risk_analyzer_policy_guide",
              "action_spend_data_recommend"
            ]
          },
          {
            "id": "concentration_analytics_simulation",
            "label": "Concentration Analytics & Simulation",
            "description": "Calculate HHI (Herfindahl-Hirschman Index) by category. Run what-if simulations modeling the impact of single-supplier failure on revenue and production. Diversification scenario modeling with qualification timeline estimates.",
            "tools": [
              "query_supplier_master_supplier_master_records",
              "query_bigquery_analytics_events",
              "lookup_concentration_risk_analyzer_policy_guide"
            ]
          },
          {
            "id": "business_risk_narrative",
            "label": "Business Risk Narrative",
            "description": "Gemini translates concentration metrics into business risk narratives: 'Category X has HHI of 0.85 — effectively single-sourced. If Supplier A experiences a 30-day disruption, estimated production impact is $12M/week across 3 product lines. Alternate qualification would take 9 months due to aerospace certification.' Reasons about whether concentration is an acceptable strategic trade-off vs. addressable risk.",
            "tools": [
              "query_supplier_master_supplier_master_records",
              "lookup_concentration_risk_analyzer_policy_guide"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Categories with concentration analysis moved from Top 10 manual toward All categories automated",
          "mustCite": [
            "spend_data.spend_data_records",
            "supplier_master.supplier_master_records"
          ],
          "sourceSystemIds": [
            "spend_data",
            "supplier_master"
          ]
        },
        {
          "claim": "Revenue impact modeling moved from Not quantified toward Per-supplier $ impact",
          "mustCite": [
            "spend_data.spend_data_records",
            "supplier_master.supplier_master_records"
          ],
          "sourceSystemIds": [
            "spend_data",
            "supplier_master"
          ]
        }
      ],
      "escalationRules": [
        {
          "trigger": "Categories with concentration analysis regresses past the Top 10 manual baseline by more than 20%",
          "action": "escalate_to_human",
          "handoffTarget": "CPO",
          "rationale": "Significant regressions need human judgment before automated remediation runs against production records."
        },
        {
          "trigger": "Source-system evidence is incomplete or stale (>24h) for any required entity",
          "action": "request_more_info",
          "rationale": "Recommendations grounded in stale evidence misrepresent current state and undermine audit defensibility."
        },
        {
          "trigger": "Proposed recommend action lacks supporting evidence from at least two systems",
          "action": "refuse",
          "rationale": "Single-system evidence is insufficient to authorize external state changes without manual review."
        }
      ],
      "refusalRules": [
        "Never fabricate metric values; only publish numbers derived from Spend Data (and other named systems) entities.",
        "Never bypass CPO approval on escalation triggers, even when confidence is high.",
        "Never expose individual personal data (PII) in summaries; aggregate or pseudonymise before output.",
        "Never act on data older than the staleness threshold defined in the runbook without a fresh re-query."
      ],
      "goldenEvals": [
        {
          "id": "concentration-risk-analyzer-end-to-end",
