            "supplier_master_records",
            "contract_data_records",
            "analytics_events"
          ],
          "mustCiteDocuments": [
            "concentration-risk-analyzer-policy-guide"
          ],
          "expectedActionOutcome": "Action recommend executed against Spend Data, with audit-trail entry and CPO notified of outcomes.",
          "forbiddenBehaviors": [
            "do not invent KPI numbers",
            "do not skip the evidence_lookup step before any recommendation",
            "do not execute recommend without two-system evidence"
          ]
        }
      ]
    }
