    },
    {
      "label": "Driver accuracy",
      "before": "One-size-fits-all",
      "after": "Activity-based optimization"
    }
  ],
  "statusQuo": [
    "Cost allocation cycles take days of manual calculation and reconciliation in SAP CO.",
    "Single allocation driver (headcount or revenue) applied uniformly despite different cost behaviors.",
    "Allocation disputes from business units resolved ad-hoc without documented rationale."
  ],
  "agentification": [
    "Activity-based costing with multiple driver comparison identifies the most equitable allocation method.",
    "Gemini interprets disputes and recommends allocations with documented rationale reducing conflict.",
    "Automated variance analysis highlights allocation shifts requiring management attention."
  ],
