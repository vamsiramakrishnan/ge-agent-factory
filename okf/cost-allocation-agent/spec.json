    "connections": [
      {
        "system": "SAP S/4HANA CO",
        "description": "Cost centers, cost elements, allocation cycles, activity types"
      },
      {
        "system": "BigQuery",
        "description": "Activity-based costing analytics, driver comparisons, variance trends"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Allocation dispute interpretation, driver recommendation reasoning"
      }
    ],
    "pipeline": [
      {
        "label": "Cost Pool Assembly",
        "description": "Aggregate shared costs from IT, facilities, corporate functions into allocation pools. Validate completeness against prior periods."
      },
      {
        "label": "Driver Optimization",
        "description": "Compare allocation results across different drivers (headcount, revenue, square footage, CPU hours). Identify which driver best reflects actual resource consumption."
      },
      {
        "label": "Dispute Resolution",
        "description": "Gemini interprets allocation disputes from business units. Compares the impact of alternative drivers, assesses fairness, and recommends the method that best reflects resource consumption with documented rationale."
      },
      {
        "label": "Posting & Reporting",
        "description": "Execute approved allocation cycles in SAP CO. Generate variance reports comparing current vs. prior period allocations."
      }
    ]
  },
