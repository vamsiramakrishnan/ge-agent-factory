  "subtitle": "IT4-01 • Cybersecurity & Threat Management",
  "persona": "CISO / Security Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-41",
  "systems": [
    "CrowdStrike Falcon",
    "Chronicle SIEM",
    "MITRE ATT&CK",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Threat contextualization time",
      "before": "4-6 hours",
      "after": "15 minutes"
    },
    {
      "label": "IOC-to-asset correlation",
      "before": "Manual lookup",
      "after": "Automated real-time"
    },
    {
      "label": "Actionable threat coverage",
      "before": "30% of feeds",
      "after": "95% of feeds"
    }
  ],
  "statusQuo": [
    "Threat feeds reviewed manually across multiple dashboards with limited correlation to internal assets.",
    "IOC matching done reactively after incidents rather than proactively against asset inventory.",
    "Threat briefs written ad-hoc without consistent framework or business context."
  ],
  "agentification": [
    "Gemini correlates threat feeds against asset inventory in real time, surfacing only threats relevant to the organization's stack.",
    "LLM generates MITRE ATT&CK-mapped threat briefs with specific remediation steps for affected systems.",
    "Continuous monitoring replaces periodic review, reducing mean-time-to-awareness from days to minutes."
  ],
  "architecture": {
    "connections": [
      {
        "system": "CrowdStrike Falcon",
        "description": "Threat intel feeds, IOC signatures, adversary profiles"
      },
      {
        "system": "Chronicle SIEM",
        "description": "Security event correlation, log aggregation"
      },
      {
        "system": "MITRE ATT&CK",
        "description": "Adversary tactics, techniques, and procedures framework"
      },
      {
        "system": "BigQuery",
        "description": "Asset inventory, vulnerability history, network topology"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Threat contextualization, natural language threat briefs"
      },
      {
        "system": "Splunk",
        "description": "Historical security event search, forensic queries"
      }
    ],
    "pipeline": [
      {
        "label": "Threat Feed Ingestion",
        "description": "Ingest threat intelligence feeds from CrowdStrike, Chronicle, and MITRE ATT&CK. Normalize IOCs (IPs, domains, hashes, CVEs) into a unified schema."
      },
      {
        "label": "Asset Correlation & Exposure Analysis",
        "description": "Match IOCs against internal asset inventory, installed software versions, and network telemetry. Score exposure based on internet-facing status and data sensitivity."
      },
      {
        "label": "Threat Contextualization",
        "description": "Gemini generates actionable threat briefs explaining why a threat matters to this specific organization, mapping to MITRE ATT&CK techniques and recommending countermeasures."
      },
      {
        "label": "Distribution & Tracking",
        "description": "Threat advisory distributed to relevant teams based on affected assets. Remediation actions tracked through to completion."
      }
    ]
  },
