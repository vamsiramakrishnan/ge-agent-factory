    "anomalies": [
      {
        "id": "sub-tier-visibility-agent-baseline-gap",
        "description": "Seed a realistic gap where Sub-tier visibility depth sits between Tier-1 only and Tier-1 through Tier-3, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "resilinc_records",
          "resilinc_events"
        ],
        "discoveryPath": [
          "Inspect Resilinc records for the affected entities",
          "Compare against Everstream historical baseline",
          "Generate a citation-backed recommendation"
        ],
        "expectedEvidence": [
          "source-system record",
          "historical baseline metric",
          "generated audit trail"
        ],
        "expectedRecommendation": "Explain the gap, cite supporting evidence, and propose the next Supply Chain Lead action."
      }
