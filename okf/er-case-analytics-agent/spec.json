  "subtitle": "A-602 • Employee Relations",
  "persona": "ER Lead",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-6",
  "systems": [
    "ServiceNow",
    "Workday",
    "Google BigQuery"
  ],
  "kpis": [
    {
      "label": "Pattern visibility",
      "before": "Annual review",
      "after": "Real-time"
    },
    {
      "label": "Hotspot prediction",
      "before": "None",
      "after": "30-day forecast"
    },
    {
      "label": "Leadership reporting",
      "before": "Quarterly",
      "after": "On-demand"
    }
  ],
  "statusQuo": [
    "ER case data analyzed annually at best, missing real-time trend visibility.",
    "Pattern detection relies on individual specialist memory rather than systematic analysis.",
    "Risk hotspots identified reactively after incidents escalate rather than proactively."
  ],
  "agentification": [
    "Real-time ER case pattern analysis across locations, demographics, and case types.",
    "Predictive risk scoring for teams and managers based on leading indicators.",
    "Automated trend reports for leadership with actionable intervention recommendations."
  ],
  "architecture": {
    "connections": [
      {
        "system": "ServiceNow",
        "description": "ER case records, outcomes, timelines, categorization data"
      },
      {
        "system": "BigQuery",
        "description": "ER analytics warehouse, trend models, predictive risk scores"
      },
      {
        "system": "Looker",
        "description": "Interactive ER trend dashboards, leadership reporting"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Pattern analysis, risk prediction, intervention narrative generation"
      }
    ],
    "pipeline": [
      {
        "label": "Case Data Aggregation",
        "description": "Continuously sync all ER cases, outcomes, and timelines from ServiceNow into BigQuery. Enrich with org hierarchy and demographic data from Workday."
      },
      {
        "label": "Pattern & Trend Analysis",
        "description": "Analyze ER case trends by type, location, manager, and demographic dimensions. Identify emerging patterns and seasonal trends with statistical significance testing."
      },
      {
        "label": "Predictive Risk Scoring",
        "description": "Build predictive models scoring teams and locations for ER risk based on leading indicators. 30-day forecast of likely hotspots for proactive intervention."
      },
      {
        "label": "Reporting & Interventions",
        "description": "Auto-generate trend reports with actionable intervention recommendations for leadership. Interactive dashboards with drill-down by region and case type."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for ER Case Analytics Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
