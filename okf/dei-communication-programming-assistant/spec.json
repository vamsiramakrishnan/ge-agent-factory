    {
      "label": "Content creation",
      "before": "Ad-hoc",
      "after": "Data-informed"
    },
    {
      "label": "Program design",
      "before": "Trend-based",
      "after": "Org-specific"
    },
    {
      "label": "Participation tracking",
      "before": "Manual",
      "after": "Automated"
    }
  ],
  "statusQuo": [
    "DEI communications drafted ad-hoc without data backing or representation context.",
    "Program design based on industry trends rather than org-specific needs.",
    "Participation tracking is manual with no connection to impact measurement."
  ],
  "agentification": [
    "Data-informed DEI communications tied to organizational representation data.",
    "Evidence-based program design informed by engagement and belonging surveys.",
    "Automated participation tracking with impact correlation to belonging metrics."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Google Docs",
        "description": "DEI communication drafts, program content, brand guidelines"
      },
      {
        "system": "Slack",
        "description": "DEI program announcements, ERG communications, event promotion"
      },
      {
        "system": "Workday",
        "description": "Representation data, belonging survey results, org demographics"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Data-informed content generation, evidence-based program design"
      }
    ],
    "pipeline": [
      {
        "label": "DEI Data Intake",
        "description": "Pull representation data and belonging survey results from Workday. Identify organizational gaps and priority areas that should inform communication and programming."
      },
      {
        "label": "Content Generation",
        "description": "Gemini generates data-backed DEI communications tied to actual organizational representation data. Ensures messaging is authentic, specific, and avoids performative language."
      },
      {
        "label": "Evidence-Based Program Design",
        "description": "Design DEI programs informed by engagement and belonging survey data. Match interventions to identified gaps with expected impact estimates."
      },
      {
        "label": "Distribution & Impact Tracking",
        "description": "Distribute content via Slack and Google Docs. Track participation rates and correlate to belonging metrics for continuous improvement."
      }
    ]
  },
