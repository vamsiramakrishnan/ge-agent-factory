  "department": "marketing",
  "sourcePath": "../presentation/src/components/slides/use-cases/marketing/PaidMediaOptimizer.tsx",
  "subtitle": "A-3104 \\u2022 Demand Generation",
  "persona": "Digital Marketing Mgr",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-31",
  "systems": [
    "Google Ads",
    "Meta Ads",
    "LinkedIn Ads",
    "BigQuery",
    "Looker"
  ],
  "kpis": [
    {
      "label": "ROAS improvement",
      "before": "Baseline",
      "after": "+25-40%"
    },
    {
      "label": "Optimization frequency",
      "before": "Weekly manual",
      "after": "Daily automated"
    },
    {
      "label": "Creative fatigue detection",
      "before": "Weeks late",
      "after": "< 3 days"
    }
  ],
  "statusQuo": [
    "Paid media optimization done weekly through manual platform checks with reactive rather than proactive adjustments.",
    "Creative fatigue discovered when performance drops significantly, days or weeks after onset.",
    "Cross-platform budget allocation based on siloed platform-level metrics without unified attribution."
  ],
  "agentification": [
    "Gemini diagnoses why campaign performance degraded by reading ad copy, landing pages, and competitive landscape for root cause analysis.",
    "Creative fatigue detection identifies saturation within 3 days, enabling proactive creative rotation.",
    "Daily automated optimization with cross-platform attribution enables continuous ROAS improvement."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Google Ads",
        "description": "Campaign performance, bid data, quality scores, conversion tracking"
      },
      {
        "system": "Meta Ads Manager",
        "description": "Ad set performance, audience metrics, creative variants"
      },
      {
        "system": "LinkedIn Ads",
        "description": "B2B ad performance, company targeting, engagement data"
      },
      {
        "system": "HubSpot",
        "description": "Lead source attribution, downstream conversion tracking"
      },
      {
        "system": "BigQuery",
        "description": "Unified ad performance data, cross-channel attribution, optimization models"
      },
      {
        "system": "Looker",
        "description": "Paid media performance dashboards, ROAS visualizations"
      }
    ],
    "pipeline": [
      {
        "label": "Performance Collection",
        "description": "Pull daily performance data from Google Ads, Meta Ads, and LinkedIn Ads. Aggregate in BigQuery with lead source attribution from HubSpot."
      },
      {
        "label": "Optimization Modeling",
        "description": "Bid optimization models. Budget pacing algorithms. Cross-channel attribution. Audience performance segmentation. Creative fatigue detection. ROAS prediction per campaign."
      },
      {
        "label": "Root Cause Diagnosis",
        "description": "Gemini interprets why campaign performance degraded \\u2014 reads ad copy, landing page, and competitive landscape to diagnose creative fatigue, audience saturation, or competitive pressure. Generates actionable optimization recommendations."
      },
      {
        "label": "Execution & Dashboards",
        "description": "Push bid adjustments and budget reallocations to ad platforms. Feed Looker dashboards. Route budget shifts >20% for manager approval."
      }
    ]
  },
