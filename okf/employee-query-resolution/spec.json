    {
      "label": "Resolution time",
      "before": "24 hrs",
      "after": "Instant"
    },
    {
      "label": "First-contact resolution",
      "before": "45%",
      "after": "82%"
    },
    {
      "label": "Ticket volume",
      "before": "Baseline",
      "after": "-55%"
    }
  ],
  "statusQuo": [
    "Queries handled via email or portal; routed manually.",
    "Tier-0 self-service limited to static, hard-to-search FAQ pages.",
    "HR reps must manually look up data in HRIS for every query."
  ],
  "agentification": [
    "Instant conversational resolution for routine policy and data queries.",
    "Real-time HRIS data retrieval (leave balances, pay stubs) via API.",
    "Seamless escalation to specialists with full interaction context."
  ],
  "architecture": {
    "connections": [
      {
        "system": "ServiceNow",
        "description": "Ticket creation, routing, knowledge base articles"
      },
      {
        "system": "Workday",
        "description": "Employee data lookup — leave balances, pay stubs, benefits"
      },
      {
        "system": "Google Drive",
        "description": "HR policy documents, SOPs, and procedure guides"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Intent classification, answer generation, escalation reasoning"
      }
    ],
    "pipeline": [
      {
        "label": "Query Intake",
        "description": "Receive employee query via chat, email, or portal. Classify intent and extract key entities (policy type, employee ID, date range) for contextual resolution."
      },
      {
        "label": "Context Retrieval",
        "description": "Pull relevant employee data from Workday (leave balances, pay stubs) and policy documents from Google Drive. Build personalized context for accurate resolution."
      },
      {
        "label": "Answer Generation",
        "description": "Gemini generates personalized answers grounded in retrieved policy documents and employee-specific data. Include self-service action links where applicable."
      },
      {
        "label": "Resolution & Escalation",
        "description": "Deliver answer to employee. For complex queries, create ServiceNow ticket with full interaction context and route to appropriate specialist."
      }
    ]
  },
