  "statusQuo": [
    "Manual checklists across 5-6 systems; high administrative burden.",
    "Day-1 readiness failures (no laptop, no badge) are common.",
    "Compliance training assigned manually and often completed late."
  ],
  "agentification": [
    "Multi-step orchestration of IT, Facilities, and HR tasks via API.",
    "Auto-assignment of training by role, location, and seniority.",
    "Real-time completion tracking with automated escalation loops."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Employee profile, role, location, compliance requirements"
      },
      {
        "system": "ServiceNow",
        "description": "IT tickets, facilities requests, access provisioning"
      },
      {
        "system": "Slack",
        "description": "Welcome messages, buddy introductions, team channels"
      },
      {
        "system": "Google Workspace",
        "description": "Training assignments, document access, team calendars"
      }
    ],
    "pipeline": [
      {
        "label": "Onboarding Plan Generation",
        "description": "Start date triggers personalized onboarding plan based on role, location, seniority, and compliance requirements from Workday."
      },
      {
        "label": "Task Orchestration",
        "description": "Multi-step orchestration across ServiceNow, Slack, and Google Workspace. Training auto-assigned, buddy paired, team channels joined."
      },
      {
        "label": "Milestone Tracking",
        "description": "30/60/90-day milestone monitoring with automated check-ins. Real-time completion tracking with escalation for overdue items."
      }
    ]
  },
