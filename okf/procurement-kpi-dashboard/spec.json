          "claim": "Dashboard refresh frequency moved from Monthly manual toward Daily automated",
          "mustCite": [
            "bigquery.analytics_events",
            "looker.dashboards"
          ],
          "sourceSystemIds": [
            "bigquery",
            "looker"
