  "kpis": [
    {
      "label": "Budget cycle time",
      "before": "8-12 weeks",
      "after": "2-3 weeks"
    },
    {
      "label": "BU submissions consolidated",
      "before": "Manual in Excel",
      "after": "Auto-consolidated"
    },
    {
      "label": "Narrative quality",
      "before": "Copy-paste fragments",
      "after": "Synthesized narrative"
    }
  ],
  "statusQuo": [
    "Budget consolidation requires manually merging 20+ Excel workbooks with inconsistent formats.",
    "BU justifications are read individually — no cross-BU synthesis or pattern detection.",
    "Budget narratives assembled by copy-pasting fragments from BU submissions into PowerPoint."
  ],
  "agentification": [
    "Gemini reads all BU narrative justifications and assesses reasonableness against historical patterns.",
    "Automated consolidation resolves cross-BU conflicts and flags outlier growth assumptions.",
    "Synthesizes 20+ submissions into a coherent CFO-ready budget narrative with strategic alignment assessment."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Anaplan",
        "description": "Budget templates, BU submissions, consolidation workspace"
      },
      {
        "system": "SAP BPC",
        "description": "Historical actuals, prior-year budget baseline"
      },
      {
        "system": "Workday Adaptive",
        "description": "Workforce planning inputs, headcount budgets"
      },
      {
        "system": "BigQuery",
        "description": "Enriched spend analytics, trend baselines, variance history"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Budget narrative synthesis, justification assessment"
      }
    ],
    "pipeline": [
      {
        "label": "Actuals & Template Distribution",
        "description": "Pull actuals from ERP, generate pre-populated budget templates with historical baselines, and distribute to 20+ BU leaders with submission deadlines."
      },
      {
        "label": "Submission Consolidation",
        "description": "Aggregate BU submissions, apply growth rate modeling, detect departmental outliers, and reconcile cross-BU dependencies."
      },
      {
        "label": "Narrative Synthesis",
        "description": "Gemini reads narrative justifications from BU leaders and assesses reasonableness against historical patterns and strategic priorities. Synthesizes into a coherent CFO-ready budget narrative."
      },
      {
        "label": "Approval & Distribution",
        "description": "Route consolidated budget to CFO for approval, then distribute approved targets back to BUs with variance explanations."
      }
    ]
  },
