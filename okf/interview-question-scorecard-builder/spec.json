        "system": "Greenhouse",
        "description": "Job descriptions, competency requirements, interview stages"
      },
      {
        "system": "Google Docs",
        "description": "Interview guides, scorecard templates, question banks"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Competency-mapped question generation, scorecard design"
      }
    ],
    "pipeline": [
      {
        "label": "Role Context Ingestion",
        "description": "Pull job description, competency framework, and interview stage configuration from Greenhouse. Structure role requirements for question generation."
      },
      {
        "label": "Question & Scorecard Generation",
        "description": "Gemini generates structured interview questions mapped to required competencies. Builds rubric-based scorecards with behavioral anchors and rating scales."
      },
      {
        "label": "Kit Distribution",
        "description": "Finalized interview kits published to Google Docs and distributed to the interview panel with preparation materials."
      }
    ]
  },
