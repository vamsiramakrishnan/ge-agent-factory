  "statusQuo": [
    "Interview questions vary wildly across interviewers with no standard alignment to role competencies.",
    "Scorecards are inconsistent in format and criteria, making cross-interviewer calibration unreliable.",
    "Structured interview best practices are difficult to enforce at scale across hiring teams."
  ],
  "agentification": [
    "Auto-generates role-specific structured interview guides mapped to required competencies and job level.",
    "Competency-mapped scorecards with standardized rating scales and behavioral anchor definitions.",
    "Bias-reducing question frameworks that ensure consistency while adapting to technical and functional domains."
  ],
