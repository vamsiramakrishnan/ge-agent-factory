    "anomalies": [
      {
        "id": "service-delivery-analytics-agent-baseline-gap",
        "description": "Seed a realistic gap where SLA visibility sits between Monthly report and Real-time, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "tickets",
          "change_requests"
        ],
        "discoveryPath": [
          "Inspect ServiceNow records for the affected entities",
          "Compare against Workday historical baseline",
          "Generate a citation-backed recommendation"
        ],
        "expectedEvidence": [
          "source-system record",
          "historical baseline metric",
          "generated audit trail"
        ],
        "expectedRecommendation": "Explain the gap, cite supporting evidence, and propose the next HR Ops Lead action."
      }
