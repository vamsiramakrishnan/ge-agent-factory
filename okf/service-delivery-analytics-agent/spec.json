    {
      "label": "SLA visibility",
      "before": "Monthly report",
      "after": "Real-time"
    },
    {
      "label": "Bottleneck detection",
      "before": "Anecdotal",
      "after": "Predictive"
    },
    {
      "label": "Capacity planning",
      "before": "Headcount-based",
      "after": "Demand-driven"
    }
  ],
  "statusQuo": [
    "HR service metrics tracked in basic ticketing dashboards with limited insight.",
    "Bottlenecks identified anecdotally rather than through systematic analysis.",
    "Capacity planning based on historical averages, missing seasonal and growth patterns."
  ],
  "agentification": [
    "Real-time service delivery analytics with queue intelligence and trend detection.",
    "Predictive bottleneck identification before SLA breaches occur.",
    "AI-driven capacity planning and SLA optimization with demand forecasting."
  ],
  "architecture": {
    "connections": [
      {
        "system": "ServiceNow",
        "description": "Ticket volumes, resolution times, SLA data, agent workloads"
      },
      {
        "system": "BigQuery",
        "description": "Service analytics warehouse, historical trends, capacity models"
      },
      {
        "system": "Looker",
        "description": "Real-time service delivery dashboards and SLA reports"
      }
    ],
    "pipeline": [
      {
        "label": "Service Data Ingestion",
        "description": "Sync ticket volumes, resolution times, SLA adherence, and agent workload data from ServiceNow. Build time-series dataset for trend and capacity analysis."
      },
      {
        "label": "Queue Intelligence",
        "description": "Analyze real-time queue health, agent workload distribution, and category-level performance. Identify emerging volume spikes and workload imbalances."
      },
      {
        "label": "Bottleneck Prediction",
        "description": "Predict SLA breaches before they occur using demand forecasting models. Identify process bottlenecks and seasonal patterns for proactive capacity planning."
      },
      {
        "label": "Dashboard & Optimization",
        "description": "Publish real-time service delivery dashboards in Looker. Generate capacity reallocation recommendations and process improvement suggestions."
      }
    ]
  },
