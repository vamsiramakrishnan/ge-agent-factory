        "affectedEntities": [
          "cost_centers",
          "internal_orders"
        ],
        "discoveryPath": [
          "Inspect SAP S/4HANA CO records for the affected entities",
          "Compare against BigQuery historical baseline",
          "Generate a citation-backed recommendation"
