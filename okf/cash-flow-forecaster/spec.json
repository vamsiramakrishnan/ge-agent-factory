  "subtitle": "A-2401 - Treasury & Cash",
  "persona": "Treasurer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-24",
  "systems": [
    "Kyriba",
    "SAP S/4HANA FI",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Forecast accuracy (30-day)",
      "before": "70-75%",
      "after": "93%"
    },
    {
      "label": "Forecast preparation time",
      "before": "4 hours/day",
      "after": "Automated"
    },
    {
      "label": "Idle cash reduction",
      "before": "$20M average",
      "after": "$5M average"
    }
  ],
  "statusQuo": [
    "Cash forecasting done in Excel by manually pulling bank balances and AR/AP reports each morning.",
    "Qualitative signals from sales and supply chain communicated via email and rarely incorporated into forecasts.",
    "Large idle cash buffers maintained because forecast uncertainty makes it unsafe to invest short-term."
  ],
  "agentification": [
    "Automated multi-horizon forecasting with seasonal decomposition achieves 93% accuracy at 30-day horizon.",
    "Gemini incorporates qualitative business signals that Excel models miss -- deal closings, expedite fees, one-time payments.",
    "Improved accuracy reduces idle cash by $15M, generating $750K+ in additional investment income annually."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Kyriba",
        "description": "Global bank balances, cash positions, investment portfolio, debt schedules"
      },
      {
        "system": "SAP S/4HANA FI",
        "description": "AR/AP projections, payment schedules, intercompany settlements"
      },
      {
        "system": "BigQuery",
        "description": "Forecast models, seasonal decomposition, variance-to-forecast tracking"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Qualitative signal incorporation, forecast narrative generation"
      },
      {
        "system": "Bloomberg",
        "description": "Market rates, FX rates, yield curves for investment planning"
      }
    ],
    "pipeline": [
      {
        "label": "Cash Position Aggregation",
        "description": "Aggregate real-time cash positions across 45+ bank accounts in 12+ currencies. Pull AR expected inflows and AP scheduled outflows from ERP sub-ledgers. Convert to reporting currency using current rates."
      },
      {
        "label": "Multi-Horizon Forecasting",
        "description": "Time-series models forecast cash at daily (1-week), weekly (1-month), and monthly (1-year) horizons. Seasonal decomposition captures payroll cycles, tax payments, and quarterly patterns. Variance-to-prior-forecast tracking measures accuracy."
      },
      {
        "label": "Qualitative Signal Integration",
        "description": "Gemini reads internal signals: 'Sales closed a $5M deal with 50% upfront payment -- adjust next week's inflows. Supply chain flagged a $2M expedite fee -- add to next month's outflows.' Adjusts forecast with narrative explanation."
      },
      {
        "label": "Decision Support Delivery",
        "description": "Present consolidated forecast to Treasurer with decision recommendations: invest excess, sweep between accounts, or arrange short-term borrowing."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Cash Flow Forecaster so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
