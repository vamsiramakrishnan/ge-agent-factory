    "pipeline": [
      {
        "label": "Report Parsing & Extraction",
        "description": "Parse penetration test reports from multiple formats (PDF, HTML, JSON). Extract individual findings with severity, affected systems, proof-of-concept details, and remediation recommendations."
      },
      {
        "label": "Business Context Scoring",
        "description": "Score findings based on asset criticality, exploit feasibility, and business impact. Identify recurring vulnerability patterns across pentest cycles."
      },
      {
        "label": "Remediation Guidance Generation",
        "description": "Gemini generates actionable remediation guidance for each finding, considering the technology stack and recommending interim mitigations for findings that cannot be patched immediately."
      },
      {
        "label": "Ticket Creation & Tracking",
        "description": "Auto-create Jira tickets with remediation guidance, assign to appropriate teams, and track progress against SLA targets. Verify fixes through automated retesting."
      }
    ]
  },
