  "id": "payment-optimization-agent",
  "title": "Payment Optimization Agent",
  "department": "procurement",
  "sourcePath": "../presentation/src/components/slides/use-cases/procurement/PaymentOptimizationAgent.tsx",
  "subtitle": "A-1507 • Procure-to-Pay",
  "persona": "Treasury",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-15",
  "systems": [
    "SAP S/4HANA FI (F110)",
    "Taulia",
    "C2FO",
    "Treasury Systems"
  ],
  "kpis": [
    {
      "label": "Early pay discount capture",
      "before": "12% of eligible",
      "after": "78% of eligible"
    },
    {
      "label": "Annual discount revenue",
      "before": "$340K",
      "after": "$2.1M"
    },
    {
      "label": "Working capital impact",
      "before": "Unoptimized DPO",
      "after": "+4 days DPO"
    }
  ],
  "statusQuo": [
    "Early payment discounts (2/10 Net 30) missed because AP processes invoices after the discount window closes.",
    "No systematic comparison between early pay discounts and supply chain finance program rates.",
    "Treasury receives no briefing on payment strategy — payments run on autopilot at standard terms."
  ],
  "agentification": [
    "Dynamic discounting engine evaluates early pay discount APR vs. company cost of capital for every invoice.",
    "Resolves edge cases: '2/10 Net 30 vs. supply chain finance at LIBOR+200bps — which is more cost-effective?' with full scenario modeling.",
    "LLM generates treasury briefings explaining payment strategy decisions and working capital impact in business terms."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA FI",
        "description": "Payment program (F110), pending payment proposals, payment term master data"
      },
      {
        "system": "Taulia",
        "description": "Dynamic discounting offers, early pay discount rates, supplier participation status"
      },
      {
        "system": "C2FO",
        "description": "Supply chain finance marketplace, available discount offers, acceptance rates"
      },
      {
        "system": "Treasury Systems",
        "description": "Cost of capital rates, working capital targets, DPO benchmarks"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Treasury briefing generation explaining payment strategy decisions in business terms"
      }
    ],
    "pipeline": [
      {
        "label": "Payment Proposal Extraction",
        "description": "Pull pending payment proposals from ERP payment program. Aggregate invoice details, payment terms, and eligible discount offers from Taulia and C2FO."
      },
      {
        "label": "Discount & Working Capital Optimization",
        "description": "Evaluate early pay discount APR against company cost of capital for each invoice. Model DPO impact across payment scenarios. Segment suppliers by payment term strategy — strategic suppliers for early pay, others for standard terms."
      },
      {
        "label": "Treasury Briefing Generation",
        "description": "LLM generates treasury briefing explaining payment strategy decisions: 'This supplier offers 2/10 Net 30 but also participates in supply chain finance at LIBOR+200bps — early pay discount yields higher APR equivalent, recommend direct early pay.' Working capital impact summarized in business terms."
      },
      {
        "label": "Payment Execution",
        "description": "Submit optimized payment batch for treasury approval. Execute approved payments through ERP payment program."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Payment Optimization Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
