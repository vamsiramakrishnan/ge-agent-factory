        "affectedEntities": [
          "gl_entries",
          "subledger_balances"
        ],
        "discoveryPath": [
          "Inspect SAP S/4HANA FI (F110) records for the affected entities",
          "Compare against Taulia historical baseline",
          "Generate a citation-backed recommendation"
