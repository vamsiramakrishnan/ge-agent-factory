    {
      "label": "Dashboard prep time",
      "before": "4 hours/week",
      "after": "Automated"
    },
    {
      "label": "KPI sources integrated",
      "before": "3 manual",
      "after": "8+ automated"
    },
    {
      "label": "Root cause commentary",
      "before": "None",
      "after": "AI-generated weekly"
    }
  ],
  "statusQuo": [
    "IT performance data scattered across ServiceNow, Jira, Datadog, and cloud consoles — no single view.",
    "CIO staff meeting prep requires 4+ hours of manual metric collection and slide building.",
    "KPIs reported without context — numbers without narrative explanation of why metrics moved."
  ],
  "agentification": [
    "Gemini generates weekly performance narratives that explain why KPIs moved, not just that they moved.",
    "Cross-metric correlation reveals leading indicators — deployment frequency predicting MTTR improvements.",
    "CIO receives a 2-minute briefing instead of a 30-minute data review at every staff meeting."
  ],
  "architecture": {
    "connections": [
      {
        "system": "ServiceNow",
        "description": "ITSM metrics — ticket volume, SLA, CSAT, resolution times"
      },
      {
        "system": "Jira",
        "description": "DevOps metrics — velocity, cycle time, backlog health"
      },
      {
        "system": "Datadog",
        "description": "Infrastructure and application performance metrics"
      },
      {
        "system": "BigQuery",
        "description": "Unified KPI warehouse, trending models, correlation data"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "KPI narrative generation, root cause reasoning"
      },
      {
        "system": "Looker",
        "description": "Executive KPI dashboard with AI commentary"
      }
    ],
    "pipeline": [
      {
        "label": "KPI Aggregation",
        "description": "Aggregate KPIs from ServiceNow (ITSM), Jira (DevOps velocity), Datadog (infrastructure), and cloud platforms (cost). Normalize metrics into a unified performance dataset."
      },
      {
        "label": "Trend & Correlation Analysis",
        "description": "KPI trending, target attainment forecasting, and cross-metric correlation. Identify leading indicators — e.g., deployment frequency predicting MTTR improvements."
      },
      {
        "label": "Performance Narrative",
        "description": "Gemini generates weekly CIO briefing: 'Deployment frequency improved 20% after GitOps rollout. MTTR regressed from 45min to 62min — root cause: 3 incidents in legacy payment system lacking observability.'"
      },
      {
        "label": "Dashboard Publication",
        "description": "Looker dashboard refreshed with KPIs, sparkline trends, and AI-generated commentary for CIO staff meeting."
      }
    ]
  },
