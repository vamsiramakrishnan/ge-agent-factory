  "statusQuo": [
    "Variance reports show numbers without root cause analysis — accountants investigate manually.",
    "Material price variances not correlated with commodity markets to distinguish market vs. supplier issues.",
    "Standard costs updated annually, drifting from reality by mid-year."
  ],
  "agentification": [
    "Gemini investigates significant variances by cross-referencing commodity markets and supplier benchmarks.",
    "Automated decomposition into price/usage/efficiency/volume components on close day.",
    "Proactive recommendations for standard cost revisions when market conditions shift."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA CO (PP)",
        "description": "Standard costs, actual costs, production orders, material master"
      },
      {
        "system": "BigQuery",
        "description": "Variance trend analytics, commodity price correlations, supplier benchmarks"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Variance root cause reasoning, sourcing recommendation generation"
      }
    ],
    "pipeline": [
      {
        "label": "Variance Calculation",
        "description": "Pull standard costs and actual production costs from SAP CO. Calculate material price, material usage, labor rate, labor efficiency, and overhead variances."
      },
      {
        "label": "Statistical Analysis",
        "description": "Decompose variances into price vs. usage vs. efficiency vs. volume. Apply threshold alerting. Correlate material price variances with commodity market movements."
      },
      {
        "label": "Root Cause Reasoning",
        "description": "Gemini investigates significant variances: Is the material price variance market-wide or supplier-specific? Is the labor efficiency variance driven by a process change or training gap? Generates corrective action recommendations."
      },
      {
        "label": "Reporting",
        "description": "Generate variance report with trend charts, root cause narratives, and recommended actions. Highlight items requiring standard cost revision."
      }
    ]
  },
