  "department": "procurement",
  "sourcePath": "../presentation/src/components/slides/use-cases/procurement/QualityIncidentAnalyzer.tsx",
  "subtitle": "A-1702 • Supplier Performance",
  "persona": "Quality Engineer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event",
  "domainId": "domain-17",
  "systems": [
    "SAP QM (QM01/QM02)",
    "Quality Management Systems",
    "CAPA Tools",
    "BigQuery"
  ],
  "kpis": [
    {
      "label": "Root cause accuracy",
      "before": "60% keyword-based",
      "after": "92% context-aware"
    },
    {
      "label": "CAPA response time",
      "before": "5-7 days",
      "after": "Same day"
    },
    {
      "label": "Recurrence detection",
      "before": "Missed patterns",
      "after": "Cross-incident linking"
    }
  ],
  "statusQuo": [
    "Root cause classification relies on dropdown menus — quality engineers pick the closest 8D category, losing nuance.",
    "NCR narratives written by inspectors ('visible tool marks near the bore') go unanalyzed beyond keyword search.",
    "Recurrence patterns across suppliers and parts are missed because historical NCRs live in disconnected systems."
  ],
  "agentification": [
    "LLM reads inspector narratives: 'surface finish appears rough with visible tool marks — possible worn tooling or incorrect feed rate' and reasons about root cause hypotheses.",
    "Cross-references recent NCRs: 'Third surface finish complaint in 6 months, same machine center — supplier CAPA said replaced tooling but recurrence suggests spindle wear or coolant system degradation.'",
    "Generates technically informed 8D reports with specific corrective actions, not just keyword categorization."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP QM (QM01/QM02)",
        "description": "Non-conformance reports, quality inspection results, defect notifications"
      },
      {
        "system": "Quality Management Systems",
        "description": "Quality records, inspection procedures, specification data"
      },
      {
        "system": "CAPA Tools",
        "description": "Corrective and preventive action tracking, 8D workflow management"
      },
      {
        "system": "BigQuery",
        "description": "Historical NCR analytics, pattern detection, recurrence prediction"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "NCR narrative interpretation, root cause reasoning, technically informed CAPA generation"
      }
    ],
    "pipeline": [
      {
        "label": "NCR Intake & History Pull",
        "description": "Receive NCR notification from SAP QM system. Pull historical quality data for the affected supplier, part, and plant. Trigger CAPA workflow in tracking system."
      },
      {
        "label": "Pattern Detection & Classification",
        "description": "Root cause classification against 8D categories. Pattern detection across suppliers, parts, and plants — is this defect type increasing? Recurrence prediction based on historical CAPA effectiveness."
      },
      {
        "label": "Root Cause Reasoning & CAPA Drafting",
        "description": "Gemini reads NCR narratives ('surface finish appears rough with visible tool marks near the bore — possible worn tooling or incorrect feed rate') and reasons about root cause hypotheses. Cross-references recent NCRs: 'Third surface finish complaint in 6 months, same machine center — supplier CAPA said replaced tooling but recurrence suggests spindle wear or coolant system degradation.'"
      }
    ]
  },
