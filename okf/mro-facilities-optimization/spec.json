{
  "id": "mro-facilities-optimization",
  "title": "MRO & Facilities Optimization",
  "department": "procurement",
  "sourcePath": "../presentation/src/components/slides/use-cases/procurement/MROFacilitiesOptimization.tsx",
  "subtitle": "A-1804 • Indirect & Tail Spend",
  "persona": "Indirect Procurement Lead",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-18",
  "systems": [
    "SAP S/4HANA MM",
    "Maximo",
    "eMaint",
    "Coupa",
    "VMI systems"
  ],
  "kpis": [
    {
      "label": "MRO stockout rate",
      "before": "8-12%",
      "after": "<2%"
    },
    {
      "label": "Excess inventory",
      "before": "$2.4M carrying cost",
      "after": "$900K (62% reduction)"
    },
    {
      "label": "Emergency orders",
      "before": "15% of MRO spend",
      "after": "<3%"
    }
  ],
  "statusQuo": [
    "MRO inventory managed by rules of thumb — safety stock levels set once and never adjusted, leading to simultaneous stockouts and excess.",
    "Usage spikes trigger emergency purchases at premium pricing with no investigation into root cause.",
    "No correlation between maintenance schedules and consumable demand — turnarounds cause surprise shortages every time."
  ],
  "agentification": [
    "Time-series demand forecasting on MRO consumables (filters, bearings, lubricants, safety gloves) with automated min/max optimization based on lead time variability.",
    "LLM interprets consumption anomalies against maintenance work orders: 'Bearing consumption at Plant C up 300% this month — plant is doing a scheduled turnaround, expected and temporary, not a trend change.'",
    "Generates plain-English recommendations: 'Current safety stock for Type-B filters covers 14 days — lead time variability suggests 21 days given sole-source supplier inconsistency.'"
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA MM",
        "description": "Plant maintenance consumption data, material master, reorder points"
      },
      {
        "system": "Maximo",
        "description": "CMMS work orders, preventive maintenance schedules, equipment history"
      },
      {
        "system": "eMaint",
        "description": "Maintenance work orders, turnaround schedules for anomaly correlation"
      },
      {
        "system": "Coupa",
        "description": "MRO catalog items, VMI replenishment triggers, supplier orders"
      },
      {
        "system": "BigQuery",
        "description": "Demand forecasting models, usage pattern analytics, min/max optimization"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Anomaly interpretation, plain-English inventory recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Consumption Data Aggregation",
        "description": "Pull MRO consumption data from CMMS and ERP plant maintenance modules. Correlate consumption patterns with maintenance work orders and turnaround schedules to distinguish trend changes from planned events."
      },
      {
        "label": "Demand Forecasting & Optimization",
        "description": "Time-series forecasting on MRO consumables (filters, bearings, lubricants, safety gloves). Min/max inventory optimization based on lead time variability, usage patterns, and supplier reliability."
      },
      {
        "label": "Anomaly Interpretation & Replenishment",
        "description": "LLM interprets usage anomalies against maintenance context — 'bearing consumption up 300% due to scheduled turnaround, temporary.' Generates plain-English recommendations and triggers optimized VMI replenishment orders."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
