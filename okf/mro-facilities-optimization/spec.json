        {
          "claim": "MRO stockout rate moved from 8-12% toward <2%",
          "mustCite": [
            "sap_s_4hana_mm.purchase_orders",
            "maximo.maximo_records"
          ],
          "sourceSystemIds": [
            "sap_s_4hana_mm",
            "maximo"
