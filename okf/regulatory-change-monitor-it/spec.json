    {
      "label": "Regulatory change awareness",
      "before": "Reactive discovery",
      "after": "Proactive weekly scan"
    },
    {
      "label": "Impact assessment time",
      "before": "2-3 weeks",
      "after": "2-3 days"
    },
    {
      "label": "Compliance deadline misses",
      "before": "3-4 per year",
      "after": "Zero"
    }
  ],
  "statusQuo": [
    "Regulatory changes discovered reactively — through vendor notices, peer conversations, or audit findings.",
    "Impact assessments take weeks because mapping new requirements to existing controls is manual detective work.",
    "Compliance deadlines missed because teams learn about new requirements too late to implement changes."
  ],
  "agentification": [
    "Gemini scans regulatory feeds weekly and filters for changes relevant to the organization's IT operations.",
    "LLM maps new requirements to existing controls, distinguishing between major gaps and minor policy updates.",
    "Proactive tracking against regulatory effective dates ensures zero missed compliance deadlines."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Thomson Reuters",
        "description": "Regulatory feeds, legal updates, compliance alerts"
      },
      {
        "system": "OneTrust",
        "description": "Privacy regulations, consent requirements, regulatory catalog"
      },
      {
        "system": "ServiceNow GRC",
        "description": "Control framework, policy mapping, compliance requirements"
      },
      {
        "system": "Confluence",
        "description": "Internal policies, procedures, standards documentation"
      },
      {
        "system": "BigQuery",
        "description": "Regulatory change analytics, compliance gap trending"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Regulatory impact reasoning, effort estimation"
      }
    ],
    "pipeline": [
      {
        "label": "Regulatory Scanning",
        "description": "Scan Thomson Reuters feeds and OneTrust regulatory catalog for new and amended regulations. Filter for relevance based on industry, jurisdiction, and IT operations scope."
      },
      {
        "label": "Control Mapping",
        "description": "Map each regulatory change to existing controls in ServiceNow GRC. Identify which current policies and procedures are affected. Flag gaps where no existing control addresses the new requirement."
      },
      {
        "label": "Impact Assessment",
        "description": "Gemini assesses the real-world impact of each change — distinguishing between regulations that require new controls vs. minor policy wording updates. Estimates implementation effort based on gap size."
      },
      {
        "label": "Notification & Tracking",
        "description": "Notify affected teams with specific action items. Create implementation tasks in ServiceNow. Track compliance timeline against regulatory effective dates."
      }
    ]
  },
