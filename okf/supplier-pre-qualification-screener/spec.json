    "Ariba SLP",
    "Jaggaer",
    "SAP S/4HANA",
    "D&B"
  ],
  "kpis": [
    {
      "label": "Screening turnaround",
      "before": "5-7 business days",
      "after": "< 4 hours"
    },
    {
      "label": "Questionnaire review depth",
      "before": "Checkbox scan",
      "after": "Full narrative analysis"
    },
    {
      "label": "Inconsistency detection rate",
      "before": "~30% caught",
      "after": "95%+ flagged"
    }
  ],
  "statusQuo": [
    "Pre-qualification questionnaires are reviewed manually, focusing on yes/no checkboxes and ignoring narrative responses.",
    "Inconsistencies between stated capabilities and supporting documentation go undetected until audit.",
    "Certification status like 'in progress' vs. 'achieved' is treated identically in manual review."
  ],
  "agentification": [
    "NLP extraction reads full narrative answers — 'currently pursuing ISO 13485 with expected Q4 completion' flagged as conditional.",
    "LLM evaluates narrative responses for credibility and cross-references against D&B data and supporting documents.",
    "Inconsistencies between stated capabilities and documentation are surfaced with specific citations for Sourcing Lead review."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Ariba SLP",
        "description": "Supplier questionnaire responses, application intake"
      },
      {
        "system": "Jaggaer",
        "description": "Alternate supplier lifecycle portal responses"
      },
      {
        "system": "SAP S/4HANA",
        "description": "Vendor master validation, existing supplier cross-reference"
      },
      {
        "system": "Dun & Bradstreet",
        "description": "Financial indicators, company profile verification"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Questionnaire narrative extraction, inconsistency detection"
      }
    ],
    "pipeline": [
      {
        "label": "Application Intake & Data Pull",
        "description": "Receive supplier application from Ariba SLP or Jaggaer. Trigger parallel data pulls from D&B for financial indicators and SAP vendor master for duplicate detection."
      },
      {
        "label": "Criteria Scoring & Red Flag Detection",
        "description": "Weighted scoring against qualification criteria matrix. Automated pass/fail on hard criteria — insurance minimums, certification requirements. Red flag detection on financial indicators from D&B."
      },
      {
        "label": "Narrative Extraction & Inconsistency Analysis",
        "description": "LLM reads 30-page questionnaire narrative responses and extracts nuanced information — 'currently pursuing ISO 13485 with expected Q4 completion' flagged as conditional. Detects inconsistencies between stated capabilities and supporting documentation."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
