  "kpis": [
    {
      "label": "Conversion rate lift",
      "before": "Generic pages",
      "after": "+35% personalized"
    },
    {
      "label": "Personalization coverage",
      "before": "2 segments",
      "after": "12+ segments"
    },
    {
      "label": "Time to first CTA",
      "before": "Static",
      "after": "Context-aware"
    }
  ],
  "statusQuo": [
    "Website serves the same experience to all visitors regardless of company, intent, or funnel stage.",
    "Personalization limited to basic rules (e.g., logged-in vs. anonymous) without behavioral context.",
    "High-value enterprise visitors get the same generic CTA as casual browsers."
  ],
  "agentification": [
    "Gemini reasons about multi-signal personalization — combining firmographic, behavioral, and intent data for contextual experiences.",
    "Real-time visitor classification with account-level matching and propensity scoring.",
    "Personalization that feels helpful, not creepy — adapting content depth and CTAs to buying stage."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Google Optimize",
        "description": "A/B test configurations, content variant serving, experiment tracking"
      },
      {
        "system": "Google Analytics 4",
        "description": "Visitor behavior signals, referral source, session context"
      },
      {
        "system": "Salesforce CRM",
        "description": "Account matching, deal stage, customer status"
      },
      {
        "system": "HubSpot",
        "description": "Known contact data, lead score, content engagement history"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Personalization strategy reasoning, content variant selection"
      }
    ],
    "pipeline": [
      {
        "label": "Visitor Context Assembly",
        "description": "Assemble visitor context from GA4 session data (referral source, pages viewed), CRM account matching (Salesforce), and MAP contact data (HubSpot lead score, engagement history)."
      },
      {
        "label": "Segmentation & Scoring",
        "description": "Real-time visitor segmentation using propensity scoring, account tier identification, and content recommendation engine. Predict conversion likelihood by visitor segment."
      },
      {
        "label": "Personalization Reasoning",
        "description": "Gemini determines the right personalization strategy — a Fortune 500 visitor from a competitor comparison keyword who has visited pricing twice should see enterprise messaging with a 'talk to sales' CTA, not a generic newsletter signup."
      },
      {
        "label": "Variant Serving & Tracking",
        "description": "Serve personalized content variant via Google Optimize. Track engagement and conversion metrics. Feed results back to optimization models."
      }
    ]
  },
  "generationSpec": {
