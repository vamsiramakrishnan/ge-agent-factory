    {
      "label": "Monitoring frequency",
      "before": "Annual review",
      "after": "Continuous quarterly"
    },
    {
      "label": "Out-of-range transactions",
      "before": "Discovered in audit",
      "after": "Proactive adjustment"
    },
    {
      "label": "Documentation time",
      "before": "6-8 weeks/year",
      "after": "Auto-generated quarterly"
    }
  ],
  "statusQuo": [
    "Transfer pricing reviewed annually with documentation prepared reactively before filing deadlines.",
    "Out-of-range pricing discovered during tax audits, resulting in penalties and double taxation.",
    "OECD guideline interpretation requires expensive external advisors for each review cycle."
  ],
  "agentification": [
    "Continuous quarterly monitoring catches out-of-range pricing before audit exposure, enabling proactive adjustment.",
    "Gemini interprets OECD guidelines and generates value-add documentation, reducing reliance on external advisors.",
    "Auto-generated TP documentation reduces preparation from 6-8 weeks to a quarterly automated output with manual review."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA FI",
        "description": "Intercompany transactions, pricing records, entity financials"
      },
      {
        "system": "BigQuery",
        "description": "Comparable company data, margin analysis, benchmark tracking"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "OECD guideline interpretation, value-add analysis, documentation generation"
      },
      {
        "system": "OECD / Bureau van Dijk",
        "description": "Comparable company databases, industry benchmarks, country-specific guidelines"
      }
    ],
    "pipeline": [
      {
        "label": "IC Transaction Extraction",
        "description": "Extract all intercompany transactions by category -- management fees, royalties, tangible goods, services. Map to entity pairs with pricing details and volumes. Identify new transaction types since last review."
      },
      {
        "label": "Benchmark Analysis",
        "description": "Run comparable company analysis using TNMM and other approved methods. Test margins against arm's length range. Track compliance trends over time. Flag out-of-range items requiring adjustment."
      },
      {
        "label": "Regulatory Interpretation",
        "description": "Gemini assesses positions: 'Management fee from US to India is 8% of revenue -- OECD guidelines suggest 3-6% for comparable services. Recommend adjusting to 5.5% and documenting the value-add justification.' Generates TP documentation."
      },
      {
        "label": "Compliance Reporting",
        "description": "Generate TP compliance report with benchmark results, out-of-range items, recommended adjustments, and documentation. Present to Tax Director for review."
      }
    ]
  },
