  "department": "it",
  "sourcePath": "../presentation/src/components/slides/use-cases/it/SecurityIncidentResponder.tsx",
  "subtitle": "IT4-08 • Cybersecurity & Threat Management",
  "persona": "CISO / Security Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event",
  "domainId": "domain-41",
  "systems": [
    "CrowdStrike",
    "Chronicle",
    "PagerDuty",
    "Splunk",
    "Slack",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Mean time to containment",
      "before": "4-6 hours",
      "after": "<45 minutes"
    },
    {
      "label": "Kill chain reconstruction",
      "before": "Days of forensics",
      "after": "Minutes automated"
    },
    {
      "label": "Playbook coverage",
      "before": "12 static runbooks",
      "after": "Dynamic per-incident"
    }
  ],
  "statusQuo": [
    "Incident response follows static runbooks that don't adapt to the specific attack type or affected systems.",
    "Kill chain reconstruction requires days of manual forensic analysis across multiple security tools.",
    "War room coordination relies on manual paging, status page updates, and stakeholder communication."
  ],
  "agentification": [
    "Gemini reconstructs the attack kill chain in minutes using MITRE ATT&CK mapping across all security telemetry.",
    "LLM generates tailored response playbooks based on specific attack type, affected assets, and business criticality.",
    "Automated war room setup with real-time status updates reduces coordination overhead during incidents."
  ],
  "architecture": {
    "connections": [
      {
        "system": "CrowdStrike",
        "description": "Endpoint detection, host isolation, forensic data"
      },
      {
        "system": "Chronicle SIEM",
        "description": "Log correlation, timeline reconstruction"
      },
      {
        "system": "PagerDuty",
        "description": "Incident lifecycle, on-call paging, escalation"
      },
      {
        "system": "Splunk",
        "description": "Deep forensic search, historical event analysis"
      },
      {
        "system": "Slack",
        "description": "War room coordination, status updates"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Kill chain reasoning, playbook generation"
      }
    ],
    "pipeline": [
      {
        "label": "Incident Classification & Scoping",
        "description": "Receive incident declaration from PagerDuty. Classify attack type, identify affected systems, and estimate blast radius using endpoint telemetry and SIEM correlation."
      },
      {
        "label": "Kill Chain Reconstruction",
        "description": "Map attack progression using MITRE ATT&CK framework. Detect lateral movement, privilege escalation, and data exfiltration attempts. Build forensic timeline."
      },
      {
        "label": "Response Playbook Generation",
        "description": "Gemini generates a tailored incident response playbook based on attack type, affected assets, and business criticality. Recommends containment, eradication, and recovery steps."
      },
      {
        "label": "Containment Execution & Communication",
        "description": "Execute approved containment actions — host isolation, domain blocking, credential rotation. Coordinate response team via Slack war room with regular status updates."
      }
    ]
  },
