{
  "id": "it-grc-dashboard-reporter",
  "title": "IT GRC Dashboard & Reporter",
  "department": "it",
  "sourcePath": "../presentation/src/components/slides/use-cases/it/ITGRCDashboard.tsx",
  "subtitle": "A-4507 • IT Governance & Compliance",
  "persona": "CIO / CTO",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-45",
  "systems": [
    "ServiceNow GRC",
    "RSA Archer",
    "OneTrust",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "GRC report preparation",
      "before": "5 days manual compilation",
      "after": "Auto-generated monthly"
    },
    {
      "label": "Metric coverage",
      "before": "60% of GRC domains",
      "after": "100% cross-domain"
    },
    {
      "label": "Board report turnaround",
      "before": "2 weeks",
      "after": "Same day"
    }
  ],
  "statusQuo": [
    "GRC reports assembled manually from 3+ platforms — takes 5 days and the data is stale before delivery.",
    "Board-level summaries require translating technical GRC metrics into business language, adding another week.",
    "No unified view across risk, compliance, audit, and policy — each domain reports separately."
  ],
  "agentification": [
    "Gemini aggregates GRC metrics from ServiceNow, RSA Archer, and OneTrust into a unified cross-domain view.",
    "LLM generates executive narratives that translate technical GRC status into board-ready business language.",
    "Automated monthly reporting with interactive drill-down dashboards replaces manual compilation."
  ],
  "architecture": {
    "connections": [
      {
        "system": "ServiceNow GRC",
        "description": "Control test results, audit findings, policy status, risk register"
      },
      {
        "system": "RSA Archer",
        "description": "Risk assessments, compliance scores, control effectiveness"
      },
      {
        "system": "OneTrust",
        "description": "Privacy compliance status, DPIA results, consent metrics"
      },
      {
        "system": "BigQuery",
        "description": "GRC metric warehouse, trend analytics, benchmark data"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Executive narrative generation, trend explanation"
      },
      {
        "system": "Looker",
        "description": "Interactive GRC dashboards, drill-down visualizations"
      }
    ],
    "pipeline": [
      {
        "label": "Cross-Domain Aggregation",
        "description": "Pull GRC metrics from ServiceNow GRC (control test results, audit findings), RSA Archer (risk scores, compliance status), and OneTrust (privacy compliance, consent rates). Normalize into unified scoring framework."
      },
      {
        "label": "Trend & Benchmark Analysis",
        "description": "Calculate compliance score trends, risk heat map evolution, audit finding aging, and policy review completion rates. Compare against targets and industry benchmarks."
      },
      {
        "label": "Executive Narrative Generation",
        "description": "Gemini generates a board-ready GRC summary — highlighting key improvements, remaining gaps, and recommended actions. Explains compliance score changes with specific causal factors."
      },
      {
        "label": "Dashboard & Report Delivery",
        "description": "Publish interactive dashboard to Looker for drill-down analysis. Generate PDF executive summary for board distribution."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for IT GRC Dashboard & Reporter so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
