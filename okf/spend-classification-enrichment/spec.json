{
  "id": "spend-classification-enrichment",
  "title": "Spend Classification & Enrichment",
  "department": "procurement",
  "sourcePath": "../presentation/src/components/slides/use-cases/procurement/SpendClassificationEnrichment.tsx",
  "subtitle": "A-1201 • Strategic Sourcing",
  "persona": "Procurement Analytics Lead",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-12",
  "systems": [
    "SAP S/4HANA FI/MM",
    "Coupa",
    "SpendHQ",
    "Sievo",
    "BigQuery"
  ],
  "kpis": [
    {
      "label": "Classification accuracy",
      "before": "78%",
      "after": "96%"
    },
    {
      "label": "Unclassified spend",
      "before": "15-20%",
      "after": "<2%"
    },
    {
      "label": "Supplier duplicates",
      "before": "12% of master",
      "after": "<1%"
    }
  ],
  "statusQuo": [
    "PO line descriptions like 'per quote #4521' or 'project materials — see attachment' defeat rule-based classifiers.",
    "Supplier master has 12%+ duplicate records from typos, legal entity variants, and acquisition-driven name changes.",
    "Category managers spend Monday mornings reconciling spend data across 3 systems before any analysis begins."
  ],
  "agentification": [
    "Gemini reads vendor context, cost center, and purchase history to classify the 20% of transactions that ML cannot confidently handle.",
    "LLM reasons about entity relationships — 'Acme Corp' vs. 'Acme Holdings GmbH' — using business judgment, not just string matching.",
    "Overnight enrichment means category managers arrive to a clean, classified spend cube ready for strategic analysis."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA FI/MM",
        "description": "PO and invoice line items with vendor, material group, cost center"
      },
      {
        "system": "Coupa",
        "description": "Requisition and PO data from cloud procurement platform"
      },
      {
        "system": "SpendHQ",
        "description": "Spend analytics platform with UNSPSC taxonomy engine"
      },
      {
        "system": "Sievo",
        "description": "Supplier entity resolution and spend enrichment"
      },
      {
        "system": "BigQuery",
        "description": "Enriched dimensional spend cube for downstream analytics"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "LLM disambiguation of ambiguous PO descriptions and entity reasoning"
      }
    ],
    "pipeline": [
      {
        "label": "Data Extraction",
        "description": "Extract PO and invoice line items from SAP S/4HANA and Coupa. Normalize fields across source systems into a common schema for classification."
      },
      {
        "label": "ML Taxonomy Classification",
        "description": "UNSPSC/eClass L1-L4 classification on structured fields — vendor name, material group, cost center. Confidence scoring determines which records route to LLM for disambiguation."
      },
      {
        "label": "LLM Disambiguation & Entity Resolution",
        "description": "Gemini interprets the 20% of transactions that ML cannot confidently classify — descriptions like 'misc. parts per drawing Rev C.' Reads vendor context, cost center, and purchase history. Resolves supplier name variants using business judgment."
      },
      {
        "label": "Spend Cube Load",
        "description": "Enriched, classified, and entity-resolved spend data loaded into BigQuery dimensional model for downstream analytics and dashboarding."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Spend Classification & Enrichment so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
