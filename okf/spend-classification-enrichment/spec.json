          "claim": "Classification accuracy moved from 78% toward 96%",
          "mustCite": [
            "sap_s_4hana_fi_mm.gl_entries",
            "coupa.requisitions"
          ],
          "sourceSystemIds": [
            "sap_s_4hana_fi_mm",
            "coupa"
