    "SAP S/4HANA FI",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Document collection time",
      "before": "2-3 weeks",
      "after": "2-3 days"
    },
    {
      "label": "Response drafting",
      "before": "1 week per topic",
      "after": "1-2 days with review"
    },
    {
      "label": "Audit assessment outcomes",
      "before": "Reactive concessions",
      "after": "Evidence-based defense"
    }
  ],
  "statusQuo": [
    "Document collection for tax audits takes 2-3 weeks as staff manually search across ERP, email, and file shares.",
    "Audit responses drafted from scratch for each request, even when similar questions were answered in prior audits.",
    "Defensive positions weakened by incomplete documentation and failure to cite specific regulatory support."
  ],
  "agentification": [
    "Automated document collection reduces preparation from 2-3 weeks to 2-3 days with organized, indexed packages.",
    "Gemini drafts responses citing specific regulatory sections -- Reg. 1.41-4(a) for R&D credits -- with project-level evidence.",
    "Prior audit responses indexed and retrieved, ensuring consistency and leveraging previously successful defense strategies."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA FI",
        "description": "Tax returns, financial statements, supporting schedules, transaction detail"
      },
      {
        "system": "Document Management",
        "description": "Tax workpapers, contracts, invoices, prior audit correspondence"
      },
      {
        "system": "BigQuery",
        "description": "Document retrieval indexing, gap analysis, audit trail reconstruction"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Audit response drafting, regulatory citation, defense narrative generation"
      }
    ],
    "pipeline": [
      {
        "label": "Audit Request Parsing",
        "description": "Parse audit notification and information document requests into structured requirements. Map each request to specific document types, time periods, and responsible teams."
      },
      {
        "label": "Document Collection & Organization",
        "description": "Automated retrieval of requested documents from ERP, document management, and archives. Organize by audit topic with index. Identify gaps where documents are missing or incomplete."
      },
      {
        "label": "Response & Defense Drafting",
        "description": "Gemini drafts audit responses: 'IRS questioning $4.5M R&D credit. Compile qualifying project documentation and timesheets. Cite Reg. 1.41-4(a) with project-level nexus to qualified research activities.' Creates defense narrative with regulatory citations."
      },
      {
        "label": "Review & Submission",
        "description": "Present response packages to Tax Director for review and disclosure strategy determination. Track submission deadlines and auditor follow-up requests."
      }
    ]
  },
