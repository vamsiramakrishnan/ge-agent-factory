  "id": "lead-scoring-qualification-agent",
  "title": "Lead Scoring & Qualification Agent",
  "department": "marketing",
  "sourcePath": "../presentation/src/components/slides/use-cases/marketing/LeadScoringQualificationAgent.tsx",
  "subtitle": "A-3102 \\u2022 Demand Generation",
  "persona": "Demand Gen Manager",
  "layer": "Layer 4: Data Agent",
  "triggerType": "event",
  "domainId": "domain-31",
  "systems": [
    "HubSpot",
    "Salesforce CRM",
    "6sense",
    "Demandbase",
    "BigQuery"
  ],
  "kpis": [
    {
      "label": "MQL-to-SQL conversion",
      "before": "18%",
      "after": "35%"
    },
    {
      "label": "Lead scoring accuracy",
      "before": "Point-based rules",
      "after": "Predictive ML"
    },
    {
      "label": "SDR context quality",
      "before": "Score only",
      "after": "Score + qualification narrative"
    }
  ],
  "statusQuo": [
    "Lead scoring based on static point rules that don't adapt to changing buyer behavior patterns.",
    "Intent signals from 6sense and Demandbase used in isolation rather than combined with behavioral data.",
    "SDRs receive a lead score number with no context on why the lead scored high or how to approach them."
  ],
  "agentification": [
    "Gemini interprets contextual signals that scoring models miss \\u2014 competitor comparison downloads, pricing webinar attendance, and company job postings.",
    "Synthesizes quantitative scores with qualitative context into qualification narratives for SDR outreach.",
    "Predictive ML scoring with behavioral velocity replaces static point-based rules for higher conversion accuracy."
  ],
  "architecture": {
    "connections": [
      {
        "system": "HubSpot",
        "description": "Behavioral events, content engagement, email interactions, form submissions"
      },
      {
        "system": "Marketo",
        "description": "Lead activity data, engagement scoring, program membership"
      },
      {
        "system": "Salesforce CRM",
        "description": "Lead/contact records, account hierarchy, deal history"
      },
      {
        "system": "6sense",
        "description": "Intent data, buying stage prediction, anonymous visitor matching"
      },
      {
        "system": "Demandbase",
        "description": "Account-level intent, firmographic enrichment, technographic data"
      },
      {
        "system": "BigQuery",
        "description": "Unified lead data, predictive scoring models, conversion history"
      }
    ],
    "pipeline": [
      {
        "label": "Signal Collection",
        "description": "Receive behavioral events from MAP. Enrich with firmographic data from 6sense/Demandbase. Match to CRM records with account hierarchy resolution."
      },
      {
        "label": "Predictive Scoring",
        "description": "Predictive lead scoring using gradient boosting on conversion history. Intent signal aggregation. Behavioral velocity scoring (acceleration of engagement). ICP fit scoring."
      },
      {
        "label": "Contextual Qualification",
        "description": "Interpret contextual signals scoring models miss \\u2014 competitor comparison downloads (high intent), pricing webinar attendance (buying signal), company job postings (org investment). Synthesize into qualification narratives for SDRs."
      },
      {
        "label": "MQL Routing",
        "description": "Update lead scores in CRM. Trigger MQL notifications to assigned SDRs with qualification narrative and recommended outreach approach."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Lead Scoring & Qualification Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
