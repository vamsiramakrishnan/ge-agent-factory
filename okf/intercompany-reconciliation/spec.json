  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-21",
  "systems": [
    "SAP S/4HANA FI",
    "BlackLine",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Auto-match rate",
      "before": "60%",
      "after": "95%"
    },
    {
      "label": "IC reconciliation time",
      "before": "3-4 days",
      "after": "4 hours"
    },
    {
      "label": "Unresolved items at close",
      "before": "15-20",
      "after": "2-3"
    }
  ],
  "statusQuo": [
    "IC reconciliation requires manual comparison of balances across 10+ entities with different currencies.",
    "Mismatches investigated by chasing entity controllers via email — days of back-and-forth.",
    "Correcting entries drafted manually after root cause is finally identified."
  ],
  "agentification": [
    "Fuzzy matching across entities resolves 95% of IC transactions automatically.",
    "Gemini traces mismatches to contract amendments or unprocessed entries without manual investigation.",
    "Auto-generates correcting entries and notifies responsible controllers with full context."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA FI",
        "description": "Intercompany balances, IC transaction details across entities"
      },
      {
        "system": "BlackLine",
        "description": "IC matching rules, reconciliation workpapers, exception tracking"
      },
      {
        "system": "BigQuery",
        "description": "Historical IC patterns, currency conversion data, aging analytics"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Mismatch root cause investigation, correcting entry generation"
      }
    ],
    "pipeline": [
      {
        "label": "IC Balance Aggregation",
        "description": "Extract intercompany balances across all entities, normalize currencies, and organize by IC partner pair for matching."
      },
      {
        "label": "Fuzzy Matching",
        "description": "Match IC transactions across entities using fuzzy matching on amounts, dates, and references. Apply currency conversion and threshold-based exception flagging for unresolved items."
      },
      {
        "label": "Mismatch Investigation",
        "description": "Gemini investigates mismatches that aren't simple timing differences. Traces discrepancies to contract amendments, unprocessed entries, or FX differences. Generates correcting entries."
      },
      {
        "label": "Resolution & Notification",
        "description": "Post correcting entries and notify responsible entity controllers of actions taken and remaining items requiring manual resolution."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Intercompany Reconciliation so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
