      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "ic_balance_aggregation",
            "label": "IC Balance Aggregation",
            "description": "Extract intercompany balances across all entities, normalize currencies, and organize by IC partner pair for matching.",
            "tools": [
              "lookup_intercompany_reconciliation_controls_playbook"
            ]
          },
          {
            "id": "mismatch_investigation",
            "label": "Mismatch Investigation",
            "description": "Gemini investigates mismatches that aren't simple timing differences. Traces discrepancies to contract amendments, unprocessed entries, or FX differences. Generates correcting entries.",
            "tools": [
              "query_sap_s_4hana_fi_gl_entries",
              "action_sap_s_4hana_fi_generate"
            ]
          },
          {
            "id": "resolution_notification",
            "label": "Resolution & Notification",
            "description": "Post correcting entries and notify responsible entity controllers of actions taken and remaining items requiring manual resolution.",
            "tools": [
              "query_sap_s_4hana_fi_gl_entries"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Auto-match rate moved from 60% toward 95%",
          "mustCite": [
            "sap_s_4hana_fi.gl_entries",
            "blackline.reconciliations"
          ],
          "sourceSystemIds": [
            "sap_s_4hana_fi",
            "blackline"
          ]
        },
        {
          "claim": "IC reconciliation time moved from 3-4 days toward 4 hours",
          "mustCite": [
            "sap_s_4hana_fi.gl_entries",
            "blackline.reconciliations"
          ],
          "sourceSystemIds": [
            "sap_s_4hana_fi",
            "blackline"
          ]
        }
      ],
      "escalationRules": [
        {
          "trigger": "Auto-match rate regresses past the 60% baseline by more than 20%",
          "action": "escalate_to_human",
          "handoffTarget": "GL Accountant / Controller",
          "rationale": "Significant regressions need human judgment before automated remediation runs against production records."
        },
        {
          "trigger": "Source-system evidence is incomplete or stale (>24h) for any required entity",
          "action": "request_more_info",
          "rationale": "Recommendations grounded in stale evidence misrepresent current state and undermine audit defensibility."
