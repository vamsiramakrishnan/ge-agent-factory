  "kpis": [
    {
      "label": "Dunning response rate",
      "before": "22%",
      "after": "58%"
    },
    {
      "label": "Time to draft",
      "before": "20 min/letter",
      "after": "< 1 min"
    },
    {
      "label": "Days to payment post-dunning",
      "before": "18 days",
      "after": "7 days"
    }
  ],
  "statusQuo": [
    "Generic template-based dunning letters that ignore customer relationship history and context.",
    "Same boilerplate sent to a 10-year strategic partner as to a first-time buyer with payment issues.",
    "AR staff spend 20+ minutes per letter trying to personalize generic templates manually."
  ],
  "agentification": [
    "Gemini drafts context-aware communications -- a courtesy reminder to a long-term customer reads differently than a final notice to a high-risk account.",
    "ML predicts optimal timing and channel based on historical response patterns by customer segment.",
    "Response rates nearly triple as communications feel personalized and contextually appropriate."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA FI",
        "description": "Dunning levels, payment history, customer master, open invoices"
      },
      {
        "system": "HighRadius",
        "description": "Customer interaction history, prior communications, promise-to-pay logs"
      },
      {
        "system": "BigQuery",
        "description": "Communication response analytics, optimal timing models, tone effectiveness data"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Dunning communication generation with tone and context adaptation"
      },
      {
        "system": "Email / CRM",
        "description": "Communication delivery and response tracking"
      }
    ],
    "pipeline": [
      {
        "label": "Dunning Context Assembly",
        "description": "Pull customer payment history, relationship tenure, open disputes, prior dunning communications, and current balance details. Build a complete picture of the collection situation."
      },
      {
        "label": "Response Prediction",
        "description": "ML model predicts payment likelihood and optimal communication timing. Analyzes which dunning tone historically drives fastest response for this customer segment."
      },
      {
        "label": "Communication Generation",
        "description": "Gemini drafts the dunning communication adapting tone to context. A first reminder to a 10-year customer reads as a courtesy; a third notice to a high-risk account includes escalation language and legal references. Personalizes with specific invoice details."
      },
      {
        "label": "Delivery & Tracking",
        "description": "Route approved communication via email or CRM. Track open, read, and response events. Feed response data back for model improvement."
      }
    ]
  },
