  "kpis": [
    {
      "label": "Goal quality",
      "before": "Vague",
      "after": "SMART-verified"
    },
    {
      "label": "Alignment score",
      "before": "40%",
      "after": "95%"
    },
    {
      "label": "Drafting time",
      "before": "2 hours",
      "after": "5 min"
    }
  ],
  "statusQuo": [
    "Goals written in vague language lacking measurable outcomes.",
    "Poor cascading from organizational objectives to individual targets.",
    "Misalignment between team and department goals discovered at review time."
  ],
  "agentification": [
    "Generates SMART goal drafts from role context and job descriptions.",
    "Auto-cascades objectives from company OKRs through every org level.",
    "Real-time alignment scoring ensures individual goals support strategic priorities."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Role profiles, job levels, organizational OKRs"
      },
      {
        "system": "Lattice",
        "description": "Team goals, OKR hierarchy, goal templates"
      },
      {
        "system": "Google Docs",
        "description": "Goal drafts with collaborative editing"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "SMART goal generation, alignment scoring"
      }
    ],
    "pipeline": [
      {
        "label": "Context Assembly",
        "description": "Pull role context, team OKRs, and company strategy from Workday and Lattice. Structure inputs for goal generation."
      },
      {
        "label": "Goal Generation & Alignment",
        "description": "Gemini drafts SMART goals from role context. Auto-cascading verification ensures alignment with org OKRs at every level."
      },
      {
        "label": "Publishing",
        "description": "Approved goals published to Lattice performance system and shared via Google Docs for collaborative review."
      }
    ]
  },
