      "label": "Launch plan creation",
      "before": "2-3 weeks",
      "after": "1 day"
    },
    {
      "label": "Cross-functional alignment",
      "before": "5+ meetings",
      "after": "Auto-orchestrated"
    },
    {
      "label": "Launch readiness score",
      "before": "Subjective",
      "after": "Data-driven checklist"
    }
  ],
  "statusQuo": [
    "Launch plans manually assembled from templates with limited adaptation to launch type or audience.",
    "Cross-functional coordination through meetings and email chains with frequent miscommunication.",
    "Messaging frameworks created from scratch each time without systematic use of historical launch performance."
  ],
  "agentification": [
    "Gemini interprets product requirements to generate tailored launch checklists appropriate for the launch tier.",
    "LLM reasons about which channels and tactics are appropriate for different launch types based on historical performance.",
    "Draft messaging frameworks and coordinate cross-functional dependencies automatically through Asana and Slack."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Asana",
        "description": "Project plan creation, task assignment, milestone tracking"
      },
      {
        "system": "Google Workspace",
        "description": "Product requirements docs, positioning briefs, launch assets"
      },
      {
        "system": "Salesforce CRM",
        "description": "Historical launch performance, pipeline impact benchmarks"
      },
      {
        "system": "HubSpot",
        "description": "Campaign setup, email sequence configuration, UTM tracking"
      },
      {
        "system": "Slack",
        "description": "Milestone notifications, cross-functional coordination alerts"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Requirements interpretation, launch plan generation, messaging frameworks"
      }
    ],
    "pipeline": [
      {
        "label": "Requirements Parsing",
        "description": "Interpret product requirements documents and positioning briefs to understand launch scope, audience, and key differentiators. Classify launch tier (major product vs. feature update vs. partnership)."
      },
      {
        "label": "Historical Benchmarking",
        "description": "Pull performance data from prior launches of similar tier. Analyze timeline risks based on past delays and resource utilization patterns."
      },
      {
        "label": "Plan & Messaging Generation",
        "description": "Generate tailored launch checklist, channel strategy, and messaging framework based on launch tier. Draft launch messaging and coordinate cross-functional dependencies."
      },
      {
        "label": "Orchestration & Setup",
        "description": "Create project plan in Asana, assign tasks across functions, set up HubSpot campaign, and schedule Slack notifications at key milestones."
      }
    ]
  },
