    "apis": [
      {
        "id": "google_sheets_publish_okr_scorecard",
        "sourceSystemId": "google_sheets",
        "method": "POST",
        "path": "/v4/spreadsheets/{spreadsheet_id}/values/{range}:batchUpdate",
        "description": "Publish the refreshed OKR scorecard rows to the team's tracking sheet.",
        "requestSchema": {
          "spreadsheet_id": "string",
          "range": "string",
          "scorecard_rows": "object[]"
        },
        "responseSchema": {
          "spreadsheet_id": "string",
          "updated_range": "string",
          "updated_rows": "number"
        },
        "idempotencyKey": "spreadsheet_id+period+revision_hash"
      },
      {
        "id": "slack_notify_okr_owner",
        "sourceSystemId": "slack",
        "method": "POST",
        "path": "/api/chat.postMessage",
        "description": "Notify the OKR owner in Slack when a key result is detected as stalled or off-track.",
        "requestSchema": {
          "channel": "string",
          "owner_user_id": "string",
          "objective_id": "string",
          "text": "string",
          "attachments": "object[]"
        },
        "responseSchema": {
          "ts": "string",
          "channel": "string",
          "message_id": "string"
        },
        "idempotencyKey": "owner_user_id+objective_id+digest_hash"
      }
    ],
    "anomalies": [
      {
        "id": "okr-progress-tracker-agent-baseline-gap",
        "description": "Seed a realistic gap where Update frequency sits between Quarterly and Continuous, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "employees",
          "positions"
        ],
        "discoveryPath": [
          "Inspect Workday records for the affected entities",
          "Compare against Jira historical baseline",
          "Generate a citation-backed recommendation"
        ],
        "expectedEvidence": [
          "source-system record",
          "historical baseline metric",
          "generated audit trail"
        ],
        "expectedRecommendation": "Explain the gap, cite supporting evidence, and propose the next Manager action."
      }
    ],
