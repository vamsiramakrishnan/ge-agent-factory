      "label": "Stalled goal detection",
      "before": "At review",
      "after": "Real-time"
    },
    {
      "label": "Recalibration speed",
      "before": "Next quarter",
      "after": "Immediate"
    }
  ],
  "statusQuo": [
    "OKR tracking managed in disconnected spreadsheets across teams.",
    "Progress updates happen quarterly at best, masking early warning signs.",
    "Recalibration of goals happens too late to course-correct meaningfully."
  ],
  "agentification": [
    "Continuous OKR progress monitoring from integrated data sources.",
    "Automated nudges for stalled goals and at-risk key results.",
    "Mid-cycle recalibration suggestions based on changing business context."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Employee goals, performance indicators"
      },
      {
        "system": "Lattice",
        "description": "OKR hierarchy, key result progress, check-ins"
      },
      {
        "system": "Jira",
        "description": "Project delivery signals, sprint velocity, task completion"
      },
      {
        "system": "BigQuery",
        "description": "OKR progress analytics, trend data, risk signals"
      }
    ],
    "pipeline": [
      {
        "label": "Progress Signal Collection",
        "description": "Continuous sync of OKR progress from Lattice, project delivery signals from Jira, and performance indicators from Workday into BigQuery."
      },
      {
        "label": "Trajectory Analysis",
        "description": "Completion trajectory modeling with at-risk detection. Statistical analysis of progress velocity and predicted end-of-cycle outcomes."
      },
      {
        "label": "Nudge & Recalibration",
        "description": "Automated nudges for stalled or at-risk goals. Mid-cycle recalibration suggestions based on changing business context."
      }
    ]
  },
