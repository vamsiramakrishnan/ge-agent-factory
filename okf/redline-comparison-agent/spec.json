      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "version_retrieval",
            "label": "Version Retrieval",
            "description": "Receive new document version from CLM. Retrieve previous version for comparison. Normalize both versions from Word/Google Docs into comparable structured format.",
            "tools": [
              "query_docusign_clm_contracts",
              "query_microsoft_word_microsoft_word_records",
              "query_google_docs_documents",
              "lookup_redline_comparison_agent_policy_guide"
            ]
          },
          {
            "id": "structural_diff_detection",
            "label": "Structural Diff Detection",
            "description": "Word-level diff detection with structural change identification — section additions, deletions, and moves. Classify changes by type: substantive, formatting, or structural.",
            "tools": [
              "query_microsoft_word_microsoft_word_records"
            ]
          },
          {
            "id": "semantic_impact_analysis",
            "label": "Semantic Impact Analysis",
            "description": "Gemini performs meaning-level comparison — understanding that 'best efforts' to 'commercially reasonable efforts' is a commitment reduction, not a word edit. Detects deleted protections (entire Data Protection clause removed) and flags as likely intentional risk reallocation. Prioritizes changes by business impact.",
            "tools": [
              "query_microsoft_word_microsoft_word_records",
              "lookup_redline_comparison_agent_policy_guide"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Review time per redline moved from 2-4 hours toward 20 minutes",
          "mustCite": [
            "icertis.contracts",
            "docusign_clm.contracts"
          ],
          "sourceSystemIds": [
            "icertis",
            "docusign_clm"
          ]
        },
        {
          "claim": "Semantic changes caught moved from Word-level only toward Meaning-level",
          "mustCite": [
            "icertis.contracts",
            "docusign_clm.contracts"
          ],
          "sourceSystemIds": [
            "icertis",
            "docusign_clm"
          ]
        }
      ],
      "escalationRules": [
        {
          "trigger": "Review time per redline regresses past the 2-4 hours baseline by more than 20%",
          "action": "escalate_to_human",
          "handoffTarget": "Contract Manager",
          "rationale": "Significant regressions need human judgment before automated remediation runs against production records."
        },
        {
          "trigger": "Source-system evidence is incomplete or stale (>24h) for any required entity",
          "action": "request_more_info",
          "rationale": "Recommendations grounded in stale evidence misrepresent current state and undermine audit defensibility."
        }
      ],
      "refusalRules": [
        "Never fabricate metric values; only publish numbers derived from Icertis (and other named systems) entities.",
        "Never bypass Contract Manager approval on escalation triggers, even when confidence is high.",
        "Never expose individual personal data (PII) in summaries; aggregate or pseudonymise before output.",
        "Never act on data older than the staleness threshold defined in the runbook without a fresh re-query."
      ],
      "goldenEvals": [
        {
