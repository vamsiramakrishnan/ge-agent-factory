    "behaviorContract": {
      "role": "Contract Manager agent for the Redline Comparison Agent workflow",
      "primaryObjective": "Gemini performs semantic diff — understanding that 'best efforts' to 'commercially reasonable efforts' is a meaningful commitment reduction. LLM detects section deletions that remove protections and flags as likely intentional risk reallocation, not editing error. so the Contract Manager can move the Review time per redline KPI.",
      "inScope": [
        "Gemini performs semantic diff — understanding that 'best efforts' to 'commercially reasonable efforts' is a meaningful commitment reduction",
        "LLM detects section deletions that remove protections and flags as likely intentional risk reallocation, not editing error",
        "Prioritizes changes by business impact rather than presenting a 200-item word-level diff list — reviewers focus on what matters"
      ],
      "outOfScope": [
        "Contract execution without legal review",
        "Supplier disqualification decisions (category lead retains authority)",
        "Single-source justification overrides above policy threshold"
      ],
