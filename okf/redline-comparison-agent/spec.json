  "subtitle": "A-1405 • Contract Lifecycle",
  "persona": "Contract Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event",
  "domainId": "domain-14",
  "systems": [
    "Icertis",
    "DocuSign CLM",
    "Microsoft Word",
    "Google Docs",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Review time per redline",
      "before": "2-4 hours",
      "after": "20 minutes"
    },
    {
      "label": "Semantic changes caught",
      "before": "Word-level only",
      "after": "Meaning-level"
    },
    {
      "label": "Deleted protections missed",
      "before": "15-20%",
      "after": "<1%"
    }
  ],
  "statusQuo": [
    "Redline comparison uses MS Word track changes — shows every word edit equally, burying critical changes in noise.",
    "Semantic shifts like 'best efforts' to 'commercially reasonable efforts' not flagged as meaningful reductions.",
    "Entire section deletions (e.g., Data Protection clause removed) treated the same as formatting changes."
  ],
  "agentification": [
    "Gemini performs semantic diff — understanding that 'best efforts' to 'commercially reasonable efforts' is a meaningful commitment reduction.",
    "LLM detects section deletions that remove protections and flags as likely intentional risk reallocation, not editing error.",
    "Prioritizes changes by business impact rather than presenting a 200-item word-level diff list — reviewers focus on what matters."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Icertis",
        "description": "Document versioning, previous contract versions"
      },
      {
        "system": "DocuSign CLM",
        "description": "New document version ingestion, version history"
      },
      {
        "system": "Microsoft Word",
        "description": "Word document parsing, track changes extraction"
      },
      {
        "system": "Google Docs",
        "description": "Google Doc version comparison, comment integration"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Semantic diff analysis, meaning-level change interpretation, impact prioritization"
      }
    ],
    "pipeline": [
      {
        "label": "Version Retrieval",
        "description": "Receive new document version from CLM. Retrieve previous version for comparison. Normalize both versions from Word/Google Docs into comparable structured format."
      },
      {
        "label": "Structural Diff Detection",
        "description": "Word-level diff detection with structural change identification — section additions, deletions, and moves. Classify changes by type: substantive, formatting, or structural."
      },
      {
        "label": "Semantic Impact Analysis",
        "description": "Gemini performs meaning-level comparison — understanding that 'best efforts' to 'commercially reasonable efforts' is a commitment reduction, not a word edit. Detects deleted protections (entire Data Protection clause removed) and flags as likely intentional risk reallocation. Prioritizes changes by business impact."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Redline Comparison Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
