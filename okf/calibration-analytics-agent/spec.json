      "label": "Pre-cal prep",
      "before": "2 weeks",
      "after": "Instant"
    },
    {
      "label": "Bias detection",
      "before": "Post-facto",
      "after": "Pre-session"
    },
    {
      "label": "Rating equity",
      "before": "Inconsistent",
      "after": "Data-validated"
    }
  ],
  "statusQuo": [
    "Calibration sessions driven by recency bias and loudest-voice dynamics.",
    "Rating distributions inconsistent across managers and business units.",
    "Equity concerns surface post-facto when remediation is costly."
  ],
  "agentification": [
    "Pre-calibration analytics surfacing distribution anomalies by manager.",
    "Bias detection across protected categories with statistical rigor.",
    "Data-driven calibration recommendations anchored in objective evidence."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Proposed ratings, employee demographics, manager assignments"
      },
      {
        "system": "BigQuery",
        "description": "Rating distribution analytics, historical calibration data"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Bias detection, disparity analysis, calibration recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Rating Data Assembly",
        "description": "Pull proposed ratings, employee demographics, and manager assignment data from Workday. Combine with historical rating patterns from BigQuery."
      },
      {
        "label": "Distribution & Bias Analysis",
        "description": "Analyze bell curve distributions, cross-manager patterns, and outlier detection. Statistical disparity analysis across protected categories."
      },
      {
        "label": "Calibration Recommendations",
        "description": "Gemini generates data-backed calibration suggestions anchored in objective evidence. Surfaces specific manager patterns and equity concerns."
      }
    ]
  },
