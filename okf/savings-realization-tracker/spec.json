  "kpis": [
    {
      "label": "Savings realization rate",
      "before": "40-50%",
      "after": "85%+"
    },
    {
      "label": "Leakage root cause coverage",
      "before": "Ad-hoc investigation",
      "after": "100% auto-analyzed"
    },
    {
      "label": "Report generation",
      "before": "3-5 days manual",
      "after": "Same-day automated"
    }
  ],
  "statusQuo": [
    "Savings tracked in spreadsheets with no reconciliation against actual PO prices paid.",
    "$9M gap between identified and realized savings unexplained — board reports use unvalidated numbers.",
    "Leakage investigation requires manual PO-by-PO review, rarely completed."
  ],
  "agentification": [
    "ML classifies savings types with realization probability scoring based on historical conversion rates.",
    "LLM interprets why savings leaked — reads PO exception context: 'supplier couldn't deliver, switched to alternate at higher price' vs. 'requester bypassed contract.'",
    "Generates narrative savings report linking leakage to demand-driven shortfalls vs. execution gaps."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Coupa",
        "description": "Savings pipeline data, contract pricing schedules, PO actuals"
      },
      {
        "system": "SAP Ariba",
        "description": "Sourcing event savings, negotiated price baselines, award data"
      },
      {
        "system": "BigQuery",
        "description": "Savings realization analytics, leakage detection, classification models"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Leakage root cause interpretation, narrative savings report generation"
      }
    ],
    "pipeline": [
      {
        "label": "Baseline-to-Actual Matching",
        "description": "Pull contracted pricing from sourcing tools and match against actual PO/invoice prices in ERP. Calculate variance by category, initiative, and supplier to quantify realized vs. identified savings."
      },
      {
        "label": "Savings Classification & Scoring",
        "description": "ML classifies savings type — negotiated price reduction, cost avoidance, demand reduction, specification change. Realization probability scoring based on historical conversion rates. Price drift analysis detects leakage patterns."
      },
      {
        "label": "Leakage Interpretation & Reporting",
        "description": "Gemini reads PO exception context to determine if leakage is capacity-driven (supplier could not deliver) or compliance-driven (requester bypassed contract). Generates narrative savings report for CPO linking the gap to demand-driven shortfalls vs. execution gaps with actionable remediation."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
