    {
      "label": "Regulation detection lag",
      "before": "Months after enactment",
      "after": "Days of publication"
    },
    {
      "label": "Supplier compliance gaps identified",
      "before": "Audit-discovered",
      "after": "Proactively flagged"
    },
    {
      "label": "Impact assessment time",
      "before": "2-3 weeks",
      "after": "48 hours"
    }
  ],
  "statusQuo": [
    "New regulations discovered months after enactment — compliance team plays catch-up.",
    "No systematic mapping of regulations to affected supplier categories and certifications.",
    "Legal texts like EU CBAM and UFLPA require expert interpretation that's slow and expensive."
  ],
  "agentification": [
    "RAG pipeline over regulatory corpus retrieves relevant rules and maps them to affected supplier categories automatically.",
    "LLM interprets new regulatory texts — 'CBAM reporting requires embedded emissions data from steel suppliers starting Jan 2027' — and identifies which 3 of 12 suppliers can provide it.",
    "Assesses whether existing supplier certifications satisfy new requirements or gaps exist, generating remediation timelines."
  ],
  "architecture": {
    "connections": [
      {
        "system": "MetricStream",
        "description": "Compliance management platform, regulatory change tracking"
      },
      {
        "system": "SAP GRC",
        "description": "Governance, risk, and compliance — supplier certification status, audit findings"
      },
      {
        "system": "Regulatory Feeds",
        "description": "Global regulatory publication feeds — EU, US, APAC regulatory bodies"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Regulatory text interpretation, supply base impact analysis, gap identification"
      },
      {
        "system": "BigQuery",
        "description": "Regulation-to-supplier mapping, certification tracking, gap scoring analytics"
      }
    ],
    "pipeline": [
      {
        "label": "Regulatory Change Detection",
        "description": "Monitor regulatory feeds for new and amended regulations. Map regulations to affected supplier categories using metadata classification. Pull supplier certification status from MetricStream and SAP GRC."
      },
      {
        "label": "Compliance Gap Scoring",
        "description": "Score compliance gaps by comparing existing supplier certifications against new regulatory requirements. Track certification expiry and renewal timelines across the supply base."
      },
      {
        "label": "Regulatory Impact Interpretation",
        "description": "Gemini reads new regulatory texts (EU CBAM, UFLPA, REACH updates) and reasons about supply base implications: 'CBAM reporting requires embedded emissions data from steel and aluminum suppliers starting Jan 2027 — only 3 of 12 suppliers can provide this data.' Interprets whether existing certifications satisfy new requirements or gaps exist."
      }
    ]
  },
