      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "regulatory_change_detection",
            "label": "Regulatory Change Detection",
            "description": "Monitor regulatory feeds for new and amended regulations. Map regulations to affected supplier categories using metadata classification. Pull supplier certification status from MetricStream and SAP GRC.",
            "tools": [
              "query_metricstream_metricstream_records",
              "query_sap_grc_control_tests",
              "query_regulatory_feeds_regulatory_feeds_records",
              "lookup_regulatory_compliance_tracker_policy_guide",
              "action_metricstream_execute"
            ]
          },
          {
            "id": "compliance_gap_scoring",
            "label": "Compliance Gap Scoring",
            "description": "Score compliance gaps by comparing existing supplier certifications against new regulatory requirements. Track certification expiry and renewal timelines across the supply base.",
            "tools": [
              "query_regulatory_feeds_regulatory_feeds_records",
              "lookup_regulatory_compliance_tracker_policy_guide"
            ]
          },
          {
            "id": "regulatory_impact_interpretation",
            "label": "Regulatory Impact Interpretation",
            "description": "Gemini reads new regulatory texts (EU CBAM, UFLPA, REACH updates) and reasons about supply base implications: 'CBAM reporting requires embedded emissions data from steel and aluminum suppliers starting Jan 2027 — only 3 of 12 suppliers can provide this data.' Interprets whether existing certifications satisfy new requirements or gaps exist.",
            "tools": [
              "query_regulatory_feeds_regulatory_feeds_records",
              "lookup_regulatory_compliance_tracker_policy_guide"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Regulation detection lag moved from Months after enactment toward Days of publication",
          "mustCite": [
            "metricstream.metricstream_records",
            "sap_grc.control_tests"
          ],
          "sourceSystemIds": [
            "metricstream",
            "sap_grc"
          ]
        },
        {
          "claim": "Supplier compliance gaps identified moved from Audit-discovered toward Proactively flagged",
          "mustCite": [
            "metricstream.metricstream_records",
            "sap_grc.control_tests"
          ],
          "sourceSystemIds": [
            "metricstream",
            "sap_grc"
          ]
        }
      ],
      "escalationRules": [
        {
          "trigger": "Regulation detection lag regresses past the Months after enactment baseline by more than 20%",
          "action": "escalate_to_human",
          "handoffTarget": "Compliance Manager",
          "rationale": "Significant regressions need human judgment before automated remediation runs against production records."
        },
        {
          "trigger": "Source-system evidence is incomplete or stale (>24h) for any required entity",
          "action": "request_more_info",
          "rationale": "Recommendations grounded in stale evidence misrepresent current state and undermine audit defensibility."
        },
        {
          "trigger": "Proposed execute action lacks supporting evidence from at least two systems",
          "action": "refuse",
          "rationale": "Single-system evidence is insufficient to authorize external state changes without manual review."
        }
      ],
