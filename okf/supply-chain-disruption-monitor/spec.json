  "kpis": [
    {
      "label": "Disruption detection time",
      "before": "Days after impact",
      "after": "Hours before impact"
    },
    {
      "label": "Signal sources monitored",
      "before": "Manual news scan",
      "after": "1,000+ feeds continuous"
    },
    {
      "label": "Supply chain tiers covered",
      "before": "Tier-1 only",
      "after": "Tier-1 through Tier-3"
    }
  ],
  "statusQuo": [
    "Disruptions discovered only when a supplier misses a delivery — reactive, not predictive.",
    "No visibility into sub-tier supplier geography or shipping lane dependencies.",
    "Risk team manually scans news — can't connect a Malaysian port strike to your specific supply chain."
  ],
  "agentification": [
    "NLP on global news, weather, and maritime data detects emerging disruptions before they hit your supply chain.",
    "LLM connects a Reuters article about a labor strike at a port to your tier-2 supplier who ships through that port.",
    "Synthesizes 12+ weak signals — factory inspections, D&B downgrades, LinkedIn departures — into coherent early-warning narratives."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Resilinc",
        "description": "Supply chain disruption alerts, supplier location mapping"
      },
      {
        "system": "Everstream",
        "description": "Predictive supply chain risk analytics, weather and geo-risk data"
      },
      {
        "system": "Google News API",
        "description": "Real-time global news feed for NLP-based disruption detection"
      },
      {
        "system": "Maritime AIS",
        "description": "Vessel tracking, port congestion data, shipping lane status"
      },
      {
        "system": "BigQuery",
        "description": "Geo-risk correlation engine, supplier-location graph, impact modeling"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "News article interpretation, weak signal synthesis, early-warning narrative generation"
      }
    ],
    "pipeline": [
      {
        "label": "Continuous Signal Ingestion",
        "description": "Poll global news feeds, ingest Resilinc and Everstream disruption alerts, correlate weather event data and maritime AIS signals with supplier locations and shipping lanes."
      },
      {
        "label": "Geo-Risk Scoring & Correlation",
        "description": "Map events to supplier locations and sub-tier dependencies. Weather event severity classification, port congestion tracking from AIS data, and impact radius estimation using geo-risk scoring models."
      },
      {
        "label": "Early-Warning Narrative Synthesis",
        "description": "Gemini reads a Reuters article about a labor strike at a Malaysian port and reasons that this affects your tier-2 electronics supplier who ships through that port. Synthesizes 12+ weak signals into coherent early-warning narratives."
      }
    ]
  },
