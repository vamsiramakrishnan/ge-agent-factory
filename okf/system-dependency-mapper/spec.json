    "GitHub",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Dependency coverage",
      "before": "40% documented",
      "after": "95% auto-discovered"
    },
    {
      "label": "SPOF identification",
      "before": "Post-incident only",
      "after": "Proactive weekly"
    },
    {
      "label": "Change blast radius accuracy",
      "before": "Gut feel",
      "after": "Data-validated"
    }
  ],
  "statusQuo": [
    "System dependencies tracked in outdated Visio diagrams and tribal knowledge — never complete or current.",
    "Single points of failure discovered only after production incidents cause cascading failures.",
    "Change blast radius assessed by gut feel, leading to surprise outages from seemingly safe changes."
  ],
  "agentification": [
    "Gemini merges APM traces, CMDB records, and code-level dependencies into a live dependency graph.",
    "LLM reasons about which dependencies are critical path vs. best-effort, recommending async patterns.",
    "Proactively identifies SPOFs and coupling risks before they cause incidents."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Datadog APM",
        "description": "Distributed traces, service call maps, latency data"
      },
      {
        "system": "ServiceNow CMDB",
        "description": "Application relationships, infrastructure mappings, business service links"
      },
      {
        "system": "GitHub",
        "description": "Import/dependency declarations, service mesh configs"
      },
      {
        "system": "BigQuery",
        "description": "Dependency graph analytics, change blast radius calculations"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Dependency risk reasoning, cascade failure analysis"
      },
      {
        "system": "Ardoq",
        "description": "Architecture model updates, dependency visualization"
      }
    ],
    "pipeline": [
      {
        "label": "Multi-Source Discovery",
        "description": "Collect service-to-service call data from Datadog APM traces, declared relationships from CMDB, and code-level dependency declarations from GitHub. Merge into a unified graph."
      },
      {
        "label": "Graph Analytics",
        "description": "Run critical path analysis, single-point-of-failure detection, circular dependency identification, and change blast radius calculation on the unified graph."
      },
      {
        "label": "Risk Reasoning",
        "description": "Gemini explains dependency risks in business context — which synchronous calls should be async, which SPOFs affect revenue-critical paths, and which coupling patterns need architectural intervention."
      },
      {
        "label": "Model Update",
        "description": "Update the architecture model in Ardoq with discovered dependencies, CMDB reconciliation, and risk annotations."
      }
    ]
  },
