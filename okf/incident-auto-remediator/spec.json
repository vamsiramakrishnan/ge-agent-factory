            "error_context"
          ],
          "evidenceEmitted": [
            "source_system_record"
          ]
        },
        {
          "name": "query_datadog_metrics",
          "kind": "query",
          "sourceSystemId": "datadog",
          "description": "Retrieve memory, CPU, disk I/O, and error rate metrics to distinguish memory leaks from code regressions.",
          "requiredInputs": [
            "service_id",
            "time_range"
          ],
          "produces": [
            "metric_snapshot"
          ],
          "evidenceEmitted": [
            "source_system_record"
          ]
        },
