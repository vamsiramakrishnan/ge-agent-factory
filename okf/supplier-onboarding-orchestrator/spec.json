    "SAP S/4HANA (XK01)",
    "Ariba SLP",
    "Banking Systems",
    "IRS TIN"
  ],
  "kpis": [
    {
      "label": "Onboarding cycle time",
      "before": "15-25 days",
      "after": "3-5 days"
    },
    {
      "label": "Duplicate vendor creation",
      "before": "8-12% of new records",
      "after": "< 1%"
    },
    {
      "label": "Document chase time",
      "before": "4-6 follow-ups",
      "after": "Automated reminders"
    }
  ],
  "statusQuo": [
    "Onboarding is a multi-week manual process with documents chased via email across 4-6 touchpoints.",
    "Entity name mismatches between W-9, bank letters, and insurance certificates create duplicate vendor records.",
    "Missing documents discovered only at payment time, delaying first invoice processing by weeks."
  ],
  "agentification": [
    "Orchestrates end-to-end workflow from document collection through vendor master creation in SAP XK01.",
    "LLM reads non-standard document formats and detects entity inconsistencies — bank letter says 'Acme LLC' but W-9 says 'Acme Industries Inc.'",
    "Context-aware follow-up emails generated automatically for missing documents with supplier-specific instructions."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA (XK01)",
        "description": "Vendor master creation, payment term setup, system access"
      },
      {
        "system": "Ariba SLP",
        "description": "Supplier application intake, document collection portal"
      },
      {
        "system": "IRS TIN Matching",
        "description": "W-9 TIN validation against IRS database"
      },
      {
        "system": "Banking Systems",
        "description": "Bank account verification, ACH setup validation"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Document extraction from non-standard formats, entity consistency detection"
      }
    ],
    "pipeline": [
      {
        "label": "Document Collection & Extraction",
        "description": "Manage multi-step document collection workflow. LLM reads submitted W-9 forms, insurance certificates, and banking letters — even from non-standard formats — and extracts key data fields for validation."
      },
      {
        "label": "Verification & Consistency Checks",
        "description": "TIN/W-9 validated via IRS matching service. Bank account verified. Entity name consistency checked across all documents — bank letter says 'Acme LLC' but W-9 says 'Acme Industries Inc.' flagged for verification rather than creating duplicates."
      },
      {
        "label": "Vendor Master Creation & Provisioning",
        "description": "Create vendor master record in SAP S/4HANA (XK01) with validated data. Configure payment terms, purchasing organization assignments, and system access. Send welcome notification with portal credentials."
      }
    ]
  },
