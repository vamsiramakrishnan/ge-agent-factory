    "anomalies": [
      {
        "id": "release-notes-generator-baseline-gap",
        "description": "Seed a realistic gap where Release notes prep time sits between 2-3 hours and <5 minutes, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "pull_requests",
          "commits"
        ],
        "discoveryPath": [
          "Inspect GitHub records for the affected entities",
          "Compare against Jira historical baseline",
          "Generate a citation-backed recommendation"
        ],
        "expectedEvidence": [
          "source-system record",
          "historical baseline metric",
          "generated audit trail"
        ],
        "expectedRecommendation": "Explain the gap, cite supporting evidence, and propose the next DevOps Lead action."
      }
    ],
