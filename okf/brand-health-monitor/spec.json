  "department": "marketing",
  "sourcePath": "../presentation/src/components/slides/use-cases/marketing/BrandHealthMonitor.tsx",
  "subtitle": "A-3501 • Brand & Communications",
  "persona": "Brand Manager",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-35",
  "systems": [
    "Brandwatch",
    "Sprout Social",
    "Google Trends",
    "SEMrush",
    "BigQuery",
    "Looker"
  ],
  "kpis": [
    {
      "label": "Brand tracking cycle",
      "before": "Monthly manual",
      "after": "Real-time continuous"
    },
    {
      "label": "Signal sources monitored",
      "before": "2-3 platforms",
      "after": "6+ platforms unified"
    },
    {
      "label": "Insight-to-action time",
      "before": "2-3 weeks",
      "after": "Same day"
    }
  ],
  "statusQuo": [
    "Brand health tracked quarterly via expensive agency surveys with 3-4 week lag.",
    "Social sentiment monitored in silos — no unified view across platforms.",
    "Competitive brand positioning based on gut feel rather than data-driven analysis."
  ],
  "agentification": [
    "Gemini synthesizes mentions, search trends, sentiment, and competitive data into a unified brand health score.",
    "LLM interprets why sentiment shifted — correlating with specific events, not just reporting numbers.",
    "Generates strategic recommendations grounded in segment-level analysis, not generic dashboards."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Brandwatch",
        "description": "Brand mention volume, sentiment data, conversation themes"
      },
      {
        "system": "Sprout Social",
        "description": "Social media mentions, engagement metrics, audience data"
      },
      {
        "system": "Google Trends",
        "description": "Brand search interest, regional trends, related queries"
      },
      {
        "system": "SEMrush",
        "description": "Share of voice, competitive brand rankings, ad intelligence"
      },
      {
        "system": "BigQuery",
        "description": "Aggregated brand health metrics, historical trends, segment analysis"
      },
      {
        "system": "Looker",
        "description": "Brand health dashboard with drill-down by segment and competitor"
      }
    ],
    "pipeline": [
      {
        "label": "Signal Aggregation",
        "description": "Pull brand mentions from Brandwatch, social metrics from Sprout Social, search interest from Google Trends, and competitive data from SEMrush into unified dataset."
      },
      {
        "label": "Quantitative Analysis",
        "description": "Compute brand awareness proxies, share of voice, sentiment trends, and brand association clusters. Time-series analysis on key metrics with anomaly detection."
      },
      {
        "label": "Strategic Interpretation",
        "description": "Gemini interprets what brand health metrics mean strategically. Correlates sentiment drops with specific events, pricing changes, or competitor actions. Generates actionable recommendations."
      },
      {
        "label": "Dashboard Delivery",
        "description": "Brand health report and dashboard published with segment-level breakdowns and competitive positioning. Alerts triggered on significant metric changes."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Brand Health Monitor so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
