      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "signal_aggregation",
            "label": "Signal Aggregation",
            "description": "Pull brand mentions from Brandwatch, social metrics from Sprout Social, search interest from Google Trends, and competitive data from SEMrush into unified dataset.",
            "tools": [
              "query_brandwatch_brand_mentions",
              "query_sprout_social_social_posts",
              "query_google_trends_google_trends_records",
              "query_semrush_keyword_rankings",
              "lookup_brand_health_monitor_playbook",
              "action_brandwatch_recommend"
            ]
          },
          {
            "id": "quantitative_analysis",
            "label": "Quantitative Analysis",
            "description": "Compute brand awareness proxies, share of voice, sentiment trends, and brand association clusters. Time-series analysis on key metrics with anomaly detection.",
            "tools": [
              "query_brandwatch_brand_mentions",
              "query_google_trends_google_trends_records",
              "lookup_brand_health_monitor_playbook"
            ]
          },
          {
            "id": "strategic_interpretation",
            "label": "Strategic Interpretation",
            "description": "Gemini interprets what brand health metrics mean strategically. Correlates sentiment drops with specific events, pricing changes, or competitor actions. Generates actionable recommendations.",
            "tools": [
              "query_brandwatch_brand_mentions",
              "lookup_brand_health_monitor_playbook",
              "action_brandwatch_recommend"
            ]
          },
          {
            "id": "dashboard_delivery",
            "label": "Dashboard Delivery",
            "description": "Brand health report and dashboard published with segment-level breakdowns and competitive positioning. Alerts triggered on significant metric changes.",
            "tools": [
              "query_brandwatch_brand_mentions",
              "lookup_brand_health_monitor_playbook"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Brand tracking cycle moved from Monthly manual toward Real-time continuous",
          "mustCite": [
            "brandwatch.brand_mentions",
            "sprout_social.social_posts"
          ],
          "sourceSystemIds": [
            "brandwatch",
            "sprout_social"
          ]
        },
        {
          "claim": "Signal sources monitored moved from 2-3 platforms toward 6+ platforms unified",
          "mustCite": [
            "brandwatch.brand_mentions",
            "sprout_social.social_posts"
          ],
          "sourceSystemIds": [
            "brandwatch",
            "sprout_social"
          ]
        }
      ],
      "escalationRules": [
        {
          "trigger": "Brand tracking cycle regresses past the Monthly manual baseline by more than 20%",
          "action": "escalate_to_human",
          "handoffTarget": "Brand Manager",
          "rationale": "Significant regressions need human judgment before automated remediation runs against production records."
        },
        {
          "trigger": "Source-system evidence is incomplete or stale (>24h) for any required entity",
          "action": "request_more_info",
          "rationale": "Recommendations grounded in stale evidence misrepresent current state and undermine audit defensibility."
        },
        {
          "trigger": "Proposed recommend action lacks supporting evidence from at least two systems",
          "action": "refuse",
          "rationale": "Single-system evidence is insufficient to authorize external state changes without manual review."
        }
      ],
      "refusalRules": [
        "Never fabricate metric values; only publish numbers derived from Brandwatch (and other named systems) entities.",
        "Never bypass Brand Manager approval on escalation triggers, even when confidence is high.",
        "Never expose individual personal data (PII) in summaries; aggregate or pseudonymise before output.",
        "Never act on data older than the staleness threshold defined in the runbook without a fresh re-query."
      ],
      "goldenEvals": [
        {
