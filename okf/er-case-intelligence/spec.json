{
  "id": "er-case-intelligence",
  "title": "ER Case Intelligence",
  "department": "hr",
  "sourcePath": "../presentation/src/components/slides/use-cases/hr/ERCaseIntelligence.tsx",
  "subtitle": "A-601 • Employee Relations",
  "persona": "ER Lead",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event",
  "domainId": "domain-6",
  "systems": [
    "ServiceNow",
    "Workday",
    "Google BigQuery",
    "Legal DB"
  ],
  "kpis": [
    {
      "label": "Case resolution",
      "before": "21 days",
      "after": "8 days"
    },
    {
      "label": "Precedent research",
      "before": "Hours",
      "after": "Instant"
    },
    {
      "label": "Pattern detection",
      "before": "Reactive",
      "after": "Predictive"
    }
  ],
  "statusQuo": [
    "Pattern detection relies on individual specialist memory.",
    "Investigation summaries written from scratch each time.",
    "Inconsistent investigation protocols across specialists."
  ],
  "agentification": [
    "Auto-classification and pattern detection across full case corpus.",
    "Precedent-based investigation approach recommendations.",
    "Automated drafting of investigation summaries and reports."
  ],
  "architecture": {
    "connections": [
      {
        "system": "ServiceNow",
        "description": "ER case records, investigation notes, evidence attachments, outcomes"
      },
      {
        "system": "Workday",
        "description": "Employee profiles, org hierarchy, performance history, tenure"
      },
      {
        "system": "NAVEX",
        "description": "Ethics hotline reports, anonymous complaint data, trend signals"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Precedent research, risk classification, investigation guidance, report drafting"
      }
    ],
    "pipeline": [
      {
        "label": "Case Intake & Classification",
        "description": "Ingest new ER case from ServiceNow with details and evidence. Auto-classify by type, severity, and applicable policy domain. Pull employee context from Workday."
      },
      {
        "label": "Precedent Research",
        "description": "Gemini searches historical case corpus for similar precedents. Analyzes outcomes, timelines, and policy citations from comparable cases to inform approach."
      },
      {
        "label": "Investigation Guidance",
        "description": "Generate structured investigation plan with evidence checklist, interview questions, and compliance verification steps based on case type and precedent analysis."
      },
      {
        "label": "Resolution & Reporting",
        "description": "Draft investigation summary and recommended actions for ER Lead review. Document resolution with complete audit trail in ServiceNow."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for ER Case Intelligence so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
