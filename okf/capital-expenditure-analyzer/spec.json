  "department": "finance",
  "sourcePath": "../presentation/src/components/slides/use-cases/finance/CapExAnalyzer.tsx",
  "subtitle": "A-2005 • FP&A",
  "persona": "CFO / VP Finance",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event",
  "domainId": "domain-20",
  "systems": [
    "SAP S/4HANA",
    "Anaplan",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "CapEx analysis time",
      "before": "1-2 weeks",
      "after": "1 day"
    },
    {
      "label": "Comparable projects reviewed",
      "before": "2-3 manual",
      "after": "All historical"
    },
    {
      "label": "Investment memo quality",
      "before": "Spreadsheet + email",
      "after": "Full memo with risks"
    }
  ],
  "statusQuo": [
    "CapEx analysis built from scratch in Excel for each request — no comparable project database.",
    "Project justifications reviewed as standalone documents without historical ROI comparison.",
    "Investment memos lack sensitivity analysis and technology obsolescence risk assessment."
  ],
  "agentification": [
    "Automated NPV/IRR/payback calculation with sensitivity analysis on key assumptions.",
    "Gemini reads project justifications and compares against actual ROI of similar past investments.",
    "Generates investment memos with strategic alignment assessment and risk factors."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA (Asset Accounting)",
        "description": "CapEx requests, asset master data, depreciation schedules"
      },
      {
        "system": "Anaplan",
        "description": "Capital budget, hurdle rates, approval workflows"
      },
      {
        "system": "BigQuery",
        "description": "Historical project ROI data, comparable project database"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Justification narrative assessment, investment memo generation"
      }
    ],
    "pipeline": [
      {
        "label": "Request & Comparable Retrieval",
        "description": "Receive CapEx request from SAP, pull comparable past projects from the project database, and retrieve current hurdle rates from Anaplan."
      },
      {
        "label": "Financial Modeling",
        "description": "Calculate NPV/IRR/payback period with sensitivity analysis on key assumptions. Model depreciation schedules and compare against hurdle rates."
      },
      {
        "label": "Strategic Alignment Assessment",
        "description": "Gemini reads the project justification narrative, compares against similar past investments and their actual ROI, and assesses strategic alignment. Generates investment memo with risk analysis."
      },
      {
        "label": "Approval Routing",
        "description": "Route investment memo to CFO and VP Finance for approval with full financial analysis and comparable project performance."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Capital Expenditure Analyzer so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
