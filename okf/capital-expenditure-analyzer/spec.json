        "affectedEntities": [
          "transactions",
          "journal_entries"
        ],
        "discoveryPath": [
          "Inspect SAP S/4HANA records for the affected entities",
          "Compare against Anaplan historical baseline",
          "Generate a citation-backed recommendation"
