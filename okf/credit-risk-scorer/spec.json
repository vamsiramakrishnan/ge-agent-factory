  "subtitle": "A-2304 - AR & Collections",
  "persona": "Credit Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event",
  "domainId": "domain-23",
  "systems": [
    "D&B",
    "Moody's",
    "SAP S/4HANA FI",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Credit assessment time",
      "before": "3-5 days",
      "after": "2 hours"
    },
    {
      "label": "Bad debt from new customers",
      "before": "2.1%",
      "after": "0.6%"
    },
    {
      "label": "Data sources analyzed",
      "before": "2-3 manual",
      "after": "8+ automated"
    }
  ],
  "statusQuo": [
    "Credit decisions based primarily on D&B score and gut feel from the credit manager's experience.",
    "Financial filings and news signals reviewed only for the largest accounts, if at all.",
    "Credit reviews are point-in-time snapshots that miss deteriorating conditions between review cycles."
  ],
  "agentification": [
    "ML model combines 40+ features from multiple bureaus with internal payment behavior for a holistic credit score.",
    "Gemini reads financial filings and news to catch signals that bureau scores miss -- restructuring, leadership changes, market shifts.",
    "Continuous monitoring replaces point-in-time reviews, catching deterioration weeks earlier than quarterly review cycles."
  ],
  "architecture": {
    "connections": [
      {
        "system": "D&B",
        "description": "Commercial credit scores, financial stress indicators, corporate linkage"
      },
      {
        "system": "Moody's",
        "description": "Credit ratings, industry risk assessments, default probability models"
      },
      {
        "system": "SAP S/4HANA FI",
        "description": "Internal payment history, AR aging, order blocks, credit master data"
      },
      {
        "system": "BigQuery",
        "description": "Credit scoring model, payment behavior analytics, portfolio risk analysis"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Financial filing analysis, news signal interpretation, credit narrative generation"
      }
    ],
    "pipeline": [
      {
        "label": "Credit Data Aggregation",
        "description": "Pull credit bureau scores, financial statements, and payment history. Aggregate internal AR data including aging, dispute frequency, and payment patterns over 24 months."
      },
      {
        "label": "Predictive Credit Scoring",
        "description": "ML model combines 40+ features -- bureau scores, payment velocity, industry risk, financial ratios, customer tenure -- into a composite credit score with default probability estimate and recommended credit limit."
      },
      {
        "label": "Qualitative Signal Analysis",
        "description": "Gemini reads financial filings and news signals that quantitative models miss. 'D&B score is stable at 75 but the company announced major restructuring and the CFO departed -- recommend reducing credit limit pending stabilization.' Generates credit assessment narrative."
      },
      {
        "label": "Decision Delivery",
        "description": "Present credit assessment to Credit Manager with score, recommended limit, supporting rationale, and risk flags for approval decision."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
