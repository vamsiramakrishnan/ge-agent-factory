      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "feedback_aggregation",
            "label": "Feedback Aggregation",
            "description": "Pull survey responses from Qualtrics, aggregate ServiceNow ticket data (resolution times, reopens, escalations), and compile email communication signals into an analysis pipeline.",
            "tools": [
              "query_qualtrics_survey_responses",
              "query_servicenow_tickets",
              "query_email_data_email_data_records",
              "lookup_stakeholder_satisfaction_analyzer_policy_guide",
              "action_qualtrics_generate"
            ]
          },
          {
            "id": "root_cause_reasoning_insights",
            "label": "Root Cause Reasoning & Insights",
            "description": "Gemini reads feedback like 'procurement always slows us down' and identifies the root cause — is this a policy communication problem, a process bottleneck, or a genuine value-add the stakeholder doesn't see? Generates actionable insights, not just sentiment scores.",
            "tools": [
              "lookup_stakeholder_satisfaction_analyzer_policy_guide",
              "action_qualtrics_generate"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Feedback analysis cycle moved from Quarterly manual toward Continuous",
          "mustCite": [
            "qualtrics.survey_responses",
            "servicenow.tickets"
          ],
          "sourceSystemIds": [
            "qualtrics",
            "servicenow"
          ]
        },
        {
          "claim": "Root cause identification moved from Anecdotal toward Data-driven",
          "mustCite": [
            "qualtrics.survey_responses",
            "servicenow.tickets"
          ],
          "sourceSystemIds": [
            "qualtrics",
            "servicenow"
          ]
        }
      ],
      "escalationRules": [
        {
          "trigger": "Feedback analysis cycle regresses past the Quarterly manual baseline by more than 20%",
          "action": "escalate_to_human",
          "handoffTarget": "VP Procurement",
          "rationale": "Significant regressions need human judgment before automated remediation runs against production records."
        },
        {
          "trigger": "Source-system evidence is incomplete or stale (>24h) for any required entity",
          "action": "request_more_info",
          "rationale": "Recommendations grounded in stale evidence misrepresent current state and undermine audit defensibility."
        },
        {
          "trigger": "Proposed generate action lacks supporting evidence from at least two systems",
