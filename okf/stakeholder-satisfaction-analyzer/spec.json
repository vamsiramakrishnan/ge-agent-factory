  "kpis": [
    {
      "label": "Feedback analysis cycle",
      "before": "Quarterly manual",
      "after": "Continuous"
    },
    {
      "label": "Root cause identification",
      "before": "Anecdotal",
      "after": "Data-driven"
    },
    {
      "label": "Stakeholder NPS",
      "before": "Not tracked",
      "after": "65+"
    }
  ],
  "statusQuo": [
    "Internal stakeholder feedback collected via annual surveys with 30% response rates.",
    "Complaints like 'procurement always slows us down' go unanalyzed.",
    "No systematic way to distinguish process problems from perception problems."
  ],
  "agentification": [
    "Sentiment analysis on survey free-text, ServiceNow ticket patterns, and email communication tone.",
    "LLM identifies root causes — 'I don't understand why I need 3 quotes for $10K' is a policy communication problem, not a process problem.",
    "Generates actionable insights, not just sentiment scores."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Qualtrics",
        "description": "Stakeholder satisfaction surveys, NPS scores, and free-text feedback"
      },
      {
        "system": "ServiceNow",
        "description": "Procurement ticket data — resolution times, reopens, escalations, categories"
      },
      {
        "system": "Email Data",
        "description": "Communication tone signals and response time patterns from procurement interactions"
      },
      {
        "system": "BigQuery",
        "description": "Satisfaction trend storage, topic clustering results, root cause analytics"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Root cause reasoning on free-text feedback and actionable insight generation"
      }
    ],
    "pipeline": [
      {
        "label": "Feedback Aggregation",
        "description": "Pull survey responses from Qualtrics, aggregate ServiceNow ticket data (resolution times, reopens, escalations), and compile email communication signals into an analysis pipeline."
      },
      {
        "label": "Sentiment & Topic Analysis",
        "description": "CSAT trend tracking, NPS calculation, topic clustering on ticket categories, response time percentile analysis. Statistical pattern detection across feedback channels."
      },
      {
        "label": "Root Cause Reasoning & Insights",
        "description": "Gemini reads feedback like 'procurement always slows us down' and identifies the root cause — is this a policy communication problem, a process bottleneck, or a genuine value-add the stakeholder doesn't see? Generates actionable insights, not just sentiment scores."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Stakeholder Satisfaction Analyzer so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
