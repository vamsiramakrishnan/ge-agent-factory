      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "query_understanding",
            "label": "Query Understanding",
            "description": "Parse tax research question and identify the key issues: deductibility, treaty application, timing, characterization. Map to relevant IRC sections, regulations, and tax topics.",
            "tools": [
              "query_bloomberg_tax_bloomberg_tax_records",
              "lookup_tax_research_assistant_controls_playbook"
            ]
          },
          {
            "id": "analysis_memo_generation",
            "label": "Analysis & Memo Generation",
            "description": "Gemini analyzes authorities and drafts research memo: 'Can we deduct the $3M write-off? Under IRC Section 165, loss is deductible if asset permanently retired with no salvage value. Our 2023 memo established precedent -- apply same treatment.' Cites specific sections.",
            "tools": [
              "lookup_tax_research_assistant_controls_playbook"
            ]
          },
          {
            "id": "memo_delivery",
            "label": "Memo Delivery",
            "description": "Deliver research memo to requesting tax professional and Tax Director for review. Index in knowledge base for future precedent retrieval.",
            "tools": [
              "query_bloomberg_tax_bloomberg_tax_records",
              "lookup_tax_research_assistant_controls_playbook"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Research time per question moved from 4-8 hours toward 30 min draft + review",
          "mustCite": [
            "cch_answerconnect.cch_answerconnect_records",
            "bloomberg_tax.bloomberg_tax_records"
          ],
          "sourceSystemIds": [
            "cch_answerconnect",
            "bloomberg_tax"
          ]
        },
        {
          "claim": "Internal precedent reuse moved from Tribal knowledge toward Systematic RAG retrieval",
          "mustCite": [
            "cch_answerconnect.cch_answerconnect_records",
            "bloomberg_tax.bloomberg_tax_records"
          ],
          "sourceSystemIds": [
            "cch_answerconnect",
            "bloomberg_tax"
          ]
        }
      ],
      "escalationRules": [
        {
          "trigger": "Research time per question regresses past the 4-8 hours baseline by more than 20%",
          "action": "escalate_to_human",
          "handoffTarget": "Tax Director / Tax Analyst",
          "rationale": "Significant regressions need human judgment before automated remediation runs against production records."
        },
        {
          "trigger": "Source-system evidence is incomplete or stale (>24h) for any required entity",
          "action": "request_more_info",
          "rationale": "Recommendations grounded in stale evidence misrepresent current state and undermine audit defensibility."
        }
      ],
      "refusalRules": [
        "Never fabricate metric values; only publish numbers derived from CCH AnswerConnect (and other named systems) entities.",
        "Never bypass Tax Director / Tax Analyst approval on escalation triggers, even when confidence is high.",
        "Never expose individual personal data (PII) in summaries; aggregate or pseudonymise before output.",
        "Never act on data older than the staleness threshold defined in the runbook without a fresh re-query."
      ],
      "goldenEvals": [
        {
          "id": "tax-research-assistant-end-to-end",
          "prompt": "Run the Tax Research Assistant workflow for the current period. Cite the relevant source-system evidence and surface any escalations required.",
