  "subtitle": "A-2505 - Tax & Compliance",
  "persona": "Tax Director / Tax Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "chat",
  "domainId": "domain-25",
  "systems": [
    "CCH AnswerConnect",
    "Bloomberg Tax",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Research time per question",
      "before": "4-8 hours",
      "after": "30 min draft + review"
    },
    {
      "label": "Internal precedent reuse",
      "before": "Tribal knowledge",
      "after": "Systematic RAG retrieval"
    },
    {
      "label": "External advisor spend",
      "before": "$800K/year",
      "after": "$300K/year (complex only)"
    }
  ],
  "statusQuo": [
    "Tax research takes 4-8 hours per question as analysts manually search CCH and Bloomberg Tax for relevant authorities.",
    "Internal tax memos and prior positions are stored in personal files, not systematically accessible as precedent.",
    "Routine questions sent to external advisors at $500-800/hour because internal research capacity is limited."
  ],
  "agentification": [
    "RAG retrieval across tax databases and internal memos delivers cited research in 30 minutes, leaving only review time.",
    "Internal precedent systematically indexed and retrieved -- the 2023 write-off memo is found and applied automatically.",
    "External advisor spend reduced 60% as routine research is handled internally, reserving advisors for complex planning."
  ],
  "architecture": {
    "connections": [
      {
        "system": "CCH AnswerConnect",
        "description": "Tax code, regulations, IRS guidance, case law, editorial analysis"
      },
      {
        "system": "Bloomberg Tax",
        "description": "Tax research, portfolios, international tax guidance, transfer pricing"
      },
      {
        "system": "Internal Tax Memos",
        "description": "Prior research memos, position papers, audit responses, planning documents"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "RAG-powered tax analysis, citation generation, research memo drafting"
      },
      {
        "system": "BigQuery",
        "description": "Research query indexing, memo repository, precedent tracking"
      }
    ],
    "pipeline": [
      {
        "label": "Query Understanding",
        "description": "Parse tax research question and identify the key issues: deductibility, treaty application, timing, characterization. Map to relevant IRC sections, regulations, and tax topics."
      },
      {
        "label": "Authority Retrieval",
        "description": "RAG retrieval across IRC, Treasury Regulations, IRS Revenue Rulings, PLRs, case law, and internal memos. Rank by relevance and recency. Identify both supporting and contrary authority."
      },
      {
        "label": "Analysis & Memo Generation",
        "description": "Gemini analyzes authorities and drafts research memo: 'Can we deduct the $3M write-off? Under IRC Section 165, loss is deductible if asset permanently retired with no salvage value. Our 2023 memo established precedent -- apply same treatment.' Cites specific sections."
      },
      {
        "label": "Memo Delivery",
        "description": "Deliver research memo to requesting tax professional and Tax Director for review. Index in knowledge base for future precedent retrieval."
      }
    ]
  },
