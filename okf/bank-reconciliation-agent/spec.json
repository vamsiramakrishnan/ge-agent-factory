  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-24",
  "systems": [
    "Kyriba",
    "SAP S/4HANA FI",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Auto-match rate",
      "before": "70%",
      "after": "96%"
    },
    {
      "label": "Reconciliation time",
      "before": "3 hours/day",
      "after": "20 min review"
    },
    {
      "label": "Unresolved items aging",
      "before": "5-10 days",
      "after": "1-2 days"
    }
  ],
  "statusQuo": [
    "Accountants spend 3+ hours daily manually matching bank transactions against GL postings across 45+ accounts.",
    "Unmatched items require calls to other departments to understand transactions like ad-hoc wire transfers.",
    "Exception investigation backlogs of 5-10 days reduce cash position visibility for treasury."
  ],
  "agentification": [
    "ML matching achieves 96% auto-reconciliation rate, reducing manual effort from 3 hours to 20 minutes of exception review.",
    "Gemini investigates unmatched items by reading bank descriptions and cross-referencing internal records -- no phone calls needed.",
    "Same-day exception resolution improves cash position accuracy for treasury forecasting."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Kyriba",
        "description": "Bank connectivity, statement aggregation, reconciliation workbench"
      },
      {
        "system": "SAP S/4HANA FI",
        "description": "GL postings, cash journal, clearing entries"
      },
      {
        "system": "Bank Portals",
        "description": "MT940/BAI2 bank statements, intraday reporting"
      },
      {
        "system": "BigQuery",
        "description": "Matching model training, exception pattern analytics, timing difference identification"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Unmatched item investigation, bank description interpretation"
      }
    ],
    "pipeline": [
      {
        "label": "Statement Ingestion & Parsing",
        "description": "Ingest bank statements in MT940 and BAI2 formats across all banking relationships. Parse transaction details including amount, date, reference, and bank description fields."
      },
      {
        "label": "Automated Matching",
        "description": "Match bank transactions against GL postings using ML model trained on historical reconciliation patterns. Categorize exceptions as timing differences, missing postings, or unknown. Auto-clear timing differences that resolve within the tolerance window."
      },
      {
        "label": "Exception Investigation",
        "description": "Gemini investigates unmatched items by interpreting bank descriptions: 'A $125K debit -- bank says WIRE OUT REF: LEGAL SETTLEMENT -- check legal department records. This was the Johnson litigation settlement authorized by the GC.' Provides resolution recommendation."
      },
      {
        "label": "Clearing & Reporting",
        "description": "Post clearing entries for resolved items. Generate reconciliation report with matched totals, outstanding items, and investigation status for each bank account."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Bank Reconciliation Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
