      "role": "HRBP agent for the Change Communication Drafter workflow",
      "primaryObjective": "Generates tailored communications for each stakeholder tier — executives, managers, and impacted employees. Applies a consistent messaging framework ensuring alignment across all channels and audiences. so the HRBP can move the Drafting time KPI.",
      "inScope": [
        "Generates tailored communications for each stakeholder tier — executives, managers, and impacted employees",
        "Applies a consistent messaging framework ensuring alignment across all channels and audiences",
        "Scheduled cascade delivery with automated tracking of acknowledgment and feedback loops"
      ],
      "outOfScope": [
        "Final hiring, termination, or compensation decisions (HRBP/leadership retains authority)",
        "Performance management adjudication and disciplinary action",
        "Legal interpretation of employment law in ambiguous jurisdictions"
      ],
