        "label": "Brief Processing",
        "description": "Receive approved content brief with target keyword, angle, outline, and differentiation strategy. Load brand style guide and voice parameters."
      },
      {
        "label": "Quality Metrics",
        "description": "Readability scoring (Flesch-Kincaid), keyword density optimization, internal link recommendation based on content graph analysis."
      },
      {
        "label": "Content Generation",
        "description": "Transform brief into a draft that reads as if written by a domain expert. Maintain brand voice while adapting tone for content type. Generate multiple headline options with reasoning."
      },
      {
        "label": "Publishing Preparation",
        "description": "Draft formatted with brand style guide, SME input sections flagged, and publishing workflow initiated in WordPress or Contentful."
      }
    ]
