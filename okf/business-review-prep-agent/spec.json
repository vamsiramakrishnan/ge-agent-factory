  "department": "procurement",
  "sourcePath": "../presentation/src/components/slides/use-cases/procurement/BusinessReviewPrepAgent.tsx",
  "subtitle": "A-1704 • Supplier Performance",
  "persona": "Supplier Relationship Manager",
  "layer": "Layer 1: OOTB",
  "triggerType": "scheduled",
  "domainId": "domain-17",
  "systems": [
    "Scorecard Data",
    "Contract Data",
    "Market Intelligence",
    "Vertex AI",
    "Google Slides"
  ],
  "kpis": [
    {
      "label": "QBR prep time",
      "before": "8-12 hours manual",
      "after": "30 minutes review"
    },
    {
      "label": "Talking point quality",
      "before": "Data charts only",
      "after": "Strategic narrative"
    },
    {
      "label": "Counterargument prep",
      "before": "None / ad hoc",
      "after": "Anticipated & drafted"
    }
  ],
  "statusQuo": [
    "QBR decks assembled manually by copying scorecard charts into PowerPoint — 8+ hours per supplier review.",
    "Talking points are improvised in the meeting — no prepared responses to supplier counterarguments.",
    "Action items from previous QBRs tracked in scattered emails and notes, often lost between reviews."
  ],
  "agentification": [
    "LLM synthesizes scorecard data, 3 prior QBR action items, contract performance, and market conditions into a compelling presentation narrative.",
    "Drafts strategic talking points: 'Open with the positive — OTIF improved 4 points. Then address pricing: raw material costs dropped 8% since last negotiation — we should see pass-through savings per the contract formula.'",
    "Anticipates supplier counterarguments and prepares responses — generates the full slide deck narrative, not just data charts."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Scorecard Data",
        "description": "Supplier performance scorecards, KPI trends, peer benchmarks"
      },
      {
        "system": "Contract Data",
        "description": "Contract terms, pricing formulas, utilization metrics, SLA performance"
      },
      {
        "system": "Market Intelligence",
        "description": "Commodity price trends, market conditions, supplier financial signals"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Presentation narrative synthesis, talking point generation, counterargument preparation"
      },
      {
        "system": "Google Slides",
        "description": "QBR deck generation with trend visualizations and narrative"
      }
    ],
    "pipeline": [
      {
        "label": "QBR Data Assembly",
        "description": "Pull scorecard data, open action items from previous 3 QBRs, contract performance metrics, and current market conditions. Aggregate into a unified review context."
      },
      {
        "label": "Trend Visualization & Action Tracking",
        "description": "Generate trend visualizations on KPI trajectories, compute contract utilization metrics, and track action item aging from previous reviews."
      },
      {
        "label": "Narrative Synthesis & Counterargument Prep",
        "description": "Gemini synthesizes all data into a compelling presentation narrative. Drafts talking points: 'Open with the positive — OTIF improved 4 points. Then address pricing: raw material costs dropped 8% since last negotiation — we should see pass-through savings per the contract formula.' Anticipates supplier counterarguments and prepares responses."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Business Review Prep Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
