  "statusQuo": [
    "Course summaries created manually by instructional designers, consuming hours per module.",
    "Quiz generation is time-consuming with inconsistent alignment to learning objectives.",
    "Content repurposing across formats (video, text, microlearning) is labor-intensive."
  ],
  "agentification": [
    "Auto-summarizes long-form learning content into bite-sized microlearning modules.",
    "Generates competency-mapped quiz questions with difficulty calibration.",
    "Multi-format content repurposing from a single source into video scripts, flashcards, and guides."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Cornerstone",
        "description": "Course catalog, SCORM packages, learning objectives metadata"
      },
      {
        "system": "Degreed",
        "description": "External content library, articles, videos, curated pathways"
      },
      {
        "system": "Google Drive",
        "description": "Long-form course materials, instructor guides, supplemental docs"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Content summarization, quiz generation, multi-format repurposing"
      }
    ],
    "pipeline": [
      {
        "label": "Content Ingestion",
        "description": "Ingest long-form course material from Cornerstone, Degreed, and Google Drive. Extract text, structure, and learning objectives from multiple source formats."
      },
      {
        "label": "Summarization & Quiz Generation",
        "description": "Gemini extracts key concepts into microlearning modules. Generates competency-mapped assessment questions with difficulty calibration aligned to learning objectives."
      },
      {
        "label": "Multi-Format Repurposing",
        "description": "Repurpose single-source content into video scripts, flashcards, mobile modules, and email drip campaigns. Publish back to LMS with metadata tagging."
      }
    ]
  },
