    {
      "label": "Stakeholder versions",
      "before": "1 generic",
      "after": "Role-specific"
    }
  ],
  "statusQuo": [
    "L&D plans written from scratch each cycle with no reusable templates.",
    "Strategy narratives disconnected from actual business priorities and skills data.",
    "Stakeholder buy-in delayed by lengthy drafting and revision loops."
  ],
  "agentification": [
    "Auto-generates L&D strategy narratives from skills gap data and business priorities.",
    "Executive-ready formatting with consistent structure and data-backed recommendations.",
    "Iterative refinement workflow incorporating stakeholder input in real time."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Workforce planning data, headcount, role requirements"
      },
      {
        "system": "Cornerstone",
        "description": "Learning catalog, program history, completion data"
      },
      {
        "system": "Google Docs",
        "description": "L&D strategy document output, stakeholder review workflows"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Strategy narrative generation, program-to-gap mapping, ROI projection"
      }
    ],
    "pipeline": [
      {
        "label": "Data Input Assembly",
        "description": "Load skills gap analysis results, business priorities, and budget parameters. Pull historical program effectiveness data from Cornerstone."
      },
      {
        "label": "Strategy Narrative Drafting",
        "description": "Gemini drafts L&D strategy narrative with data citations, linking recommended programs to specific capability gaps and business objectives."
      },
      {
        "label": "Formatting & Distribution",
        "description": "Format as executive-ready document with consistent structure, ROI projections, and role-specific stakeholder versions. Publish to Google Docs for review."
      }
    ]
  },
