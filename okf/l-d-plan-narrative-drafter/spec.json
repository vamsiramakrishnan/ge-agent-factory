          "sourceSystemId": "google_docs",
          "description": "Look up sections of the L&D Plan Narrative Drafter Policy Handbook to cite in narrative output, escalation rationale, and audit evidence.",
          "requiredInputs": [
            "section_anchor"
          ],
          "produces": [
            "document_section",
            "citation_anchor"
