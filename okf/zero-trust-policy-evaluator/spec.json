              "lookup_zero_trust_policy_evaluator_runbook"
            ]
          },
          {
            "id": "maturity_assessment_roadmap",
            "label": "Maturity Assessment & Roadmap",
            "description": "Gemini assesses overall zero trust maturity level and generates prioritized improvement roadmap, focusing on PII-handling applications and internet-facing services first.",
            "tools": [
              "lookup_zero_trust_policy_evaluator_runbook"
