{
  "id": "employee-data-change-orchestrator",
  "title": "Employee Data Change Orchestrator",
  "department": "hr",
  "sourcePath": "../presentation/src/components/slides/use-cases/hr/DataChangeOrchestrator.tsx",
  "subtitle": "A-802 • HR Operations",
  "persona": "HR Ops Lead",
  "layer": "Layer 2: Agent Designer",
  "triggerType": "event",
  "domainId": "domain-8",
  "systems": [
    "Workday",
    "SAP SuccessFactors",
    "ServiceNow",
    "Active Directory"
  ],
  "kpis": [
    {
      "label": "Transaction time",
      "before": "3 days",
      "after": "15 min"
    },
    {
      "label": "Error rate",
      "before": "12%",
      "after": "<1%"
    },
    {
      "label": "Downstream sync",
      "before": "Manual triggers",
      "after": "Automated"
    }
  ],
  "statusQuo": [
    "Lifecycle transactions (hires, transfers) processed manually.",
    "Data validation is post-hoc, leading to downstream errors.",
    "Triggers for payroll, benefits, and access are manual and slow."
  ],
  "agentification": [
    "Automated processing via HRIS APIs with built-in validation.",
    "Real-time enforcement of business rules and data standards.",
    "Instant triggering of downstream system updates and access."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Employee master data, lifecycle events, job changes"
      },
      {
        "system": "ServiceNow",
        "description": "Change request tickets, approval workflows, audit logs"
      },
      {
        "system": "BigQuery",
        "description": "Change history, validation rules, cross-system sync status"
      },
      {
        "system": "Active Directory",
        "description": "Identity and access provisioning, group membership updates"
      }
    ],
    "pipeline": [
      {
        "label": "Change Detection",
        "description": "Detect employee data changes from HRIS lifecycle events — hires, transfers, promotions, terminations. Validate completeness and route through appropriate approval workflow."
      },
      {
        "label": "Cross-System Validation",
        "description": "Validate change against business rules across all connected systems. Check for conflicts, data dependencies, and downstream impact before execution."
      },
      {
        "label": "Multi-System Propagation",
        "description": "Execute validated changes across Workday, Active Directory, payroll, and benefits systems in the correct sequence. Handle rollback on partial failures."
      },
      {
        "label": "Audit & Confirmation",
        "description": "Log all changes with full audit trail in BigQuery. Confirm completion across all systems and notify stakeholders of successful propagation."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Employee Data Change Orchestrator so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
