  "persona": "HRBP",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event",
  "domainId": "domain-7",
  "systems": [
    "Culture Amp",
    "Qualtrics",
    "Workday",
    "Google BigQuery"
  ],
  "kpis": [
    {
      "label": "Analysis time",
      "before": "6 weeks",
      "after": "24 hours"
    },
    {
      "label": "Driver identification",
      "before": "Top-level only",
      "after": "Team-specific"
    },
    {
      "label": "Action plan quality",
      "before": "Generic",
      "after": "Contextualized"
    }
  ],
  "statusQuo": [
    "Survey results shared in static decks weeks after closing.",
    "Action planning is unstructured and follow-through is inconsistent.",
    "No systematic driver analysis to identify causal impact."
  ],
  "agentification": [
    "Instant multi-dimensional analysis and driver identification.",
    "Automated generation of team-level action planning guides.",
    "Longitudinal tracking of action plan effectiveness over time."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Qualtrics",
        "description": "Survey responses, demographic cuts, open-text feedback"
      },
      {
        "system": "Workday",
        "description": "Org hierarchy, team structure, tenure and level data"
      },
      {
        "system": "BigQuery",
        "description": "Engagement data warehouse, historical trends, driver models"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "NLP theme extraction, driver analysis, action plan generation"
      },
      {
        "system": "Google Slides",
        "description": "Team-level engagement reports and action planning decks"
      }
    ],
    "pipeline": [
      {
        "label": "Response Ingestion",
        "description": "Pull survey responses with full demographic and org hierarchy context from Qualtrics. Join with Workday data for team-level segmentation and tenure-based analysis."
      },
      {
        "label": "Statistical Driver Analysis",
        "description": "Run multi-dimensional driver analysis to identify which factors most strongly predict engagement scores. Segment by team, level, and tenure cohort for targeted insights."
      },
      {
        "label": "Theme & Sentiment Extraction",
        "description": "Gemini performs NLP on open-text responses to extract themes, sentiment, and actionable signals. Cross-references quantitative drivers for narrative coherence."
      },
      {
        "label": "Action Plan Generation",
        "description": "Generate team-specific action plans with owner assignments and progress tracking templates. Format as presentation-ready reports for HRBP distribution."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Engagement Insight Synthesizer so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
