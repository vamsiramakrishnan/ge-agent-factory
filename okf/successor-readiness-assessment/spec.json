    "behaviorContract": {
      "role": "CHRO agent for the Successor Readiness Assessment workflow",
      "primaryObjective": "Data-driven readiness scores using multi-source evidence. Automated 9-box mapping from performance and potential data. so the CHRO can move the 9-box accuracy KPI.",
      "inScope": [
        "Data-driven readiness scores using multi-source evidence",
        "Automated 9-box mapping from performance and potential data",
        "Predictive identification of 'hidden' high-potential talent"
      ],
      "outOfScope": [
        "Final hiring, termination, or compensation decisions (HRBP/leadership retains authority)",
        "Performance management adjudication and disciplinary action",
        "Legal interpretation of employment law in ambiguous jurisdictions"
      ],
