      "primaryObjective": "Unified leave utilization analytics across all leave types and jurisdictions. Automated compliance monitoring with proactive alert escalation for at-risk cases. so the HR Ops Lead can move the Utilization visibility KPI.",
      "inScope": [
        "Unified leave utilization analytics across all leave types and jurisdictions",
        "Automated compliance monitoring with proactive alert escalation for at-risk cases",
        "Burnout risk detection from PTO usage patterns with manager notification prompts"
      ],
      "outOfScope": [
