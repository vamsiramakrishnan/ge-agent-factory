  "kpis": [
    {
      "label": "Utilization visibility",
      "before": "Per-jurisdiction silos",
      "after": "Unified view"
    },
    {
      "label": "Compliance monitoring",
      "before": "Audit-triggered",
      "after": "Continuous"
    },
    {
      "label": "Burnout detection",
      "before": "None",
      "after": "PTO pattern alerts"
    }
  ],
  "statusQuo": [
    "Leave utilization data siloed per jurisdiction with no unified visibility.",
    "FMLA, ADA, and local leave compliance tracked manually with risk of missed obligations.",
    "Burnout risk from PTO non-usage invisible to managers and HR leadership."
  ],
  "agentification": [
    "Unified leave utilization analytics across all leave types and jurisdictions.",
    "Automated compliance monitoring with proactive alert escalation for at-risk cases.",
    "Burnout risk detection from PTO usage patterns with manager notification prompts."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Leave balances, absence records, employee demographics, org hierarchy"
      },
      {
        "system": "BigQuery",
        "description": "Leave analytics warehouse, utilization trends, compliance models"
      },
      {
        "system": "Looker",
        "description": "Interactive leave utilization dashboards, compliance reporting"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Pattern analysis, compliance reasoning, burnout risk detection"
      }
    ],
    "pipeline": [
      {
        "label": "Leave Data Aggregation",
        "description": "Sync all leave types and absence records from Workday across jurisdictions. Normalize leave categories and merge with employee demographics and org data."
      },
      {
        "label": "Pattern & Anomaly Analysis",
        "description": "Analyze utilization patterns, seasonal trends, and anomalies across leave types, teams, and geographies. Detect PTO non-usage patterns indicating burnout risk."
      },
      {
        "label": "Compliance Validation",
        "description": "Validate FMLA, ADA, and jurisdiction-specific leave compliance continuously. Flag at-risk cases where obligations may not be met."
      },
      {
        "label": "Reporting & Alerts",
        "description": "Interactive dashboards for HR Ops with drill-down by leave type, team, and jurisdiction. Proactive burnout risk alerts and manager notification prompts."
      }
    ]
  },
