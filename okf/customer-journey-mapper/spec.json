  "id": "customer-journey-mapper",
  "title": "Customer Journey Mapper",
  "department": "marketing",
  "sourcePath": "../presentation/src/components/slides/use-cases/marketing/CustomerJourneyMapper.tsx",
  "subtitle": "A-3404 • Marketing Analytics & Attribution",
  "persona": "Marketing Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-34",
  "systems": [
    "GA4",
    "Salesforce CRM",
    "HubSpot",
    "6sense",
    "BigQuery"
  ],
  "kpis": [
    {
      "label": "Journey visibility",
      "before": "Single channel",
      "after": "Full cross-channel"
    },
    {
      "label": "Path analysis frequency",
      "before": "Quarterly manual",
      "after": "Monthly automated"
    },
    {
      "label": "Multi-stakeholder detection",
      "before": "None",
      "after": "Automated"
    }
  ],
  "statusQuo": [
    "Customer journeys tracked within individual systems without cross-channel stitching.",
    "Path analysis done quarterly in spreadsheets — too slow to inform campaign adjustments.",
    "No visibility into multi-stakeholder engagement patterns within target accounts."
  ],
  "agentification": [
    "Gemini interprets journey patterns strategically — revealing multi-stakeholder engagement as a key conversion driver.",
    "Automated cross-channel journey stitching with intent signal enrichment from 6sense.",
    "Monthly journey maps with drop-off hotspots and recommended marketing interventions."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Google Analytics 4",
        "description": "Web touchpoints, user flow, cross-device behavior"
      },
      {
        "system": "Salesforce CRM",
        "description": "Deal touchpoints, stakeholder engagement, close data"
      },
      {
        "system": "HubSpot",
        "description": "Marketing touchpoints, email engagement, form submissions"
      },
      {
        "system": "6sense",
        "description": "Intent signals, account-level buying stage, anonymous activity"
      },
      {
        "system": "BigQuery",
        "description": "Journey data warehouse, pattern mining, transition analysis"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Journey pattern interpretation, strategic recommendation generation"
      }
    ],
    "pipeline": [
      {
        "label": "Cross-System Journey Stitching",
        "description": "Stitch anonymous and known touchpoints across GA4, Salesforce CRM, and HubSpot. Enrich with 6sense intent signals and account-level buying stage data. Build complete journey per deal/segment."
      },
      {
        "label": "Sequential Pattern Mining",
        "description": "Mine conversion paths for common sequences. Journey clustering by segment. Touchpoint transition probabilities. Time-between-touch analysis and journey length distribution."
      },
      {
        "label": "Strategic Journey Interpretation",
        "description": "Gemini interprets journey patterns strategically. 'Enterprise accounts with 10+ stakeholder touches convert at 4x — different personas engaging (technical, business, procurement). Non-converters have repetitive single-person touches. Recommend ABM plays targeting multiple stakeholders.'"
      },
      {
        "label": "Journey Map Visualization",
        "description": "Generate visual journey maps per segment with drop-off hotspots and recommended marketing interventions. Publish to Looker for ongoing monitoring."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Customer Journey Mapper so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
