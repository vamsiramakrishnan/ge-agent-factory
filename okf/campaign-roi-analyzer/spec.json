      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "cost_revenue_matching",
            "label": "Cost & Revenue Matching",
            "description": "Pull campaign cost data from ad platforms and MAP. Match to pipeline and revenue data in Salesforce. Aggregate in BigQuery with proper attribution windows.",
            "tools": [
              "query_salesforce_crm_opportunities",
              "query_salesforce_crm_campaign_influence",
              "query_bigquery_attribution_results",
              "lookup_attribution_methodology_handbook"
            ]
          },
          {
            "id": "attribution_modeling",
