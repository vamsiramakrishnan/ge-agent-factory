            "lookup_key",
            "date_range"
          ],
          "produces": [
            "documents_records",
            "documents_summary"
          ],
          "evidenceEmitted": [
            "source_system_record"
          ]
        },
        {
          "name": "query_lattice_engagement_surveys",
