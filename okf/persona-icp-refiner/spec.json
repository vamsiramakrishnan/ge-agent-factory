  "department": "marketing",
  "sourcePath": "../presentation/src/components/slides/use-cases/marketing/PersonaICPRefiner.tsx",
  "subtitle": "A-3704 • Customer & Market Intelligence",
  "persona": "Product Marketing Mgr",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-37",
  "systems": [
    "Salesforce CRM",
    "HubSpot",
    "6sense",
    "Clearbit",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "ICP update frequency",
      "before": "Annual manual refresh",
      "after": "Quarterly data-driven"
    },
    {
      "label": "Win rate in ICP segment",
      "before": "24% average",
      "after": "38% with refined ICP"
    },
    {
      "label": "Attributes in model",
      "before": "Size + Industry",
      "after": "12+ signals including maturity"
    }
  ],
  "statusQuo": [
    "ICP defined once per year based on gut feel — company size and industry only.",
    "Winning deal patterns invisible — no systematic analysis of what makes best customers convert.",
    "Persona narratives disconnected from actual buyer behavior and deal data."
  ],
  "agentification": [
    "Gemini discovers ICP signals beyond firmographics — digital maturity, hiring patterns, technology adoption.",
    "LLM generates persona narratives grounded in actual buyer behavior, not marketing assumptions.",
    "Continuously refines ICP scoring model as new deals close, keeping targeting current."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce CRM",
        "description": "Closed-won/lost deals, account profiles, opportunity data, deal velocity"
      },
      {
        "system": "HubSpot",
        "description": "Engagement data, content consumption patterns, lead scoring attributes"
      },
      {
        "system": "6sense",
        "description": "Intent signals, buying stage data, account-level engagement"
      },
      {
        "system": "Clearbit",
        "description": "Firmographic enrichment, technographic data, company signals"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Pattern analysis, ICP narrative generation, persona development"
      },
      {
        "system": "BigQuery",
        "description": "Deal analytics, segment profitability, ICP scoring model"
      }
    ],
    "pipeline": [
      {
        "label": "Deal Profile Assembly",
        "description": "Pull closed-won deal profiles from CRM, engagement data from HubSpot, firmographic enrichment from Clearbit, and intent signals from 6sense. Build comprehensive deal-level feature set."
      },
      {
        "label": "ICP Scoring Model",
        "description": "Train ICP scoring model on closed-won patterns. Identify which firmographic, technographic, and behavioral attributes predict conversion. Cluster winning deals to discover segments."
      },
      {
        "label": "Pattern Interpretation",
        "description": "Gemini analyzes winning patterns beyond quantitative attributes. Discovers signals like 'companies that recently hired a VP of Digital with legacy ERP and engaging with modernization content' — digital maturity signals that predict conversion."
      },
      {
        "label": "Activation & Distribution",
        "description": "Package updated ICP for go-to-market activation. Push refined scoring criteria to lead scoring models. Update targeting parameters across campaigns and ABM programs."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Persona & ICP Refiner so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
