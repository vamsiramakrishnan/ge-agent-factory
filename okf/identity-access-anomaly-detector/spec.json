  "kpis": [
    {
      "label": "Anomaly detection to action",
      "before": "Days (if detected)",
      "after": "<1 hour"
    },
    {
      "label": "Orphaned account detection",
      "before": "Quarterly audit",
      "after": "Real-time HR correlation"
    },
    {
      "label": "Insider threat coverage",
      "before": "Reactive investigation",
      "after": "Proactive UBA monitoring"
    }
  ],
  "statusQuo": [
    "Identity anomalies discovered during quarterly access reviews, weeks or months after the event.",
    "Orphaned accounts from terminated employees persist due to gaps between HR and IT offboarding.",
    "Insider threat detection relies on reactive investigation rather than proactive behavioral monitoring."
  ],
  "agentification": [
    "Gemini correlates identity anomalies with HR events in real time, catching orphaned accounts within hours.",
    "LLM contextualizes anomalies — distinguishing VPN routing artifacts from genuine credential compromise.",
    "Continuous UBA monitoring replaces quarterly reviews, reducing exposure window from months to minutes."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Okta",
        "description": "Authentication events, session data, group membership"
      },
      {
        "system": "Google Workspace",
        "description": "Login activity, file access, admin console events"
      },
      {
        "system": "CrowdStrike",
        "description": "Endpoint activity, process execution, device posture"
      },
      {
        "system": "Chronicle SIEM",
        "description": "Authentication event correlation, UBA baselines"
      },
      {
        "system": "BigQuery",
        "description": "User behavior baselines, HR event correlation"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Anomaly contextualization, risk narrative generation"
      }
    ],
    "pipeline": [
      {
        "label": "Identity Event Collection",
        "description": "Monitor authentication events from Okta and Google Workspace. Track login locations, times, devices, privilege escalations, and dormant account reactivation."
      },
      {
        "label": "Behavioral Baseline & Anomaly Detection",
        "description": "Build per-user behavior baselines from login patterns. Detect anomalies using UBA models — impossible travel, unusual access times, privilege escalation, and dormant account usage."
      },
      {
        "label": "HR-Correlated Risk Assessment",
        "description": "Gemini cross-references anomalies with HR events (terminations, role changes, contractor end dates). Generates risk narrative explaining whether anomaly is benign or requires investigation."
      },
      {
        "label": "Revocation & Audit",
        "description": "Confirmed unauthorized access triggers immediate account suspension in Okta. Full audit trail of accessed resources generated for compliance."
      }
    ]
  },
