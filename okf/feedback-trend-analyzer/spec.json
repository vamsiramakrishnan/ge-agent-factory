      "label": "Feedback aggregation",
      "before": "Never",
      "after": "Continuous"
    },
    {
      "label": "Theme detection",
      "before": "Manual read",
      "after": "NLP-automated"
    },
    {
      "label": "Review input quality",
      "before": "Sparse",
      "after": "Rich longitudinal"
    }
  ],
  "statusQuo": [
    "Feedback collected but never aggregated into actionable insights.",
    "Patterns and themes invisible across teams and time periods.",
    "Performance reviews lack longitudinal data to support fair assessments."
  ],
  "agentification": [
    "NLP-powered feedback theme extraction across all feedback channels.",
    "Sentiment trend analysis tracking employee development over time.",
    "Auto-generated performance review input summaries with evidence citations."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Performance reviews, manager assessments, historical ratings"
      },
      {
        "system": "Lattice",
        "description": "360 feedback, peer reviews, pulse survey responses"
      },
      {
        "system": "BigQuery",
        "description": "Feedback analytics warehouse, longitudinal trend data"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "NLP theme extraction, sentiment analysis, trend synthesis"
      }
    ],
    "pipeline": [
      {
        "label": "Feedback Aggregation",
        "description": "Ingest 360 feedback, pulse surveys, and peer reviews from Lattice and Workday. Normalize and store in BigQuery analytics warehouse."
      },
      {
        "label": "NLP Theme Extraction",
        "description": "Gemini performs NLP analysis to extract recurring themes, sentiment trends, and development patterns across all feedback channels."
      },
      {
        "label": "Longitudinal Trend Analysis",
        "description": "Time-series analysis of feedback themes by team, manager, and individual. Generate review input summaries with evidence citations."
      }
    ]
  },
