  "statusQuo": [
    "Manual cross-referencing of HRIS changes and timesheets.",
    "Discrepancies often discovered during or after the payroll run.",
    "High cost of corrections, off-cycle checks, and potential penalties."
  ],
  "agentification": [
    "Automated pre-run validation across T&A, HRIS, and Benefits.",
    "Proactive flagging of garnishment conflicts and missing data.",
    "Exception-based workflow focusing human effort on complex errors."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "HRIS changes, benefits elections, time and attendance data"
      },
      {
        "system": "ADP",
        "description": "Payroll inputs, garnishment data, tax withholding rules"
      },
      {
        "system": "BigQuery",
        "description": "Validation rules engine, historical payroll patterns, anomaly thresholds"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Anomaly reasoning, exception explanation, validation narrative"
      }
    ],
    "pipeline": [
      {
        "label": "Payroll Data Aggregation",
        "description": "Pull all payroll inputs from Workday (HRIS changes, benefits), ADP (garnishments, tax), and time systems. Build unified pre-run dataset with every input source cross-referenced."
      },
      {
        "label": "Cross-System Validation",
        "description": "Validate every payroll input against source systems and business rules. Check for missing timesheets, benefit election mismatches, and garnishment conflicts."
      },
      {
        "label": "Anomaly Detection & Explanation",
        "description": "Gemini analyzes flagged exceptions, explains root causes, and prioritizes by financial impact. Distinguishes legitimate changes from errors requiring correction."
      },
      {
        "label": "Approval Workflow",
        "description": "Route clean payroll for manager approval. Present exception dashboard with one-click resolution actions for each flagged item."
      }
    ]
  },
