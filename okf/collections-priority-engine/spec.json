    "HighRadius",
    "SAP S/4HANA FI",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Collection effectiveness",
      "before": "72%",
      "after": "91%"
    },
    {
      "label": "Collector productivity",
      "before": "30 calls/day",
      "after": "50 targeted calls/day"
    },
    {
      "label": "Bad debt write-off",
      "before": "1.2% of revenue",
      "after": "0.4% of revenue"
    }
  ],
  "statusQuo": [
    "Collectors work through aging reports sorted by dollar amount, missing context about why accounts are past due.",
    "High-value long-term customers get the same dunning treatment as high-risk accounts.",
    "No systematic way to incorporate external signals like customer financial distress into collection strategy."
  ],
  "agentification": [
    "ML scoring prioritizes by collection probability, not just amount -- a $50K receivable with 90% collection chance outranks a $200K one at 20%.",
    "Gemini interprets customer context: CFO transitions, ERP migrations, and earnings announcements that explain payment delays.",
    "Strategy recommendations adapt tone and approach based on relationship history and customer situation."
  ],
  "architecture": {
    "connections": [
      {
        "system": "HighRadius",
        "description": "Collection worklist, customer interaction history, promise-to-pay tracking"
      },
      {
        "system": "SAP S/4HANA FI",
        "description": "AR aging, open invoices, customer master, payment history"
      },
      {
        "system": "BigQuery",
        "description": "Payment behavior model, collection probability scoring, segment analytics"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Customer context interpretation, strategy recommendation generation"
      },
      {
        "system": "D&B",
        "description": "Customer financial health signals, credit events, corporate changes"
      }
    ],
    "pipeline": [
      {
        "label": "Receivables Aggregation",
        "description": "Extract all open receivables with aging, payment history, dispute status, and customer attributes. Merge with interaction logs from collections system."
      },
      {
        "label": "Collection Probability Scoring",
        "description": "ML model trained on historical payment patterns scores each receivable for collection probability. Features include customer segment, amount, aging bucket, day-of-week, industry cycle, and past behavior."
      },
      {
        "label": "Contextual Priority Adjustment",
        "description": "Gemini reads external signals -- a Fortune 500 customer announced a CFO transition and AP processing delays -- to adjust priority. Recommends strategy: courtesy call vs. formal collection action based on relationship context."
      },
      {
        "label": "Worklist Distribution",
        "description": "Deliver prioritized worklist to collectors with context cards showing why each account is ranked as it is and recommended next action."
      }
    ]
  },
