  "subtitle": "A-901 • DEI & Belonging",
  "persona": "CHRO",
  "layer": "Layer 4: Data Agent",
  "triggerType": "scheduled",
  "domainId": "domain-9",
  "systems": [
    "Workday",
    "Google BigQuery",
    "Tableau"
  ],
  "kpis": [
    {
      "label": "Data freshness",
      "before": "Quarterly report",
      "after": "Real-time"
    },
    {
      "label": "Representation tracking",
      "before": "Top-level only",
      "after": "Intersectional"
    },
    {
      "label": "Data suppression",
      "before": "Manual",
      "after": "Automated privacy"
    }
  ],
  "statusQuo": [
    "Representation data pulled manually into Excel for board decks.",
    "Inconsistent data suppression rules for small group sizes.",
    "External reporting (EEO-1) is a labor-intensive annual project."
  ],
  "agentification": [
    "Real-time DEI dashboards with automated data suppression.",
    "One-click generation of board-ready reports and disclosures.",
    "Continuous monitoring of promotion equity and inclusion trends."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Demographics, hiring, promotion, attrition data by dimension"
      },
      {
        "system": "BigQuery",
        "description": "DEI analytics warehouse, intersectional representation models"
      },
      {
        "system": "Looker",
        "description": "Interactive DEI dashboards with drill-down and goal tracking"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Intersectional analysis, data suppression logic, narrative generation"
      }
    ],
    "pipeline": [
      {
        "label": "Workforce Data Sync",
        "description": "Sync demographics, hiring, promotion, and attrition data from Workday. Build intersectional representation models across gender, ethnicity, level, and location dimensions."
      },
      {
        "label": "Representation Analysis",
        "description": "Calculate representation metrics across all intersectional dimensions. Compare against industry benchmarks and organizational goals with statistical significance testing."
      },
      {
        "label": "Privacy Controls",
        "description": "Apply automated data suppression rules for small group sizes to prevent re-identification. Gemini validates suppression logic and generates compliant reporting narratives."
      },
      {
        "label": "Dashboard Publication",
        "description": "Publish interactive dashboards in Looker with goal tracking, trend lines, and board-ready report generation. Enable one-click EEO-1 and regulatory disclosure exports."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for DEI Dashboard & Reporting so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
