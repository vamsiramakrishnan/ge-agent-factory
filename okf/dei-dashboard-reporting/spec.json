            "generated_audit_trail"
          ]
        }
      ],
      "workflow": {
        "mode": "sequential",
        "steps": [
          {
            "id": "workforce_data_sync",
            "label": "Workforce Data Sync",
            "description": "Sync demographics, hiring, promotion, and attrition data from Workday. Build intersectional representation models across gender, ethnicity, level, and location dimensions.",
            "tools": [
              "query_workday_employees",
              "action_workday_execute"
            ]
          },
          {
            "id": "privacy_controls",
            "label": "Privacy Controls",
            "description": "Apply automated data suppression rules for small group sizes to prevent re-identification. Gemini validates suppression logic and generates compliant reporting narratives.",
            "tools": [
              "lookup_dei_dashboard_reporting_policy_handbook"
            ]
          },
          {
            "id": "dashboard_publication",
            "label": "Dashboard Publication",
            "description": "Publish interactive dashboards in Looker with goal tracking, trend lines, and board-ready report generation. Enable one-click EEO-1 and regulatory disclosure exports.",
            "tools": [
              "query_tableau_dashboards",
              "lookup_dei_dashboard_reporting_policy_handbook"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Data freshness moved from Quarterly report toward Real-time",
          "mustCite": [
            "workday.employees",
            "google_bigquery.analytics_events"
          ],
          "sourceSystemIds": [
            "workday",
            "google_bigquery"
          ]
        },
