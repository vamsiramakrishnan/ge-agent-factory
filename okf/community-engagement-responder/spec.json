      "before": "4-6 hours",
      "after": "< 30 minutes"
    },
    {
      "label": "Mentions addressed",
      "before": "40% manual",
      "after": "95% automated"
    },
    {
      "label": "Customer satisfaction",
      "before": "3.2/5",
      "after": "4.5/5"
    }
  ],
  "statusQuo": [
    "Social mentions triaged manually — many go unanswered or receive delayed responses.",
    "No systematic classification of mentions by intent, leading to missed sales signals.",
    "Response tone inconsistent across team members without clear brand voice guidelines."
  ],
  "agentification": [
    "Gemini classifies intent and drafts contextually appropriate responses — empathetic for complaints, informative for prospects.",
    "Support issues auto-routed to Zendesk, sales signals flagged in CRM without manual triage.",
    "Brand voice maintained consistently while adapting tone to each interaction type."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Sprout Social",
        "description": "Social mentions, DMs, comment threads, engagement queue"
      },
      {
        "system": "Hootsuite",
        "description": "Cross-platform mention monitoring, response publishing"
      },
      {
        "system": "Zendesk",
        "description": "Support ticket creation for product issues mentioned on social"
      },
      {
        "system": "Salesforce CRM",
        "description": "Customer value lookup, sales opportunity flagging"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Intent classification, response generation, tone adaptation"
      }
    ],
    "pipeline": [
      {
        "label": "Mention Intake & Classification",
        "description": "Receive social mentions and DMs from Sprout Social and Hootsuite. Classify by intent — support request, sales inquiry, product feedback, or engagement opportunity. Check customer value in Salesforce CRM."
      },
      {
        "label": "Urgency & Routing Scoring",
        "description": "Urgency scoring based on sentiment, reach, and customer value. Support issues routed to Zendesk. Sales signals flagged in CRM. Response time tracking."
      },
      {
        "label": "Contextual Response Generation",
        "description": "Gemini drafts responses that maintain brand voice while addressing specific situations. Distinguishes between a customer with a real product issue (empathetic, helpful), a prospect asking about features (informative, inviting), and a troll (ignore or light engagement)."
      },
      {
        "label": "Publishing & Escalation",
        "description": "Standard responses queued for auto-publish. Escalations and sensitive responses routed to Social Media Manager for review. Support issues create Zendesk tickets."
      }
    ]
  },
