        "mode": "sequential",
        "steps": [
          {
            "id": "mention_intake_classification",
            "label": "Mention Intake & Classification",
            "description": "Receive social mentions and DMs from Sprout Social and Hootsuite. Classify by intent — support request, sales inquiry, product feedback, or engagement opportunity. Check customer value in Salesforce CRM.",
            "tools": [
              "query_sprout_social_social_posts",
              "query_hootsuite_social_posts",
              "query_salesforce_crm_accounts",
              "lookup_community_engagement_responder_playbook",
              "action_sprout_social_route"
            ]
          },
          {
            "id": "urgency_routing_scoring",
            "label": "Urgency & Routing Scoring",
            "description": "Urgency scoring based on sentiment, reach, and customer value. Support issues routed to Zendesk. Sales signals flagged in CRM. Response time tracking.",
            "tools": [
              "query_zendesk_tickets",
              "query_salesforce_crm_accounts",
              "action_sprout_social_route"
            ]
          },
          {
            "id": "contextual_response_generation",
            "label": "Contextual Response Generation",
            "description": "Gemini drafts responses that maintain brand voice while addressing specific situations. Distinguishes between a customer with a real product issue (empathetic, helpful), a prospect asking about features (informative, inviting), and a troll (ignore or light engagement).",
            "tools": [
              "lookup_community_engagement_responder_playbook"
            ]
          },
          {
            "id": "publishing_escalation",
            "label": "Publishing & Escalation",
            "description": "Standard responses queued for auto-publish. Escalations and sensitive responses routed to Social Media Manager for review. Support issues create Zendesk tickets.",
            "tools": [
              "query_sprout_social_social_posts",
              "query_hootsuite_social_posts",
              "query_zendesk_tickets",
              "lookup_community_engagement_responder_playbook",
              "action_sprout_social_route"
            ]
          }
        ]
      },
      "evidenceRequirements": [
        {
          "claim": "Avg response time moved from 4-6 hours toward < 30 minutes",
          "mustCite": [
            "sprout_social.social_posts",
            "hootsuite.social_posts"
          ],
          "sourceSystemIds": [
            "sprout_social",
            "hootsuite"
