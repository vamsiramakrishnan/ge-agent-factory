    {
      "label": "Scenario modeling",
      "before": "3 scenarios",
      "after": "Unlimited"
    },
    {
      "label": "Budget accuracy",
      "before": "+/-15%",
      "after": "+/-2%"
    },
    {
      "label": "Cycle time",
      "before": "6 weeks",
      "after": "1 week"
    }
  ],
  "statusQuo": [
    "Merit budgets set top-down without granular scenario modeling.",
    "Promotion cost impact estimated roughly, leading to budget surprises.",
    "Budget overruns discovered late in the cycle when options are limited."
  ],
  "agentification": [
    "Multi-scenario merit and promotion budget modeling with sensitivity analysis.",
    "Real-time cost projections by org unit, job family, and geography.",
    "Automated what-if analysis for optimizing budget allocation trade-offs."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Workday",
        "description": "Employee compensation, performance ratings, grade structures, headcount"
      },
      {
        "system": "Mercer",
        "description": "Market benchmark data for merit budget calibration"
      },
      {
        "system": "BigQuery",
        "description": "Historical merit/promo spend, budget variance analytics, scenario storage"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Multi-scenario budget modeling, sensitivity analysis, allocation optimization"
      }
    ],
    "pipeline": [
      {
        "label": "Budget & Comp Data Ingestion",
        "description": "Pull current compensation data, performance ratings, and headcount from Workday. Load merit pool parameters and promotion budget guidelines from finance."
      },
      {
        "label": "Multi-Scenario Modeling",
        "description": "Gemini generates unlimited what-if scenarios varying merit pool allocation, promotion rates, and equity adjustments across org units, levels, and performance tiers."
      },
      {
        "label": "Cost Impact & Equity Analysis",
        "description": "Real-time cost projections by org unit with internal equity checks. Statistical analysis of pay gap impact across demographics for each scenario."
      },
      {
        "label": "Approval & Distribution",
        "description": "Optimized allocation plan presented to Comp Manager for review and approval. Approved budgets distributed to managers with guidelines."
      }
    ]
  },
