  "kpis": [
    {
      "label": "Event setup time",
      "before": "2-3 days",
      "after": "2 hours"
    },
    {
      "label": "Post-event follow-up",
      "before": "Generic blast",
      "after": "Topic-personalized"
    },
    {
      "label": "Webinar-to-pipeline rate",
      "before": "8%",
      "after": "18%"
    }
  ],
  "statusQuo": [
    "Webinar setup requires 2-3 days of manual configuration across Zoom, HubSpot, email, and CRM.",
    "Post-event follow-up is a generic email blast with recording link \\u2014 no personalization by engagement or topic.",
    "Q&A questions from webinars not analyzed for buying signals or topic-specific follow-up opportunities."
  ],
  "agentification": [
    "Gemini generates promotional copy adapted for each channel and drafts speaker briefs from webinar content.",
    "Post-event Q&A analysis identifies hot topics and generates personalized follow-up referencing specific discussions.",
    "End-to-end orchestration from setup through post-event pipeline capture in a single automated workflow."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Zoom",
        "description": "Webinar creation, registration management, attendee engagement data"
      },
      {
        "system": "HubSpot",
        "description": "Registration forms, email promotion sequences, lead tracking"
      },
      {
        "system": "Salesforce CRM",
        "description": "Registrant matching, campaign attribution, pipeline tracking"
      },
      {
        "system": "Google Calendar",
        "description": "Event scheduling, team availability coordination"
      },
      {
        "system": "Slack",
        "description": "Internal notifications, speaker coordination, real-time alerts"
      },
      {
        "system": "Vertex AI (Gemini)",
        "description": "Promotional copy generation, Q&A analysis, follow-up personalization"
      }
    ],
    "pipeline": [
      {
        "label": "Event Configuration",
        "description": "Create webinar in Zoom. Set up registration in HubSpot. Build email promotion sequences. Configure reminder cadence. Sync registrants to Salesforce campaign."
      },
      {
        "label": "Promotion & Prediction",
        "description": "Attendance prediction based on registration patterns and historical data. Optimal promotion timing for each channel. Registration-to-attendance conversion prediction."
      },
      {
        "label": "Content & Follow-Up Generation",
        "description": "Generate promotional copy adapted for email, social, and website. Post-event: analyze Q&A questions to identify hot topics. Draft personalized follow-up messages for high-intent attendees referencing specific discussion points."
      },
      {
        "label": "Post-Event Orchestration",
        "description": "Trigger follow-up workflows in HubSpot. Send recording to no-shows. Route high-intent attendees to sales. Update Salesforce campaign with attendance data."
      }
    ]
  },
