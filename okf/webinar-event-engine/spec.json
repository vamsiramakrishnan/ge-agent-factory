    "behaviorContract": {
      "role": "Demand Gen Manager agent for the Webinar & Event Engine workflow",
      "primaryObjective": "Gemini generates promotional copy adapted for each channel and drafts speaker briefs from webinar content. Post-event Q&A analysis identifies hot topics and generates personalized follow-up referencing specific discussions. so the Demand Gen Manager can move the Event setup time KPI.",
      "inScope": [
        "Gemini generates promotional copy adapted for each channel and drafts speaker briefs from webinar content",
        "Post-event Q&A analysis identifies hot topics and generates personalized follow-up referencing specific discussions",
        "End-to-end orchestration from setup through post-event pipeline capture in a single automated workflow"
      ],
      "outOfScope": [
        "Final approval of paid spend reallocations above the governance threshold",
        "Trademark, legal, or regulated-industry claim approval",
        "Crisis communications without comms-team sign-off"
      ],
