{
  "name": "@ge/run-ledger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Framework-agnostic 'follow any long-running pipeline' observability core: a durable run/stage ledger (SQLite adapter, lazy Firestore backend), the SSE frame/event schema, status normalization, and a pure frames→state reducer. No React, no DOM.",
  "scripts": {
    "test": "bun test src/index.test.mjs",
    "typecheck": "bunx tsc --noEmit -p ."
  },
  "optionalDependencies": {
    "@google-cloud/firestore": "^8.6.0"
  },
  "main": "./src/index.mjs",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.mjs"
    },
    "./firestore": {
      "types": "./src/firestore.d.ts",
      "default": "./src/firestore.mjs"
    },
    "./status": {
      "types": "./src/status.d.ts",
      "default": "./src/status.mjs"
    },
    "./frames": {
      "types": "./src/frames.d.ts",
      "default": "./src/frames.mjs"
    },
    "./control-plane": {
      "types": "./src/control-plane.d.ts",
      "default": "./src/control-plane.mjs"
    },
    "./reduce": {
      "types": "./src/reduce.d.ts",
      "default": "./src/reduce.mjs"
    }
  }
}
