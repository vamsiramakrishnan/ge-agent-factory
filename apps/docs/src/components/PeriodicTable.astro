---
/**
 * PeriodicTable.astro — the "periodic table of agents", ported from the deck's
 * PeriodicTableSlide.tsx into the Astro docs site (no React/Tailwind/motion).
 *
 * All data comes from src/data/agent-catalog.json, generated by
 * scripts/gen-catalog.mjs from the presentation constants + the drift-gated
 * agent-spec registry. Colors are pre-resolved to hex there; everything else
 * (surfaces, borders, ink) reads from the Starlight theme vars so the grid
 * follows light/dark automatically.
 *
 * Every department's groups are rendered up front and toggled client-side by
 * the department switcher — the small module script at the bottom is the only
 * JS, standing in for the deck's React state + framer-motion.
 */
import catalog from "../data/agent-catalog.json";

const base = import.meta.env.BASE_URL; // "/ge-agent-factory/"
const agentHref = (slug: string) => `${base}catalog/agents/${slug}/`;

const { departments, domains, legend, agents, meta } = catalog as any;

// Group agents by domain, domains by department; compute a faithful column
// count per department (deck: 8/10/12/13 by the largest domain in view).
const gridColsFor = (max: number) => (max <= 8 ? 8 : max <= 10 ? 10 : max <= 12 ? 12 : 13);

const byDept = departments.map((dept: any) => {
  const deptDomains = domains
    .filter((d: any) => d.department === dept.key)
    .sort((a: any, b: any) => a.num - b.num)
    .map((d: any) => ({
      ...d,
      agents: agents
        .filter((a: any) => a.domain === d.num)
        .sort((a: any, b: any) => a.num - b.num),
    }));
  const maxInDomain = Math.max(...deptDomains.map((d: any) => d.agents.length), 1);
  return { ...dept, deptDomains, gridCols: gridColsFor(maxInDomain) };
});

// Lookup the hover panel + a11y need, keyed by ucId.
const hoverData = Object.fromEntries(
  agents.map((a: any) => [
    a.ucId,
    {
      agentId: a.agentId,
      shortName: a.shortName,
      title: a.title,
      domainTitle: a.domainTitle,
      domainColor: a.domainColor,
      layerLabel: a.layerLabel,
      layerColor: a.layerColor,
      triggerLabel: a.triggerLabel,
      triggerColor: a.triggerColor,
      hitl: a.hitl,
      hitlActor: a.hitlActor,
      href: agentHref(a.slug),
    },
  ]),
);

// Inline icon paths (lucide is unavailable in the docs site).
const TRIGGER_PATHS: Record<string, string> = {
  event: "M13 2 3 14h7l-1 8 10-12h-7l1-8Z", // zap
  chat: "M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z", // message-circle
  scheduled: "M12 6v6l4 2M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20Z", // clock
};
const SHIELD_PATH = "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z M9 12l2 2 4-4"; // shield-check
---

<section class="pt" data-active-dept={departments[0]?.key}>
  {/* ── Department switcher ─────────────────────────────────────── */}
  <div class="pt-tabs" role="tablist" aria-label="Departments">
    {
      departments.map((dept: any) => (
        <button
          class="pt-tab"
          role="tab"
          data-dept={dept.key}
          aria-selected={dept.key === departments[0]?.key ? "true" : "false"}
        >
          <span class="pt-tab-label">{dept.shortLabel}</span>
          <span class="pt-tab-count">{dept.agentCount}</span>
        </button>
      ))
    }
  </div>

  {/* ── Per-department views ────────────────────────────────────── */}
  {
    byDept.map((dept: any) => (
      <div
        class="pt-view"
        data-dept-view={dept.key}
        hidden={dept.key !== departments[0]?.key}
      >
        <header class="pt-head">
          <div class="pt-head-titles">
            <h2 class="pt-title">{dept.title}</h2>
            <p class="pt-subtitle">{dept.subtitle}</p>
          </div>
          <div class="pt-stats">
            <span class="pt-stat">
              <strong>{dept.agentCount}</strong> agents
            </span>
            <span class="pt-stat">
              <strong>{dept.deptDomains.length}</strong> domains
            </span>
          </div>
        </header>

        <div class="pt-body">
          {/* Grid, grouped by domain */}
          <div class="pt-grid-wrap">
            {dept.deptDomains.map((domain: any) => (
              <div class="pt-group">
                <a class="pt-group-head" href={`#${domain.id}`}>
                  <span class="pt-group-swatch" style={`background:${domain.color}`} />
                  <span class="pt-group-title">{domain.title}</span>
                  <span class="pt-group-count">{domain.agents.length}</span>
                </a>
                <div class="pt-grid" style={`--pt-cols:${dept.gridCols}`}>
                  {domain.agents.map((a: any) => (
                    <a
                      class="pt-cell"
                      href={agentHref(a.slug)}
                      data-uc={a.ucId}
                      style={`--pt-domain:${a.domainColor}`}
                      title={`${a.agentId} · ${a.title}`}
                    >
                      <span class="pt-cell-num">{a.num}</span>
                      <span class="pt-cell-name">{a.shortName}</span>
                      <span class="pt-cell-dot" style={`background:${a.layerColor}`} />
                      <svg class="pt-cell-trig" style={`color:${a.triggerColor}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d={TRIGGER_PATHS[a.triggerType]} />
                      </svg>
                      {a.hitl && (
                        <svg class="pt-cell-hitl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d={SHIELD_PATH} />
                        </svg>
                      )}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>

          {/* Sidebar: hover detail + legend */}
          <aside class="pt-side">
            <div class="pt-detail" data-detail hidden>
              <div class="pt-detail-top">
                <span class="pt-detail-badge" data-detail-badge></span>
                <div>
                  <div class="pt-detail-name" data-detail-name></div>
                  <div class="pt-detail-meta" data-detail-meta></div>
                </div>
              </div>
              <div class="pt-detail-tags">
                <span class="pt-tag" data-detail-layer></span>
                <span class="pt-tag" data-detail-trigger></span>
                <span class="pt-tag pt-tag-hitl" data-detail-hitl hidden></span>
              </div>
              <a class="pt-detail-link" data-detail-link>View agent spec →</a>
            </div>
            <div class="pt-detail pt-detail-empty" data-detail-empty>
              Hover or tap an element to see its details.
            </div>

            <div class="pt-legend">
              <div class="pt-legend-block">
                <div class="pt-legend-label">Layers</div>
                {legend.layers.map((l: any) => (
                  <div class="pt-legend-row">
                    <span class="pt-legend-dot" style={`background:${l.color}`} />
                    <span>{l.label}</span>
                  </div>
                ))}
              </div>
              <div class="pt-legend-block">
                <div class="pt-legend-label">Triggers</div>
                {legend.triggers.map((t: any) => (
                  <div class="pt-legend-row">
                    <svg class="pt-legend-trig" style={`color:${t.color}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d={TRIGGER_PATHS[t.key]} />
                    </svg>
                    <span>{t.label}</span>
                  </div>
                ))}
                <div class="pt-legend-row">
                  <svg class="pt-legend-trig pt-legend-hitl" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={SHIELD_PATH} />
                  </svg>
                  <span>Human-in-the-loop</span>
                </div>
              </div>
              <div class="pt-legend-block">
                <div class="pt-legend-label">Domains</div>
                {dept.deptDomains.map((d: any) => (
                  <a class="pt-legend-row pt-legend-domain" href={`#${d.id}`}>
                    <span class="pt-legend-swatch" style={`background:${d.color}`} />
                    <span class="pt-legend-domain-title">{d.title}</span>
                    <span class="pt-legend-domain-count">{d.agents.length}</span>
                  </a>
                ))}
              </div>
            </div>
          </aside>
        </div>
      </div>
    ))
  }

  <script type="application/json" data-pt-hover set:html={JSON.stringify(hoverData)} />
</section>

<script>
  const root = document.querySelector<HTMLElement>(".pt");
  if (root) {
    const hover = JSON.parse(
      root.querySelector<HTMLElement>("[data-pt-hover]")?.textContent || "{}",
    );

    // Department switcher
    const tabs = root.querySelectorAll<HTMLButtonElement>(".pt-tab");
    const views = root.querySelectorAll<HTMLElement>("[data-dept-view]");
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const key = tab.dataset.dept;
        tabs.forEach((t) => t.setAttribute("aria-selected", String(t === tab)));
        views.forEach((v) => (v.hidden = v.dataset.deptView !== key));
        root.dataset.activeDept = key || "";
      });
    });

    // Hover / focus / tap detail panel (scoped per department view)
    views.forEach((view) => {
      const panel = view.querySelector<HTMLElement>("[data-detail]");
      const empty = view.querySelector<HTMLElement>("[data-detail-empty]");
      if (!panel || !empty) return;
      const set = (sel: string, text: string) => {
        const el = view.querySelector<HTMLElement>(sel);
        if (el) el.textContent = text;
      };

      const show = (uc: string | undefined) => {
        const d = uc ? hover[uc] : null;
        if (!d) {
          panel.hidden = true;
          empty.hidden = false;
          return;
        }
        const badge = view.querySelector<HTMLElement>("[data-detail-badge]");
        if (badge) {
          badge.textContent = d.agentId.replace("A-", "");
          badge.style.background = d.domainColor;
        }
        set("[data-detail-name]", d.title);
        set("[data-detail-meta]", `${d.agentId} · ${d.domainTitle}`);
        const layer = view.querySelector<HTMLElement>("[data-detail-layer]");
        if (layer) {
          layer.textContent = d.layerLabel;
          layer.style.color = d.layerColor;
        }
        const trig = view.querySelector<HTMLElement>("[data-detail-trigger]");
        if (trig) {
          trig.textContent = d.triggerLabel;
          trig.style.color = d.triggerColor;
        }
        const hitl = view.querySelector<HTMLElement>("[data-detail-hitl]");
        if (hitl) {
          hitl.hidden = !d.hitl;
          hitl.textContent = d.hitl ? `HITL · ${d.hitlActor}` : "";
        }
        const link = view.querySelector<HTMLAnchorElement>("[data-detail-link]");
        if (link) link.href = d.href;
        panel.hidden = false;
        empty.hidden = true;
      };

      view.querySelectorAll<HTMLElement>(".pt-cell").forEach((cell) => {
        cell.addEventListener("mouseenter", () => show(cell.dataset.uc));
        cell.addEventListener("focus", () => show(cell.dataset.uc));
      });
    });
  }
</script>

<!-- Widen the reading measure for the catalog route only. Astro ships this
     with the component, so it loads solely on the page that renders the table. -->
<style is:global>
  :root {
    --sl-content-width: 78rem;
  }
</style>

<style>
  .pt {
    --pt-ink: var(--sl-color-white);
    --pt-ink-dim: var(--sl-color-gray-3);
    --pt-surface: var(--sl-color-black);
    --pt-surface-2: var(--sl-color-gray-6);
    --pt-border: var(--sl-color-gray-5);
    font-family: var(--sl-font-sans);
    margin-block: 1.5rem;
  }

  /* ── Tabs ── */
  .pt-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }
  .pt-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--pt-border);
    border-radius: 999px;
    background: var(--pt-surface);
    color: var(--pt-ink-dim);
    font-family: var(--ge-display-font);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    cursor: pointer;
    transition: color 120ms ease, border-color 120ms ease, background 120ms ease;
  }
  .pt-tab:hover {
    color: var(--pt-ink);
    border-color: color-mix(in srgb, var(--sl-color-accent) 40%, var(--pt-border));
  }
  .pt-tab[aria-selected="true"] {
    background: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    color: #fff;
  }
  .pt-tab-count {
    font-family: var(--sl-font-mono);
    font-size: 0.7em;
    opacity: 0.7;
  }

  /* ── Header ── */
  .pt-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .pt-title {
    font-size: var(--sl-text-xl);
    margin: 0;
    border: none;
    padding: 0;
  }
  .pt-subtitle {
    margin: 0.15rem 0 0;
    font-size: var(--sl-text-xs);
    color: var(--pt-ink-dim);
    max-width: 46rem;
  }
  .pt-stats {
    display: flex;
    gap: 0.5rem;
  }
  .pt-stat {
    font-size: var(--sl-text-xs);
    color: var(--pt-ink-dim);
    border: 1px solid var(--pt-border);
    border-radius: 0.4rem;
    padding: 0.15rem 0.5rem;
    white-space: nowrap;
  }
  .pt-stat strong {
    color: var(--pt-ink);
  }

  /* ── Layout: grid + sidebar ── */
  .pt-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 60rem) {
    .pt-body {
      grid-template-columns: minmax(0, 1fr) 15rem;
    }
  }

  /* ── Domain groups ── */
  .pt-group {
    margin-bottom: 0.9rem;
    scroll-margin-top: 5rem;
  }
  .pt-group-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.2rem 0;
    text-decoration: none;
    color: var(--pt-ink-dim);
  }
  .pt-group-head:hover .pt-group-title {
    color: var(--sl-color-text-accent);
  }
  .pt-group-swatch {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 0.15rem;
    flex-shrink: 0;
  }
  .pt-group-title {
    font-family: var(--ge-display-font);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .pt-group-count {
    font-family: var(--sl-font-mono);
    font-size: 0.65rem;
    opacity: 0.6;
  }

  /* ── Element grid ── */
  .pt-grid {
    display: grid;
    grid-template-columns: repeat(var(--pt-cols, 10), minmax(0, 1fr));
    gap: 3px;
  }
  .pt-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.9rem 0.15rem 0.3rem;
    border: 1px solid var(--pt-border);
    border-top: 3px solid var(--pt-domain, var(--pt-border));
    border-radius: 6px 6px 4px 4px;
    background: var(--pt-surface);
    color: var(--pt-ink);
    text-decoration: none;
    cursor: pointer;
    transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
  }
  .pt-cell:hover,
  .pt-cell:focus-visible {
    transform: scale(1.12);
    z-index: 5;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.18);
    outline: none;
  }
  .pt-cell-num {
    font-family: var(--sl-font-mono);
    font-size: 0.52rem;
    line-height: 1;
    color: var(--pt-ink-dim);
    position: absolute;
    top: 0.28rem;
    left: 50%;
    transform: translateX(-50%);
  }
  .pt-cell-name {
    font-family: var(--ge-display-font);
    font-size: 0.56rem;
    font-weight: 600;
    line-height: 1.15;
    text-align: center;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pt-cell-dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    margin-top: 0.25rem;
    opacity: 0.85;
  }
  .pt-cell-trig {
    position: absolute;
    top: 0.25rem;
    right: 0.25rem;
    width: 0.6rem;
    height: 0.6rem;
    opacity: 0.65;
  }
  .pt-cell:hover .pt-cell-trig {
    opacity: 1;
  }
  .pt-cell-hitl {
    position: absolute;
    top: 0.25rem;
    left: 0.25rem;
    width: 0.6rem;
    height: 0.6rem;
    color: #e11d48;
    opacity: 0.7;
  }

  /* ── Sidebar ── */
  .pt-side {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 60rem) {
    .pt-side {
      position: sticky;
      top: 5rem;
      align-self: start;
    }
  }
  .pt-detail {
    border: 1px solid var(--pt-border);
    border-radius: 0.6rem;
    padding: 0.75rem;
    background: var(--pt-surface-2);
  }
  .pt-detail-empty {
    border-style: dashed;
    text-align: center;
    font-size: var(--sl-text-xs);
    color: var(--pt-ink-dim);
  }
  .pt-detail-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }
  .pt-detail-badge {
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 0.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: var(--sl-font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .pt-detail-name {
    font-family: var(--ge-display-font);
    font-weight: 600;
    font-size: 0.85rem;
    line-height: 1.15;
  }
  .pt-detail-meta {
    font-family: var(--sl-font-mono);
    font-size: 0.65rem;
    color: var(--pt-ink-dim);
  }
  .pt-detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .pt-tag {
    font-size: 0.62rem;
    font-weight: 600;
    padding: 0.12rem 0.4rem;
    border-radius: 0.3rem;
    border: 1px solid var(--pt-border);
    background: var(--pt-surface);
  }
  .pt-tag-hitl {
    color: #e11d48;
    border-color: color-mix(in srgb, #e11d48 35%, var(--pt-border));
  }
  .pt-detail-link {
    display: inline-block;
    margin-top: 0.6rem;
    font-size: var(--sl-text-xs);
    font-weight: 600;
  }

  /* ── Legend ── */
  .pt-legend {
    border: 1px solid var(--pt-border);
    border-radius: 0.6rem;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 60rem) {
    .pt-legend {
      max-height: 60vh;
      overflow-y: auto;
    }
  }
  .pt-legend-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--pt-ink-dim);
    margin-bottom: 0.4rem;
  }
  .pt-legend-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    color: var(--pt-ink);
    padding: 0.08rem 0;
    text-decoration: none;
  }
  .pt-legend-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .pt-legend-swatch {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 0.12rem;
    flex-shrink: 0;
  }
  .pt-legend-trig {
    width: 0.7rem;
    height: 0.7rem;
    flex-shrink: 0;
  }
  .pt-legend-hitl {
    color: #e11d48;
  }
  .pt-legend-domain:hover .pt-legend-domain-title {
    color: var(--sl-color-text-accent);
  }
  .pt-legend-domain-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .pt-legend-domain-count {
    margin-left: auto;
    font-family: var(--sl-font-mono);
    font-size: 0.6rem;
    color: var(--pt-ink-dim);
    flex-shrink: 0;
  }
</style>
