---
/**
 * AgentDetail.astro — the per-agent spec page, rendered inside a StarlightPage
 * by src/pages/catalog/agents/[slug].astro. A dense header (identity, layer /
 * trigger / governance tags, objective, spec stat-strip, factory status) over
 * the structured OKF explorer (OkfSpec.astro). Fed the light record from the
 * catalog plus the full OKF spec projection; both come from gen-catalog.mjs.
 */
import OkfSpec from "./OkfSpec.astro";

interface Props {
  agent: any;
  okf?: any;
}
const { agent, okf } = Astro.props;
const d = agent.detail;
// Normalize the trailing slash — BASE_URL is "/ge-agent-factory" (no slash),
// so a bare `${base}catalog/` would render "/ge-agent-factorycatalog/".
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const stageLabel = (s: string | null) =>
  s ? s.replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase()) : null;

const c = okf?.counts || {};
const stats = [
  { n: c.systems, label: "systems" },
  { n: c.entities, label: "entities" },
  { n: c.columns, label: "fields" },
  { n: c.tools, label: "tools" },
  { n: c.steps, label: "workflow steps" },
  { n: c.evidence, label: "evidence rules" },
  { n: c.evals, label: "evals" },
  { n: c.anomalies, label: "anomalies" },
].filter((s) => s.n > 0);
---

<div class="agent">
  <p class="agent-back"><a href={`${base}catalog/`}>← Periodic table</a></p>

  <div class="agent-hero">
    <span class="agent-badge" style={`background:${agent.domainColor}`}>{agent.num}</span>
    <div class="agent-crumb">
      {agent.department?.toUpperCase()} · {agent.domainTitle} ·
      <span class="agent-code">{agent.agentId}</span>
    </div>
  </div>

  {okf?.objective && <p class="agent-objective">{okf.objective}</p>}

  <div class="agent-tags">
    <span class="agent-tag" style={`--c:${agent.layerColor}`}>
      <span class="agent-tag-dot" style={`background:${agent.layerColor}`}></span>
      {agent.layerLabel}{agent.layerDesc ? ` · ${agent.layerDesc}` : ""}
    </span>
    <span class="agent-tag" style={`--c:${agent.triggerColor}`}>{agent.triggerLabel}</span>
    {agent.hitl && (
      <span class="agent-tag agent-tag-hitl">
        Human-in-the-loop{agent.hitlActor ? ` · ${agent.hitlActor}` : ""}
      </span>
    )}
    {d.hasBehaviorContract && <span class="agent-tag">Behavior contract</span>}
    {d.buildable && <span class="agent-tag agent-tag-ok">Buildable</span>}
    {stageLabel(d.targetStage) && <span class="agent-tag">→ {stageLabel(d.targetStage)}</span>}
  </div>

  {stats.length > 0 && (
    <div class="agent-stats">
      {stats.map((s) => (
        <div class="agent-stat"><span class="agent-stat-n">{s.n}</span><span class="agent-stat-l">{s.label}</span></div>
      ))}
    </div>
  )}

  {agent.hitl && agent.hitlAction && (
    <p class="agent-hitl-note">
      <strong>Checkpoint:</strong> {agent.hitlActor} — {agent.hitlAction}
    </p>
  )}

  {okf ? (
    <OkfSpec spec={okf} sources={d.sources} />
  ) : (
    <>
      <h2>Systems &amp; integration</h2>
      <ul>{(d.systems || []).map((s: string) => <li>{s}</li>)}</ul>
    </>
  )}

  <p class="agent-source">
    Spec source: <code>{d.sourcePath?.replace(/^(\.\.\/)+/, "apps/presentation/")}</code>
    {d.maturity ? <> · {d.maturity.replace(/_/g, " ")}</> : null}
    {d.rows ? <> · {d.rows} mock rows / entity</> : null}
  </p>
</div>

<style>
  .agent-back {
    font-size: var(--sl-text-xs);
    margin-bottom: 1rem;
  }
  .agent-hero {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .agent-badge {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: var(--sl-font-mono);
    font-weight: 700;
    flex-shrink: 0;
  }
  .agent-crumb {
    font-family: var(--sl-font-mono);
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .agent-code {
    color: var(--sl-color-text-accent);
  }
  .agent-objective {
    font-size: var(--sl-text-base);
    color: var(--sl-color-gray-2);
    max-width: 46rem;
    margin: 0.5rem 0 0.9rem;
  }
  .agent-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }
  .agent-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: 0.35rem;
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
  }
  .agent-tag-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
  }
  .agent-tag-hitl {
    color: var(--ge-status-blocked-text);
    border-color: color-mix(in srgb, var(--ge-status-blocked) 35%, var(--sl-color-gray-5));
  }
  .agent-tag-ok {
    color: var(--ge-status-passed-text);
    border-color: color-mix(in srgb, var(--ge-status-passed) 35%, var(--sl-color-gray-5));
  }

  /* Spec stat-strip */
  .agent-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(6rem, 1fr));
    gap: 0.5rem;
    margin: 0 0 1.25rem;
  }
  .agent-stat {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 0.5rem 0.6rem;
    text-align: center;
  }
  .agent-stat-n {
    display: block;
    font-family: var(--ge-display-font);
    font-weight: 700;
    font-size: 1.15rem;
    line-height: 1;
    color: var(--sl-color-white);
  }
  .agent-stat-l {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3);
  }

  .agent-hitl-note {
    border: 1px solid color-mix(in srgb, var(--ge-status-blocked) 35%, transparent);
    background: color-mix(in srgb, var(--ge-status-blocked) 8%, transparent);
    border-radius: 0.5rem;
    padding: 0.6rem 0.75rem;
    font-size: var(--sl-text-sm);
  }
  .agent-source {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    margin-top: 2.5rem;
  }
</style>

<!-- Widen the reading measure on agent spec pages only (dense schema tables) —
     shipped with this component, so it loads solely on pages that render it. -->
<style is:global>
  :root {
    --sl-content-width: 58rem;
  }
</style>
