---
// Risk-tier badge for operator commands. The tiers and their meanings are the
// registry's field contract (tools/lib/ge-command-registry.mjs, `risk`);
// colors go from calm (read-only) to hot (mutates-cloud), each mapped onto
// the status ramp (--ge-status-* in src/styles/custom.css, mirroring
// packages/design/src/status-ramp.mjs) so risk reads in the same vocabulary
// as run state everywhere else.
const { risk } = Astro.props;

const TIERS = {
  "read-only": { label: "read-only", tone: "ge-status-passed" },
  "starts-local-workloads": { label: "starts local workloads", tone: "ge-status-running" },
  "writes-repo": { label: "writes repo", tone: "ge-accent-synthesized" },
  "starts-workloads": { label: "starts cloud workloads", tone: "ge-status-blocked" },
  "mutates-cloud": { label: "mutates cloud", tone: "ge-status-failed" },
};
const tier = TIERS[risk] ?? { label: risk, tone: null };
const toneStyle = tier.tone
  ? `--risk-tone: var(--${tier.tone}); --risk-text: var(--${tier.tone}-text);`
  : "--risk-tone: var(--sl-color-gray-4); --risk-text: var(--sl-color-gray-2);";
---

<span class="risk-badge" style={toneStyle}>{tier.label}</span>

<style>
  .risk-badge {
    display: inline-block;
    padding: 0.1rem 0.55rem;
    border: 1px solid color-mix(in srgb, var(--risk-tone) 45%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--risk-tone) 12%, transparent);
    color: var(--risk-text);
    font-family: var(--sl-font-system-mono, monospace);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
</style>
