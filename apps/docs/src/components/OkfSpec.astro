---
/**
 * OkfSpec.astro — the dense, structured explorer for an agent's OKF spec.
 * Fed the projection built by gen-catalog.mjs (behaviorContract +
 * generationSpec). Renders governance, workflow, tools, source systems, the
 * typed data model, and evals/validation as scannable structured sections —
 * not flattened markdown. Native HTML only; no client JS.
 */
interface Props {
  spec: any;
  sources?: any[];
}
import { createFragmentIndex } from "../lib/catalog-fragments.mjs";

const { spec, sources = [] } = Astro.props;

const CATEGORY_LABEL: Record<string, string> = {
  erp: "ERP / operational",
  analytics: "Analytics warehouse",
  ai: "AI / model",
  clm: "Contract lifecycle",
  "market-data": "Market data",
  collaboration: "Collaboration",
  declared: "Declared",
};
const norm = (s: string) => String(s || "").toLowerCase().replace(/[^a-z0-9]/g, "");
const sourceByName = new Map(sources.map((s: any) => [norm(s.system), s]));

const titleize = (s: string) =>
  String(s || "")
    .replace(/[_-]+/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());

// Tool kinds ride the status ramp (--ge-* tokens in src/styles/custom.css,
// mirroring packages/design/src/status-ramp.mjs): reads are calm, writes are
// hot, compute is the one green. Each token has a `-text` AA companion.
const KIND_TONE: Record<string, string> = {
  query: "ge-status-running",
  action: "ge-status-blocked",
  mutation: "ge-status-failed",
  lookup: "ge-status-queued",
  compute: "ge-status-passed",
};
const kindStyle = (k: string) => {
  const tone = KIND_TONE[k];
  return tone
    ? `--k: var(--${tone}); --k-text: var(--${tone}-text);`
    : "--k: var(--sl-color-gray-4); --k-text: var(--sl-color-gray-2);";
};

// Column type → readable label; enum columns list their values.
const colType = (c: any) => {
  if (c.type === "enum") return "enum";
  return c.type;
};

const g = spec.governance || {};
const steps = spec.workflow?.steps || [];
const toolBySystem = (id: string) => (spec.systems || []).find((s: any) => s.id === id)?.name || titleize(id);
const toolFragments = createFragmentIndex(spec.tools || [], { prefix: "tool", name: (t: any) => t.name });
const entityFragments = createFragmentIndex(spec.entities || [], { prefix: "entity", name: (e: any) => e.name });
const toolTarget = (name: string) => toolFragments.resolve(name);
const entityTarget = (name: string) => entityFragments.resolve(name);
---

<div class="okf">
  {/* ── Governance ─────────────────────────────────────────── */}
  <h2 id="governance">Playbook &amp; governance</h2>
  {spec.role && <p class="okf-lead"><strong>Role.</strong> {spec.role}</p>}

  <div class="okf-scope">
    <div class="okf-scope-col okf-scope-in">
      <div class="okf-mini-label">In scope</div>
      <ul>{(g.inScope || []).map((x: string) => <li>{x}</li>)}</ul>
    </div>
    <div class="okf-scope-col okf-scope-out">
      <div class="okf-mini-label">Out of scope</div>
      <ul>{(g.outOfScope || []).map((x: string) => <li>{x}</li>)}</ul>
    </div>
  </div>

  {g.escalationRules?.length > 0 && (
    <>
      <div class="okf-mini-label">Escalation rules</div>
      <div class="okf-table-wrap">
        <table class="okf-table">
          <thead><tr><th>Trigger</th><th>Action</th><th>Rationale</th></tr></thead>
          <tbody>
            {g.escalationRules.map((r: any) => (
              <tr>
                <td>{r.trigger}</td>
                <td><code class="okf-action">{r.action}</code></td>
                <td class="okf-dim">{r.rationale}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}

  {g.refusalRules?.length > 0 && (
    <>
      <div class="okf-mini-label">Hard guardrails</div>
      <ul class="okf-guardrails">{g.refusalRules.map((x: string) => <li>{x}</li>)}</ul>
    </>
  )}

  {g.evidenceRequirements?.length > 0 && (
    <>
      <div class="okf-mini-label">Evidence requirements</div>
      <ul class="okf-evidence">
        {g.evidenceRequirements.map((e: any) => (
          <li>
            <span class="okf-claim">{e.claim}</span>
            <span class="okf-cites">
              {(e.mustCite || []).map((c: string) => <code>{c}</code>)}
            </span>
          </li>
        ))}
      </ul>
    </>
  )}

  {/* ── Workflow ───────────────────────────────────────────── */}
  {steps.length > 0 && (
    <>
      <h2 id="workflow">Workflow</h2>
      <p class="okf-dim okf-mode">{titleize(spec.workflow?.mode || "sequential")} · {steps.length} stages</p>
      <ol class="okf-flow">
        {steps.map((s: any, i: number) => (
          <li class="okf-step">
            <div class="okf-step-n">{i + 1}</div>
            <div class="okf-step-body">
              <div class="okf-step-title">{s.label || titleize(s.id)}</div>
              <p class="okf-dim">{s.description}</p>
              {s.tools?.length > 0 && (
                <div class="okf-chips">
                  {s.tools.map((t: string) => {
                    const target = toolTarget(t);
                    return target
                      ? <a class="okf-chip okf-chip-tool" href={`#${target}`}>{t}</a>
                      : <span class="okf-chip okf-chip-missing" title="Referenced by the spec; not included in this rendered inventory." aria-label={`${t}; referenced but not included in this tool inventory`}>{t}</span>;
                  })}
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </>
  )}

  {/* ── Tools ──────────────────────────────────────────────── */}
  {spec.tools?.length > 0 && (
    <>
      <h2 id="tools">Agent tools <span class="okf-count">{spec.tools.length}</span></h2>
      <div class="okf-tools">
        {toolFragments.entries.map(({ item: t, id }) => (
          <div class="okf-tool" id={id}>
            <div class="okf-tool-head">
              <code class="okf-tool-name">{t.name}</code>
              <span class="okf-kind" style={kindStyle(t.kind)}>{t.kind}</span>
              {t.sourceSystemId && <span class="okf-tool-sys">{toolBySystem(t.sourceSystemId)}</span>}
            </div>
            {t.description && <p class="okf-dim okf-tool-desc">{t.description}</p>}
            <div class="okf-io">
              {t.requiredInputs?.length > 0 && (
                <div><span class="okf-io-label">in</span>{t.requiredInputs.map((x: string) => <code>{x}</code>)}</div>
              )}
              {t.produces?.length > 0 && (
                <div><span class="okf-io-label">out</span>{t.produces.map((x: string) => <code>{x}</code>)}</div>
              )}
              {t.evidenceEmitted?.length > 0 && (
                <div><span class="okf-io-label">evidence</span>{t.evidenceEmitted.map((x: string) => <code class="okf-ev">{x}</code>)}</div>
              )}
            </div>
          </div>
        ))}
      </div>
    </>
  )}

  {/* ── Source systems ─────────────────────────────────────── */}
  {spec.systems?.length > 0 && (
    <>
      <h2 id="systems">Source systems <span class="okf-count">{spec.systems.length}</span></h2>
      <div class="okf-systems">
        {spec.systems.map((s: any) => {
          const src = sourceByName.get(norm(s.name || s.id)) || {};
          return (
          <div class="okf-sys">
            <div class="okf-sys-head">
              <span class="okf-sys-name">{s.name || titleize(s.id)}</span>
              {s.protocol && <span class="okf-sys-proto">{s.protocol}</span>}
            </div>
            <div class="okf-sys-badges">
              {src.direction && <span class="okf-sys-badge">{src.direction}</span>}
              {src.category && <span class="okf-sys-badge">{CATEGORY_LABEL[src.category] ?? src.category}</span>}
            </div>
            {src.description && <p class="okf-dim okf-sys-desc">{src.description}</p>}
            {s.owns?.length > 0 && (
              <div class="okf-sys-row"><span class="okf-io-label">owns</span>
                {s.owns.map((e: string) => {
                  const target = entityTarget(e);
                  return target
                    ? <a class="okf-chip" href={`#${target}`}>{e}</a>
                    : <span class="okf-chip okf-chip-missing" title="Referenced by the spec; not included in this rendered inventory." aria-label={`${e}; referenced but not included in this entity inventory`}>{e}</span>;
                })}
              </div>
            )}
            {s.toolNames?.length > 0 && (
              <div class="okf-sys-row"><span class="okf-io-label">tools</span>
                {s.toolNames.map((t: string) => {
                  const target = toolTarget(t);
                  return target
                    ? <a class="okf-chip okf-chip-tool" href={`#${target}`}>{t}</a>
                    : <span class="okf-chip okf-chip-missing" title="Referenced by the spec; not included in this rendered inventory." aria-label={`${t}; referenced but not included in this tool inventory`}>{t}</span>;
                })}
              </div>
            )}
          </div>
          );
        })}
      </div>
    </>
  )}

  {/* ── Data model ─────────────────────────────────────────── */}
  {spec.entities?.length > 0 && (
    <>
      <h2 id="data-model">
        Data model <span class="okf-count">{spec.entities.length} entities · {spec.counts?.columns} fields</span>
      </h2>
      <div class="okf-entities">
        {entityFragments.entries.map(({ item: e, id }) => (
          <details class="okf-entity" id={id} open={spec.entities.length <= 6}>
            <summary>
              <code class="okf-entity-name">{e.name}</code>
              <span class="okf-entity-meta">
                {e.columns?.length} cols · {e.rowCount} rows · {toolBySystem(e.sourceSystemId)}
                {e.datastore && ` · ${e.datastore}`}
              </span>
            </summary>
            <div class="okf-table-wrap">
              <table class="okf-table okf-schema">
                <thead><tr><th>Column</th><th>Type</th><th>Constraints</th></tr></thead>
                <tbody>
                  {(e.columns || []).map((c: any) => (
                    <tr>
                      <td><code>{c.name}</code>{c.name === e.primaryKey && <span class="okf-pk">PK</span>}</td>
                      <td class="okf-dim">{colType(c)}</td>
                      <td class="okf-dim">
                        {c.required && <span class="okf-req">required</span>}
                        {c.values && <span class="okf-enum">{c.values.slice(0, 6).join(" · ")}{c.values.length > 6 ? " …" : ""}</span>}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </details>
        ))}
      </div>

      {spec.relationships?.length > 0 && (
        <>
          <div class="okf-mini-label">Relationships</div>
          <ul class="okf-rels">
            {spec.relationships.map((r: any) => (
              <li><code>{r.from}</code> <span class="okf-arrow">→</span> <code>{r.to}</code> <span class="okf-dim">{r.cardinality}</span></li>
            ))}
          </ul>
        </>
      )}

      {spec.anomalies?.length > 0 && (
        <>
          <div class="okf-mini-label">Seeded anomalies (what the agent must catch)</div>
          <div class="okf-anoms">
            {spec.anomalies.map((a: any) => (
              <div class="okf-anom">
                <p class="okf-anom-desc">{a.description}</p>
                {a.affectedEntities?.length > 0 && (
                  <div class="okf-chips">
                    {a.affectedEntities.map((x: string) => {
                      const target = entityTarget(x);
                      return target
                        ? <a class="okf-chip" href={`#${target}`}>{x}</a>
                        : <span class="okf-chip okf-chip-missing" title="Referenced by the spec; not included in this rendered inventory." aria-label={`${x}; referenced but not included in this entity inventory`}>{x}</span>;
                    })}
                  </div>
                )}
                {a.expectedRecommendation && <p class="okf-dim"><strong>Expected:</strong> {a.expectedRecommendation}</p>}
              </div>
            ))}
          </div>
        </>
      )}
    </>
  )}

  {/* ── Evals & validation ─────────────────────────────────── */}
  {(spec.evals?.length > 0 || spec.queries?.length > 0 || spec.documents?.length > 0) && (
    <>
      <h2 id="evals">Evals &amp; proof</h2>

      {spec.evals?.length > 0 && (
        <div class="okf-evals">
          {spec.evals.map((ev: any) => (
            <div class="okf-eval">
              <p class="okf-eval-prompt">“{ev.prompt}”</p>
              <div class="okf-eval-rows">
                {ev.expectedToolCalls?.length > 0 && (
                  <div><span class="okf-io-label">expects tools</span>{[...new Set(ev.expectedToolCalls)].map((t: any) => <code>{t}</code>)}</div>
                )}
                {ev.mustReferenceEntities?.length > 0 && (
                  <div><span class="okf-io-label">cites entities</span>{[...new Set(ev.mustReferenceEntities)].map((t: any) => <code>{t}</code>)}</div>
                )}
                {ev.expectedActionOutcome && (
                  <div class="okf-dim okf-eval-outcome"><strong>Outcome.</strong> {ev.expectedActionOutcome}</div>
                )}
              </div>
            </div>
          ))}
        </div>
      )}

      {spec.queries?.length > 0 && (
        <>
          <div class="okf-mini-label">Answerable queries</div>
          <ul class="okf-queries">
            {spec.queries.map((q: any) => <li>{q.request}</li>)}
          </ul>
        </>
      )}

      {spec.documents?.length > 0 && (
        <>
          <div class="okf-mini-label">Governing documents</div>
          <div class="okf-docs">
            {spec.documents.map((d: any) => (
              <div class="okf-doc">
                <div class="okf-doc-head"><strong>{d.title}</strong> <span class="okf-doc-type">{d.type}</span></div>
                {d.requiredSections?.length > 0 && (
                  <div class="okf-chips">{d.requiredSections.map((x: string) => <span class="okf-chip">{x}</span>)}</div>
                )}
              </div>
            ))}
          </div>
        </>
      )}

      {spec.validation?.smokePrompt && (
        <p class="okf-dim okf-smoke"><strong>Smoke check.</strong> {spec.validation.smokePrompt}</p>
      )}
    </>
  )}
</div>

<style>
  .okf {
    margin-top: 0.5rem;
  }
  .okf h2 {
    margin-top: 2rem;
  }
  .okf-count {
    font-family: var(--sl-font-mono);
    font-size: 0.6em;
    font-weight: 500;
    color: var(--sl-color-gray-3);
  }
  .okf-lead {
    font-size: var(--sl-text-sm);
  }
  .okf-dim {
    color: var(--sl-color-gray-3);
  }
  .okf-mini-label {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-3);
    margin: 1.25rem 0 0.4rem;
  }

  /* scope */
  .okf-scope {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin: 0.5rem 0;
  }
  @media (min-width: 40rem) {
    .okf-scope { grid-template-columns: 1fr 1fr; }
  }
  .okf-scope-col {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 0.6rem 0.85rem;
  }
  .okf-scope-col ul { margin: 0.25rem 0 0; padding-left: 1.1rem; }
  .okf-scope-col li { font-size: var(--sl-text-sm); margin: 0.15rem 0; }
  .okf-scope-in {
    border-color: color-mix(in srgb, var(--ge-status-passed) 40%, var(--sl-color-gray-5));
    background: color-mix(in srgb, var(--ge-status-passed) 5%, transparent);
  }
  .okf-scope-out { background: var(--sl-color-gray-6); }

  /* tables */
  .okf-table-wrap { overflow-x: auto; }
  .okf-table { width: 100%; font-size: var(--sl-text-xs); margin: 0.25rem 0; }
  .okf-table td { vertical-align: top; }
  .okf-action { color: var(--ge-status-blocked-text); }
  code.okf-action, .okf-req { white-space: nowrap; }

  .okf-guardrails li, .okf-evidence li { font-size: var(--sl-text-sm); }
  .okf-guardrails { padding-left: 1.1rem; }
  .okf-evidence { list-style: none; padding: 0; margin: 0; }
  .okf-evidence li {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }
  .okf-claim { flex: 1 1 16rem; }
  .okf-cites code, .okf-io code, .okf-eval-rows code {
    font-size: 0.72rem;
    background: var(--sl-color-gray-6);
    padding: 0.05rem 0.35rem;
    border-radius: 0.25rem;
    margin-right: 0.25rem;
  }

  /* workflow */
  .okf-mode { font-size: var(--sl-text-xs); margin: 0.25rem 0 0.75rem; }
  .okf-flow { list-style: none; padding: 0; margin: 0; }
  .okf-step { display: flex; gap: 0.75rem; padding: 0.5rem 0; }
  .okf-step-n {
    flex-shrink: 0;
    width: 1.6rem; height: 1.6rem;
    border-radius: 999px;
    background: var(--sl-color-accent);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--sl-font-mono); font-size: 0.75rem; font-weight: 700;
  }
  .okf-step-body { flex: 1; min-width: 0; }
  .okf-step-title { font-family: var(--ge-display-font); font-weight: 600; }
  .okf-step-body p { margin: 0.15rem 0 0.35rem; font-size: var(--sl-text-sm); }

  .okf-chips { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.35rem; }
  .okf-chip {
    font-family: var(--sl-font-mono);
    font-size: 0.68rem;
    padding: 0.08rem 0.4rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.3rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
  }
  a.okf-chip:hover { border-color: var(--sl-color-accent); color: var(--sl-color-text-accent); }
  .okf-chip-tool { color: var(--sl-color-text-accent); }
  .okf-chip-missing { color: var(--sl-color-gray-3); border-style: dashed; }

  /* tools */
  .okf-tools, .okf-systems, .okf-evals, .okf-docs, .okf-anoms {
    display: grid; gap: 0.6rem; margin: 0.5rem 0;
  }
  @media (min-width: 48rem) {
    .okf-tools, .okf-systems { grid-template-columns: 1fr 1fr; }
  }
  .okf-tool, .okf-sys, .okf-eval, .okf-doc, .okf-anom {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 0.6rem 0.75rem;
    background: var(--sl-color-gray-6);
  }
  .okf-tool-head, .okf-sys-head { display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem; }
  .okf-tool-name, .okf-entity-name { font-size: 0.78rem; font-weight: 600; }
  .okf-kind {
    font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    color: var(--k-text); border: 1px solid color-mix(in srgb, var(--k) 40%, transparent);
    border-radius: 0.25rem; padding: 0 0.35rem;
  }
  .okf-tool-sys, .okf-sys-proto { margin-left: auto; font-size: 0.68rem; color: var(--sl-color-gray-3); }
  .okf-sys-badges { display: flex; flex-wrap: wrap; gap: 0.3rem; margin: 0.35rem 0; }
  .okf-sys-badge {
    font-size: 0.6rem; font-weight: 600; text-transform: capitalize;
    color: var(--sl-color-gray-2); background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5); border-radius: 0.25rem; padding: 0 0.35rem;
  }
  .okf-sys-desc { font-size: var(--sl-text-xs); margin: 0.25rem 0 0.5rem; }
  .okf-tool-desc { margin: 0.35rem 0; font-size: var(--sl-text-xs); }
  .okf-io, .okf-sys-row { display: flex; flex-direction: column; gap: 0.25rem; }
  .okf-io > div, .okf-sys-row { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.25rem; }
  .okf-io-label {
    font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--sl-color-gray-4); min-width: 3.8rem;
  }
  .okf-ev { color: var(--ge-status-passed-text) !important; }

  /* data model */
  .okf-entities { display: flex; flex-direction: column; gap: 0.4rem; margin: 0.5rem 0; }
  .okf-entity {
    border: 1px solid var(--sl-color-gray-5); border-radius: 0.5rem; overflow: hidden;
  }
  .okf-entity > summary {
    display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap;
    padding: 0.5rem 0.75rem; cursor: pointer; background: var(--sl-color-gray-6);
    list-style: none;
  }
  .okf-entity > summary::-webkit-details-marker { display: none; }
  .okf-entity > summary::before { content: "▸"; color: var(--sl-color-gray-3); }
  .okf-entity[open] > summary::before { content: "▾"; }
  .okf-entity-meta { font-size: 0.68rem; color: var(--sl-color-gray-3); font-family: var(--sl-font-mono); }
  .okf-schema { margin: 0; }
  .okf-schema td, .okf-schema th { padding: 0.25rem 0.75rem; }
  .okf-pk {
    font-size: 0.55rem; font-weight: 700; margin-left: 0.35rem; color: var(--ge-status-blocked-text);
    border: 1px solid color-mix(in srgb, var(--ge-status-blocked) 40%, transparent); border-radius: 0.2rem; padding: 0 0.25rem;
  }
  .okf-req { font-size: 0.65rem; color: var(--sl-color-gray-3); margin-right: 0.4rem; }
  .okf-enum { font-size: 0.68rem; color: var(--sl-color-gray-2); }

  .okf-rels { list-style: none; padding: 0; margin: 0.25rem 0; }
  .okf-rels li { font-size: var(--sl-text-xs); padding: 0.15rem 0; }
  .okf-rels code { font-size: 0.72rem; }
  .okf-arrow { color: var(--sl-color-accent); }

  .okf-anom-desc { margin: 0 0 0.35rem; font-size: var(--sl-text-sm); }
  .okf-anom p:last-child { margin-bottom: 0; font-size: var(--sl-text-xs); }

  /* evals */
  .okf-eval-prompt { font-style: italic; margin: 0 0 0.5rem; font-size: var(--sl-text-sm); }
  .okf-eval-rows { display: flex; flex-direction: column; gap: 0.25rem; }
