---
/**
 * Per-agent spec pages — one static route per agent in the generated catalog.
 * Wrapped in StarlightPage so they carry the full site chrome (nav, search,
 * theme) without living in the content collection, which keeps 363 pages out
 * of the autogenerated sidebar. Reached from the periodic-table tiles.
 */
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import AgentDetail from "../../../components/AgentDetail.astro";
import catalog from "../../../data/agent-catalog.json";
import okf from "../../../data/agent-okf.json";

export async function getStaticPaths() {
  const { agents } = catalog as any;
  // A handful of use-cases appear as a tile in two departments (e.g. a
  // regulatory monitor in both Finance and IT) and share one spec slug — emit
  // one page per unique slug; both tiles link to it.
  const seen = new Set<string>();
  return agents
    .filter((a: any) => !seen.has(a.slug) && seen.add(a.slug))
    .map((agent: any) => ({
      params: { slug: agent.slug },
      props: { agent, okf: (okf as any)[agent.slug] ?? null },
    }));
}

const { agent, okf: agentOkf } = Astro.props;
const description = `${agent.title} — ${agent.department?.toUpperCase()} · ${agent.domainTitle}. Governance, workflow, tools, source systems, data model, and evals.`;

// Section headings for the OKF explorer — passed explicitly because Starlight
// can't auto-detect headings rendered inside an Astro component.
const o = agentOkf;
const headings = o
  ? [
      { depth: 2, slug: "governance", text: "Playbook & governance" },
      o.workflow?.steps?.length && { depth: 2, slug: "workflow", text: "Workflow" },
      o.tools?.length && { depth: 2, slug: "tools", text: "Agent tools" },
      o.systems?.length && { depth: 2, slug: "systems", text: "Source systems" },
      o.entities?.length && { depth: 2, slug: "data-model", text: "Data model" },
      (o.evals?.length || o.queries?.length || o.documents?.length) && {
        depth: 2,
        slug: "evals",
        text: "Evals & proof",
      },
    ].filter(Boolean)
  : [];
---

<StarlightPage
  frontmatter={{
    title: agent.title,
    description,
    pagefind: false,
  }}
  headings={headings}
>
  <AgentDetail agent={agent} okf={agentOkf} />
</StarlightPage>
