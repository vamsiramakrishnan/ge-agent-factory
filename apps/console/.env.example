# GE Agent Factory — Console UI (apps/console/server.js)
#
# Access control: by default the deployed console is AUTHENTICATED-ONLY via IAM
# run.invoker (callers need a Google identity token; it fails closed). Set
# enable_iap=true in Terraform to add native Cloud Run IAP, restricting access to
# var.iap_members. Either way there is no in-app auth to configure here (unlike the
# gateway's legacy LB+IAP path).

# --- Runtime (Bun server) ---
# Port the server listens on (Cloud Run sets PORT=8080).
PORT=8080

# GCP project (used by the GE API read paths: status, fleet, doctor).
GOOGLE_CLOUD_PROJECT=my-gcp-project-id

# Cloud Run URL of the factory gateway. Terraform injects this as API_GATEWAY_URL
# on the console service; actions that mutate the cloud are routed to the gateway.
API_GATEWAY_URL="https://ge-agent-factory-gateway-<hash>-<region>.a.run.app"

# Gateway transport for any direct gateway calls: "proxy" (gcloud tunnel; local
# only) or "direct" (HTTPS + minted ID token). In a deployed container use direct.
GE_GATEWAY_TRANSPORT=direct

# Run ledger reads (default on). Set 0 to fall back to the legacy file stores.
GE_LEDGER_READS=1

# Local runtime daemon port (proxied at /api/runtime/*). No daemon runs in the
# deployed container, so that surface degrades gracefully to "daemon down".
GE_DAEMON_PORT=17654

# Optional: make the console read-only (disable mutating actions) when hosted.
# GE_CONSOLE_READONLY=true

# --- Frontend (Vite, VITE_* are build-time, exposed to the browser) ---
# Presentation app base URL. When set, the interview Spec Canvas shows a
# "Deploy in presentation" button that opens the presentation deploy panel with
# ?spec=<console>/api/interviews/<id>/generation-spec (served CORS-open, GET-only).
# NOTE: cross-origin behind IAP, the browser fetch won't carry IAP creds — deploy
# the two apps same-origin (path-routed) or expose this GET path unauthenticated.
# VITE_PRESENTATION_URL="https://ge-presentation-<hash>-<region>.a.run.app"

# Optional: GCS bucket to mirror uploaded interview BRDs (else local .ge/ only).
# GE_INTERVIEW_BUCKET="my-bucket"

# Optional bucket for GCS BRD mirror (falls back to GE_FACTORY_BUCKET / GE_BUCKET).

# --- Optional: Firebase Google sign-in (OPT-IN; default OFF) -------------------
# This is an ALTERNATIVE to the default IAM/IAP access model above, for deployments
# that want in-app Google sign-in instead of (or behind) IAP. It is INERT by default:
# with none of these set, the console behaves exactly as today — no sign-in screen,
# no token required on /api/*. The central IAP-fronted deploy must NOT set these.
#
# Enabling has TWO independent switches that should be turned on together:
#
# Server (Bun, runtime) — enforces ID-token verification on every /api/* request:
#   GE_AUTH_MODE=firebase        # any other/unset value ⇒ enforcement OFF (passthrough)
#   # Project id for token verification comes from FIREBASE_PROJECT_ID, else
#   # GOOGLE_CLOUD_PROJECT (set above). Tokens are verified against Google's
#   # securetoken x509 certs (signature + iss + aud + exp).
#   # FIREBASE_PROJECT_ID=my-gcp-project-id
#
# Client (Vite, BUILD-TIME — VITE_* are baked into the bundle and shipped to the
# browser; these are public Firebase web-app config values, not secrets):
#   # Enabled iff VITE_AUTH_MODE==="firebase" AND VITE_FIREBASE_API_KEY is present.
#   VITE_AUTH_MODE=firebase
#   VITE_FIREBASE_API_KEY=AIza...
#   VITE_FIREBASE_AUTH_DOMAIN=my-project.firebaseapp.com
#   VITE_FIREBASE_PROJECT_ID=my-gcp-project-id
#
# Note: EventSource (SSE) can't send an Authorization header, so when auth is on
# the client passes the ID token as ?access_token=<jwt> on stream URLs. The token
# therefore appears in the SSE request URL (and possibly server access logs) — this
# is standard for browser SSE auth; the same short-lived Firebase ID token is used.
