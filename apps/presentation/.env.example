# --- Runtime (Bun server) ---
# GCP project the gateway runs in (also used for Vertex/Discovery API calls).
GOOGLE_CLOUD_PROJECT=my-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# OIDC-secured Cloud Run URL of the factory worker (required).
GE_AGENT_FACTORY_WORKER_URL="https://ge-agent-factory-worker-<hash>-<region>.a.run.app"

# IAP gate. When "true", the gateway verifies X-Goog-IAP-JWT-Assertion on every request
# (with an OIDC bearer fallback for service-account callers like tools/bulk-provision.js).
REQUIRE_IAP=false

# Audience for IAP JWT verification when REQUIRE_IAP=true. Format:
#   /projects/<PROJECT_NUMBER>/global/backendServices/<BACKEND_SERVICE_ID>
# (or the Cloud Run service path; see Google IAP docs).
IAP_EXPECTED_AUDIENCE=

# --- Per-agent cloud provisioning (the in-deck "Deploy This Agent" panel) ---
# DEFAULT-OFF. Disabled, the deck never provisions from the central worker into a
# target project (no shared/cross-project deploys); the panel shows an "Open in
# Cloud Shell" notice that installs the whole factory into the user's OWN project.
# Re-enable in a trusted env by setting BOTH (server gate + client UI):
GE_ENABLE_AGENT_PROVISION=false
VITE_ENABLE_AGENT_PROVISION=false

# --- Vite build-time defaults (baked into the SPA bundle) ---
VITE_DEFAULT_PROJECT_ID=
VITE_DEFAULT_REGION=us-central1
VITE_DEFAULT_GEMINI_LOCATION=global
VITE_DEFAULT_GEMINI_APP_ID=

# --- AI Studio specific (only used when hosted via AI Studio) ---
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# --- Optional: opt-in Firebase (Google) sign-in ---
# DEFAULT-OFF. Leave these unset for the central IAP deployment — the app then
# behaves exactly as today (no sign-in screen, no token required on /api/*).
#
# Server (Bun): enforcement turns ON only when GE_AUTH_MODE=firebase. When ON,
# every /api/* request must carry a valid Firebase ID token (Authorization:
# Bearer <token>, or ?access_token=<token> for the SSE stream); otherwise 401
# {"error":"unauthenticated"}. Static SPA assets are never gated. The project id
# used to verify the token's iss/aud comes from FIREBASE_PROJECT_ID, falling back
# to GOOGLE_CLOUD_PROJECT.
GE_AUTH_MODE=
FIREBASE_PROJECT_ID=
#
# Client (Vite, baked into the bundle): the sign-in gate turns ON only when
# VITE_AUTH_MODE=firebase AND VITE_FIREBASE_API_KEY is present.
VITE_AUTH_MODE=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
