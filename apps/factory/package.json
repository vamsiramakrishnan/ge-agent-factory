{
  "name": "@ge/factory",
  "version": "5.0",
  "description": "Portable AI Agent Demo Generator using BigQuery and Maps MCP",
  "type": "module",
  "bin": {
    "ge-harness": "./src/cli.js",
    "factory-data": "./scripts/generate-mock-data.mjs",
    "factory": "./scripts/factory.mjs",
    "ge-agent-factory-worker": "./scripts/factory-worker.mjs"
  },
  "scripts": {
    "ge": "node src/cli.js",
    "dev": "bun scripts/dev-bun.mjs",
    "dev:node": "node src/cli.js web --port 17655 --no-open",
    "dev:bun": "bun scripts/dev-bun.mjs",
    "reset": "node src/cli.js reset",
    "daemon": "node src/cli.js daemon --no-open",
    "web": "node src/cli.js web --port 17655 --no-open",
    "daemon:bun": "bun src/cli.js daemon --no-open",
    "web:bun": "bun src/cli.js web --port 17655 --no-open",
    "start": "node src/cli.js",
    "test": "GE_HARNESS_DATA_ROOT=../../.ge/test/factory node --test tests/*.test.js",
    "use-cases:sync": "node scripts/sync-use-cases-from-slides.mjs",
    "use-cases:sources": "node scripts/analyze-usecase-sources.mjs --slides ../presentation/src/components/slides/use-cases",
    "agents:batch": "node scripts/batch-generate-agents.mjs",
    "agents:setup": "UV_CACHE_DIR=../../.ge/cache/uv uvx google-agents-cli setup",
    "agents:info": "UV_CACHE_DIR=../../.ge/cache/uv uvx google-agents-cli info",
    "agents:scaffold:adk": "UV_CACHE_DIR=../../.ge/cache/uv uvx google-agents-cli scaffold create",
    "factory:worker": "node scripts/factory-worker.mjs",
    "register:gemini-enterprise": "bash scripts/register-gemini-enterprise-adk.sh",
    "push": "clasp push",
    "pull": "clasp pull",
    "open": "clasp open",
    "deploy": "clasp deploy"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@ge/okf": "workspace:*",
    "@ge/run-ledger": "workspace:*",
    "@ge/runtime": "workspace:*",
    "@ge/std": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "yaml": "^2.9.0"
  }
}
