        { "name": "pollutant", "type": "enum", "required": true, "values": ["co2", "ch4", "n2o", "nox", "sox", "voc", "pm25"], "weights": [30, 8, 5, 18, 8, 22, 9] },
        { "name": "ghg_scope", "type": "enum", "required": true, "values": ["scope_1", "scope_2", "scope_3"], "weights": [55, 30, 15] },
