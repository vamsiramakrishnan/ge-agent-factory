{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "verification_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "remaining_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "spec_to_code_fidelity": {
      "type": "string",
      "enum": [
        "pass",
        "partial",
        "fail"
      ]
    }
  },
  "required": [
    "changed_files",
    "summary",
    "verification_commands",
    "remaining_gaps",
    "spec_to_code_fidelity"
  ],
  "additionalProperties": {}
}
