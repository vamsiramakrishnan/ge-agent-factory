  "id": "bom-plm-erp-sync-monitor",
  "title": "BOM PLM-ERP Sync Monitor",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/bom-plm-erp-sync-monitor.json",
  "subtitle": "M-5502 • Engineering & PLM",
  "persona": "PLM Administrator",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-55",
  "systems": [
    "PTC Windchill PLM",
    "SAP S/4HANA PP",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "BOM discrepancies between PLM and ERP",
      "before": "260 active",
      "after": "15 active"
    },
    {
      "label": "Builds executed against stale BOMs",
      "before": "6 per quarter",
      "after": "0 per quarter"
    },
    {
      "label": "Discrepancy detection lag",
      "before": "3 weeks",
      "after": "1 day"
    }
  ],
  "statusQuo": [
    "Windchill and SAP BOMs drift apart through failed interface transfers and manual ERP edits that nobody reconciles.",
    "Discrepancies are found by periodic manual audits that sample a fraction of the part universe.",
    "A stale ERP BOM triggers wrong-part picks that surface as assembly-line stoppages weeks later."
  ],
  "agentification": [
    "Compares released PTC Windchill PLM structures against SAP S/4HANA PP production BOMs in BigQuery every night, item by item.",
    "Classifies each mismatch by cause — failed transfer, manual override, or pending change — and routes it to the right owner with fix instructions.",
    "Escalates discrepancies on parts with imminent planned orders so they are corrected before a build starts."
  ],
  "architecture": {
    "connections": [
      {
        "system": "PTC Windchill PLM",
        "description": "engineering change orders, bom revisions, cad document records records"
      },
      {
        "system": "SAP S/4HANA PP",
        "description": "process orders, work center confirmations, material stagings records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query engineering change orders and bom revisions from PTC Windchill PLM and correlate with SAP S/4HANA PP for the BOM PLM-ERP Sync Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the PLM Administrator's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the BOM PLM-ERP Sync Monitor Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in PTC Windchill PLM with a full audit trail, and escalate exceptions to the PLM Administrator."
      }
    ]
  },
