{
  "id": "reserve-adequacy-analyzer",
  "title": "Reserve Adequacy Analyzer",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/reserve-adequacy-analyzer.json",
  "subtitle": "I-3502 • Actuarial & Portfolio Risk",
  "persona": "Actuary",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-35",
  "systems": [
    "Guidewire ClaimCenter",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Quarterly reserve review preparation time",
      "before": "3 weeks",
      "after": "4 days"
    },
    {
      "label": "Segments with material adverse development",
      "before": "detected 2 quarters late",
      "after": "detected within 1 month"
    },
    {
      "label": "IBNR estimate range width",
      "before": "±12%",
      "after": "±6%"
    }
  ],
  "statusQuo": [
    "Actuaries spend the first two weeks of every quarter assembling and cleaning loss triangles before analysis can even start.",
    "Development anomalies hide inside aggregated triangles until they are large enough to move the whole segment.",
    "Case reserve philosophy shifts in claims go unnoticed by actuarial until they distort paid-to-incurred ratios."
  ],
  "agentification": [
    "Builds clean, reconciled loss triangles from ClaimCenter transactional data in BigQuery continuously rather than quarterly.",
    "Runs multiple development methods per segment, detects diagnostics drifting outside expected ranges, and flags case-reserving pattern shifts.",
    "Drafts the quarterly reserve review deck with segment-level commentary and highlights the exhibits that most need actuarial judgment."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire ClaimCenter",
        "description": "claims, claim exposures, reserve lines records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query claims and claim exposures from Guidewire ClaimCenter for the Reserve Adequacy Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Actuary's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Reserve Adequacy Analyzer Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the draft step in Guidewire ClaimCenter with a full audit trail, and escalate exceptions to the Actuary."
      }
    ]
  },
