{
  "id": "returns-abuse-analyzer",
  "title": "Returns Abuse Analyzer",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/returns-abuse-analyzer.json",
  "subtitle": "R-1405 • E-Commerce & Digital",
  "persona": "Fraud Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-14",
  "systems": [
    "Salesforce Commerce Cloud",
    "Zendesk",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Return fraud loss",
      "before": "1.9% of online sales",
      "after": "0.7% of online sales"
    },
    {
      "label": "False-positive rate on return blocks",
      "before": "18%",
      "after": "3%"
    },
    {
      "label": "Wardrobing/bracketing detection lead time",
      "before": "90 days",
      "after": "real time"
    }
  ],
  "statusQuo": [
    "Return decisions are made per transaction with no view of the customer's cross-channel history.",
    "Serial wardrobers and empty-box claimants are identified quarterly, after losses accumulate.",
    "Blanket tightening of the return policy punishes loyal customers along with abusers."
  ],
  "agentification": [
    "Builds a cross-channel return-behavior graph per customer spanning web orders, store returns, and care tickets.",
    "Scores each return claim in real time and routes only high-risk claims to manual review with evidence.",
    "Recommends tiered policy actions — from receipt checks to account flags — and drafts case files for the Fraud Analyst."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Commerce Cloud",
        "description": "online orders, product catalog entries, cart events records"
      },
      {
        "system": "Zendesk",
        "description": "tickets, macros, satisfaction scores records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query online orders and product catalog entries from Salesforce Commerce Cloud and correlate with Zendesk for the Returns Abuse Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Fraud Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Returns Abuse Analyzer Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in Salesforce Commerce Cloud with a full audit trail, and escalate exceptions to the Fraud Analyst."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Returns Abuse Analyzer so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
