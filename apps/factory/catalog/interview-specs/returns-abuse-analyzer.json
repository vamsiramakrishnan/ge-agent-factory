        "id": "returns-abuse-analyzer-baseline-gap",
        "description": "Seed a realistic gap where Return fraud loss sits between 1.9% of online sales and 0.7% of online sales, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "online_orders",
          "product_catalog_entries"
        ],
        "discoveryPath": [
          "Inspect Salesforce Commerce Cloud records for the affected entities",
          "Compare against Zendesk historical baseline",
          "Generate a citation-backed recommendation"
        ],
        "expectedEvidence": [
          "source-system record",
          "historical baseline metric",
          "generated audit trail"
        ],
        "expectedRecommendation": "Explain the gap, cite supporting evidence, and propose the next Fraud Analyst action."
