  "kpis": [
    {
      "label": "On-time production launches",
      "before": "58%",
      "after": "88%"
    },
    {
      "label": "Readiness status compilation effort",
      "before": "2 days per gate",
      "after": "0 (continuous)"
    },
    {
      "label": "Deliverables discovered missing at gate review",
      "before": "14 per launch",
      "after": "2 per launch"
    }
  ],
  "statusQuo": [
    "Launch readiness is tracked in a 400-row spreadsheet that is out of date the day after each program review.",
    "Missing PPAP documents, unreleased drawings, and open tooling tasks surface at the gate review instead of weeks before.",
    "The program manager spends two days per gate chasing status from twelve functions by email."
  ],
  "agentification": [
    "Continuously reconciles gate deliverables against actual state — released drawings and documents in PTC Windchill PLM, task completion in Jira, and tooling and qualification records in BigQuery.",
    "Predicts gate readiness from current burn-down trends and flags deliverables that will miss the date while there is still time to recover.",
    "Generates the gate review readiness pack automatically and escalates critical-path blockers to the accountable function lead."
  ],
  "architecture": {
    "connections": [
      {
        "system": "PTC Windchill PLM",
        "description": "engineering change orders, bom revisions, cad document records records"
      },
      {
        "system": "Jira",
        "description": "issues, sprints, epics records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query engineering change orders and bom revisions from PTC Windchill PLM and correlate with Jira for the NPI Launch Readiness Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the NPI Program Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the NPI Launch Readiness Orchestrator Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in PTC Windchill PLM with a full audit trail, and escalate exceptions to the NPI Program Manager."
      }
    ]
  },
