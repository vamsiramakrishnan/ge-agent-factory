{
  "id": "supplier-quality-scorecard-engine",
  "title": "Supplier Quality Scorecard Engine",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/supplier-quality-scorecard-engine.json",
  "subtitle": "M-5203 • Quality Management",
  "persona": "Supplier Quality Engineer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-52",
  "systems": [
    "SAP S/4HANA QM",
    "SAP S/4HANA MM",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Incoming inspection PPM",
      "before": "4,200",
      "after": "1,600"
    },
    {
      "label": "Scorecard preparation effort per quarter",
      "before": "3 weeks",
      "after": "2 hours"
    },
    {
      "label": "Suppliers on data-backed improvement plans",
      "before": "5",
      "after": "24"
    }
  ],
  "statusQuo": [
    "Quarterly supplier scorecards are assembled by hand from SAP QM inspection lots and MM receipts, and half the quarter is over before they ship.",
    "PPM, on-time delivery, and 8D responsiveness live in different reports, so no one sees a supplier's full risk picture.",
    "Supplier review meetings run on anecdotes because the data is six weeks stale."
  ],
  "agentification": [
    "Refreshes supplier PPM, lot rejection rate, deviation history, and 8D closure speed weekly from SAP QM and SAP S/4HANA MM data in BigQuery.",
    "Generates a ranked risk scorecard per supplier and drafts the quarterly business review pack automatically.",
    "Recommends which suppliers need a formal improvement plan and publishes trend dashboards to Looker for the sourcing team."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA QM",
        "description": "inspection lots, nonconformance records, capa actions records"
      },
      {
        "system": "SAP S/4HANA MM",
        "description": "purchase orders, material movements, vendors records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query inspection lots and nonconformance records from SAP S/4HANA QM and correlate with SAP S/4HANA MM for the Supplier Quality Scorecard Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Supplier Quality Engineer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Supplier Quality Scorecard Engine Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in SAP S/4HANA QM with a full audit trail, and escalate exceptions to the Supplier Quality Engineer."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Supplier Quality Scorecard Engine so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
