{
  "id": "carrier-delivery-sla-analyzer",
  "title": "Carrier Delivery SLA Analyzer",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/carrier-delivery-sla-analyzer.json",
  "subtitle": "R-1205 • Supply Chain & Fulfillment",
  "persona": "Transportation Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-12",
  "systems": [
    "Manhattan Active WM",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "On-time delivery rate",
      "before": "89%",
      "after": "97%"
    },
    {
      "label": "Carrier claim recovery cycle",
      "before": "45 days",
      "after": "7 days"
    },
    {
      "label": "Cost per package variance vs. contract",
      "before": "+6.5%",
      "after": "+0.9%"
    }
  ],
  "statusQuo": [
    "Carrier scorecards are built monthly from CSV invoice dumps and are stale on arrival.",
    "Invoice overcharges against contracted rates are spot-checked on a 2% sample.",
    "Lane-level performance problems persist for quarters because no one connects tracking data to tenders."
  ],
  "agentification": [
    "Audits every carrier invoice against contract rate cards and delivery scans in BigQuery.",
    "Drafts dispute claims for late deliveries and overbilling with shipment-level evidence attached.",
    "Recommends lane reassignments to the Transportation Manager when a carrier trends below SLA."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Manhattan Active WM",
        "description": "warehouse orders, pick tasks, inventory snapshots records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query warehouse orders and pick tasks from Manhattan Active WM for the Carrier Delivery SLA Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Transportation Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Carrier Delivery SLA Analyzer Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in Manhattan Active WM with a full audit trail, and escalate exceptions to the Transportation Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Carrier Delivery SLA Analyzer so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
