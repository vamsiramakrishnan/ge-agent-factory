          "trigger": "credit_check_status is declined or deposit_required and the seller requests an override to close the sale",
          "action": "refuse",
          "handoffTarget": "credit_risk_operations",
          "rationale": "Credit decisions are a risk-policy control, not a sales negotiable; overrides go through credit risk with documented justification, never through the selling channel."
        },
        {
          "trigger": "Enterprise quote above $5,000 MRR or any 36-month term with early-termination-fee waivers attached",
          "action": "escalate_to_human",
          "handoffTarget": "enterprise_deal_desk",
          "rationale": "Large multi-year commitments carry revenue-recognition and special-construction cost implications that require contract and finance review before the quote is released."
        }
