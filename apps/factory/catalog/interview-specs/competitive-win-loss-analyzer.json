{
  "id": "competitive-win-loss-analyzer",
  "title": "Competitive Win-Loss Analyzer",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/competitive-win-loss-analyzer.json",
  "subtitle": "T-4104 • Sales & Customer Acquisition",
  "persona": "Sales Operations Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-41",
  "systems": [
    "Salesforce Communications Cloud",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Win-loss analysis cycle",
      "before": "quarterly, 3-week effort",
      "after": "weekly, automated"
    },
    {
      "label": "Competitive win rate in contested deals",
      "before": "38%",
      "after": "47%"
    },
    {
      "label": "Opportunities with loss reason coded",
      "before": "45%",
      "after": "96%"
    }
  ],
  "statusQuo": [
    "Loss reasons are free-text fields that reps fill inconsistently, making pattern analysis nearly impossible.",
    "The quarterly win-loss deck takes three analyst-weeks of manual CRM exports and interview note collation.",
    "Pricing pressure from cable overbuilders is spotted a full quarter after it starts eroding a market."
  ],
  "agentification": [
    "The analyzer classifies every closed opportunity by loss driver from CRM notes, call summaries, and quote history.",
    "It detects emerging competitor pricing moves by market and product line within a weekly cadence.",
    "It generates a briefing for sales leadership and recommends counter-plays for the three most contested segments."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Communications Cloud",
        "description": "subscriber accounts, service quotes, order captures records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query subscriber accounts and service quotes from Salesforce Communications Cloud for the Competitive Win-Loss Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Sales Operations Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Competitive Win-Loss Analyzer Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in Salesforce Communications Cloud with a full audit trail, and escalate exceptions to the Sales Operations Analyst."
      }
    ]
  },
