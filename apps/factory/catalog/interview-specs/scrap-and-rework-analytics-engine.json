{
  "id": "scrap-and-rework-analytics-engine",
  "title": "Scrap and Rework Analytics Engine",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/scrap-and-rework-analytics-engine.json",
  "subtitle": "M-5105 • Production & Shop Floor",
  "persona": "Plant Controller",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-51",
  "systems": [
    "Siemens Opcenter MES",
    "SAP S/4HANA PP",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Scrap rate",
      "before": "3.8%",
      "after": "2.1%"
    },
    {
      "label": "Monthly scrap cost",
      "before": "$290K",
      "after": "$155K"
    },
    {
      "label": "Scrap variance investigation cycle",
      "before": "10 days",
      "after": "1 day"
    }
  ],
  "statusQuo": [
    "Scrap is booked in SAP at month-end as a lump cost variance with no link back to the machine, shift, or lot that produced it.",
    "The controller chases production leads by email for scrap explanations, and answers arrive after the close.",
    "Rework loops are invisible because reworked units re-enter the line under the same order number."
  ],
  "agentification": [
    "Joins MES defect confirmations with SAP S/4HANA PP order costs in BigQuery nightly to attribute scrap dollars to machine, shift, material lot, and operator.",
    "Detects scrap spikes against a rolling baseline and drafts a variance explanation with the top contributing factors.",
    "Publishes a daily scrap cost dashboard in Looker and escalates any single-day spike above threshold to the plant controller and production supervisor."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Siemens Opcenter MES",
        "description": "production orders, machine events, quality checks records"
      },
      {
        "system": "SAP S/4HANA PP",
        "description": "process orders, work center confirmations, material stagings records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query production orders and machine events from Siemens Opcenter MES and correlate with SAP S/4HANA PP for the Scrap and Rework Analytics Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Plant Controller's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Scrap and Rework Analytics Engine Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Siemens Opcenter MES with a full audit trail, and escalate exceptions to the Plant Controller."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Scrap and Rework Analytics Engine so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
