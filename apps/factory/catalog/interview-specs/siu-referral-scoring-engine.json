{
  "id": "siu-referral-scoring-engine",
  "title": "SIU Referral Scoring Engine",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/siu-referral-scoring-engine.json",
  "subtitle": "I-3601 • Fraud, SIU & Compliance",
  "persona": "SIU Investigator",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-36",
  "systems": [
    "FRISS Fraud Detection",
    "Guidewire ClaimCenter",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "SIU referral precision (referrals confirmed)",
      "before": "24%",
      "after": "61%"
    },
    {
      "label": "Fraud detected before payment",
      "before": "31%",
      "after": "74%"
    },
    {
      "label": "Investigator hours per cleared referral",
      "before": "14",
      "after": "6"
    }
  ],
  "statusQuo": [
    "Referrals depend on adjuster intuition, so the SIU queue mixes solid cases with hunches that consume investigator weeks.",
    "Fraud indicators buried in claim notes and documents are never systematically compared across the book.",
    "Most fraud is detected after indemnity payments have already gone out the door."
  ],
  "agentification": [
    "Rescored every open claim on each new document or transaction, combining FRISS indicators with text signals mined from ClaimCenter notes.",
    "Routes high-score claims to SIU with an evidence dossier summarizing the specific red flags and their sources.",
    "Recommends payment holds on claims crossing the fraud threshold and notifies the assigned adjuster with the rationale."
  ],
  "architecture": {
    "connections": [
      {
        "system": "FRISS Fraud Detection",
        "description": "fraud screening scores, network link indicators, siu referrals records"
      },
      {
        "system": "Guidewire ClaimCenter",
        "description": "claims, claim exposures, reserve lines records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query fraud screening scores and network link indicators from FRISS Fraud Detection and correlate with Guidewire ClaimCenter for the SIU Referral Scoring Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the SIU Investigator's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the SIU Referral Scoring Engine Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in FRISS Fraud Detection with a full audit trail, and escalate exceptions to the SIU Investigator."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
