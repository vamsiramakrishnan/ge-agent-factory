{
  "id": "regulatory-emissions-reporting-agent",
  "title": "Regulatory Emissions Reporting Agent",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/regulatory-emissions-reporting-agent.json",
  "subtitle": "M-5604 • EHS & Sustainability",
  "persona": "Environmental Compliance Specialist",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-56",
  "systems": [
    "Sphera EHS",
    "OSIsoft PI System",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Emissions report preparation time",
      "before": "3 weeks per cycle",
      "after": "2 days per cycle"
    },
    {
      "label": "Permit exceedances caught before violation",
      "before": "50%",
      "after": "96%"
    },
    {
      "label": "Reporting data corrections after submission",
      "before": "8 per year",
      "after": "1 per year"
    }
  ],
  "statusQuo": [
    "Quarterly emissions reports are compiled by hand from CEMS exports, fuel logs, and production records across a dozen spreadsheets.",
    "A permit limit exceedance is often discovered during report preparation, weeks after it happened.",
    "Each report cycle rediscovers the same data gaps and unit-conversion errors under deadline pressure."
  ],
  "agentification": [
    "Aggregates continuous emissions data from the PI System with fuel and production records in BigQuery, validated daily against permit limits in Sphera EHS.",
    "Notifies the compliance specialist immediately when any rolling-average parameter trends toward a permit threshold.",
    "Drafts the complete regulatory submission with calculation lineage attached, ready for review and sign-off."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Sphera EHS",
        "description": "safety incidents, permit records, emissions readings records"
      },
      {
        "system": "OSIsoft PI System",
        "description": "sensor readings, asset tag hierarchies, downtime events records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query safety incidents and permit records from Sphera EHS and correlate with OSIsoft PI System for the Regulatory Emissions Reporting Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Environmental Compliance Specialist's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Regulatory Emissions Reporting Agent Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the draft step in Sphera EHS with a full audit trail, and escalate exceptions to the Environmental Compliance Specialist."
      }
    ]
  },
