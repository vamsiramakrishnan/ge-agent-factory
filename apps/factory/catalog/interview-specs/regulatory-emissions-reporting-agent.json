        "id": "regulatory-emissions-reporting-agent-baseline-gap",
        "description": "Seed a realistic gap where Emissions report preparation time sits between 3 weeks per cycle and 2 days per cycle, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "safety_incidents",
          "permit_records"
        ],
        "discoveryPath": [
          "Inspect Sphera EHS records for the affected entities",
          "Compare against OSIsoft PI System historical baseline",
          "Generate a citation-backed recommendation"
        ],
        "expectedEvidence": [
          "source-system record",
          "historical baseline metric",
          "generated audit trail"
        ],
        "expectedRecommendation": "Explain the gap, cite supporting evidence, and propose the next Environmental Compliance Specialist action."
      }
