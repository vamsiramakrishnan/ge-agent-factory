{
  "id": "dispatch-optimization-orchestrator",
  "title": "Dispatch Optimization Orchestrator",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/dispatch-optimization-orchestrator.json",
  "subtitle": "T-4601 • Field Service & Infrastructure",
  "persona": "Field Operations Supervisor",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-46",
  "systems": [
    "Oracle Field Service",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Jobs completed per technician per day",
      "before": "4.2",
      "after": "6.1"
    },
    {
      "label": "Appointment window compliance",
      "before": "76%",
      "after": "94%"
    },
    {
      "label": "Drive time share of workday",
      "before": "31%",
      "after": "18%"
    }
  ],
  "statusQuo": [
    "Dispatchers hand-shuffle the day's route board every morning and again after every cancellation or overrun.",
    "Skill and equipment mismatches send DSL-certified techs to fiber jobs they cannot complete.",
    "Emergency tickets bump scheduled installs arbitrarily, cascading missed appointments across the rest of the day."
  ],
  "agentification": [
    "The orchestrator builds optimized daily routes balancing skills, parts inventory, SLA clocks, and traffic, and re-optimizes continuously as the day unfolds.",
    "It absorbs emergency work by recommending the insertion that minimizes total appointment breakage.",
    "It notifies customers with live technician ETAs and automatically rebooks any job that can no longer be met within its window."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Field Service",
        "description": "field work orders, technician schedules, service appointments records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query field work orders and technician schedules from Oracle Field Service for the Dispatch Optimization Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Field Operations Supervisor's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Dispatch Optimization Orchestrator Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in Oracle Field Service with a full audit trail, and escalate exceptions to the Field Operations Supervisor."
      }
    ]
  },
