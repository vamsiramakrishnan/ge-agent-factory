{
  "id": "loyalty-churn-prediction-agent",
  "title": "Loyalty Churn Prediction Agent",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/loyalty-churn-prediction-agent.json",
  "subtitle": "R-1501 • Customer & Loyalty",
  "persona": "Loyalty Program Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-15",
  "systems": [
    "Salesforce Commerce Cloud",
    "Salesforce Marketing Cloud",
    "Segment",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "12-month member retention",
      "before": "58%",
      "after": "73%"
    },
    {
      "label": "At-risk members identified before lapse",
      "before": "12%",
      "after": "78%"
    },
    {
      "label": "Win-back campaign ROI",
      "before": "1.4x",
      "after": "4.2x"
    }
  ],
  "statusQuo": [
    "Churn is defined as 12 months of silence, so intervention starts a year too late.",
    "Save offers go to a static 'lapsed' segment refreshed monthly by an analyst.",
    "High-value members quietly defect to competitors with no early-warning signal."
  ],
  "agentification": [
    "Scores every member weekly on lapse risk from purchase cadence decay, engagement, and browse signals.",
    "Recommends the retention treatment per member — points bonus, category offer, or concierge outreach — by predicted incrementality.",
    "Creates triggered save journeys in Marketing Cloud and reports saved-revenue attribution to the Loyalty Program Manager."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Commerce Cloud",
        "description": "online orders, product catalog entries, cart events records"
      },
      {
        "system": "Salesforce Marketing Cloud",
        "description": "accounts, opportunities, campaign influence records"
      },
      {
        "system": "Segment",
        "description": "segment records, segment events, segment audit trail records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query online orders and product catalog entries from Salesforce Commerce Cloud and correlate with Salesforce Marketing Cloud for the Loyalty Churn Prediction Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Loyalty Program Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Loyalty Churn Prediction Agent Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in Salesforce Commerce Cloud with a full audit trail, and escalate exceptions to the Loyalty Program Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Loyalty Churn Prediction Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
