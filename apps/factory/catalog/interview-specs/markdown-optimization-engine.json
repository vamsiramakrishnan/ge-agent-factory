{
  "id": "markdown-optimization-engine",
  "title": "Markdown Optimization Engine",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/markdown-optimization-engine.json",
  "subtitle": "R-1601 • Pricing & Promotions",
  "persona": "Pricing Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-16",
  "systems": [
    "Revionics Price Optimization",
    "Oracle Retail MFCS",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Season-end sell-through",
      "before": "78%",
      "after": "94%"
    },
    {
      "label": "Markdown spend as % of sales",
      "before": "9.1%",
      "after": "6.2%"
    },
    {
      "label": "Clearance cadence planning time",
      "before": "2 days/week",
      "after": "2 hours/week"
    }
  ],
  "statusQuo": [
    "Markdowns follow a fixed 25/50/75 cadence applied chain-wide regardless of local sell-through.",
    "Analysts rebuild clearance ladders in spreadsheets every Friday from stale inventory extracts.",
    "Aged inventory is discovered when the warehouse flags space, deep into its value decay."
  ],
  "agentification": [
    "Models price elasticity per item-location and simulates markdown ladders against sell-through targets.",
    "Recommends localized markdown depth and timing into Revionics with projected margin recovery per decision.",
    "Escalates aging inventory pockets to the Pricing Analyst before they breach the clearance-exit date."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Revionics Price Optimization",
        "description": "price recommendations, price zones, elasticity models records"
      },
      {
        "system": "Oracle Retail MFCS",
        "description": "item master, merchandise hierarchy, cost changes records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query price recommendations and price zones from Revionics Price Optimization and correlate with Oracle Retail MFCS for the Markdown Optimization Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Pricing Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Markdown Optimization Engine Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Revionics Price Optimization with a full audit trail, and escalate exceptions to the Pricing Analyst."
      }
    ]
  },
