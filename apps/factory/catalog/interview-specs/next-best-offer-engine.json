{
  "id": "next-best-offer-engine",
  "title": "Next Best Offer Engine",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/next-best-offer-engine.json",
  "subtitle": "R-1502 • Customer & Loyalty",
  "persona": "CRM Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-15",
  "systems": [
    "Oracle Xstore POS",
    "Salesforce Marketing Cloud",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Offer redemption rate",
      "before": "3.2%",
      "after": "12.5%"
    },
    {
      "label": "Incremental revenue per contacted member",
      "before": "$1.80",
      "after": "$6.40"
    },
    {
      "label": "Campaign audience build time",
      "before": "3 days",
      "after": "minutes"
    }
  ],
  "statusQuo": [
    "Everyone in a segment gets the same monthly coupon regardless of what they actually buy.",
    "In-store purchase history and online behavior sit in separate systems and are never joined for targeting.",
    "Offer fatigue grows as members receive irrelevant categories week after week."
  ],
  "agentification": [
    "Unifies POS and digital signals in BigQuery to model each member's category propensities and price sensitivity.",
    "Selects the next best offer per member per channel under budget and margin guardrails.",
    "Publishes decisioned audiences to Marketing Cloud daily and retires offers that underperform their holdout."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Xstore POS",
        "description": "pos transactions, tender records, store shift summaries records"
      },
      {
        "system": "Salesforce Marketing Cloud",
        "description": "accounts, opportunities, campaign influence records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query pos transactions and tender records from Oracle Xstore POS and correlate with Salesforce Marketing Cloud for the Next Best Offer Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the CRM Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Next Best Offer Engine Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Oracle Xstore POS with a full audit trail, and escalate exceptions to the CRM Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Next Best Offer Engine so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
