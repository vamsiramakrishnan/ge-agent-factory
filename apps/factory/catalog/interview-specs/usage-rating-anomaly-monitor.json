{
  "id": "usage-rating-anomaly-monitor",
  "title": "Usage Rating Anomaly Monitor",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/usage-rating-anomaly-monitor.json",
  "subtitle": "T-4405 • Billing & Revenue Assurance",
  "persona": "Revenue Assurance Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-44",
  "systems": [
    "Amdocs CES Billing",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Rating error detection time",
      "before": "post-invoice, 30+ days",
      "after": "same day"
    },
    {
      "label": "Invoice rebill rate",
      "before": "3.2% of invoices",
      "after": "0.6% of invoices"
    },
    {
      "label": "Suspense/unrated record backlog",
      "before": "4.5M records",
      "after": "under 200K records"
    }
  ],
  "statusQuo": [
    "Rating misconfigurations after catalog changes are caught by angry customers reading their invoices, not by internal controls.",
    "Millions of CDRs sit in rating suspense queues that analysts drain by hand with one-off SQL fixes.",
    "A single bad tariff push once double-rated a full day of data traffic and forced a mass rebill and press cycle."
  ],
  "agentification": [
    "The monitor baselines rated revenue per product, plan, and event type daily and flags statistical deviations within hours of a catalog change.",
    "It classifies suspense records by failure cause and auto-reprocesses those matching known correction patterns.",
    "It alerts billing operations before invoice generation when an anomaly would affect a bill run, and recommends holding the impacted cycle."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Amdocs CES Billing",
        "description": "billing accounts, usage records, rated events records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query billing accounts and usage records from Amdocs CES Billing for the Usage Rating Anomaly Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Revenue Assurance Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Usage Rating Anomaly Monitor Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in Amdocs CES Billing with a full audit trail, and escalate exceptions to the Revenue Assurance Analyst."
      }
    ]
  },
