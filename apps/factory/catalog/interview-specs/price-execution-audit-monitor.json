{
  "id": "price-execution-audit-monitor",
  "title": "Price Execution Audit Monitor",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/price-execution-audit-monitor.json",
  "subtitle": "R-1604 • Pricing & Promotions",
  "persona": "Pricing Operations Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-16",
  "systems": [
    "Revionics Price Optimization",
    "Oracle Xstore POS",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Shelf-to-POS price match rate",
      "before": "94.1%",
      "after": "99.6%"
    },
    {
      "label": "Scan-error margin leakage",
      "before": "$4.2M/yr",
      "after": "$0.6M/yr"
    },
    {
      "label": "Time to detect a mis-scanned price",
      "before": "2 weeks",
      "after": "2 hours"
    }
  ],
  "statusQuo": [
    "Price audits are quarterly store walks with a scan gun on a 200-item sample.",
    "Expired promo prices keep ringing for days after events end, silently eroding margin.",
    "Customers discover mismatches at the register, forcing overrides and eroding trust."
  ],
  "agentification": [
    "Reconciles every POS transaction price against the Revionics price of record in near real time.",
    "Detects stale promo prices, missed activations, and unit-of-measure errors by store and item.",
    "Creates fix-it tasks for store teams and escalates systemic feed failures to the Pricing Operations Manager."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Revionics Price Optimization",
        "description": "price recommendations, price zones, elasticity models records"
      },
      {
        "system": "Oracle Xstore POS",
        "description": "pos transactions, tender records, store shift summaries records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query price recommendations and price zones from Revionics Price Optimization and correlate with Oracle Xstore POS for the Price Execution Audit Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Pricing Operations Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Price Execution Audit Monitor Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Revionics Price Optimization with a full audit trail, and escalate exceptions to the Pricing Operations Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Price Execution Audit Monitor so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
