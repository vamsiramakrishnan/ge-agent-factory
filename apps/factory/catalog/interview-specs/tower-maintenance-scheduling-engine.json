  "kpis": [
    {
      "label": "Preventive maintenance compliance",
      "before": "71%",
      "after": "97%"
    },
    {
      "label": "Unplanned tower site visits",
      "before": "480/quarter",
      "after": "170/quarter"
    },
    {
      "label": "Battery/generator failure incidents during outages",
      "before": "26/year",
      "after": "5/year"
    }
  ],
  "statusQuo": [
    "Preventive maintenance schedules live in an annual spreadsheet that ignores site alarm history and climb-crew availability.",
    "Crews visit the same remote tower three times in a month for separate work orders that could have been bundled.",
    "Backup batteries and generators fail during storm outages because degradation trends were never reviewed."
  ],
  "agentification": [
    "The engine builds risk-ranked maintenance schedules from equipment age, alarm trends, environmental telemetry, and storm-season timing.",
    "It bundles compatible work orders per site visit and matches them to certified climb crews and required equipment.",
    "It flags degrading power systems from telemetry trends and creates priority work orders before failure, notifying the planner of sites at highest storm risk."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Field Service",
        "description": "field work orders, technician schedules, service appointments records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Splunk",
        "description": "log events, search jobs, alert actions records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query field work orders and technician schedules from Oracle Field Service and correlate with Splunk for the Tower Maintenance Scheduling Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Infrastructure Maintenance Planner's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Tower Maintenance Scheduling Engine Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the notify step in Oracle Field Service with a full audit trail, and escalate exceptions to the Infrastructure Maintenance Planner."
      }
    ]
  },
