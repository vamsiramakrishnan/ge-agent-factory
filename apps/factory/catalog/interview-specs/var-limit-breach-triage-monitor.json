        {
          "name": "query_murex_mx_3_trades",
          "kind": "query",
          "sourceSystemId": "murex_mx_3",
          "description": "Retrieve trades from Murex MX.3 for the VaR Limit Breach Triage Monitor workflow.",
          "requiredInputs": [
