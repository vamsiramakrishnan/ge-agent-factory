  "kpis": [
    {
      "label": "Time from breach to explained root cause",
      "before": "6 hours",
      "after": "30 minutes"
    },
    {
      "label": "Limit excesses aged past policy deadline",
      "before": "12/quarter",
      "after": "1/quarter"
    },
    {
      "label": "Analyst hours on breach paperwork",
      "before": "25 hrs/week",
      "after": "5 hrs/week"
    }
  ],
  "statusQuo": [
    "When a desk breaches a VaR or sensitivity limit, analysts manually decompose the risk run to find which trades and factors drove it.",
    "Breach memos, desk-head acknowledgments, and remediation tracking are handled over email with no consistent audit trail.",
    "Stale limit excesses linger past the policy escalation deadline, drawing internal-audit findings every year."
  ],
  "agentification": [
    "Decomposes each Murex MX.3 limit breach to the contributing trades, risk factors, and market moves within minutes of the risk run.",
    "Drafts the breach notification memo with root-cause analysis and routes acknowledgment tasks through ServiceNow.",
    "Escalates unresolved excesses automatically up the delegation chain when policy deadlines approach."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Murex MX.3",
        "description": "trades, positions, risk measures records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query trades and positions from Murex MX.3 and correlate with ServiceNow for the VaR Limit Breach Triage Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Market Risk Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the VaR Limit Breach Triage Monitor Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Murex MX.3 with a full audit trail, and escalate exceptions to the Market Risk Analyst."
      }
    ]
  },
