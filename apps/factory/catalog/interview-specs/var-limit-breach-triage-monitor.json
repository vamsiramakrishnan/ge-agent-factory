  "title": "VaR Limit Breach Triage Monitor",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/var-limit-breach-triage-monitor.json",
  "subtitle": "B-2602 • Treasury & Market Risk",
  "persona": "Market Risk Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-26",
