{
  "id": "on-shelf-availability-monitor",
  "title": "On-Shelf Availability Monitor",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/on-shelf-availability-monitor.json",
  "subtitle": "R-1303 • Store Operations",
  "persona": "Store Operations Director",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-13",
  "systems": [
    "Oracle Xstore POS",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "On-shelf availability",
      "before": "91%",
      "after": "97.5%"
    },
    {
      "label": "Phantom-inventory positions detected/week",
      "before": "0 (untracked)",
      "after": "4,800"
    },
    {
      "label": "Recovered sales from OSA fixes",
      "before": "$0 baseline",
      "after": "$2.6M/qtr"
    }
  ],
  "statusQuo": [
    "Out-of-stocks are found by shoppers and associates walking aisles, not by any system.",
    "Phantom inventory shows on-hand in the system while the shelf sits empty for weeks.",
    "Zone managers print gap-scan lists that are outdated before the shift ends."
  ],
  "agentification": [
    "Detects zero-sales anomalies against expected sell rates to infer empty shelves despite positive on-hand.",
    "Creates prioritized shelf-recovery and cycle-count tasks on store devices, sequenced by lost-sales value.",
    "Publishes a chain OSA scorecard to Looker and escalates stores trending below threshold to the Store Operations Director."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Xstore POS",
        "description": "pos transactions, tender records, store shift summaries records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query pos transactions and tender records from Oracle Xstore POS for the On-Shelf Availability Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Store Operations Director's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the On-Shelf Availability Monitor Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Oracle Xstore POS with a full audit trail, and escalate exceptions to the Store Operations Director."
      }
    ]
  },
