{
  "id": "member-winback-orchestrator",
  "title": "Lapsed Member Win-Back Orchestrator",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/member-winback-orchestrator.json",
  "subtitle": "R-1505 • Customer & Loyalty",
  "persona": "Retention Marketing Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-15",
  "systems": [
    "Oracle Xstore POS",
    "Salesforce Marketing Cloud",
    "Segment",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Lapsed-member reactivation rate",
      "before": "2.8%",
      "after": "9.6%"
    },
    {
      "label": "Cost per reactivation",
      "before": "$31",
      "after": "$9"
    },
    {
      "label": "Second-purchase rate post win-back",
      "before": "19%",
      "after": "41%"
    }
  ],
  "statusQuo": [
    "One generic 'we miss you' blast goes to the entire lapsed file twice a year.",
    "No distinction is made between members who moved, switched channels, or churned on price.",
    "Reactivated members get no follow-up journey and immediately lapse again."
  ],
  "agentification": [
    "Segments lapsed members by inferred lapse reason using last-purchase context, store proximity, and browse signals.",
    "Generates tailored win-back journeys per segment and tests offer depth against predicted reactivation value.",
    "Creates a post-reactivation nurture sequence and reports cohort payback to the Retention Marketing Manager."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Xstore POS",
        "description": "pos transactions, tender records, store shift summaries records"
      },
      {
        "system": "Salesforce Marketing Cloud",
        "description": "accounts, opportunities, campaign influence records"
      },
      {
        "system": "Segment",
        "description": "segment records, segment events, segment audit trail records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query pos transactions and tender records from Oracle Xstore POS and correlate with Salesforce Marketing Cloud for the Lapsed Member Win-Back Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Retention Marketing Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Lapsed Member Win-Back Orchestrator Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the generate step in Oracle Xstore POS with a full audit trail, and escalate exceptions to the Retention Marketing Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Lapsed Member Win-Back Orchestrator so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
