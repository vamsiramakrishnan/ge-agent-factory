{
  "id": "shrink-anomaly-analyzer",
  "title": "Shrink Anomaly Analyzer",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/shrink-anomaly-analyzer.json",
  "subtitle": "R-1301 • Store Operations",
  "persona": "Loss Prevention Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-13",
  "systems": [
    "Oracle Xstore POS",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Shrink rate",
      "before": "2.3% of sales",
      "after": "1.4% of sales"
    },
    {
      "label": "Time to flag suspicious register activity",
      "before": "3 weeks",
      "after": "same day"
    },
    {
      "label": "LP investigation hit rate",
      "before": "22%",
      "after": "61%"
    }
  ],
  "statusQuo": [
    "LP analysts run canned exception reports and manually cross-reference refunds, voids, and discounts per cashier.",
    "Sweethearting and refund fraud patterns emerge only at cycle-count time, months after the loss.",
    "Field LP visits are scheduled by rotation, not by risk, so high-shrink stores go unvisited."
  ],
  "agentification": [
    "Scores every transaction stream nightly for void, refund, no-sale, and discount anomalies at cashier and store level.",
    "Builds ranked case files linking POS events, timeclock data, and inventory adjustments for each anomaly cluster.",
    "Routes high-confidence cases to the Loss Prevention Manager and prioritizes store visits by predicted shrink risk."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Xstore POS",
        "description": "pos transactions, tender records, store shift summaries records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query pos transactions and tender records from Oracle Xstore POS for the Shrink Anomaly Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Loss Prevention Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Shrink Anomaly Analyzer Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in Oracle Xstore POS with a full audit trail, and escalate exceptions to the Loss Prevention Manager."
      }
    ]
  },
