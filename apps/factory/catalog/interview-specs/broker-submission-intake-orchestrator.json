  "kpis": [
    {
      "label": "Submission data entry time",
      "before": "45 min per submission",
      "after": "4 min per submission"
    },
    {
      "label": "Missing-information follow-up cycles",
      "before": "2.7 per submission",
      "after": "0.8 per submission"
    },
    {
      "label": "Intake data accuracy",
      "before": "91%",
      "after": "99.2%"
    }
  ],
  "statusQuo": [
    "Underwriting assistants rekey ACORD applications, loss runs, and schedules of values into Duck Creek by hand.",
    "Incomplete submissions bounce back and forth with brokers over email for days before anyone notices a missing signature.",
    "Loss runs arrive in dozens of carrier-specific formats that each require manual interpretation."
  ],
  "agentification": [
    "Parses ACORD forms, loss runs, and SOV spreadsheets and creates structured submission records in Duck Creek Policy automatically.",
    "Detects missing or inconsistent fields and generates a single consolidated information request to the broker, including a DocuSign envelope for unsigned forms.",
    "Publishes a clean submission dataset to BigQuery so intake quality and broker responsiveness can be tracked over time."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Duck Creek Policy",
        "description": "policy forms, rating worksheets, endorsement records records"
      },
      {
        "system": "DocuSign",
        "description": "envelopes, recipients, audit trails records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query policy forms and rating worksheets from Duck Creek Policy and correlate with DocuSign for the Broker Submission Intake Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Underwriting Assistant's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Broker Submission Intake Orchestrator Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Duck Creek Policy with a full audit trail, and escalate exceptions to the Underwriting Assistant."
      }
    ]
  },
