    {
      "label": "Leakage rate on audited book",
      "before": "3.9% of written premium",
      "after": "1.2% of written premium"
    },
    {
      "label": "Audit hit rate (audits finding material misstatement)",
      "before": "18%",
      "after": "57%"
    },
    {
      "label": "Additional premium recovered annually",
      "before": "$5.5M",
      "after": "$16.2M"
    }
  ],
  "statusQuo": [
    "Premium audits are scheduled by policy size and rotation, not by likelihood of misreported payroll, mileage, or class codes.",
    "Auditors discover undisclosed business operations only if the insured volunteers them during a site visit.",
    "Unrated exposure — extra drivers, new locations, higher payrolls — accrues all term and is often never recovered."
  ],
  "agentification": [
    "Cross-references declared exposures against LexisNexis business intelligence, public filings, and telematics-derived signals in BigQuery.",
    "Scores every policy for leakage probability and expected recovery, and recommends which audits to prioritize each month.",
    "Drafts pre-audit findings summaries for auditors and publishes recovered-premium tracking in Looker."
  ],
  "architecture": {
    "connections": [
      {
        "system": "LexisNexis Risk Solutions",
        "description": "risk reports, mvr records, prefill datasets records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query risk reports and mvr records from LexisNexis Risk Solutions for the Premium Leakage Detection Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Premium Audit Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Premium Leakage Detection Analyzer Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in LexisNexis Risk Solutions with a full audit trail, and escalate exceptions to the Premium Audit Manager."
      }
    ]
  },
