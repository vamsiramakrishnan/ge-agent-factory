  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/work-order-backlog-triage-orchestrator.json",
  "subtitle": "M-5304 • Maintenance & Reliability",
  "persona": "Maintenance Supervisor",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-53",
  "systems": [
    "IBM Maximo",
    "ServiceNow",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Maintenance backlog",
      "before": "11 crew-weeks",
      "after": "4 crew-weeks"
    },
    {
      "label": "Schedule compliance",
      "before": "61%",
      "after": "85%"
    },
    {
      "label": "Weekly planning meeting duration",
      "before": "3 hours",
      "after": "45 minutes"
    }
  ],
  "statusQuo": [
    "The backlog holds 800 open work orders and the supervisor triages them by scrolling and instinct every Monday.",
    "Duplicate requests for the same failing asset are dispatched to different technicians on different days.",
    "High-criticality safety work sits behind cosmetic requests because every ticket enters the queue at the same priority."
  ],
  "agentification": [
    "Scores the entire IBM Maximo backlog weekly on asset criticality, safety impact, age, and parts availability from BigQuery.",
    "Merges duplicate requests, bundles work orders on the same asset into single visits, and drafts the weekly schedule proposal.",
    "Escalates safety-critical orders aging past threshold to the supervisor through ServiceNow and tracks them to closure."
  ],
  "architecture": {
    "connections": [
      {
        "system": "IBM Maximo",
        "description": "maintenance work orders, asset registry entries, failure codes records"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query maintenance work orders and asset registry entries from IBM Maximo and correlate with ServiceNow for the Work Order Backlog Triage Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Maintenance Supervisor's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Work Order Backlog Triage Orchestrator Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in IBM Maximo with a full audit trail, and escalate exceptions to the Maintenance Supervisor."
      }
    ]
  },
