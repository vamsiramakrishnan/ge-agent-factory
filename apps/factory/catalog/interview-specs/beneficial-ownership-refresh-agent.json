  "id": "beneficial-ownership-refresh-agent",
  "title": "Beneficial Ownership Refresh Agent",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/beneficial-ownership-refresh-agent.json",
  "subtitle": "B-2401 • KYC, AML & Compliance",
  "persona": "KYC Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-24",
