  "kpis": [
    {
      "label": "Ownership refreshes completed on schedule",
      "before": "64%",
      "after": "97%"
    },
    {
      "label": "Average refresh cycle time",
      "before": "21 days",
      "after": "4 days"
    },
    {
      "label": "Customer outreach touches per refresh",
      "before": "4.5",
      "after": "1.3"
    }
  ],
  "statusQuo": [
    "Analysts manually re-collect ownership structures for thousands of entity customers on rolling refresh cycles tracked in Fenergo work queues.",
    "Corporate registry lookups, document requests, and 25%-threshold calculations are repeated from scratch even when nothing has changed.",
    "Refresh backlogs push high-risk entities past their due dates, a finding repeated in the last two regulatory exams."
  ],
  "agentification": [
    "Pre-screens each due refresh by comparing Fenergo records against corporate registries and flags entities with actual ownership changes.",
    "Drafts targeted outreach requesting only the changed documents and routes certification forms through DocuSign.",
    "Recalculates beneficial-ownership percentages, updates the Fenergo profile for analyst approval, and escalates newly identified high-risk owners."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Fenergo CLM",
        "description": "kyc cases, entity profiles, screening results records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "DocuSign",
        "description": "envelopes, recipients, audit trails records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query kyc cases and entity profiles from Fenergo CLM and correlate with DocuSign for the Beneficial Ownership Refresh Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the KYC Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Beneficial Ownership Refresh Agent Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in Fenergo CLM with a full audit trail, and escalate exceptions to the KYC Analyst."
      }
    ]
  },
