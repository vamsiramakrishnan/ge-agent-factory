{
  "id": "card-dispute-chargeback-orchestrator",
  "title": "Card Dispute Chargeback Orchestrator",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/card-dispute-chargeback-orchestrator.json",
  "subtitle": "B-2303 • Payments & Fraud",
  "persona": "Dispute Resolution Specialist",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-23",
  "systems": [
    "FIS Payments Hub",
    "BigQuery",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Chargeback win rate",
      "before": "48%",
      "after": "71%"
    },
    {
      "label": "Network deadline misses",
      "before": "8%",
      "after": "0.5%"
    },
    {
      "label": "Cost per dispute processed",
      "before": "$32",
      "after": "$9"
    }
  ],
  "statusQuo": [
    "Specialists manually classify each dispute into network reason codes and assemble evidence packets transaction by transaction.",
    "Visa and Mastercard representment deadlines are tracked in a shared calendar, and misses mean automatic write-offs.",
    "Provisional credit decisions are inconsistent because Reg E and Reg Z timelines are computed by hand for every case."
  ],
  "agentification": [
    "Classifies incoming disputes to the correct network reason code and computes Reg E/Reg Z provisional-credit deadlines automatically.",
    "Generates the representment evidence packet from FIS Payments Hub transaction data, merchant records, and customer history.",
    "Tracks every network deadline, escalates cases at risk of expiry, and creates ServiceNow follow-ups for merchant responses."
  ],
  "architecture": {
    "connections": [
      {
        "system": "FIS Payments Hub",
        "description": "payment instructions, clearing batches, settlement records records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query payment instructions and clearing batches from FIS Payments Hub and correlate with ServiceNow for the Card Dispute Chargeback Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Dispute Resolution Specialist's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Card Dispute Chargeback Orchestrator Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in FIS Payments Hub with a full audit trail, and escalate exceptions to the Dispute Resolution Specialist."
      }
    ]
  },
