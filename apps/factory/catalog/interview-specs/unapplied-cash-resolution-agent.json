  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-33",
  "systems": [
    "Guidewire BillingCenter",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Unapplied cash balance",
      "before": "$4.7M average",
      "after": "$0.6M average"
    },
    {
      "label": "Auto-match rate on lockbox receipts",
      "before": "71%",
      "after": "96%"
    },
    {
      "label": "Aged suspense items over 30 days",
      "before": "1,900",
      "after": "150"
    }
  ],
  "statusQuo": [
    "Lockbox payments with mistyped policy numbers or agency bulk remittances land in suspense and wait for manual research.",
    "Specialists match payments by searching BillingCenter one candidate account at a time.",
    "Suspense balances trigger erroneous dunning notices to customers who already paid."
  ],
  "agentification": [
    "Matches suspense payments to open receivables using fuzzy matching across payer name, amount, bank data, and agency remittance files in BigQuery.",
    "Applies high-confidence matches automatically and queues ambiguous ones with ranked candidates for one-click specialist review.",
    "Suppresses dunning on accounts with pending matched payments and notifies the specialist of any item aging past 15 days."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire BillingCenter",
        "description": "billing accounts, premium invoices, payment plans records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query billing accounts and premium invoices from Guidewire BillingCenter for the Unapplied Cash Resolution Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Cash Applications Specialist's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Unapplied Cash Resolution Agent Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in Guidewire BillingCenter with a full audit trail, and escalate exceptions to the Cash Applications Specialist."
      }
    ]
  },
