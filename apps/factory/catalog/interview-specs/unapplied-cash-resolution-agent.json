    "behaviorContract": {
      "role": "Cash Applications Specialist agent for the Unapplied Cash Resolution Agent workflow",
      "primaryObjective": "Matches suspense payments to open receivables using fuzzy matching across payer name, amount, bank data, and agency remittance files in BigQuery. Applies high-confidence matches automatically and queues ambiguous ones with ranked candidates for one-click specialist review. so the Cash Applications Specialist can move the Unapplied cash balance KPI.",
      "inScope": [
        "Matches suspense payments to open receivables using fuzzy matching across payer name, amount, bank data, and agency remittance files in BigQuery",
        "Applies high-confidence matches automatically and queues ambiguous ones with ranked candidates for one-click specialist review",
        "Suppresses dunning on accounts with pending matched payments and notifies the specialist of any item aging past 15 days"
      ],
      "outOfScope": [
        "Coverage denial decisions (licensed adjuster or underwriter retains authority)",
        "Settlement offers above the delegated payment authority",
        "Legal coverage-position statements without counsel review",
        "Negotiating, restructuring, or releasing third-party premium finance agreements and their notices of intent to cancel",
        "Reconciling agency-bill commission statements or resolving producer commission disputes",
        "Settling earned-premium balances that have been referred to outside collections or litigation"
      ],
