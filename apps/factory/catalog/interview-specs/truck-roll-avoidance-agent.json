  "kpis": [
    {
      "label": "Truck rolls avoided",
      "before": "0/month baseline",
      "after": "5,800/month"
    },
    {
      "label": "No-fault-found dispatch rate",
      "before": "27%",
      "after": "9%"
    },
    {
      "label": "Cost per resolved trouble ticket",
      "before": "$142",
      "after": "$61"
    }
  ],
  "statusQuo": [
    "More than a quarter of dispatched technicians find nothing wrong on site because remote diagnostics were never run.",
    "CPE reboots, provisioning refreshes, and line resets that would fix the issue remotely are skipped under call-time pressure.",
    "Every avoidable roll costs a hundred-plus dollars and blocks a slot a genuinely broken customer needed."
  ],
  "agentification": [
    "The agent runs a full remote diagnostic battery on the line, CPE, and provisioning state before any dispatch is booked.",
    "It executes safe remote remediations like ONT resets, profile re-pushes, and firmware updates, and verifies service restoration with the customer.",
    "It attaches complete diagnostic results to unavoidable dispatches and recommends the parts the technician should carry."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Field Service",
        "description": "field work orders, technician schedules, service appointments records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Zendesk",
        "description": "tickets, macros, satisfaction scores records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query field work orders and technician schedules from Oracle Field Service and correlate with Zendesk for the Truck Roll Avoidance Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Field Operations Supervisor's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Truck Roll Avoidance Agent Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in Oracle Field Service with a full audit trail, and escalate exceptions to the Field Operations Supervisor."
      }
    ]
  },
