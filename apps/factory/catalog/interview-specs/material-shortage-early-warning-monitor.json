  "id": "material-shortage-early-warning-monitor",
  "title": "Material Shortage Early Warning Monitor",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/material-shortage-early-warning-monitor.json",
  "subtitle": "M-5401 • Supply Chain & Materials",
  "persona": "Supply Planner",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-54",
  "systems": [
    "Kinaxis RapidResponse",
    "SAP S/4HANA MM",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Line stoppages from material shortages",
      "before": "7 per month",
      "after": "1 per month"
    },
    {
      "label": "Shortage detection horizon",
      "before": "2 days",
      "after": "15 days"
    },
    {
      "label": "Premium freight spend",
      "before": "$95K/month",
      "after": "$30K/month"
    }
  ],
  "statusQuo": [
    "Shortages surface when a picker reports an empty bin, hours before the line needs the part.",
    "The planner manually walks MRP exception messages in SAP every morning and triages a few hundred by instinct.",
    "Supplier delay notifications arrive by email and rarely make it into the plan before the impact hits."
  ],
  "agentification": [
    "Projects material coverage daily by netting Kinaxis RapidResponse supply plans against SAP S/4HANA MM inventory, open POs, and confirmed supplier dates in BigQuery.",
    "Ranks emerging shortages by production impact and identifies which specific orders and lines each one will stop.",
    "Notifies the supply planner with a resolution option per shortage — expedite, substitute, or reschedule — and drafts the expedite request when chosen."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Kinaxis RapidResponse",
        "description": "supply plans, demand signals, scenario runs records"
      },
      {
        "system": "SAP S/4HANA MM",
        "description": "purchase orders, material movements, vendors records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query supply plans and demand signals from Kinaxis RapidResponse and correlate with SAP S/4HANA MM for the Material Shortage Early Warning Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Supply Planner's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Material Shortage Early Warning Monitor Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the draft step in Kinaxis RapidResponse with a full audit trail, and escalate exceptions to the Supply Planner."
      }
    ]
  },
