{
  "id": "advisory-fee-billing-anomaly-analyzer",
  "title": "Advisory Fee Billing Anomaly Analyzer",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/advisory-fee-billing-anomaly-analyzer.json",
  "subtitle": "B-2505 • Wealth & Advisory",
  "persona": "Advisory Operations Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-25",
  "systems": [
    "Salesforce Financial Services Cloud",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Fee errors caught before client billing",
      "before": "35%",
      "after": "96%"
    },
    {
      "label": "Client fee reimbursements per year",
      "before": "$380K",
      "after": "$45K"
    },
    {
      "label": "Quarterly billing audit cycle time",
      "before": "3 weeks",
      "after": "2 days"
    }
  ],
  "statusQuo": [
    "Quarterly fee runs are spot-checked on a small sample, so breakpoint misses and wrong household groupings reach client statements.",
    "Fee schedule exceptions negotiated by advisors live in emails and are applied inconsistently at billing time.",
    "Every SEC exam requests fee-billing accuracy evidence that takes the operations team weeks to assemble."
  ],
  "agentification": [
    "Recomputes every account's expected fee from the contracted schedule, householding rules, and billable-asset data in BigQuery.",
    "Flags discrepancies against the actual fee run with a root-cause classification before invoices are released.",
    "Generates the quarterly billing-accuracy attestation package and publishes exception trends to Looker for compliance."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Financial Services Cloud",
        "description": "client households, financial accounts, advisory referrals records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query client households and financial accounts from Salesforce Financial Services Cloud for the Advisory Fee Billing Anomaly Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Advisory Operations Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Advisory Fee Billing Anomaly Analyzer Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Salesforce Financial Services Cloud with a full audit trail, and escalate exceptions to the Advisory Operations Manager."
      }
    ]
  },
