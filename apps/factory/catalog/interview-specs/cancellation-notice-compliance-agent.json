{
  "id": "cancellation-notice-compliance-agent",
  "title": "Cancellation Notice Compliance Agent",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/cancellation-notice-compliance-agent.json",
  "subtitle": "I-3303 • Billing & Payments",
  "persona": "Billing Supervisor",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-33",
  "systems": [
    "Guidewire BillingCenter",
    "DocuSign",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Statutorily defective cancellation notices",
      "before": "3.2%",
      "after": "0.1%"
    },
    {
      "label": "Reinstatement disputes from notice errors",
      "before": "45 per quarter",
      "after": "4 per quarter"
    },
    {
      "label": "Notice preparation time",
      "before": "25 min per notice",
      "after": "fully automated"
    }
  ],
  "statusQuo": [
    "Cancellation notice timing and wording requirements differ across 50 states, and staff work from a wiki that lags regulatory changes.",
    "A notice sent one day short of the statutory period forces the carrier to keep covering a non-paying insured.",
    "Proof-of-mailing records are stored in three places, making defense of a disputed cancellation a scavenger hunt."
  ],
  "agentification": [
    "Validates every pending cancellation against the current state-specific notice period, format, and lienholder-copy requirements before release.",
    "Generates the compliant notice, dispatches it with tracked delivery, and files proof-of-mailing evidence against the policy record.",
    "Blocks and escalates any cancellation whose notice window or content would be defective, with the specific statute cited."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire BillingCenter",
        "description": "billing accounts, premium invoices, payment plans records"
      },
      {
        "system": "DocuSign",
        "description": "envelopes, recipients, audit trails records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query billing accounts and premium invoices from Guidewire BillingCenter and correlate with DocuSign for the Cancellation Notice Compliance Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Billing Supervisor's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Cancellation Notice Compliance Agent Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in Guidewire BillingCenter with a full audit trail, and escalate exceptions to the Billing Supervisor."
      }
    ]
  },
