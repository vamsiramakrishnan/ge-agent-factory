{
  "id": "suitability-drift-review-monitor",
  "title": "Suitability Drift Review Monitor",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/suitability-drift-review-monitor.json",
  "subtitle": "B-2502 • Wealth & Advisory",
  "persona": "Wealth Compliance Officer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-25",
  "systems": [
    "Salesforce Financial Services Cloud",
    "BigQuery",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Accounts screened for suitability monthly",
      "before": "5% sample",
      "after": "100%"
    },
    {
      "label": "Time to detect a suitability mismatch",
      "before": "9 months",
      "after": "5 days"
    },
    {
      "label": "Supervisory review hours per month",
      "before": "200 hrs",
      "after": "60 hrs"
    }
  ],
  "statusQuo": [
    "Suitability surveillance is a quarterly manual sample, so most accounts are never checked between onboarding and a complaint.",
    "Risk-tolerance profiles in Salesforce go stale for years while portfolio risk drifts with markets and trading activity.",
    "Compliance discovers concentration and risk mismatches only when FINRA inquiries or customer complaints arrive."
  ],
  "agentification": [
    "Scores every account monthly for drift between documented risk tolerance, investment objectives, and actual portfolio composition.",
    "Creates ServiceNow review cases for material mismatches with the evidence and the applicable suitability rule cited.",
    "Drafts client re-profiling outreach for advisors when tolerance documentation is stale or contradicted by stated objectives."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Financial Services Cloud",
        "description": "client households, financial accounts, advisory referrals records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query client households and financial accounts from Salesforce Financial Services Cloud and correlate with ServiceNow for the Suitability Drift Review Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Wealth Compliance Officer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Suitability Drift Review Monitor Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the draft step in Salesforce Financial Services Cloud with a full audit trail, and escalate exceptions to the Wealth Compliance Officer."
      }
    ]
  },
