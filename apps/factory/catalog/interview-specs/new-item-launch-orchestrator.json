{
  "id": "new-item-launch-orchestrator",
  "title": "New Item Launch Orchestrator",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/new-item-launch-orchestrator.json",
  "subtitle": "R-1104 • Merchandising & Assortment",
  "persona": "Category Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-11",
  "systems": [
    "Oracle Retail MFCS",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Item setup cycle time",
      "before": "12 days",
      "after": "36 hours"
    },
    {
      "label": "Launch-week on-shelf availability",
      "before": "77%",
      "after": "96%"
    },
    {
      "label": "Item data error rate at setup",
      "before": "9%",
      "after": "0.8%"
    }
  ],
  "statusQuo": [
    "New-item forms bounce between vendor, merchandising, and data teams over email for two weeks.",
    "Attribute gaps and wrong cost/retail entries are caught only when stores can't scan the item.",
    "No one tracks whether first allocation actually landed before the ad breaks."
  ],
  "agentification": [
    "Validates vendor-submitted item attributes, costs, and hierarchy placement before MFCS entry.",
    "Orchestrates setup, first allocation, and price activation as a tracked launch runbook with owners and SLAs.",
    "Escalates blocked steps and publishes a launch-readiness scorecard to Looker for every new item."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Retail MFCS",
        "description": "item master, merchandise hierarchy, cost changes records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query item master and merchandise hierarchy from Oracle Retail MFCS for the New Item Launch Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Category Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the New Item Launch Orchestrator Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Oracle Retail MFCS with a full audit trail, and escalate exceptions to the Category Manager."
      }
    ]
  },
