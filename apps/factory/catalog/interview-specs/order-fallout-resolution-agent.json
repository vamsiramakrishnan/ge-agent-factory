{
  "id": "order-fallout-resolution-agent",
  "title": "Order Fallout Resolution Agent",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/order-fallout-resolution-agent.json",
  "subtitle": "T-4201 • Order Management & Provisioning",
  "persona": "Order Management Specialist",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-42",
  "systems": [
    "Netcracker Service Orchestration",
    "BigQuery",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Order fallout rate",
      "before": "14%",
      "after": "4%"
    },
    {
      "label": "Mean time to resolve fallout",
      "before": "2.3 days",
      "after": "3 hours"
    },
    {
      "label": "Manual fallout tickets per month",
      "before": "8,500",
      "after": "1,700"
    }
  ],
  "statusQuo": [
    "Failed orders pile up in a fallout queue where specialists triage them one by one across four different swivel-chair systems.",
    "The same address-mismatch and inventory-conflict errors recur daily because nobody has bandwidth to fix root causes.",
    "Customers learn their install date slipped only when they call in, days after the order actually stalled."
  ],
  "agentification": [
    "The agent classifies each fallout by error signature and auto-remediates known patterns like address normalization and port conflicts.",
    "It replays corrected orders through the orchestration flow and verifies downstream activation completes.",
    "It escalates unrecognized failure patterns to the fallout team with a full diagnostic trail and suggested fix."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Netcracker Service Orchestration",
        "description": "service orders, provisioning tasks, network inventory items records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query service orders and provisioning tasks from Netcracker Service Orchestration and correlate with ServiceNow for the Order Fallout Resolution Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Order Management Specialist's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Order Fallout Resolution Agent Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Netcracker Service Orchestration with a full audit trail, and escalate exceptions to the Order Management Specialist."
      }
    ]
  },
