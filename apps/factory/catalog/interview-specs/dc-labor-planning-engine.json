{
  "id": "dc-labor-planning-engine",
  "title": "DC Labor Planning Engine",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/dc-labor-planning-engine.json",
  "subtitle": "R-1202 • Supply Chain & Fulfillment",
  "persona": "DC Operations Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-12",
  "systems": [
    "Manhattan Active WM",
    "UKG Dimensions",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Units per labor hour",
      "before": "112",
      "after": "141"
    },
    {
      "label": "Overtime spend",
      "before": "11% of payroll",
      "after": "4% of payroll"
    },
    {
      "label": "Shift plan build time",
      "before": "5 hours/day",
      "after": "20 minutes/day"
    }
  ],
  "statusQuo": [
    "Shift supervisors size tomorrow's waves from yesterday's volumes in a whiteboard-and-spreadsheet ritual.",
    "Inbound surges force same-day scramble calls for temps at premium rates.",
    "Labor standards in Manhattan and schedules in UKG are reconciled manually and disagree constantly."
  ],
  "agentification": [
    "Forecasts wave-level volume by function from Manhattan order pipelines and inbound ASNs.",
    "Generates department-level shift plans in UKG Dimensions matched to forecast workload and labor standards.",
    "Notifies the DC Operations Manager of projected capacity gaps 72 hours out with flex-labor options."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Manhattan Active WM",
        "description": "warehouse orders, pick tasks, inventory snapshots records"
      },
      {
        "system": "UKG Dimensions",
        "description": "shift schedules, timecards, labor forecasts records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query warehouse orders and pick tasks from Manhattan Active WM and correlate with UKG Dimensions for the DC Labor Planning Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the DC Operations Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the DC Labor Planning Engine Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the generate step in Manhattan Active WM with a full audit trail, and escalate exceptions to the DC Operations Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for DC Labor Planning Engine so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
