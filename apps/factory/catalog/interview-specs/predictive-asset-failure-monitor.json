{
  "id": "predictive-asset-failure-monitor",
  "title": "Predictive Asset Failure Monitor",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/predictive-asset-failure-monitor.json",
  "subtitle": "M-5301 • Maintenance & Reliability",
  "persona": "Reliability Engineer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-53",
  "systems": [
    "OSIsoft PI System",
    "IBM Maximo",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Unplanned downtime hours",
      "before": "540 hrs/yr",
      "after": "210 hrs/yr"
    },
    {
      "label": "Failures predicted before functional loss",
      "before": "12%",
      "after": "68%"
    },
    {
      "label": "Emergency work orders",
      "before": "31% of total",
      "after": "11% of total"
    }
  ],
  "statusQuo": [
    "Vibration and temperature trends sit in the PI historian, but nobody looks at them until a bearing has already seized.",
    "Condition monitoring rounds happen monthly on a clipboard, so a fault that develops in week one runs three more weeks.",
    "The same pump fails the same way every year and the pattern lives only in one technician's memory."
  ],
  "agentification": [
    "Continuously scores critical-asset sensor streams from the PI System in BigQuery against learned degradation signatures.",
    "Raises an early-warning alert with estimated remaining useful life when an asset's signature departs from its healthy baseline.",
    "Creates a prioritized condition-based work order in IBM Maximo with the suspect component, evidence trends, and recommended repair window."
  ],
  "architecture": {
    "connections": [
      {
        "system": "OSIsoft PI System",
        "description": "sensor readings, asset tag hierarchies, downtime events records"
      },
      {
        "system": "IBM Maximo",
        "description": "maintenance work orders, asset registry entries, failure codes records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query sensor readings and asset tag hierarchies from OSIsoft PI System and correlate with IBM Maximo for the Predictive Asset Failure Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Reliability Engineer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Predictive Asset Failure Monitor Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in OSIsoft PI System with a full audit trail, and escalate exceptions to the Reliability Engineer."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Predictive Asset Failure Monitor so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
