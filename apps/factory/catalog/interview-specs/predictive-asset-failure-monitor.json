          "sensor_readings",
          "asset_tag_hierarchies"
        ],
        "discoveryPath": [
          "Inspect OSIsoft PI System records for the affected entities",
          "Compare against IBM Maximo historical baseline",
          "Generate a citation-backed recommendation"
        ],
        "expectedEvidence": [
          "source-system record",
          "historical baseline metric",
          "generated audit trail"
        ],
        "expectedRecommendation": "Explain the gap, cite supporting evidence, and propose the next Reliability Engineer action."
      }
