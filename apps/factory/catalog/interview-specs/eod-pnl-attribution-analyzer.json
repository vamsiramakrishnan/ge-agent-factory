{
  "id": "eod-pnl-attribution-analyzer",
  "title": "End-of-Day P&L Attribution Analyzer",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/eod-pnl-attribution-analyzer.json",
  "subtitle": "B-2603 • Treasury & Market Risk",
  "persona": "Product Control Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-26",
  "systems": [
    "Murex MX.3",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Unexplained P&L above threshold",
      "before": "15 desks/day",
      "after": "2 desks/day"
    },
    {
      "label": "T+1 P&L sign-off completion by 10am",
      "before": "60%",
      "after": "98%"
    },
    {
      "label": "Time to investigate a P&L break",
      "before": "3 hours",
      "after": "25 minutes"
    }
  ],
  "statusQuo": [
    "Product controllers manually reconcile flash P&L against the Murex end-of-day run, chasing breaks across trades, market data, and new deals.",
    "Explaining daily P&L into risk-based buckets is a spreadsheet exercise that regularly slips past the sign-off deadline.",
    "Recurring breaks from the same booking-model issues are rediscovered from scratch every time they appear."
  ],
  "agentification": [
    "Runs risk-based P&L attribution per desk each night, decomposing moves into market factors, new trades, and amendments from Murex MX.3 data.",
    "Matches residual breaks against a learned library of historical break patterns and drafts the likely explanation for controller review.",
    "Publishes the attribution pack to Looker by 7am and escalates desks with unexplained P&L above threshold."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Murex MX.3",
        "description": "trades, positions, risk measures records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query trades and positions from Murex MX.3 for the End-of-Day P&L Attribution Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Product Control Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the End-of-Day P&L Attribution Analyzer Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Murex MX.3 with a full audit trail, and escalate exceptions to the Product Control Analyst."
      }
    ]
  },
