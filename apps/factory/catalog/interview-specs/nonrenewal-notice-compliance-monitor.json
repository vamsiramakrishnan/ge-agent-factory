{
  "id": "nonrenewal-notice-compliance-monitor",
  "title": "Non-Renewal Notice Compliance Monitor",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/nonrenewal-notice-compliance-monitor.json",
  "subtitle": "I-3403 • Policy Servicing",
  "persona": "Compliance Officer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-34",
  "systems": [
    "Guidewire PolicyCenter",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Non-renewals with defective notice",
      "before": "2.6%",
      "after": "0.05%"
    },
    {
      "label": "Forced renewals from missed notice deadlines",
      "before": "$1.9M premium annually",
      "after": "$0.1M premium annually"
    },
    {
      "label": "Regulator complaints on non-renewal handling",
      "before": "28 per year",
      "after": "5 per year"
    }
  ],
  "statusQuo": [
    "Notice deadlines ranging from 30 to 120 days by state and line are tracked in a spreadsheet updated by hand.",
    "A missed deadline legally obligates the carrier to renew a risk underwriting wanted off the books.",
    "Reason-for-non-renewal wording that is lawful in one state draws a market conduct inquiry in another."
  ],
  "agentification": [
    "Audits every planned non-renewal daily against state-specific deadline, delivery-method, and permissible-reason rules.",
    "Alerts the servicing team weeks ahead of each notice deadline and drafts compliant notice language with the correct statutory citations.",
    "Publishes a compliance exception report to BigQuery and escalates any at-risk deadline to the compliance officer immediately."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire PolicyCenter",
        "description": "policies, policy quotes, underwriting submissions records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query policies and policy quotes from Guidewire PolicyCenter for the Non-Renewal Notice Compliance Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Compliance Officer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Non-Renewal Notice Compliance Monitor Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Guidewire PolicyCenter with a full audit trail, and escalate exceptions to the Compliance Officer."
      }
    ]
  },
