  "id": "cell-congestion-forecasting-engine",
  "title": "Cell Congestion Forecasting Engine",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/cell-congestion-forecasting-engine.json",
  "subtitle": "T-4302 • Network Operations & Assurance",
  "persona": "Capacity Planner",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-43",
  "systems": [
    "Ericsson Network Manager",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Congested-cell detection lead time",
      "before": "after customer complaints",
      "after": "8 weeks ahead"
    },
    {
      "label": "Capacity augment cycle time",
      "before": "9 months",
      "after": "4 months"
    },
    {
      "label": "PRB utilization above 85% threshold",
      "before": "11% of cells",
      "after": "3% of cells"
    }
  ],
  "statusQuo": [
    "Capacity planners review utilization reports monthly, so a cell can run hot for weeks before anyone notices.",
    "Sector-level growth forecasting is a spreadsheet extrapolation that misses event-driven and seasonal traffic shifts.",
    "Augment budgets are allocated to whoever complains loudest rather than to the cells with the worst subscriber impact."
  ],
  "agentification": [
    "The engine forecasts per-sector PRB and throughput demand weekly, blending trend, seasonality, and local event calendars.",
    "It ranks the augment backlog by predicted subscriber-experience impact and revenue at risk.",
    "It recommends the cheapest sufficient remedy per cell, from parameter rebalancing to carrier adds to new site builds, and publishes the plan to the capacity board."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Ericsson Network Manager",
        "description": "network alarms, cell sites, performance counters records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query network alarms and cell sites from Ericsson Network Manager for the Cell Congestion Forecasting Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Capacity Planner's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Cell Congestion Forecasting Engine Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Ericsson Network Manager with a full audit trail, and escalate exceptions to the Capacity Planner."
      }
    ]
  },
