{
  "id": "spc-drift-detection-monitor",
  "title": "SPC Drift Detection Monitor",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/spc-drift-detection-monitor.json",
  "subtitle": "M-5201 • Quality Management",
  "persona": "Quality Engineer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-52",
  "systems": [
    "SAP S/4HANA QM",
    "Siemens Opcenter MES",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "First-pass yield",
      "before": "91.2%",
      "after": "96.5%"
    },
    {
      "label": "Out-of-control conditions caught before defects ship",
      "before": "55%",
      "after": "94%"
    },
    {
      "label": "Manual control chart reviews per week",
      "before": "120",
      "after": "8"
    }
  ],
  "statusQuo": [
    "Quality engineers eyeball dozens of control charts once a day, so a process that drifts at 2 a.m. runs out of spec for hours.",
    "Western Electric rule violations are detected inconsistently because each engineer applies the rules by memory.",
    "By the time an inspection lot fails in SAP QM, an entire batch has already been produced against a drifting process."
  ],
  "agentification": [
    "Streams inspection results from SAP QM and in-line measurements from MES into BigQuery and evaluates every point against SPC run rules in near real time.",
    "Distinguishes true process drift from measurement noise using historical process capability baselines per characteristic.",
    "Notifies the quality engineer and line lead the moment a drift signature emerges and recommends whether to hold the affected lots."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA QM",
        "description": "inspection lots, nonconformance records, capa actions records"
      },
      {
        "system": "Siemens Opcenter MES",
        "description": "production orders, machine events, quality checks records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query inspection lots and nonconformance records from SAP S/4HANA QM and correlate with Siemens Opcenter MES for the SPC Drift Detection Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Quality Engineer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the SPC Drift Detection Monitor Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in SAP S/4HANA QM with a full audit trail, and escalate exceptions to the Quality Engineer."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for SPC Drift Detection Monitor so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
