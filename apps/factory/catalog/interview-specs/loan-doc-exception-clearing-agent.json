{
  "id": "loan-doc-exception-clearing-agent",
  "title": "Loan Documentation Exception Clearing Agent",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/loan-doc-exception-clearing-agent.json",
  "subtitle": "B-2203 • Lending & Credit",
  "persona": "Loan Operations Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-22",
  "systems": [
    "nCino Loan Origination",
    "BigQuery",
    "DocuSign",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Open documentation exceptions",
      "before": "2,400",
      "after": "350"
    },
    {
      "label": "Average exception age",
      "before": "94 days",
      "after": "12 days"
    },
    {
      "label": "Exam findings on collateral perfection",
      "before": "7 per exam",
      "after": "0-1 per exam"
    }
  ],
  "statusQuo": [
    "The exception report from nCino runs to thousands of lines and is reviewed line by line in a monthly meeting.",
    "Chasing missing UCC filings, insurance certificates, and signed amendments means swivel-chairing between nCino, email, and county filing sites.",
    "Regulators cite the aged-exception backlog every exam cycle, and collateral perfection gaps surface only when a loan defaults."
  ],
  "agentification": [
    "Classifies every new nCino exception by risk severity and cure path the moment it is created.",
    "Drafts borrower and insurer request letters, routes signature items through DocuSign, and opens ServiceNow tasks for internal cure steps.",
    "Notifies the loan operations manager weekly with an aging waterfall and escalates exceptions on classified credits immediately."
  ],
  "architecture": {
    "connections": [
      {
        "system": "nCino Loan Origination",
        "description": "loan applications, credit memos, covenant records records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "DocuSign",
        "description": "envelopes, recipients, audit trails records"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query loan applications and credit memos from nCino Loan Origination and correlate with DocuSign for the Loan Documentation Exception Clearing Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Loan Operations Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Loan Documentation Exception Clearing Agent Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in nCino Loan Origination with a full audit trail, and escalate exceptions to the Loan Operations Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Loan Documentation Exception Clearing Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
