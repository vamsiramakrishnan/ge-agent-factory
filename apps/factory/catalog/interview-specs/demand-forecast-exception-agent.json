  "department": "retail",
  "sourcePath": "catalog/interview-specs/demand-forecast-exception-agent.json",
  "subtitle": "R-1201 • Supply Chain & Fulfillment",
  "persona": "Demand Planner",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-12",
  "systems": [
    "Blue Yonder Demand Planning",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Forecast accuracy (WMAPE)",
      "before": "68%",
      "after": "86%"
    },
    {
      "label": "Planner time on manual overrides",
      "before": "60% of week",
      "after": "15% of week"
    },
    {
      "label": "Forecast exceptions resolved per day",
      "before": "40",
      "after": "300"
    }
  ],
  "statusQuo": [
    "Planners eyeball thousands of item-location forecast exceptions in Blue Yonder queues each Monday.",
    "Override decisions rely on gut feel because weather, promo, and social signals live in separate tools.",
    "Value-destroying overrides are never measured against what the statistical forecast would have done."
  ],
  "agentification": [
    "Triages the exception queue nightly, auto-clearing noise and enriching real exceptions with causal context.",
    "Recommends override values with confidence intervals and the driver evidence behind each one.",
    "Publishes a forecast-value-added report that scores every human override against the baseline."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Blue Yonder Demand Planning",
        "description": "demand forecasts, forecast overrides, seasonal profiles records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query demand forecasts and forecast overrides from Blue Yonder Demand Planning for the Demand Forecast Exception Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Demand Planner's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Demand Forecast Exception Agent Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Blue Yonder Demand Planning with a full audit trail, and escalate exceptions to the Demand Planner."
      }
    ]
  },
