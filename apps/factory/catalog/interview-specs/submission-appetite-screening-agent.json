  "id": "submission-appetite-screening-agent",
  "title": "Submission Appetite Screening Agent",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/submission-appetite-screening-agent.json",
  "subtitle": "I-3101 • Distribution & Underwriting",
  "persona": "Underwriter",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-31",
  "systems": [
    "Guidewire PolicyCenter",
    "LexisNexis Risk Solutions",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Submission-to-quote turnaround",
      "before": "5.2 days",
      "after": "1.1 days"
    },
    {
      "label": "Out-of-appetite submissions worked",
      "before": "34%",
      "after": "6%"
    },
    {
      "label": "Underwriter submissions triaged per day",
      "before": "12",
      "after": "38"
    }
  ],
  "statusQuo": [
    "Underwriters manually read every broker submission email and PDF ACORD form to decide if the risk is even in appetite.",
    "A third of underwriting hours go to declining risks the carrier was never going to write.",
    "Appetite guidelines live in a 90-page PDF that changes quarterly, so screening decisions are inconsistent across desks."
  ],
  "agentification": [
    "Extracts risk attributes from inbound submissions and scores them against the current appetite matrix within minutes of receipt.",
    "Routes in-appetite submissions to the right underwriting desk and drafts decline letters for clear out-of-appetite risks.",
    "Flags borderline risks with a rationale summary and enriches them with LexisNexis loss history before an underwriter opens the file."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire PolicyCenter",
        "description": "policies, policy quotes, underwriting submissions records"
      },
      {
        "system": "LexisNexis Risk Solutions",
        "description": "risk reports, mvr records, prefill datasets records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query policies and policy quotes from Guidewire PolicyCenter and correlate with LexisNexis Risk Solutions for the Submission Appetite Screening Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Underwriter's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Submission Appetite Screening Agent Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in Guidewire PolicyCenter with a full audit trail, and escalate exceptions to the Underwriter."
      }
    ]
  },
