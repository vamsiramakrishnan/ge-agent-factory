{
  "id": "dormant-account-remediation-agent",
  "title": "Dormant Account Remediation Agent",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/dormant-account-remediation-agent.json",
  "subtitle": "B-2101 • Retail Banking & Deposits",
  "persona": "Deposit Operations Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-21",
  "systems": [
    "Temenos Transact",
    "BigQuery",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Dormant accounts remediated per month",
      "before": "1,200",
      "after": "4,800"
    },
    {
      "label": "Escheatment filing errors per quarter",
      "before": "35",
      "after": "3"
    },
    {
      "label": "Manual review hours per week",
      "before": "60 hrs",
      "after": "8 hrs"
    }
  ],
  "statusQuo": [
    "Analysts export dormant-account lists from Temenos Transact into spreadsheets each month and reconcile them by hand against state escheatment calendars.",
    "Customer re-contact letters are drafted one at a time, so thousands of accounts sit past the outreach deadline every cycle.",
    "Missed escheatment deadlines trigger state penalties and remediation projects that pull staff off daily deposit operations."
  ],
  "agentification": [
    "Scans Temenos Transact and BigQuery nightly to classify accounts by dormancy stage and applicable state escheatment rules.",
    "Generates personalized re-contact letters and creates ServiceNow tasks for accounts requiring branch follow-up.",
    "Escalates accounts approaching statutory deadlines to the operations queue with a prepared escheatment filing package."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Temenos Transact",
        "description": "core accounts, account transactions, standing orders records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query core accounts and account transactions from Temenos Transact and correlate with ServiceNow for the Dormant Account Remediation Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Deposit Operations Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Dormant Account Remediation Agent Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Temenos Transact with a full audit trail, and escalate exceptions to the Deposit Operations Analyst."
      }
    ]
  },
