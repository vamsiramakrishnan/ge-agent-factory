  "subtitle": "R-1602 • Pricing & Promotions",
  "persona": "Pricing Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-16",
  "systems": [
    "Revionics Price Optimization",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Price-index drift on KVIs",
      "before": "±7% weekly",
      "after": "±1.5% weekly"
    },
    {
      "label": "Competitive response time",
      "before": "5 days",
      "after": "4 hours"
    },
    {
      "label": "Margin lost to blind price matching",
      "before": "180 bps",
      "after": "40 bps"
    }
  ],
  "statusQuo": [
    "Competitor price files arrive weekly and are reviewed in a spreadsheet on Wednesdays.",
    "Every competitor move on a key item triggers a reflexive match, even on inelastic SKUs.",
    "Price changes queue behind manual approval chains and land after the competitor's promo ends."
  ],
  "agentification": [
    "Monitors competitor price feeds continuously and detects moves on key-value items within hours.",
    "Recommends respond/hold/partial-match decisions per item from elasticity and price-image weight, executed through Revionics rules.",
    "Notifies the Pricing Manager of margin-material moves with the modeled impact of each response option."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Revionics Price Optimization",
        "description": "price recommendations, price zones, elasticity models records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query price recommendations and price zones from Revionics Price Optimization for the Competitive Price Response Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Pricing Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Competitive Price Response Agent Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in Revionics Price Optimization with a full audit trail, and escalate exceptions to the Pricing Manager."
      }
    ]
  },
