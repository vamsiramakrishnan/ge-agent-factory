{
  "id": "credit-portfolio-concentration-monitor",
  "title": "Credit Portfolio Concentration Monitor",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/credit-portfolio-concentration-monitor.json",
  "subtitle": "B-2205 • Lending & Credit",
  "persona": "Credit Portfolio Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-22",
  "systems": [
    "nCino Loan Origination",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Time to produce concentration report",
      "before": "10 days",
      "after": "Continuous"
    },
    {
      "label": "Limit breaches detected before booking",
      "before": "0%",
      "after": "92%"
    },
    {
      "label": "Analyst hours on quarterly portfolio review",
      "before": "120 hrs",
      "after": "20 hrs"
    }
  ],
  "statusQuo": [
    "Concentration reporting by industry, geography, and sponsor is compiled quarterly in spreadsheets from nCino extracts and is stale on arrival.",
    "New deals are approved without visibility into whether they push a sector or single-name limit past board thresholds.",
    "CRE and leveraged-lending concentrations flagged by regulators require weeks of scramble to quantify and explain."
  ],
  "agentification": [
    "Recomputes exposure against every board concentration limit daily as commitments and outstandings change in nCino.",
    "Simulates the concentration impact of pipeline deals and notifies underwriters when a pending approval would breach a limit.",
    "Publishes a live concentration dashboard to Looker and drafts the quarterly board narrative with trend commentary."
  ],
  "architecture": {
    "connections": [
      {
        "system": "nCino Loan Origination",
        "description": "loan applications, credit memos, covenant records records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query loan applications and credit memos from nCino Loan Origination for the Credit Portfolio Concentration Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Credit Portfolio Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Credit Portfolio Concentration Monitor Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in nCino Loan Origination with a full audit trail, and escalate exceptions to the Credit Portfolio Manager."
      }
    ]
  },
