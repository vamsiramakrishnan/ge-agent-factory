{
  "id": "customer-care-triage-agent",
  "title": "Customer Care Triage Agent",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/customer-care-triage-agent.json",
  "subtitle": "R-1503 • Customer & Loyalty",
  "persona": "Customer Care Director",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-15",
