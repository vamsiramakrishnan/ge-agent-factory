    "Salesforce Commerce Cloud",
    "Zendesk",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "First response time",
      "before": "9 hours",
      "after": "4 minutes"
    },
    {
      "label": "Contacts resolved without agent touch",
      "before": "8%",
      "after": "44%"
    },
    {
      "label": "CSAT",
      "before": "3.6/5",
      "after": "4.5/5"
    }
  ],
  "statusQuo": [
    "Every ticket lands in one Zendesk queue and waits for a human to read, tag, and route it.",
    "Agents swivel between order systems and the ticket to reconstruct what happened.",
    "VIP customers with delivery failures wait behind password-reset requests."
  ],
  "agentification": [
    "Classifies inbound tickets by intent and urgency, enriched with live order and delivery status from Commerce Cloud.",
    "Resolves where-is-my-order, return-label, and appeasement cases end to end under policy limits.",
    "Routes complex cases to the right specialist queue with a drafted response and escalates VIP incidents to the Customer Care Director."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Commerce Cloud",
        "description": "online orders, product catalog entries, cart events records"
      },
      {
        "system": "Zendesk",
        "description": "tickets, macros, satisfaction scores records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query online orders and product catalog entries from Salesforce Commerce Cloud and correlate with Zendesk for the Customer Care Triage Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Customer Care Director's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Customer Care Triage Agent Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Salesforce Commerce Cloud with a full audit trail, and escalate exceptions to the Customer Care Director."
      }
    ]
  },
