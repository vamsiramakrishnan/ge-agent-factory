{
  "id": "planogram-compliance-analyzer",
  "title": "Planogram Compliance Analyzer",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/planogram-compliance-analyzer.json",
  "subtitle": "R-1102 • Merchandising & Assortment",
  "persona": "Planogram Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-11",
  "systems": [
    "Oracle Retail MFCS",
    "Oracle Xstore POS",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Planogram compliance rate",
      "before": "72%",
      "after": "93%"
    },
    {
      "label": "Reset audit coverage",
      "before": "8% of stores",
      "after": "100% of stores"
    },
    {
      "label": "Days to detect non-compliant reset",
      "before": "21 days",
      "after": "1 day"
    }
  ],
  "statusQuo": [
    "Field teams photograph shelves and email images that sit unreviewed for weeks.",
    "Compliance is inferred from a 5% store sample walked by third-party auditors twice a year.",
    "Sales dips from botched resets are discovered only after the category post-mortem."
  ],
  "agentification": [
    "Analyzes shelf images and POS sales-rate deviations against the planogram of record after every reset window.",
    "Flags facings, position, and missing-item violations store by store with photo evidence.",
    "Creates corrective tasks for store teams and escalates chronic non-compliance to the Planogram Manager."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Retail MFCS",
        "description": "item master, merchandise hierarchy, cost changes records"
      },
      {
        "system": "Oracle Xstore POS",
        "description": "pos transactions, tender records, store shift summaries records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query item master and merchandise hierarchy from Oracle Retail MFCS and correlate with Oracle Xstore POS for the Planogram Compliance Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Planogram Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Planogram Compliance Analyzer Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Oracle Retail MFCS with a full audit trail, and escalate exceptions to the Planogram Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Planogram Compliance Analyzer so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
