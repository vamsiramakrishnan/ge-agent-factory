{
  "id": "pm-schedule-optimization-engine",
  "title": "PM Schedule Optimization Engine",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/pm-schedule-optimization-engine.json",
  "subtitle": "M-5302 • Maintenance & Reliability",
  "persona": "Maintenance Planner",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-53",
  "systems": [
    "IBM Maximo",
    "OSIsoft PI System",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "PM labor hours with no findings",
      "before": "44%",
      "after": "18%"
    },
    {
      "label": "Failures occurring between PMs",
      "before": "9 per month",
      "after": "3 per month"
    },
    {
      "label": "Wrench time",
      "before": "32%",
      "after": "48%"
    }
  ],
  "statusQuo": [
    "PM intervals were set from OEM manuals a decade ago and have never been revisited against actual failure history.",
    "Technicians grease and inspect healthy equipment while assets that actually fail sit on the same calendar cadence.",
    "The planner has no way to see which PM tasks have never once produced a finding."
  ],
  "agentification": [
    "Cross-references every PM task in IBM Maximo against failure history and runtime data from the PI System in BigQuery quarterly.",
    "Recommends interval extensions for zero-finding PMs and tightened or condition-based triggers for failure-prone assets, with the evidence attached.",
    "Drafts the updated PM route packages for the planner's approval and tracks failure rates after each change to validate it."
  ],
  "architecture": {
    "connections": [
      {
        "system": "IBM Maximo",
        "description": "maintenance work orders, asset registry entries, failure codes records"
      },
      {
        "system": "OSIsoft PI System",
        "description": "sensor readings, asset tag hierarchies, downtime events records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query maintenance work orders and asset registry entries from IBM Maximo and correlate with OSIsoft PI System for the PM Schedule Optimization Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Maintenance Planner's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the PM Schedule Optimization Engine Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in IBM Maximo with a full audit trail, and escalate exceptions to the Maintenance Planner."
      }
    ]
  },
