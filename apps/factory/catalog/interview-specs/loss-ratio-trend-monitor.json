{
  "id": "loss-ratio-trend-monitor",
  "title": "Loss Ratio Trend Monitor",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/loss-ratio-trend-monitor.json",
  "subtitle": "I-3503 • Actuarial & Portfolio Risk",
  "persona": "Chief Actuary",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-35",
  "systems": [
    "Verisk ISO ERC",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Time to detect a deteriorating segment",
      "before": "4-6 months",
      "after": "3 weeks"
    },
    {
      "label": "Segments monitored continuously",
      "before": "12 top-level",
      "after": "400+ granular"
    },
    {
      "label": "Combined ratio impact of late detection",
      "before": "1.8 points",
      "after": "0.4 points"
    }
  ],
  "statusQuo": [
    "Loss ratio reviews happen monthly at line-of-business level, hiding a deteriorating state-class-tier cell inside a healthy aggregate.",
    "Analysts manually cut the data a few dimensions at a time and inevitably miss interaction effects.",
    "By the time deterioration is confirmed, two more months of underpriced business has been written."
  ],
  "agentification": [
    "Continuously scans loss ratios across hundreds of state, class, tier, and cohort combinations in BigQuery, benchmarked against Verisk industry trends.",
    "Distinguishes credible deterioration from noise using severity, frequency, and large-loss decomposition.",
    "Escalates confirmed adverse trends to the chief actuary with a driver analysis and recommends which cells to fast-track for rate review."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Verisk ISO ERC",
        "description": "loss cost benchmarks, circular updates, territory factors records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query loss cost benchmarks and circular updates from Verisk ISO ERC for the Loss Ratio Trend Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Chief Actuary's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Loss Ratio Trend Monitor Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Verisk ISO ERC with a full audit trail, and escalate exceptions to the Chief Actuary."
      }
    ]
  },
