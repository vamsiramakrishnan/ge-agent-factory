{
  "id": "vendor-promo-funding-reconciliation-agent",
  "title": "Vendor Promo Funding Reconciliation Agent",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/vendor-promo-funding-reconciliation-agent.json",
  "subtitle": "R-1605 • Pricing & Promotions",
  "persona": "Trade Promotions Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-16",
  "systems": [
    "Oracle Retail MFCS",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Vendor funding collected vs. committed",
      "before": "83%",
      "after": "98%"
    },
    {
      "label": "Deal reconciliation cycle time",
      "before": "60 days",
      "after": "5 days"
    },
    {
      "label": "Disputed claim rate",
      "before": "17%",
      "after": "4%"
    }
  ],
  "statusQuo": [
    "Deal sheets live in email attachments and are re-keyed into MFCS with frequent errors.",
    "Scan-based funding claims are computed quarterly in a giant workbook nobody else can open.",
    "Millions in committed co-op and markdown support expire unclaimed every year."
  ],
  "agentification": [
    "Matches promo execution data — scans, markdowns, ad placements — against vendor deal terms in MFCS automatically.",
    "Generates substantiated funding claims with transaction-level backup and drafts dispute responses.",
    "Notifies the Trade Promotions Analyst of expiring commitments and under-collected deals before quarter close."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Retail MFCS",
        "description": "item master, merchandise hierarchy, cost changes records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query item master and merchandise hierarchy from Oracle Retail MFCS for the Vendor Promo Funding Reconciliation Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Trade Promotions Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Vendor Promo Funding Reconciliation Agent Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the generate step in Oracle Retail MFCS with a full audit trail, and escalate exceptions to the Trade Promotions Analyst."
      }
    ]
  },
