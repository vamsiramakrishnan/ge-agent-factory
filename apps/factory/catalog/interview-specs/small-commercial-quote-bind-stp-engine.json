  "department": "insurance",
  "sourcePath": "catalog/interview-specs/small-commercial-quote-bind-stp-engine.json",
  "subtitle": "I-3103 • Distribution & Underwriting",
  "persona": "Underwriting Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "on-demand",
  "domainId": "domain-31",
  "systems": [
    "Guidewire PolicyCenter",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Straight-through processing rate",
      "before": "22%",
      "after": "68%"
    },
    {
      "label": "Quote-to-bind conversion",
      "before": "31%",
      "after": "44%"
    },
    {
      "label": "Cost per bound small commercial policy",
      "before": "$310",
      "after": "$95"
    }
  ],
  "statusQuo": [
    "Small BOP and workers' comp quotes under $10K premium still queue behind large accounts for manual underwriter review.",
    "Referral rules in PolicyCenter are so conservative that routine risks trigger the same review path as complex ones.",
    "Brokers abandon quotes because turnaround on simple risks stretches past 48 hours."
  ],
  "agentification": [
    "Evaluates small commercial quotes against underwriting guidelines and historical loss data in BigQuery to clear routine risks for automatic bind.",
    "Escalates only genuinely non-standard exposures to a human underwriter with a pre-built referral summary.",
    "Publishes STP rate and referral-reason dashboards in Looker so the underwriting manager can tune thresholds weekly."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire PolicyCenter",
        "description": "policies, policy quotes, underwriting submissions records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query policies and policy quotes from Guidewire PolicyCenter for the Small Commercial Quote-Bind STP Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Underwriting Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Small Commercial Quote-Bind STP Engine Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Guidewire PolicyCenter with a full audit trail, and escalate exceptions to the Underwriting Manager."
      }
    ]
  },
