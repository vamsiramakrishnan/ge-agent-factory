  "kpis": [
    {
      "label": "Time to full counterparty exposure view",
      "before": "T+1",
      "after": "Intraday"
    },
    {
      "label": "Collateral disputes open >5 days",
      "before": "40",
      "after": "6"
    },
    {
      "label": "Wrong-way risk cases identified per quarter",
      "before": "2",
      "after": "11"
    }
  ],
  "statusQuo": [
    "A consolidated view of derivative exposure, collateral, and ratings per counterparty is only available the next day after batch aggregation.",
    "Margin-call disputes are worked from email threads, and aged disputes inflate uncollateralized exposure unnoticed.",
    "Deteriorating counterparties are caught by quarterly reviews rather than market signals like CDS spread widening."
  ],
  "agentification": [
    "Aggregates potential future exposure, collateral balances, and netting-set details from Murex MX.3 into an intraday counterparty view.",
    "Monitors market signals such as ratings actions and CDS moves, escalating counterparties whose risk profile deteriorates.",
    "Drafts margin-call dispute summaries with valuation comparisons and recommends resolution actions to the collateral team."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Murex MX.3",
        "description": "trades, positions, risk measures records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query trades and positions from Murex MX.3 for the Counterparty Credit Exposure Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Counterparty Risk Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Counterparty Credit Exposure Monitor Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in Murex MX.3 with a full audit trail, and escalate exceptions to the Counterparty Risk Manager."
      }
    ]
  },
