{
  "id": "store-task-compliance-agent",
  "title": "Store Task Compliance Agent",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/store-task-compliance-agent.json",
  "subtitle": "R-1304 • Store Operations",
  "persona": "District Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-13",
  "systems": [
    "UKG Dimensions",
    "Oracle Xstore POS",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Corporate task on-time completion",
      "before": "64%",
      "after": "92%"
    },
    {
      "label": "District visit prep time",
      "before": "4 hours",
      "after": "15 minutes"
    },
    {
      "label": "Promo setup verification rate",
      "before": "30% of events",
      "after": "100% of events"
    }
  ],
  "statusQuo": [
    "Task completion is self-reported by stores, and district managers have no way to verify it.",
    "DMs spend Sunday nights compiling store dashboards from five systems before their weekly route.",
    "Promo displays that never went up are discovered when the event's sales miss plan."
  ],
  "agentification": [
    "Cross-checks reported task completion against POS signals, labor punches, and photo evidence.",
    "Drafts each District Manager's store-visit brief with exceptions, trends, and coaching points per location.",
    "Escalates unverified promo setups to the district before the event's first weekend."
  ],
  "architecture": {
    "connections": [
      {
        "system": "UKG Dimensions",
        "description": "shift schedules, timecards, labor forecasts records"
      },
      {
        "system": "Oracle Xstore POS",
        "description": "pos transactions, tender records, store shift summaries records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query shift schedules and timecards from UKG Dimensions and correlate with Oracle Xstore POS for the Store Task Compliance Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the District Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Store Task Compliance Agent Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in UKG Dimensions with a full audit trail, and escalate exceptions to the District Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Store Task Compliance Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
