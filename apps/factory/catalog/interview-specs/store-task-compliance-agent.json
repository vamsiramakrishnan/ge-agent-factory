    "anomalies": [
      {
        "id": "store-task-compliance-agent-baseline-gap",
        "description": "Seed a realistic gap where Corporate task on-time completion sits between 64% and 92%, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "shift_schedules",
          "timecards"
        ],
        "discoveryPath": [
          "Inspect UKG Dimensions records for the affected entities",
          "Compare against Oracle Xstore POS historical baseline",
          "Generate a citation-backed recommendation"
        ],
        "expectedEvidence": [
          "source-system record",
          "historical baseline metric",
          "generated audit trail"
        ],
        "expectedRecommendation": "Explain the gap, cite supporting evidence, and propose the next District Manager action."
      }
