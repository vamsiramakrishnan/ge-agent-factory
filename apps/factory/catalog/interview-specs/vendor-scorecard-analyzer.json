{
  "id": "vendor-scorecard-analyzer",
  "title": "Vendor Performance Scorecard Analyzer",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/vendor-scorecard-analyzer.json",
  "subtitle": "R-1105 • Merchandising & Assortment",
  "persona": "Vendor Performance Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-11",
  "systems": [
    "Oracle Retail MFCS",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Vendor fill rate",
      "before": "88%",
      "after": "96%"
    },
    {
      "label": "Scorecard preparation time per vendor",
      "before": "6 hours",
      "after": "10 minutes"
    },
    {
      "label": "Cost recovery from compliance claims",
      "before": "$1.1M/yr",
      "after": "$3.4M/yr"
    }
  ],
  "statusQuo": [
    "Analysts assemble quarterly vendor scorecards by exporting PO, receipt, and invoice data into Excel.",
    "Fill-rate and lead-time misses surface a quarter late, long after negotiation leverage is gone.",
    "Chargeback-eligible violations go unclaimed because nobody has time to document them."
  ],
  "agentification": [
    "Computes fill rate, on-time delivery, lead-time variance, and invoice accuracy per vendor weekly in BigQuery.",
    "Drafts the quarterly business review deck with trend narratives and benchmark comparisons per vendor.",
    "Generates compliance-claim packets with PO-level evidence and routes them to the Vendor Performance Manager."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Retail MFCS",
        "description": "item master, merchandise hierarchy, cost changes records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query item master and merchandise hierarchy from Oracle Retail MFCS for the Vendor Performance Scorecard Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Vendor Performance Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Vendor Performance Scorecard Analyzer Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in Oracle Retail MFCS with a full audit trail, and escalate exceptions to the Vendor Performance Manager."
      }
    ]
  },
  "generationSpec": {
