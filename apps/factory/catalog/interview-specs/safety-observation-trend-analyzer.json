{
  "id": "safety-observation-trend-analyzer",
  "title": "Safety Observation Trend Analyzer",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/safety-observation-trend-analyzer.json",
  "subtitle": "M-5605 • EHS & Sustainability",
  "persona": "Plant Safety Coordinator",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-56",
  "systems": [
    "Sphera EHS",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Leading-indicator coverage of incidents",
      "before": "20% preceded by flagged trend",
      "after": "75% preceded by flagged trend"
    },
    {
      "label": "Observation-to-insight cycle",
      "before": "quarterly review",
      "after": "weekly"
    },
    {
      "label": "Recordable incident rate (TRIR)",
      "before": "1.9",
      "after": "1.2"
    }
  ],
  "statusQuo": [
    "Thousands of behavior-based safety observations are collected each year and read by no one beyond a raw count on a slide.",
    "Emerging risk patterns — the same unsafe condition reported in three departments — are invisible in the quarterly rollup.",
    "Toolbox talk topics are recycled from a stale list instead of reflecting what observers are actually reporting."
  ],
  "agentification": [
    "Mines Sphera EHS observation free-text weekly in BigQuery to cluster emerging unsafe conditions and behaviors by area, shift, and task type.",
    "Correlates observation clusters with incident history to surface the leading indicators that historically precede recordables.",
    "Drafts targeted toolbox talk content for the highest-risk clusters and publishes the trend dashboard to Looker for area supervisors."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Sphera EHS",
        "description": "safety incidents, permit records, emissions readings records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query safety incidents and permit records from Sphera EHS for the Safety Observation Trend Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Plant Safety Coordinator's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Safety Observation Trend Analyzer Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Sphera EHS with a full audit trail, and escalate exceptions to the Plant Safety Coordinator."
      }
    ]
  },
