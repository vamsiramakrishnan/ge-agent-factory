{
  "id": "midterm-cancellation-retention-agent",
  "title": "Mid-Term Cancellation Retention Agent",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/midterm-cancellation-retention-agent.json",
  "subtitle": "I-3405 • Policy Servicing",
  "persona": "Retention Specialist",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-34",
  "systems": [
    "Guidewire PolicyCenter",
    "Salesforce Marketing Cloud",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Mid-term cancellation save rate",
      "before": "12%",
      "after": "34%"
    },
    {
      "label": "Annualized premium retained",
      "before": "$3.1M",
      "after": "$8.8M"
    },
    {
      "label": "Time from cancel request to retention contact",
      "before": "3 days",
      "after": "under 1 hour"
    }
  ],
  "statusQuo": [
    "Cancellation requests are processed transactionally with no retention attempt unless the customer happens to mention price.",
    "By the time a weekly cancellation report reaches the retention team, most customers have already bound elsewhere.",
    "Reps have no visibility into which discounts or coverage adjustments the departing customer actually qualifies for."
  ],
  "agentification": [
    "Detects cancellation intent the moment a request or competitor-comparison inquiry hits PolicyCenter and scores the account's retention value.",
    "Generates a personalized save offer — eligible discounts, coverage rebalancing, payment plan changes — priced against the live policy.",
    "Notifies the retention specialist within minutes for high-value accounts and triggers a tailored win-back journey in Salesforce Marketing Cloud for the rest."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire PolicyCenter",
        "description": "policies, policy quotes, underwriting submissions records"
      },
      {
        "system": "Salesforce Marketing Cloud",
        "description": "accounts, opportunities, campaign influence records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query policies and policy quotes from Guidewire PolicyCenter and correlate with Salesforce Marketing Cloud for the Mid-Term Cancellation Retention Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Retention Specialist's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Mid-Term Cancellation Retention Agent Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the generate step in Guidewire PolicyCenter with a full audit trail, and escalate exceptions to the Retention Specialist."
      }
    ]
  },
