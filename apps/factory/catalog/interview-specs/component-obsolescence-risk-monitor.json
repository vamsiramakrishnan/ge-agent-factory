  "id": "component-obsolescence-risk-monitor",
  "title": "Component Obsolescence Risk Monitor",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/component-obsolescence-risk-monitor.json",
  "subtitle": "M-5505 • Engineering & PLM",
  "persona": "Component Engineer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-55",
  "systems": [
    "PTC Windchill PLM",
    "SAP S/4HANA MM",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Line-down events from obsolete components",
      "before": "4 per year",
      "after": "0 per year"
    },
    {
      "label": "Last-time-buy decisions made proactively",
      "before": "30%",
      "after": "92%"
    },
    {
      "label": "Redesign projects started reactively",
      "before": "9 per year",
      "after": "2 per year"
    }
  ],
  "statusQuo": [
    "End-of-life notices arrive in a shared inbox and are matched to product BOMs by hand, weeks later, if at all.",
    "Last-time-buy windows close before anyone calculates how many units of remaining demand the part covers.",
    "A discontinued component is often discovered when a purchase order bounces back unfulfilled."
  ],
  "agentification": [
    "Cross-references supplier end-of-life and lifecycle-risk signals against active PTC Windchill PLM BOM usage and remaining demand from SAP S/4HANA MM in BigQuery weekly.",
    "Quantifies exposure per affected product — remaining demand, current stock, and last-time-buy quantity required.",
    "Notifies the component engineer with a recommended action per part — last-time buy, qualify an alternate, or launch a redesign — and creates the tracking task for the chosen path."
  ],
  "architecture": {
    "connections": [
      {
        "system": "PTC Windchill PLM",
        "description": "engineering change orders, bom revisions, cad document records records"
      },
      {
        "system": "SAP S/4HANA MM",
        "description": "purchase orders, material movements, vendors records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query engineering change orders and bom revisions from PTC Windchill PLM and correlate with SAP S/4HANA MM for the Component Obsolescence Risk Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Component Engineer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Component Obsolescence Risk Monitor Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in PTC Windchill PLM with a full audit trail, and escalate exceptions to the Component Engineer."
      }
    ]
  },
