  "id": "sar-filing-preparation-agent",
  "title": "SAR Filing Preparation Agent",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/sar-filing-preparation-agent.json",
  "subtitle": "B-2403 • KYC, AML & Compliance",
  "persona": "AML Compliance Officer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-24",
  "systems": [
    "NICE Actimize",
    "BigQuery",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "SAR filing timeliness (within 30 days)",
      "before": "82%",
      "after": "99.5%"
    },
    {
      "label": "Time to draft SAR narrative",
      "before": "6 hours",
      "after": "40 minutes"
    },
    {
      "label": "FinCEN rejection/correction rate",
      "before": "6%",
      "after": "0.8%"
    }
  ],
  "statusQuo": [
    "SAR narratives are drafted by hand from investigation notes, and the 30-day filing clock is tracked in a spreadsheet.",
    "Writers re-key subject, account, and transaction details into the FinCEN form, introducing transcription errors that trigger corrections.",
    "Continuing-activity reviews at 90 days are frequently missed because there is no systematic tickler process."
  ],
  "agentification": [
    "Drafts the SAR narrative in FinCEN's expected structure directly from the escalated Actimize case file and transaction data.",
    "Pre-populates form fields from system-of-record data and validates them against FinCEN error rules before filing.",
    "Tracks 30-day deadlines and 90-day continuing-activity reviews, escalating anything at risk to the AML compliance officer."
  ],
  "architecture": {
    "connections": [
      {
        "system": "NICE Actimize",
        "description": "fraud alerts, transaction risk scores, investigation cases records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query fraud alerts and transaction risk scores from NICE Actimize and correlate with ServiceNow for the SAR Filing Preparation Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the AML Compliance Officer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the SAR Filing Preparation Agent Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in NICE Actimize with a full audit trail, and escalate exceptions to the AML Compliance Officer."
      }
    ]
  },
