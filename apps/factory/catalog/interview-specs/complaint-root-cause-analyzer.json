{
  "id": "complaint-root-cause-analyzer",
  "title": "Complaint Root Cause Analyzer",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/complaint-root-cause-analyzer.json",
  "subtitle": "T-4504 • Customer Care & Retention",
  "persona": "Care Team Lead",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-45",
  "systems": [
    "Genesys Cloud CX",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Repeat contact rate",
      "before": "28%",
      "after": "14%"
    },
    {
      "label": "Emerging-issue detection time",
      "before": "2-3 weeks",
      "after": "48 hours"
    },
    {
      "label": "Regulator complaint escalations",
      "before": "85/quarter",
      "after": "30/quarter"
    }
  ],
  "statusQuo": [
    "Contact drivers are inferred from agent disposition codes that are wrong or generic more than half the time.",
    "A billing or firmware defect generates thousands of calls for weeks before anyone connects the dots across regions.",
    "The monthly complaints review is anecdote-driven, so fixes chase the loudest recent story rather than the biggest driver."
  ],
  "agentification": [
    "The analyzer mines call transcripts, chat logs, and tickets daily to classify true contact reasons independent of disposition codes.",
    "It detects emerging complaint clusters and correlates them with recent releases, bill runs, and network changes.",
    "It generates a ranked contact-driver report with estimated cost-to-serve and routes defect cases to the owning product or billing team."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Genesys Cloud CX",
        "description": "customer interactions, queue metrics, agent schedules records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query customer interactions and queue metrics from Genesys Cloud CX for the Complaint Root Cause Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Care Team Lead's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Complaint Root Cause Analyzer Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in Genesys Cloud CX with a full audit trail, and escalate exceptions to the Care Team Lead."
      }
    ]
  },
