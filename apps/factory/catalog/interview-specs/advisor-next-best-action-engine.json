{
  "id": "advisor-next-best-action-engine",
  "title": "Advisor Next Best Action Engine",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/advisor-next-best-action-engine.json",
  "subtitle": "B-2503 • Wealth & Advisory",
  "persona": "Relationship Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-25",
  "systems": [
    "Salesforce Financial Services Cloud",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Qualified advice conversations per month",
      "before": "6 per RM",
      "after": "22 per RM"
    },
    {
      "label": "Held-away asset capture",
      "before": "$40M/yr",
      "after": "$130M/yr"
    },
    {
      "label": "Client attrition in top decile",
      "before": "7%",
      "after": "3%"
    }
  ],
  "statusQuo": [
    "Relationship managers learn about maturing CDs, large cash inflows, and executive stock vesting events weeks late or not at all.",
    "Prioritizing the day's outreach means scrolling Salesforce lists with no signal about which client actually needs a call.",
    "Money-in-motion moments pass to competitors because the first conversation happens after the funds have moved."
  ],
  "agentification": [
    "Detects money-in-motion signals such as large deposits, maturing instruments, and rollover-eligible balances from BigQuery in near real time.",
    "Recommends the next best action per client with a suggested product conversation and compliant talking points.",
    "Creates prioritized Salesforce tasks and notifies the relationship manager when a top-decile client shows attrition signals."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Financial Services Cloud",
        "description": "client households, financial accounts, advisory referrals records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query client households and financial accounts from Salesforce Financial Services Cloud for the Advisor Next Best Action Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Relationship Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Advisor Next Best Action Engine Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in Salesforce Financial Services Cloud with a full audit trail, and escalate exceptions to the Relationship Manager."
      }
    ]
  },
