  "department": "banking",
  "sourcePath": "catalog/interview-specs/deposit-attrition-early-warning-monitor.json",
  "subtitle": "B-2104 • Retail Banking & Deposits",
  "persona": "Retail Deposits Product Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-21",
  "systems": [
    "Temenos Transact",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "At-risk balances identified before outflow",
      "before": "22%",
      "after": "68%"
    },
    {
      "label": "Retention offer response rate",
      "before": "4%",
      "after": "14%"
    },
    {
      "label": "Time to produce attrition analysis",
      "before": "2 weeks",
      "after": "Same day"
    }
  ],
  "statusQuo": [
    "The deposits team learns about large balance run-off from month-end Looker dashboards, weeks after the money has already left.",
    "Analysts manually stitch Temenos Transact balance trends with rate-sheet data to guess which customers are rate shopping.",
    "Retention offers go out in blanket campaigns because nobody can rank individual accounts by flight risk."
  ],
  "agentification": [
    "Scores every deposit relationship weekly for attrition risk using balance velocity, external transfer patterns, and competitor rate spreads.",
    "Generates a ranked retention worklist with a recommended offer and talking points for each at-risk household.",
    "Publishes an attrition heatmap to Looker and notifies product managers when a segment's outflow breaches threshold."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Temenos Transact",
        "description": "core accounts, account transactions, standing orders records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query core accounts and account transactions from Temenos Transact for the Deposit Attrition Early Warning Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Retail Deposits Product Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Deposit Attrition Early Warning Monitor Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Temenos Transact with a full audit trail, and escalate exceptions to the Retail Deposits Product Manager."
      }
    ]
  },
