  "id": "cat-exposure-rollup-engine",
  "title": "Catastrophe Exposure Rollup Engine",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/cat-exposure-rollup-engine.json",
  "subtitle": "I-3501 • Actuarial & Portfolio Risk",
  "persona": "Portfolio Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-35",
  "systems": [
    "Verisk ISO ERC",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Exposure rollup refresh cycle",
      "before": "quarterly",
      "after": "daily"
    },
    {
      "label": "PML estimate variance vs. modeled",
      "before": "±18%",
      "after": "±5%"
    },
    {
      "label": "Time to answer a reinsurer exposure query",
      "before": "2 weeks",
      "after": "same day"
    }
  ],
  "statusQuo": [
    "Cat aggregation runs quarterly on extracts that are weeks stale by the time the rollup is finished.",
    "New policies bound in a hurricane-exposed county between rollups are invisible to the accumulation view.",
    "Reinsurance renewal questionnaires trigger a two-week scramble of manual geocoding and spreadsheet consolidation."
  ],
  "agentification": [
    "Geocodes and aggregates the full in-force book daily in BigQuery, enriched with Verisk hazard and construction data.",
    "Monitors accumulation against zone appetite limits and escalates any county or coastal band approaching capacity before new business breaches it.",
    "Publishes live PML and TIV dashboards in Looker and generates reinsurer-ready exposure schedules on demand."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Verisk ISO ERC",
        "description": "loss cost benchmarks, circular updates, territory factors records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query loss cost benchmarks and circular updates from Verisk ISO ERC for the Catastrophe Exposure Rollup Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Portfolio Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Catastrophe Exposure Rollup Engine Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Verisk ISO ERC with a full audit trail, and escalate exceptions to the Portfolio Manager."
      }
    ]
  },
