      "escalationRules": [
        {
          "trigger": "Time to detect declining agency production regresses past the 1 quarter baseline by more than 20%",
          "action": "escalate_to_human",
          "handoffTarget": "Agency Distribution Manager",
          "rationale": "Significant regressions need human judgment before automated remediation runs against production records."
        },
