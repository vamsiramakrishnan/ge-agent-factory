{
  "id": "agency-production-performance-monitor",
  "title": "Agency Production Performance Monitor",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/agency-production-performance-monitor.json",
  "subtitle": "I-3104 • Distribution & Underwriting",
  "persona": "Agency Distribution Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-31",
  "systems": [
    "Duck Creek Policy",
    "Salesforce Marketing Cloud",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Time to detect declining agency production",
      "before": "1 quarter",
      "after": "1 week"
    },
    {
      "label": "Agency book growth in managed territories",
      "before": "2.1% YoY",
      "after": "6.4% YoY"
    },
    {
      "label": "Distribution manager prep time per agency review",
      "before": "3 hours",
      "after": "20 min"
    }
  ],
  "statusQuo": [
    "Agency production reports are compiled quarterly in spreadsheets, so a slipping agency isn't noticed until two quarters of premium are gone.",
    "Distribution managers manually stitch together quote volume, hit ratio, and retention from three different systems before every agency visit.",
    "Underperforming agencies get the same outreach cadence as top producers because no one has time to segment."
  ],
  "agentification": [
    "Runs weekly production scans across the Duck Creek book in BigQuery and detects agencies with falling quote volume, hit ratio, or retention.",
    "Generates a briefing pack for each flagged agency with trend charts and recommended talking points before the distribution manager's visit.",
    "Triggers segmented re-engagement campaigns through Salesforce Marketing Cloud for agencies that have gone quiet."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Duck Creek Policy",
        "description": "policy forms, rating worksheets, endorsement records records"
      },
      {
        "system": "Salesforce Marketing Cloud",
        "description": "accounts, opportunities, campaign influence records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query policy forms and rating worksheets from Duck Creek Policy and correlate with Salesforce Marketing Cloud for the Agency Production Performance Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Agency Distribution Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Agency Production Performance Monitor Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in Duck Creek Policy with a full audit trail, and escalate exceptions to the Agency Distribution Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Agency Production Performance Monitor so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
