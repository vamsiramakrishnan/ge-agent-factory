{
  "id": "account-opening-doc-followup-agent",
  "title": "Account Opening Document Follow-Up Agent",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/account-opening-doc-followup-agent.json",
  "subtitle": "B-2102 • Retail Banking & Deposits",
  "persona": "Branch Operations Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-21",
  "systems": [
    "Temenos Transact",
    "BigQuery",
    "DocuSign",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Accounts opened with incomplete documents",
      "before": "18%",
      "after": "3%"
    },
    {
      "label": "Average days to cure a document exception",
      "before": "12 days",
      "after": "2.5 days"
    },
    {
      "label": "Branch staff hours chasing documents per week",
      "before": "25 hrs",
      "after": "4 hrs"
    }
  ],
  "statusQuo": [
    "Branch staff keep personal spreadsheets of missing signature cards and ID documents because Temenos Transact exceptions are only reviewed weekly.",
    "Follow-up calls and emails to customers are ad hoc, so exceptions age for weeks before anyone notices.",
    "Audit findings repeatedly cite unsigned account agreements that were never routed for e-signature."
  ],
  "agentification": [
    "Detects new-account document exceptions in Temenos Transact the moment an account is booked and matches them against required-document checklists.",
    "Routes missing agreements to DocuSign and drafts customer reminder messages on a cadence until the packet is complete.",
    "Notifies the branch operations manager with a daily aging summary and escalates exceptions older than ten days."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Temenos Transact",
        "description": "core accounts, account transactions, standing orders records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "DocuSign",
        "description": "envelopes, recipients, audit trails records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query core accounts and account transactions from Temenos Transact and correlate with DocuSign for the Account Opening Document Follow-Up Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Branch Operations Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Account Opening Document Follow-Up Agent Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Temenos Transact with a full audit trail, and escalate exceptions to the Branch Operations Manager."
      }
    ]
  },
