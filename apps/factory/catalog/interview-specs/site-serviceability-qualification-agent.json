    {
      "label": "Serviceability check turnaround",
      "before": "3 days",
      "after": "under 5 minutes"
    },
    {
      "label": "Orders cancelled for non-serviceability",
      "before": "9%",
      "after": "1.5%"
    },
    {
      "label": "Multi-site qualification throughput",
      "before": "20 sites/day",
      "after": "500 sites/day"
    }
  ],
  "statusQuo": [
    "Solution consultants email the network planning team a spreadsheet of addresses and wait days for lit-building answers.",
    "Address-matching errors between CRM and network inventory produce false negatives that kill viable deals.",
    "Near-net buildings requiring short fiber laterals are quoted as off-net because build-cost data is buried in planning tools."
  ],
  "agentification": [
    "The agent qualifies entire multi-site address lists against fiber routes, lit buildings, and fixed-wireless coverage in one pass.",
    "It resolves fuzzy address matches and flags near-net sites with an estimated lateral build cost and interval.",
    "It publishes a color-coded serviceability matrix back to the opportunity and recommends the best access technology per site."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Communications Cloud",
        "description": "subscriber accounts, service quotes, order captures records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query subscriber accounts and service quotes from Salesforce Communications Cloud for the Site Serviceability Qualification Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Sales Solution Consultant's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Site Serviceability Qualification Agent Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Salesforce Communications Cloud with a full audit trail, and escalate exceptions to the Sales Solution Consultant."
      }
    ]
  },
