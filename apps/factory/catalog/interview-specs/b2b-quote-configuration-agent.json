  "kpis": [
    {
      "label": "Quote turnaround time",
      "before": "4.5 days",
      "after": "6 hours"
    },
    {
      "label": "Quote configuration error rate",
      "before": "12%",
      "after": "2%"
    },
    {
      "label": "Quote-to-order conversion",
      "before": "31%",
      "after": "44%"
    }
  ],
  "statusQuo": [
    "Sales engineers manually assemble multi-site MPLS and SD-WAN quotes across spreadsheets and legacy price books.",
    "Each enterprise quote requires back-and-forth email threads with product management to validate discount thresholds.",
    "Misconfigured bandwidth tiers and missing cross-connect charges surface only after the order hits provisioning."
  ],
  "agentification": [
    "The agent assembles a validated multi-site quote from the opportunity record, applying current price books and approved discount bands automatically.",
    "It checks serviceability and access technology per site against network inventory before any line item is priced.",
    "It drafts the customer-ready proposal document and routes out-of-policy discounts to the deal desk for approval."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Communications Cloud",
        "description": "subscriber accounts, service quotes, order captures records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query subscriber accounts and service quotes from Salesforce Communications Cloud for the B2B Quote Configuration Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the B2B Sales Engineer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the B2B Quote Configuration Agent Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in Salesforce Communications Cloud with a full audit trail, and escalate exceptions to the B2B Sales Engineer."
      }
    ]
  },
