  "department": "telco",
  "sourcePath": "catalog/interview-specs/b2b-quote-configuration-agent.json",
  "subtitle": "T-4101 • Sales & Customer Acquisition",
  "persona": "B2B Sales Engineer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "on-demand",
