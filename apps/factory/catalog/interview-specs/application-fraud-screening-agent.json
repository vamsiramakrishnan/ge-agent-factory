{
  "id": "application-fraud-screening-agent",
  "title": "Application Fraud Screening Agent",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/application-fraud-screening-agent.json",
  "subtitle": "I-3603 • Fraud, SIU & Compliance",
  "persona": "Underwriting Fraud Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-36",
  "systems": [
    "FRISS Fraud Detection",
    "LexisNexis Risk Solutions",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Material misrepresentation caught at bind",
      "before": "9%",
      "after": "48%"
    },
    {
      "label": "Rate evasion premium loss",
      "before": "$7.3M annually",
      "after": "$2.6M annually"
    },
    {
      "label": "False-positive hold rate on clean applications",
      "before": "11%",
      "after": "3%"
    }
  ],
  "statusQuo": [
    "Garaging address fraud, undisclosed drivers, and prior-carrier cancellation history surface only after a claim is filed.",
    "Analysts manually spot-check a small sample of new business applications against third-party data.",
    "Agent-assisted rate manipulation patterns go undetected because no one aggregates application anomalies by producer."
  ],
  "agentification": [
    "Screens every application at quote and bind against FRISS device, identity, and behavior signals plus LexisNexis household and vehicle data.",
    "Flags discrepancies — garaging mismatches, undisclosed operators, recycled identities — and routes them for verification before issue.",
    "Aggregates anomaly patterns by producer in BigQuery and escalates suspicious agency-level clusters to the fraud analyst."
  ],
  "architecture": {
    "connections": [
      {
        "system": "FRISS Fraud Detection",
        "description": "fraud screening scores, network link indicators, siu referrals records"
      },
      {
        "system": "LexisNexis Risk Solutions",
        "description": "risk reports, mvr records, prefill datasets records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query fraud screening scores and network link indicators from FRISS Fraud Detection and correlate with LexisNexis Risk Solutions for the Application Fraud Screening Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Underwriting Fraud Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Application Fraud Screening Agent Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in FRISS Fraud Detection with a full audit trail, and escalate exceptions to the Underwriting Fraud Analyst."
      }
    ]
  },
