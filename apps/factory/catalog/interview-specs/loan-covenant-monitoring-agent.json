{
  "id": "loan-covenant-monitoring-agent",
  "title": "Loan Covenant Monitoring Agent",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/loan-covenant-monitoring-agent.json",
  "subtitle": "B-2201 • Lending & Credit",
  "persona": "Credit Risk Officer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-22",
  "systems": [
    "nCino Loan Origination",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Covenant tests completed on time",
      "before": "71%",
      "after": "99%"
    },
    {
      "label": "Days from financials received to covenant result",
      "before": "18 days",
      "after": "1 day"
    },
    {
      "label": "Undetected covenant breaches per year",
      "before": "9",
      "after": "0"
    }
  ],
  "statusQuo": [
    "Analysts track hundreds of financial covenants in spreadsheets keyed off loan agreements stored as PDFs in nCino.",
    "Borrower financial statements arrive by email and sit unprocessed for weeks before ratios are calculated by hand.",
    "Breaches are often discovered months late, forcing hurried waiver negotiations and criticized-asset write-ups."
  ],
  "agentification": [
    "Extracts covenant terms from executed loan agreements in nCino and builds a per-facility testing calendar automatically.",
    "Computes leverage, coverage, and liquidity ratios from incoming borrower financials and records pass/fail results in BigQuery.",
    "Escalates breaches and near-breaches to the credit risk officer with a drafted waiver memo and trend analysis."
  ],
  "architecture": {
    "connections": [
      {
        "system": "nCino Loan Origination",
        "description": "loan applications, credit memos, covenant records records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query loan applications and credit memos from nCino Loan Origination for the Loan Covenant Monitoring Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Credit Risk Officer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Loan Covenant Monitoring Agent Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in nCino Loan Origination with a full audit trail, and escalate exceptions to the Credit Risk Officer."
      }
    ]
  },
