  "id": "number-porting-exception-agent",
  "title": "Number Porting Exception Agent",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/number-porting-exception-agent.json",
  "subtitle": "T-4203 • Order Management & Provisioning",
  "persona": "Porting Desk Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-42",
  "systems": [
    "Netcracker Service Orchestration",
    "BigQuery",
    "Zendesk",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Port-in rejection rate",
      "before": "22%",
      "after": "7%"
    },
    {
      "label": "Average port completion time",
      "before": "5.5 days",
      "after": "1.8 days"
    },
    {
      "label": "Porting escalations to regulator",
      "before": "35/quarter",
      "after": "6/quarter"
    }
  ],
  "statusQuo": [
    "Porting analysts manually compare rejected LSR fields against losing-carrier CSRs to find the one mismatched character.",
    "Account-number and ZIP mismatches bounce ports back to the customer, who often abandons the switch entirely.",
    "Wholesale partner porting disputes are tracked in email threads with no visibility into aging or ownership."
  ],
  "agentification": [
    "The agent parses each port rejection, identifies the mismatched field, and drafts the corrected resubmission for one-click approval.",
    "It proactively validates port-in requests against carrier CSR data before first submission to prevent rejections.",
    "It escalates ports approaching regulatory interval deadlines with a complete case history attached."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Netcracker Service Orchestration",
        "description": "service orders, provisioning tasks, network inventory items records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Zendesk",
        "description": "tickets, macros, satisfaction scores records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query service orders and provisioning tasks from Netcracker Service Orchestration and correlate with Zendesk for the Number Porting Exception Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Porting Desk Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Number Porting Exception Agent Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Netcracker Service Orchestration with a full audit trail, and escalate exceptions to the Porting Desk Analyst."
      }
    ]
  },
