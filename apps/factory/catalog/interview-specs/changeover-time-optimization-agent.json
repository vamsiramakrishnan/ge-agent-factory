  "id": "changeover-time-optimization-agent",
  "title": "Changeover Time Optimization Agent",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/changeover-time-optimization-agent.json",
  "subtitle": "M-5104 • Production & Shop Floor",
  "persona": "Production Supervisor",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-51",
  "systems": [
    "SAP S/4HANA PP",
    "Siemens Opcenter MES",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Average changeover time",
      "before": "47 min",
      "after": "28 min"
    },
    {
      "label": "Changeovers exceeding standard",
      "before": "35%",
      "after": "9%"
    },
    {
      "label": "Weekly capacity recovered",
      "before": "0 hrs",
      "after": "11 hrs"
    }
  ],
  "statusQuo": [
    "Changeover durations vary wildly between crews and nobody knows which sequence tricks the fastest crew uses.",
    "The production sequence from SAP ignores changeover families, so the line runs light-to-dark-to-light color swaps back to back.",
    "Supervisors find out a changeover blew past standard only when the whole shift output number comes in short."
  ],
  "agentification": [
    "Analyzes every changeover recorded in Opcenter MES weekly and benchmarks duration by crew, product family, and sequence.",
    "Recommends changeover-family-aware sequencing adjustments to the SAP S/4HANA PP planned order sequence.",
    "Notifies the supervisor in real time when a live changeover exceeds 120% of standard so help can be routed to the line."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA PP",
        "description": "process orders, work center confirmations, material stagings records"
      },
      {
        "system": "Siemens Opcenter MES",
        "description": "production orders, machine events, quality checks records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query process orders and work center confirmations from SAP S/4HANA PP and correlate with Siemens Opcenter MES for the Changeover Time Optimization Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Production Supervisor's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Changeover Time Optimization Agent Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in SAP S/4HANA PP with a full audit trail, and escalate exceptions to the Production Supervisor."
      }
    ]
  },
