{
  "id": "supplier-delivery-risk-analyzer",
  "title": "Supplier Delivery Risk Analyzer",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/supplier-delivery-risk-analyzer.json",
  "subtitle": "M-5402 • Supply Chain & Materials",
  "persona": "Materials Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-54",
  "systems": [
    "Kinaxis RapidResponse",
    "SAP S/4HANA MM",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Supplier on-time delivery",
      "before": "84%",
      "after": "95%"
    },
    {
      "label": "POs flagged at risk before due date",
      "before": "10%",
      "after": "72%"
    },
    {
      "label": "Safety stock held against unreliable suppliers",
      "before": "$3.1M",
      "after": "$1.9M"
    }
  ],
  "statusQuo": [
    "On-time delivery is reported monthly in arrears, so a supplier's slide shows up in the metrics six weeks after it started hurting the plant.",
    "Buyers chase overdue POs one by one with no view of which supplier's slippage actually threatens production.",
    "Safety stocks are padded uniformly because nobody quantifies delivery risk per supplier."
  ],
  "agentification": [
    "Scores every open purchase order's late-delivery probability from the supplier's rolling performance, order size, and lead-time trend in BigQuery.",
    "Simulates the production impact of predicted slips through Kinaxis RapidResponse and highlights the POs worth chasing this week.",
    "Publishes supplier reliability trend dashboards in Looker and recommends differentiated safety stock levels to the materials manager."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Kinaxis RapidResponse",
        "description": "supply plans, demand signals, scenario runs records"
      },
      {
        "system": "SAP S/4HANA MM",
        "description": "purchase orders, material movements, vendors records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query supply plans and demand signals from Kinaxis RapidResponse and correlate with SAP S/4HANA MM for the Supplier Delivery Risk Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Materials Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Supplier Delivery Risk Analyzer Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Kinaxis RapidResponse with a full audit trail, and escalate exceptions to the Materials Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Supplier Delivery Risk Analyzer so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
