{
  "id": "field-job-closure-quality-analyzer",
  "title": "Field Job Closure Quality Analyzer",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/field-job-closure-quality-analyzer.json",
  "subtitle": "T-4605 • Field Service & Infrastructure",
  "persona": "Field Quality Auditor",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-46",
  "systems": [
    "Oracle Field Service",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Repeat dispatch within 30 days",
      "before": "17%",
      "after": "6%"
    },
    {
      "label": "Jobs audited per cycle",
      "before": "2% manual sample",
      "after": "100%"
    },
    {
      "label": "As-built inventory accuracy",
      "before": "82%",
      "after": "97%"
    }
  ],
  "statusQuo": [
    "Quality auditors manually review a 2% sample of closed jobs, so poor workmanship patterns persist for months.",
    "Closure photos and light-level readings are attached inconsistently and nobody checks them against standards.",
    "Inaccurate as-built updates from rushed closures corrupt the inventory that every downstream order depends on."
  ],
  "agentification": [
    "The analyzer audits every closed job by checking photos, signal readings, and test results against workmanship standards.",
    "It scores technicians and crews on closure quality trends and recommends targeted coaching to their supervisors.",
    "It flags jobs with high repeat-dispatch risk for proactive follow-up and creates inventory correction tasks when as-built data conflicts with network records."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Field Service",
        "description": "field work orders, technician schedules, service appointments records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query field work orders and technician schedules from Oracle Field Service for the Field Job Closure Quality Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Field Quality Auditor's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Field Job Closure Quality Analyzer Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in Oracle Field Service with a full audit trail, and escalate exceptions to the Field Quality Auditor."
      }
    ]
  },
