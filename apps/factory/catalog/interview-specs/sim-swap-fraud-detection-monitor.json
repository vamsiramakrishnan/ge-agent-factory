  "kpis": [
    {
      "label": "Fraudulent SIM swap interception rate",
      "before": "31%",
      "after": "88%"
    },
    {
      "label": "Fraud loss per incident",
      "before": "$4,200 average",
      "after": "$600 average"
    },
    {
      "label": "False-positive customer friction rate",
      "before": "8% of legit swaps challenged",
      "after": "1.5%"
    }
  ],
  "statusQuo": [
    "Fraud analysts review SIM swap alerts from a rules engine hours after the swap, well after account-takeover damage is done.",
    "Static rules flag thousands of legitimate device upgrades, burying the handful of genuine takeover attempts.",
    "Correlating a swap with subsequent high-risk actions like international premium calls requires manual queries across three systems."
  ],
  "agentification": [
    "The monitor scores every SIM swap in real time against behavioral signals like recent credential resets, dormancy, and channel anomalies.",
    "It automatically holds high-risk swaps pending step-up verification and applies temporary blocks on premium and international routing.",
    "It escalates confirmed fraud patterns to the fraud team with a complete event timeline and notifies affected customers through a verified channel."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Amdocs CES Billing",
        "description": "billing accounts, usage records, rated events records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Splunk",
        "description": "log events, search jobs, alert actions records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query billing accounts and usage records from Amdocs CES Billing and correlate with Splunk for the SIM Swap Fraud Detection Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Fraud Operations Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the SIM Swap Fraud Detection Monitor Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Amdocs CES Billing with a full audit trail, and escalate exceptions to the Fraud Operations Analyst."
      }
    ]
  },
