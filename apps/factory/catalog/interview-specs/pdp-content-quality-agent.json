{
  "id": "pdp-content-quality-agent",
  "title": "PDP Content Quality Agent",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/pdp-content-quality-agent.json",
  "subtitle": "R-1401 • E-Commerce & Digital",
  "persona": "E-Commerce Merchandiser",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-14",
  "systems": [
    "Salesforce Commerce Cloud",
    "GA4",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "PDP content completeness score",
      "before": "67%",
      "after": "96%"
    },
    {
      "label": "PDP conversion rate",
      "before": "2.1%",
      "after": "3.0%"
    },
    {
      "label": "Time to enrich a new product page",
      "before": "4 days",
      "after": "20 minutes"
    }
  ],
  "statusQuo": [
    "Merchandisers audit product pages one at a time against a checklist in a shared doc.",
    "Thin descriptions and missing size charts are found via customer complaints, not monitoring.",
    "Copywriting backlogs delay long-tail items from ever getting proper content."
  ],
  "agentification": [
    "Scans every PDP in Commerce Cloud for missing attributes, weak copy, image gaps, and broken cross-sells.",
    "Drafts SEO-aware descriptions and bullet copy from supplier data for merchandiser approval.",
    "Prioritizes fixes by GA4 traffic and revenue impact and publishes approved content back to the site."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Commerce Cloud",
        "description": "online orders, product catalog entries, cart events records"
      },
      {
        "system": "GA4",
        "description": "session events, conversion paths, audience segments records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query online orders and product catalog entries from Salesforce Commerce Cloud and correlate with GA4 for the PDP Content Quality Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the E-Commerce Merchandiser's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the PDP Content Quality Agent Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Salesforce Commerce Cloud with a full audit trail, and escalate exceptions to the E-Commerce Merchandiser."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for PDP Content Quality Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
