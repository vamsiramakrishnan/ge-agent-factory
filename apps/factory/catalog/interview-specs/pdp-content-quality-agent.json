        "id": "pdp-content-quality-agent-baseline-gap",
        "description": "Seed a realistic gap where PDP content completeness score sits between 67% and 96%, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "online_orders",
          "product_catalog_entries"
        ],
        "discoveryPath": [
          "Inspect Salesforce Commerce Cloud records for the affected entities",
          "Compare against GA4 historical baseline",
          "Generate a citation-backed recommendation"
