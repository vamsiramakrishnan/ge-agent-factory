  "id": "inventory-rebalancing-orchestrator",
  "title": "Inventory Rebalancing Orchestrator",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/inventory-rebalancing-orchestrator.json",
  "subtitle": "M-5403 • Supply Chain & Materials",
  "persona": "Inventory Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-54",
  "systems": [
    "Kinaxis RapidResponse",
    "SAP S/4HANA MM",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Excess and obsolete inventory",
      "before": "$4.8M",
      "after": "$2.6M"
    },
    {
      "label": "Inter-site transfer cycle time",
      "before": "12 days",
      "after": "4 days"
    },
    {
      "label": "Inventory turns",
      "before": "5.2",
      "after": "7.4"
    }
  ],
  "statusQuo": [
    "One plant expedites a component at premium cost while a sister plant sits on eight months of the same part.",
    "Rebalancing opportunities are found once a quarter through a manual multi-site spreadsheet reconciliation.",
    "Transfer orders take days to arrange because each one requires an email negotiation between site planners."
  ],
  "agentification": [
    "Scans multi-site stock positions and projected demand in Kinaxis RapidResponse and SAP S/4HANA MM data in BigQuery every night for surplus-deficit pairs.",
    "Recommends specific inter-site transfers with freight cost versus expedite cost trade-offs quantified.",
    "Drafts the stock transport orders in SAP for approval and tracks each transfer through receipt."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Kinaxis RapidResponse",
        "description": "supply plans, demand signals, scenario runs records"
      },
      {
        "system": "SAP S/4HANA MM",
        "description": "purchase orders, material movements, vendors records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query supply plans and demand signals from Kinaxis RapidResponse and correlate with SAP S/4HANA MM for the Inventory Rebalancing Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Inventory Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Inventory Rebalancing Orchestrator Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in Kinaxis RapidResponse with a full audit trail, and escalate exceptions to the Inventory Analyst."
      }
    ]
  },
