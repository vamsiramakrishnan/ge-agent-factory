{
  "id": "demand-supply-gap-scenario-engine",
  "title": "Demand-Supply Gap Scenario Engine",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/demand-supply-gap-scenario-engine.json",
  "subtitle": "M-5405 • Supply Chain & Materials",
  "persona": "S&OP Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "on-demand",
  "domainId": "domain-54",
  "systems": [
    "Kinaxis RapidResponse",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "S&OP scenario turnaround",
      "before": "4 days",
      "after": "20 minutes"
    },
    {
      "label": "Forecast bias",
      "before": "+9%",
      "after": "+2%"
    },
    {
      "label": "Revenue at risk identified pre-quarter",
      "before": "$2M of $8M",
      "after": "$7M of $8M"
    }
  ],
  "statusQuo": [
    "Each what-if question from the executive S&OP meeting takes the planning team most of a week to model.",
    "Demand-supply gaps are presented as aggregate units, hiding which customers and SKUs actually absorb the shortfall.",
    "Scenario assumptions live in personal spreadsheets that disagree with the system of record."
  ],
  "agentification": [
    "Runs demand-shift, capacity-loss, and supplier-disruption scenarios through Kinaxis RapidResponse on request and lands results in BigQuery for comparison.",
    "Translates each gap into affected customers, SKUs, revenue, and margin rather than aggregate units.",
    "Generates the executive S&OP briefing with side-by-side scenario trade-offs and publishes it to Looker before the meeting."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Kinaxis RapidResponse",
        "description": "supply plans, demand signals, scenario runs records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query supply plans and demand signals from Kinaxis RapidResponse for the Demand-Supply Gap Scenario Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the S&OP Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Demand-Supply Gap Scenario Engine Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Kinaxis RapidResponse with a full audit trail, and escalate exceptions to the S&OP Manager."
      }
    ]
  },
