{
  "id": "production-schedule-adherence-monitor",
  "title": "Production Schedule Adherence Monitor",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/production-schedule-adherence-monitor.json",
  "subtitle": "M-5102 • Production & Shop Floor",
  "persona": "Production Scheduler",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-51",
  "systems": [
    "SAP S/4HANA PP",
    "Siemens Opcenter MES",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Schedule adherence",
      "before": "78%",
      "after": "93%"
    },
    {
      "label": "Late order detection lead time",
      "before": "0 days (found at due date)",
      "after": "3 days early"
    },
    {
      "label": "Expedite freight spend per quarter",
      "before": "$410K",
      "after": "$180K"
    }
  ],
  "statusQuo": [
    "The scheduler reconciles SAP planned orders against MES confirmations in a spreadsheet every morning, an exercise that takes two hours.",
    "Orders slipping behind plan are only discovered when a customer service rep calls asking where the shipment is.",
    "Re-sequencing decisions are made from gut feel because the true capacity impact of a slip is never quantified."
  ],
  "agentification": [
    "Runs every shift to compare SAP S/4HANA PP planned orders against actual MES confirmations landed in BigQuery.",
    "Flags orders trending late, quantifies the downstream capacity and customer impact, and recommends a re-sequencing option.",
    "Publishes a shift-start adherence dashboard in Looker and notifies the scheduler of the top three at-risk orders."
  ],
  "architecture": {
    "connections": [
      {
        "system": "SAP S/4HANA PP",
        "description": "process orders, work center confirmations, material stagings records"
      },
      {
        "system": "Siemens Opcenter MES",
        "description": "production orders, machine events, quality checks records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query process orders and work center confirmations from SAP S/4HANA PP and correlate with Siemens Opcenter MES for the Production Schedule Adherence Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Production Scheduler's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Production Schedule Adherence Monitor Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in SAP S/4HANA PP with a full audit trail, and escalate exceptions to the Production Scheduler."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Production Schedule Adherence Monitor so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
