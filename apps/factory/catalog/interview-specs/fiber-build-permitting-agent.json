  "id": "fiber-build-permitting-agent",
  "title": "Fiber Build Permitting Agent",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/fiber-build-permitting-agent.json",
  "subtitle": "T-4603 • Field Service & Infrastructure",
  "persona": "Construction Program Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "on-demand",
  "domainId": "domain-46",
  "systems": [
    "Oracle Field Service",
    "BigQuery",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Permit application preparation time",
      "before": "6 hours each",
      "after": "35 minutes each"
    },
    {
      "label": "Permit rejection/resubmission rate",
      "before": "33%",
      "after": "10%"
    },
    {
      "label": "Average permit-driven build delay",
      "before": "45 days",
      "after": "18 days"
    }
  ],
  "statusQuo": [
    "Program managers track thousands of municipal permits across dozens of jurisdictions in a shared spreadsheet with no aging alerts.",
    "Each jurisdiction's application format and traffic-control requirements are tribal knowledge held by one or two coordinators.",
    "Expired permits and missed utility-locate windows idle construction crews at $10K per day."
  ],
  "agentification": [
    "The agent drafts permit applications pre-filled with route drawings, traffic plans, and jurisdiction-specific requirements from a maintained rules library.",
    "It tracks every application's status, ages against jurisdiction SLAs, and escalates stalled permits with the required follow-up action.",
    "It sequences build segments around forecast permit-grant dates and alerts crews before locates or permits expire."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Oracle Field Service",
        "description": "field work orders, technician schedules, service appointments records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query field work orders and technician schedules from Oracle Field Service and correlate with ServiceNow for the Fiber Build Permitting Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Construction Program Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Fiber Build Permitting Agent Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Oracle Field Service with a full audit trail, and escalate exceptions to the Construction Program Manager."
      }
    ]
  },
