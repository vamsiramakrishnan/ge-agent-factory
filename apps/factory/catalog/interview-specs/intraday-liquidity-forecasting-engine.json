{
  "id": "intraday-liquidity-forecasting-engine",
  "title": "Intraday Liquidity Forecasting Engine",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/intraday-liquidity-forecasting-engine.json",
  "subtitle": "B-2601 • Treasury & Market Risk",
  "persona": "Treasury Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-26",
  "systems": [
    "Murex MX.3",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Intraday forecast error",
      "before": "±18%",
      "after": "±5%"
    },
    {
      "label": "Excess liquidity buffer held",
      "before": "$900M",
      "after": "$550M"
    },
    {
      "label": "Forecast production time each morning",
      "before": "2.5 hrs",
      "after": "10 min"
    }
  ],
  "statusQuo": [
    "The morning liquidity forecast is assembled in spreadsheets from Murex positions, nostro statements, and payment schedules before markets open.",
    "Large unexpected outflows force same-day borrowing at penalty rates because the forecast missed a settlement spike.",
    "The bank holds an oversized liquidity buffer as insurance against forecast error, dragging on net interest income."
  ],
  "agentification": [
    "Forecasts intraday cash positions per currency by combining Murex MX.3 settlement ladders, historical payment flows, and scheduled client activity.",
    "Publishes an hourly-updated funding plan to Looker with recommended money-market actions per currency.",
    "Escalates projected shortfalls to the treasury manager hours before cutoffs with ranked funding options and costs."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Murex MX.3",
        "description": "trades, positions, risk measures records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query trades and positions from Murex MX.3 for the Intraday Liquidity Forecasting Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Treasury Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Intraday Liquidity Forecasting Engine Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Murex MX.3 with a full audit trail, and escalate exceptions to the Treasury Manager."
      }
    ]
  },
