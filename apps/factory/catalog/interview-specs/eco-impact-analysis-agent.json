      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for ECO Impact Analysis Agent so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
