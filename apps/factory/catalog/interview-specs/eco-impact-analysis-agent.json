{
  "id": "eco-impact-analysis-agent",
  "title": "ECO Impact Analysis Agent",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/eco-impact-analysis-agent.json",
  "subtitle": "M-5501 • Engineering & PLM",
  "persona": "Manufacturing Engineer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-55",
  "systems": [
    "PTC Windchill PLM",
    "SAP S/4HANA PP",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "ECO cycle time",
      "before": "34 days",
      "after": "12 days"
    },
    {
      "label": "Obsolete inventory written off per change",
      "before": "$45K avg",
      "after": "$12K avg"
    },
    {
      "label": "Changes released with missed impacts",
      "before": "15%",
      "after": "3%"
    }
  ],
  "statusQuo": [
    "Assessing a change means manually tracing where-used across Windchill BOMs, then separately checking SAP for open orders and on-hand stock.",
    "Effectivity dates are picked without knowing how much inventory the change will strand.",
    "Downstream teams learn about a released change when a part stops fitting on the line."
  ],
  "agentification": [
    "Traces full where-used impact across PTC Windchill PLM product structures the moment an ECO enters review, joined with open orders, WIP, and inventory from SAP S/4HANA PP in BigQuery.",
    "Recommends the effectivity date that minimizes stranded inventory and open-order disruption, with the cost trade-off quantified.",
    "Drafts the impact summary for the change board and notifies affected planners, buyers, and line engineers on release."
  ],
  "architecture": {
    "connections": [
      {
        "system": "PTC Windchill PLM",
        "description": "engineering change orders, bom revisions, cad document records records"
      },
      {
        "system": "SAP S/4HANA PP",
        "description": "process orders, work center confirmations, material stagings records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query engineering change orders and bom revisions from PTC Windchill PLM and correlate with SAP S/4HANA PP for the ECO Impact Analysis Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Manufacturing Engineer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the ECO Impact Analysis Agent Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in PTC Windchill PLM with a full audit trail, and escalate exceptions to the Manufacturing Engineer."
      }
    ]
  },
  "generationSpec": {
