{
  "id": "fraud-ring-network-analyzer",
  "title": "Fraud Ring Network Analyzer",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/fraud-ring-network-analyzer.json",
  "subtitle": "I-3602 • Fraud, SIU & Compliance",
  "persona": "SIU Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-36",
  "systems": [
    "FRISS Fraud Detection",
    "LexisNexis Risk Solutions",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Organized fraud rings identified per year",
      "before": "3",
      "after": "14"
    },
    {
      "label": "Average ring exposure at detection",
      "before": "$2.1M",
      "after": "$0.5M"
    },
    {
      "label": "Cross-claim link discovery time",
      "before": "weeks of manual research",
      "after": "hours"
    }
  ],
  "statusQuo": [
    "Investigators spot ring activity only when the same body shop or clinic name happens to catch someone's eye across files.",
    "Shared phone numbers, addresses, and bank accounts across claims are invisible without manual cross-referencing.",
    "Staged-accident rings rotate participants faster than case-by-case investigation can connect them."
  ],
  "agentification": [
    "Builds entity-resolution graphs across claims, providers, and participants nightly in BigQuery, enriched with LexisNexis identity data.",
    "Detects suspicious clusters — shared identifiers, provider billing patterns, choreographed loss sequences — and scores them for organized activity.",
    "Creates ring case files with network visualizations and recommends which claims to consolidate under a single SIU investigation."
  ],
  "architecture": {
    "connections": [
      {
        "system": "FRISS Fraud Detection",
        "description": "fraud screening scores, network link indicators, siu referrals records"
      },
      {
        "system": "LexisNexis Risk Solutions",
        "description": "risk reports, mvr records, prefill datasets records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query fraud screening scores and network link indicators from FRISS Fraud Detection and correlate with LexisNexis Risk Solutions for the Fraud Ring Network Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the SIU Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Fraud Ring Network Analyzer Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in FRISS Fraud Detection with a full audit trail, and escalate exceptions to the SIU Manager."
      }
    ]
  },
