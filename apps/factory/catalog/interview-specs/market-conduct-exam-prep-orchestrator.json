    "Guidewire PolicyCenter",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Exam data call fulfillment time",
      "before": "6 weeks",
      "after": "1 week"
    },
    {
      "label": "Findings from unpreparedness (vs. substantive)",
      "before": "40% of findings",
      "after": "8% of findings"
    },
    {
      "label": "Staff hours consumed per exam",
      "before": "2,800",
      "after": "900"
    }
  ],
  "statusQuo": [
    "A market conduct data call pulls a dozen staff off their jobs for weeks to extract, reconcile, and format policy and claims records.",
    "Self-audit happens only after an exam is announced, so known issues surface with no time to remediate.",
    "Prior exam findings and remediation commitments live in scattered documents nobody re-checks until the next exam."
  ],
  "agentification": [
    "Maintains exam-ready data marts in BigQuery mapped to NAIC market conduct standards, refreshed from PolicyCenter continuously.",
    "Runs ongoing self-audits against timeliness, disclosure, and handling standards and escalates emerging violations before regulators find them.",
    "Generates examiner data-call packages in the requested format and drafts responses to prior-finding follow-ups with remediation evidence attached."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire PolicyCenter",
        "description": "policies, policy quotes, underwriting submissions records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query policies and policy quotes from Guidewire PolicyCenter for the Market Conduct Exam Prep Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Regulatory Affairs Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Market Conduct Exam Prep Orchestrator Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Guidewire PolicyCenter with a full audit trail, and escalate exceptions to the Regulatory Affairs Manager."
      }
    ]
  },
