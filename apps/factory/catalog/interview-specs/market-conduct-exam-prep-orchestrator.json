  "sourcePath": "catalog/interview-specs/market-conduct-exam-prep-orchestrator.json",
  "subtitle": "I-3605 • Fraud, SIU & Compliance",
  "persona": "Regulatory Affairs Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "on-demand",
  "domainId": "domain-36",
