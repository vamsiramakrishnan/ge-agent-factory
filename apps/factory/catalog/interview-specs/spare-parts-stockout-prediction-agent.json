  "sourcePath": "catalog/interview-specs/spare-parts-stockout-prediction-agent.json",
  "subtitle": "M-5303 • Maintenance & Reliability",
  "persona": "MRO Storeroom Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-53",
  "systems": [
    "IBM Maximo",
    "SAP S/4HANA MM",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Stockout-driven downtime hours",
      "before": "95 hrs/yr",
      "after": "20 hrs/yr"
    },
    {
      "label": "Spare parts inventory value",
      "before": "$6.4M",
      "after": "$5.1M"
    },
    {
      "label": "Critical spares service level",
      "before": "88%",
      "after": "99%"
    }
  ],
  "statusQuo": [
    "Min/max levels were set once at commissioning and never adjusted, so fast movers stock out while obsolete parts gather dust.",
    "A critical repair stalls for two weeks because the one bearing on the shelf turned out to be reserved against another work order.",
    "The storeroom manager discovers a lead-time change only when the expedite quote comes back at triple the price."
  ],
  "agentification": [
    "Forecasts part-level demand from IBM Maximo work order history, upcoming PM schedules, and asset criticality in BigQuery.",
    "Predicts stockout risk against on-hand and on-order quantities in SAP S/4HANA MM, accounting for current supplier lead times.",
    "Recommends reorder point changes and drafts purchase requisitions for at-risk critical spares before the shelf goes empty."
  ],
  "architecture": {
    "connections": [
      {
        "system": "IBM Maximo",
        "description": "maintenance work orders, asset registry entries, failure codes records"
      },
      {
        "system": "SAP S/4HANA MM",
        "description": "purchase orders, material movements, vendors records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query maintenance work orders and asset registry entries from IBM Maximo and correlate with SAP S/4HANA MM for the Spare Parts Stockout Prediction Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the MRO Storeroom Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Spare Parts Stockout Prediction Agent Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in IBM Maximo with a full audit trail, and escalate exceptions to the MRO Storeroom Manager."
      }
    ]
  },
