  "sourcePath": "catalog/interview-specs/commercial-credit-memo-drafting-agent.json",
  "subtitle": "B-2202 • Lending & Credit",
  "persona": "Commercial Credit Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "on-demand",
  "domainId": "domain-22",
  "systems": [
    "nCino Loan Origination",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Time to first-draft credit memo",
      "before": "3 days",
      "after": "45 minutes"
    },
    {
      "label": "Deals underwritten per analyst per month",
      "before": "6",
      "after": "15"
    },
    {
      "label": "Memo rework cycles before committee",
      "before": "3.2",
      "after": "1.1"
    }
  ],
  "statusQuo": [
    "Analysts spend two to three days per deal copying borrower financials, collateral details, and exposure data from nCino into a Word memo template.",
    "Industry and market context is researched from scratch for every deal, even for repeat borrowers in familiar sectors.",
    "Credit committee sends memos back repeatedly for missing global-exposure tables and inconsistent ratio calculations."
  ],
  "agentification": [
    "Assembles borrower financial spreads, global exposure, and collateral positions from nCino and BigQuery into the bank's memo template.",
    "Drafts the narrative sections including industry outlook, repayment analysis, and risk mitigants for analyst review.",
    "Flags policy exceptions such as LTV or hold-limit overages and generates the required exception justification section."
  ],
  "architecture": {
    "connections": [
      {
        "system": "nCino Loan Origination",
        "description": "loan applications, credit memos, covenant records records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query loan applications and credit memos from nCino Loan Origination for the Commercial Credit Memo Drafting Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Commercial Credit Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Commercial Credit Memo Drafting Agent Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the generate step in nCino Loan Origination with a full audit trail, and escalate exceptions to the Commercial Credit Analyst."
      }
    ]
  },
