{
  "id": "site-search-relevance-engine",
  "title": "Site Search Relevance Engine",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/site-search-relevance-engine.json",
  "subtitle": "R-1402 • E-Commerce & Digital",
  "persona": "Digital Merchandising Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-14",
  "systems": [
    "Salesforce Commerce Cloud",
    "GA4",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Null search result rate",
      "before": "14%",
      "after": "2.5%"
    },
    {
      "label": "Search-led conversion rate",
      "before": "3.8%",
      "after": "5.6%"
    },
    {
      "label": "Synonym/redirect rules maintained",
      "before": "400 manual",
      "after": "9,000 automated"
    }
  ],
  "statusQuo": [
    "The team reviews a top-50 null-results report monthly and hand-writes synonym rules.",
    "Seasonal vocabulary shifts (e.g. 'puffer' vs 'quilted jacket') lag customer language by months.",
    "Nobody knows which search rules help or hurt because there is no per-rule measurement."
  ],
  "agentification": [
    "Mines full search-log tails in BigQuery to detect null, low-click, and misrouted queries daily.",
    "Generates synonym, redirect, and boost-and-bury rules and ships winners through automated A/B tests.",
    "Notifies the Digital Merchandising Manager when trending queries have no matching assortment."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Commerce Cloud",
        "description": "online orders, product catalog entries, cart events records"
      },
      {
        "system": "GA4",
        "description": "session events, conversion paths, audience segments records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query online orders and product catalog entries from Salesforce Commerce Cloud and correlate with GA4 for the Site Search Relevance Engine workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Digital Merchandising Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Site Search Relevance Engine Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in Salesforce Commerce Cloud with a full audit trail, and escalate exceptions to the Digital Merchandising Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Site Search Relevance Engine so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
