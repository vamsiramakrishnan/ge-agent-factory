  "id": "regulatory-complaint-response-agent",
  "title": "Regulatory Complaint Response Agent",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/regulatory-complaint-response-agent.json",
  "subtitle": "I-3604 • Fraud, SIU & Compliance",
  "persona": "Compliance Officer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-36",
  "systems": [
    "Guidewire PolicyCenter",
    "Zendesk",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "DOI complaint response time",
      "before": "18 days",
      "after": "5 days"
    },
    {
      "label": "Late responses incurring regulator follow-up",
      "before": "12%",
      "after": "0.5%"
    },
    {
      "label": "Complaint file assembly effort",
      "before": "6 hours per complaint",
      "after": "45 min per complaint"
    }
  ],
  "statusQuo": [
    "Each DOI complaint kicks off a manual hunt across policy, claims, billing, and correspondence systems to reconstruct what happened.",
    "Response drafting starts from scratch every time, even for recurring complaint themes.",
    "Deadlines vary by state and are tracked in a shared calendar that has missed entries before."
  ],
  "agentification": [
    "Assembles the complete customer file — policy transactions from PolicyCenter, correspondence, Zendesk interactions — the moment a DOI complaint is logged.",
    "Drafts the regulator response with a factual timeline and citations to the governing policy provisions and state rules.",
    "Tracks every statutory deadline, escalates responses at risk of lateness, and publishes complaint-trend analytics to BigQuery for root-cause review."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire PolicyCenter",
        "description": "policies, policy quotes, underwriting submissions records"
      },
      {
        "system": "Zendesk",
        "description": "tickets, macros, satisfaction scores records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query policies and policy quotes from Guidewire PolicyCenter and correlate with Zendesk for the Regulatory Complaint Response Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Compliance Officer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Regulatory Complaint Response Agent Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Guidewire PolicyCenter with a full audit trail, and escalate exceptions to the Compliance Officer."
      }
    ]
  },
