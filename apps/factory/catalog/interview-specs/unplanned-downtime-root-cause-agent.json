{
  "id": "unplanned-downtime-root-cause-agent",
  "title": "Unplanned Downtime Root-Cause Agent",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/unplanned-downtime-root-cause-agent.json",
  "subtitle": "M-5101 • Production & Shop Floor",
  "persona": "Plant Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-51",
  "systems": [
    "Siemens Opcenter MES",
    "OSIsoft PI System",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Unplanned downtime hours per month",
      "before": "62 hrs",
      "after": "38 hrs"
    },
    {
      "label": "Mean time to root cause",
      "before": "3.5 days",
      "after": "4 hours"
    },
    {
      "label": "OEE",
      "before": "68%",
      "after": "76%"
    }
  ],
  "statusQuo": [
    "Downtime events are logged in the MES with generic reason codes that operators pick under time pressure, so the top loss category is 'Other'.",
    "Engineers manually export historian trends and MES logs into spreadsheets days after an event to reconstruct what happened.",
    "Recurring failure patterns across shifts and lines go unnoticed because nobody correlates events across data silos."
  ],
  "agentification": [
    "Listens for downtime events from Opcenter MES and automatically pulls the surrounding sensor window from the PI historian into BigQuery.",
    "Correlates the event against historical failure signatures and drafts a ranked root-cause hypothesis with supporting trend charts.",
    "Escalates repeat offenders to the plant manager and creates a follow-up action item with the evidence package attached."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Siemens Opcenter MES",
        "description": "production orders, machine events, quality checks records"
      },
      {
        "system": "OSIsoft PI System",
        "description": "sensor readings, asset tag hierarchies, downtime events records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query production orders and machine events from Siemens Opcenter MES and correlate with OSIsoft PI System for the Unplanned Downtime Root-Cause Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Plant Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Unplanned Downtime Root-Cause Agent Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Siemens Opcenter MES with a full audit trail, and escalate exceptions to the Plant Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
