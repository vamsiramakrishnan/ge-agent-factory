{
  "id": "network-slice-sla-monitor",
  "title": "5G Network Slice SLA Monitor",
  "department": "telco",
  "sourcePath": "catalog/interview-specs/network-slice-sla-monitor.json",
  "subtitle": "T-4304 • Network Operations & Assurance",
  "persona": "Service Assurance Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-43",
  "systems": [
    "Ericsson Network Manager",
    "BigQuery",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Slice SLA breach detection time",
      "before": "next-day report",
      "after": "under 60 seconds"
    },
    {
      "label": "SLA credits paid to slice customers",
      "before": "$1.8M/year",
      "after": "$400K/year"
    },
    {
      "label": "Slice KPI reporting effort",
      "before": "3 analyst-days/month per customer",
      "after": "fully automated"
    }
  ],
  "statusQuo": [
    "Latency and throughput commitments for private 5G slices are checked against next-day reports, long after the breach hurt the customer.",
    "Each enterprise slice customer gets a hand-assembled monthly SLA pack built from raw counter exports.",
    "Nobody can say in real time whether a factory automation slice is meeting its 10ms latency commitment."
  ],
  "agentification": [
    "The monitor evaluates per-slice latency, throughput, and availability against contracted SLOs continuously.",
    "It triggers slice reconfiguration or resource reallocation workflows when a KPI trends toward breach.",
    "It generates customer-facing SLA reports automatically and escalates confirmed breaches to the account team with credit exposure calculated."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Ericsson Network Manager",
        "description": "network alarms, cell sites, performance counters records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query network alarms and cell sites from Ericsson Network Manager and correlate with ServiceNow for the 5G Network Slice SLA Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Service Assurance Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the 5G Network Slice SLA Monitor Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Ericsson Network Manager with a full audit trail, and escalate exceptions to the Service Assurance Manager."
      }
    ]
  },
