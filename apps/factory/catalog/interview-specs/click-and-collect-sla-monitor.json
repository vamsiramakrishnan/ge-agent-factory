          "trigger": "Online price or promotion displays materially below the store shelf price for BOPIS/curbside items without an approved channel-pricing exception.",
          "action": "escalate_to_human",
          "handoffTarget": "omnichannel_pricing_analyst",
          "rationale": "Unintended channel divergence on pickup orders creates honor-the-lower-price liability at scale and store-level customer friction."
        }
