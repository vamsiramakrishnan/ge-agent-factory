{
  "id": "click-and-collect-sla-monitor",
  "title": "Click-and-Collect SLA Monitor",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/click-and-collect-sla-monitor.json",
  "subtitle": "R-1404 • E-Commerce & Digital",
  "persona": "Fulfillment Operations Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-14",
  "systems": [
    "Salesforce Commerce Cloud",
    "Manhattan Active WM",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "BOPIS orders ready within 2-hour SLA",
      "before": "81%",
      "after": "97%"
    },
    {
      "label": "Pickup order cancellation rate",
      "before": "7.2%",
      "after": "2.0%"
    },
    {
      "label": "Curbside wait time",
      "before": "11 minutes",
      "after": "3 minutes"
    }
  ],
  "statusQuo": [
    "Store pick queues are monitored by whoever remembers to check the tablet between customers.",
    "Orders silently age past SLA and customers arrive to unpicked baskets.",
    "Substitution decisions wait on a manager who is usually on the sales floor."
  ],
  "agentification": [
    "Tracks every BOPIS order against its SLA clock and predicts breaches from store pick-rate telemetry.",
    "Escalates at-risk orders to store leadership and reroutes overflow to nearby locations with inventory.",
    "Recommends substitutions from live availability and notifies the customer with accurate ready times."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Commerce Cloud",
        "description": "online orders, product catalog entries, cart events records"
      },
      {
        "system": "Manhattan Active WM",
        "description": "warehouse orders, pick tasks, inventory snapshots records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query online orders and product catalog entries from Salesforce Commerce Cloud and correlate with Manhattan Active WM for the Click-and-Collect SLA Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Fulfillment Operations Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Click-and-Collect SLA Monitor Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Salesforce Commerce Cloud with a full audit trail, and escalate exceptions to the Fulfillment Operations Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Click-and-Collect SLA Monitor so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
