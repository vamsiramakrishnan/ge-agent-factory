        "description": "Seed a realistic gap where BOPIS orders ready within 2-hour SLA sits between 81% and 97%, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "online_orders",
          "product_catalog_entries"
        ],
        "discoveryPath": [
          "Inspect Salesforce Commerce Cloud records for the affected entities",
          "Compare against Manhattan Active WM historical baseline",
          "Generate a citation-backed recommendation"
