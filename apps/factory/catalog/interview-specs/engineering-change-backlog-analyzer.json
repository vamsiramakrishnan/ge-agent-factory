{
  "id": "engineering-change-backlog-analyzer",
  "title": "Engineering Change Backlog Analyzer",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/engineering-change-backlog-analyzer.json",
  "subtitle": "M-5504 • Engineering & PLM",
  "persona": "Design Engineer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "on-demand",
  "domainId": "domain-55",
  "systems": [
    "PTC Windchill PLM",
    "Jira",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Open change requests older than 90 days",
      "before": "170",
      "after": "35"
    },
    {
      "label": "Change board meeting throughput",
      "before": "8 CRs per session",
      "after": "20 CRs per session"
    },
    {
      "label": "Duplicate change requests",
      "before": "11%",
      "after": "2%"
    }
  ],
  "statusQuo": [
    "Hundreds of open change requests sit in Windchill with no ranking, so the change board reviews them in submission order.",
    "Duplicate and overlapping requests against the same part consume separate review cycles.",
    "Cost-reduction changes worth six figures wait behind typo-level drawing corrections."
  ],
  "agentification": [
    "Clusters the open change request backlog in PTC Windchill PLM by affected part and problem description, merging duplicates and linking related Jira issues.",
    "Scores each request on cost impact, quality risk, and affected production volume from BigQuery data.",
    "Drafts a prioritized change board agenda with a one-paragraph summary per request so the board decides instead of deciphering."
  ],
  "architecture": {
    "connections": [
      {
        "system": "PTC Windchill PLM",
        "description": "engineering change orders, bom revisions, cad document records records"
      },
      {
        "system": "Jira",
        "description": "issues, sprints, epics records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query engineering change orders and bom revisions from PTC Windchill PLM and correlate with Jira for the Engineering Change Backlog Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Design Engineer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Engineering Change Backlog Analyzer Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the draft step in PTC Windchill PLM with a full audit trail, and escalate exceptions to the Design Engineer."
      }
    ]
  },
