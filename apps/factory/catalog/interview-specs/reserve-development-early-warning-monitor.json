{
  "id": "reserve-development-early-warning-monitor",
  "title": "Reserve Development Early Warning Monitor",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/reserve-development-early-warning-monitor.json",
  "subtitle": "I-3203 • Claims",
  "persona": "Claims Operations Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-32",
  "systems": [
    "Guidewire ClaimCenter",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Claims with late reserve strengthening",
      "before": "23%",
      "after": "7%"
    },
    {
      "label": "Average reserve change detection lag",
      "before": "60 days",
      "after": "5 days"
    },
    {
      "label": "Adverse development on open inventory",
      "before": "9.5% of incurred",
      "after": "3.8% of incurred"
    }
  ],
  "statusQuo": [
    "Reserve adequacy on individual claims is only questioned at 90-day diary reviews, long after new medical or legal facts emerged.",
    "Managers discover under-reserved files when a settlement demand blows past the posted reserve.",
    "Stair-stepped reserving distorts actuarial triangles and quarterly IBNR estimates."
  ],
  "agentification": [
    "Monitors new documents, medical bills, and attorney correspondence on every open claim for facts that change expected ultimate cost.",
    "Compares posted reserves against model-predicted severity for similar historical claims in BigQuery and flags gaps above threshold.",
    "Escalates under-reserved files to the claims operations manager with a suggested reserve range and the driving evidence."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire ClaimCenter",
        "description": "claims, claim exposures, reserve lines records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query claims and claim exposures from Guidewire ClaimCenter for the Reserve Development Early Warning Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Claims Operations Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Reserve Development Early Warning Monitor Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in Guidewire ClaimCenter with a full audit trail, and escalate exceptions to the Claims Operations Manager."
      }
    ]
  },
