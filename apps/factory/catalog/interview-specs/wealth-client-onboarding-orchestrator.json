{
  "id": "wealth-client-onboarding-orchestrator",
  "title": "Wealth Client Onboarding Orchestrator",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/wealth-client-onboarding-orchestrator.json",
  "subtitle": "B-2504 • Wealth & Advisory",
  "persona": "Wealth Operations Specialist",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-25",
  "systems": [
    "Salesforce Financial Services Cloud",
    "BigQuery",
    "DocuSign",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Days from signed agreement to funded account",
      "before": "18 days",
      "after": "4 days"
    },
    {
      "label": "NIGO (not-in-good-order) paperwork rate",
      "before": "31%",
      "after": "6%"
    },
    {
      "label": "Onboarding status inquiries to service desk",
      "before": "450/month",
      "after": "70/month"
    }
  ],
  "statusQuo": [
    "New-client paperwork bounces between the advisor, operations, and custodian with a third of packets rejected as not in good order.",
    "ACAT transfer status is checked manually at the custodian portal, and clients call repeatedly asking where their money is.",
    "Each onboarding step is tracked in a different tool, so nobody owns the end-to-end timeline."
  ],
  "agentification": [
    "Validates account applications against custodian requirements before submission and routes corrected forms through DocuSign.",
    "Tracks every onboarding milestone including ACAT transfers, publishing live status to Salesforce for the advisor and client portal.",
    "Escalates stalled transfers to operations with the custodian rejection reason and drafted follow-up already prepared."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Salesforce Financial Services Cloud",
        "description": "client households, financial accounts, advisory referrals records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "DocuSign",
        "description": "envelopes, recipients, audit trails records"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query client households and financial accounts from Salesforce Financial Services Cloud and correlate with DocuSign for the Wealth Client Onboarding Orchestrator workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Wealth Operations Specialist's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Wealth Client Onboarding Orchestrator Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in Salesforce Financial Services Cloud with a full audit trail, and escalate exceptions to the Wealth Operations Specialist."
      }
    ]
  },
