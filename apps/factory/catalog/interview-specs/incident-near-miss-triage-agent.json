{
  "id": "incident-near-miss-triage-agent",
  "title": "Incident and Near-Miss Triage Agent",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/incident-near-miss-triage-agent.json",
  "subtitle": "M-5602 • EHS & Sustainability",
  "persona": "Site Safety Officer",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-56",
  "systems": [
    "Sphera EHS",
    "ServiceNow",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Recordable incident rate (TRIR)",
      "before": "2.4",
      "after": "1.1"
    },
    {
      "label": "Near-miss investigation start time",
      "before": "5 days",
      "after": "4 hours"
    },
    {
      "label": "Corrective actions closed on time",
      "before": "52%",
      "after": "90%"
    }
  ],
  "statusQuo": [
    "Near-miss reports pile up unread for a week because the safety officer triages them between audits and training sessions.",
    "Serious-injury-potential events get the same cursory handling as a paper cut because severity screening is inconsistent.",
    "Corrective actions from investigations drift past due dates with no systematic follow-up."
  ],
  "agentification": [
    "Classifies every new Sphera EHS report by severity potential and regulatory reportability within minutes of submission.",
    "Routes serious-injury-potential events to immediate investigation, drafts the initial investigation record, and proposes similar historical events from BigQuery.",
    "Creates corrective-action tasks in ServiceNow and escalates any action aging past its due date to the responsible manager."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Sphera EHS",
        "description": "safety incidents, permit records, emissions readings records"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query safety incidents and permit records from Sphera EHS and correlate with ServiceNow for the Incident and Near-Miss Triage Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Site Safety Officer's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Incident and Near-Miss Triage Agent Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Sphera EHS with a full audit trail, and escalate exceptions to the Site Safety Officer."
      }
    ]
  },
