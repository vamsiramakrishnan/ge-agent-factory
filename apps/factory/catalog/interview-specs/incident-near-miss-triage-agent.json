          "action": "escalate_to_human",
          "handoffTarget": "site_leader",
          "rationale": "OSHA requires fatality reporting within 8 hours and hospitalization/amputation/eye-loss within 24; site leadership owns the report, scene preservation, and family/agency communication."
        }
