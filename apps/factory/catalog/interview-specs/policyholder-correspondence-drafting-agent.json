  "subtitle": "I-3404 • Policy Servicing",
  "persona": "Customer Service Team Lead",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "on-demand",
  "domainId": "domain-34",
  "systems": [
    "Duck Creek Policy",
    "Zendesk",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Written inquiry response time",
      "before": "3.2 days",
      "after": "4 hours"
    },
    {
      "label": "Correspondence requiring supervisor rewrite",
      "before": "22%",
      "after": "4%"
    },
    {
      "label": "Complaint escalations from unclear letters",
      "before": "60 per quarter",
      "after": "14 per quarter"
    }
  ],
  "statusQuo": [
    "Reps compose coverage-explanation and complaint-response letters from a library of stale templates that no longer match current forms.",
    "Every letter touching coverage interpretation waits in a supervisor review queue.",
    "Inconsistent explanations of the same exclusion across letters create ammunition for disputes."
  ],
  "agentification": [
    "Drafts personalized correspondence grounded in the customer's actual Duck Creek policy forms, endorsements, and Zendesk interaction history.",
    "Checks every draft against approved coverage-interpretation language and plain-language readability standards before it reaches review.",
    "Routes drafts touching denials or complaints to the team lead with cited policy provisions attached for one-pass approval."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Duck Creek Policy",
        "description": "policy forms, rating worksheets, endorsement records records"
      },
      {
        "system": "Zendesk",
        "description": "tickets, macros, satisfaction scores records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query policy forms and rating worksheets from Duck Creek Policy and correlate with Zendesk for the Policyholder Correspondence Drafting Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Customer Service Team Lead's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Policyholder Correspondence Drafting Agent Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in Duck Creek Policy with a full audit trail, and escalate exceptions to the Customer Service Team Lead."
      }
    ]
  },
