  "id": "fraud-rule-tuning-analyzer",
  "title": "Fraud Rule Tuning Analyzer",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/fraud-rule-tuning-analyzer.json",
  "subtitle": "B-2305 • Payments & Fraud",
  "persona": "Fraud Strategy Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-23",
  "systems": [
    "NICE Actimize",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Alert volume per $1M protected",
      "before": "310",
      "after": "140"
    },
    {
      "label": "Fraud detection rate",
      "before": "61%",
      "after": "78%"
    },
    {
      "label": "Rule-tuning cycle time",
      "before": "Quarterly",
      "after": "Weekly"
    }
  ],
  "statusQuo": [
    "Detection rules in NICE Actimize are reviewed quarterly at best, so decayed rules keep generating thousands of worthless alerts.",
    "Measuring a rule's true hit rate requires analysts to join alert outcomes with confirmed-fraud data manually in spreadsheets.",
    "New fraud patterns from the industry sharing groups take months to translate into deployed rule changes."
  ],
  "agentification": [
    "Evaluates every Actimize rule weekly against confirmed-fraud outcomes in BigQuery, scoring precision, recall, and dollar coverage.",
    "Recommends threshold adjustments and retirement candidates with a projected impact on alert volume and detection rate.",
    "Drafts the rule-change proposal document with backtest evidence for the fraud strategy governance meeting."
  ],
  "architecture": {
    "connections": [
      {
        "system": "NICE Actimize",
        "description": "fraud alerts, transaction risk scores, investigation cases records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query fraud alerts and transaction risk scores from NICE Actimize for the Fraud Rule Tuning Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Fraud Strategy Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Fraud Rule Tuning Analyzer Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the recommend step in NICE Actimize with a full audit trail, and escalate exceptions to the Fraud Strategy Manager."
      }
    ]
  },
