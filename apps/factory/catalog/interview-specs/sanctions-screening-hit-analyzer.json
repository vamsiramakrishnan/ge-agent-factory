{
  "id": "sanctions-screening-hit-analyzer",
  "title": "Sanctions Screening Hit Analyzer",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/sanctions-screening-hit-analyzer.json",
  "subtitle": "B-2405 • KYC, AML & Compliance",
  "persona": "Sanctions Screening Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-24",
  "systems": [
    "Fenergo CLM",
    "NICE Actimize",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Screening hits auto-adjudicated",
      "before": "0%",
      "after": "62%"
    },
    {
      "label": "Average hit disposition time",
      "before": "22 min",
      "after": "3 min"
    },
    {
      "label": "Payment delays from screening queues",
      "before": "4.2 hrs avg",
      "after": "35 min avg"
    }
  ],
  "statusQuo": [
    "Over 98% of sanctions screening hits are name-match false positives, each dispositioned manually with a copy-pasted rationale.",
    "Analysts compare dates of birth, addresses, and identifiers across Fenergo records and list entries by eye under intense time pressure.",
    "Payment-screening queues back up during OFAC list updates, delaying legitimate wires for hours and drawing customer complaints."
  ],
  "agentification": [
    "Compares each hit's identifiers against Fenergo customer data and list-entry details, scoring true-match likelihood with cited evidence.",
    "Auto-clears obvious mismatches with a standardized, auditable rationale and releases the associated payments.",
    "Escalates potential true matches to a senior analyst within minutes with a side-by-side identity comparison prepared."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Fenergo CLM",
        "description": "kyc cases, entity profiles, screening results records"
      },
      {
        "system": "NICE Actimize",
        "description": "fraud alerts, transaction risk scores, investigation cases records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query kyc cases and entity profiles from Fenergo CLM and correlate with NICE Actimize for the Sanctions Screening Hit Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Sanctions Screening Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Sanctions Screening Hit Analyzer Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Fenergo CLM with a full audit trail, and escalate exceptions to the Sanctions Screening Analyst."
      }
    ]
  },
