  "id": "fraud-alert-triage-agent",
  "title": "Fraud Alert Triage Agent",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/fraud-alert-triage-agent.json",
  "subtitle": "B-2301 • Payments & Fraud",
  "persona": "Fraud Operations Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-23",
  "systems": [
    "NICE Actimize",
    "BigQuery",
    "ServiceNow",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "False-positive alert rate",
      "before": "94%",
      "after": "68%"
    },
    {
      "label": "Average alert handling time",
      "before": "18 min",
      "after": "4 min"
    },
    {
      "label": "Fraud losses from delayed action",
      "before": "$2.1M/yr",
      "after": "$700K/yr"
    }
  ],
  "statusQuo": [
    "Analysts work through thousands of NICE Actimize alerts a day, the vast majority of which close as false positives after fifteen minutes of research each.",
    "Context gathering means opening five systems to check device history, travel patterns, and recent contact-center interactions per alert.",
    "Genuine account-takeover alerts wait in the same FIFO queue as low-risk card alerts, so real fraud runs for hours before anyone looks."
  ],
  "agentification": [
    "Enriches each Actimize alert with device, transaction, and customer-history context from BigQuery and drafts a disposition summary.",
    "Auto-closes alerts matching well-understood benign patterns with a documented rationale and full audit trail.",
    "Escalates high-risk alerts to the front of the queue and routes confirmed-fraud cases to ServiceNow with the case file pre-built."
  ],
  "architecture": {
    "connections": [
      {
        "system": "NICE Actimize",
        "description": "fraud alerts, transaction risk scores, investigation cases records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query fraud alerts and transaction risk scores from NICE Actimize and correlate with ServiceNow for the Fraud Alert Triage Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Fraud Operations Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Fraud Alert Triage Agent Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the file step in NICE Actimize with a full audit trail, and escalate exceptions to the Fraud Operations Analyst."
      }
    ]
  },
