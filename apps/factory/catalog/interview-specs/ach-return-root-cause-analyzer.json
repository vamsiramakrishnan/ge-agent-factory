{
  "id": "ach-return-root-cause-analyzer",
  "title": "ACH Return Root Cause Analyzer",
  "department": "banking",
  "sourcePath": "catalog/interview-specs/ach-return-root-cause-analyzer.json",
  "subtitle": "B-2304 • Payments & Fraud",
  "persona": "ACH Operations Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "scheduled",
  "domainId": "domain-23",
  "systems": [
    "FIS Payments Hub",
    "BigQuery",
    "Looker",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Unauthorized return rate on originations",
      "before": "0.42%",
      "after": "0.19%"
    },
    {
      "label": "Time to identify a problem originator",
      "before": "3 weeks",
      "after": "1 day"
    },
    {
      "label": "Nacha compliance inquiries per year",
      "before": "5",
      "after": "0"
    }
  ],
  "statusQuo": [
    "Return-code analysis is a monthly spreadsheet exercise that lumps R01 insufficient-funds noise together with serious unauthorized-debit signals.",
    "Corporate originators creeping toward Nacha return-rate thresholds are discovered only after the network sends a warning letter.",
    "Nobody traces repeat returns back to bad account-validation practices at specific origination channels."
  ],
  "agentification": [
    "Analyzes daily ACH return files from the FIS Payments Hub, clustering returns by originator, SEC code, and root cause.",
    "Notifies relationship owners when an originator trends toward the 0.5% unauthorized threshold with a projected breach date.",
    "Publishes a return-rate scorecard to Looker and recommends validation-control fixes for the worst offending channels."
  ],
  "architecture": {
    "connections": [
      {
        "system": "FIS Payments Hub",
        "description": "payment instructions, clearing batches, settlement records records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Looker",
        "description": "Dashboards and metric definitions for KPI reporting"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query payment instructions and clearing batches from FIS Payments Hub for the ACH Return Root Cause Analyzer workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the ACH Operations Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the ACH Return Root Cause Analyzer Banking Compliance Policy and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the publish step in FIS Payments Hub with a full audit trail, and escalate exceptions to the ACH Operations Analyst."
      }
    ]
  },
