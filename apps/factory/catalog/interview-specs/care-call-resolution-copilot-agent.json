    {
      "label": "First-call resolution",
      "before": "62%",
      "after": "81%"
    },
    {
      "label": "Average handle time",
      "before": "11.5 minutes",
      "after": "7 minutes"
    },
    {
      "label": "New-agent time to proficiency",
      "before": "4 months",
      "after": "6 weeks"
    }
  ],
  "statusQuo": [
    "Agents toggle among seven applications mid-call to see billing, device, network, and order status for one customer.",
    "Troubleshooting quality depends entirely on individual agent tenure, and new hires transfer anything complicated.",
    "After-call work consumes two minutes per contact writing free-text notes nobody can analyze later."
  ],
  "agentification": [
    "The copilot assembles a unified customer context panel with billing, outage, device, and order status before the agent says hello.",
    "It suggests the next-best troubleshooting step in real time based on the live conversation and known-issue signatures.",
    "It drafts structured wrap-up notes and disposition codes automatically, and creates follow-up tickets when the issue needs field or engineering work."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Genesys Cloud CX",
        "description": "customer interactions, queue metrics, agent schedules records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Zendesk",
        "description": "tickets, macros, satisfaction scores records"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query customer interactions and queue metrics from Genesys Cloud CX and correlate with Zendesk for the Care Call Resolution Copilot Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Care Team Lead's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Care Call Resolution Copilot Agent Service Assurance Runbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the draft step in Genesys Cloud CX with a full audit trail, and escalate exceptions to the Care Team Lead."
      }
    ]
  },
