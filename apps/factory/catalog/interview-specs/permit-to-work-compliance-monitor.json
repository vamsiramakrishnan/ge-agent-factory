{
  "id": "permit-to-work-compliance-monitor",
  "title": "Permit-to-Work Compliance Monitor",
  "department": "manufacturing",
  "sourcePath": "catalog/interview-specs/permit-to-work-compliance-monitor.json",
  "subtitle": "M-5601 • EHS & Sustainability",
  "persona": "EHS Manager",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-56",
  "systems": [
    "Sphera EHS",
    "ServiceNow",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "High-risk work performed without valid permit",
      "before": "6 events per quarter",
      "after": "0 events per quarter"
    },
    {
      "label": "Permit audit preparation time",
      "before": "4 days",
      "after": "2 hours"
    },
    {
      "label": "Expired permits caught before work continues",
      "before": "40%",
      "after": "98%"
    }
  ],
  "statusQuo": [
    "Hot work and confined-space permits are checked against actual work activity only during spot walkdowns.",
    "Permits expire mid-job and crews keep working because nobody tracks the clock across dozens of active permits.",
    "Contractor permits are filed on paper, making audit preparation a multi-day scavenger hunt."
  ],
  "agentification": [
    "Cross-checks every active high-risk work order against valid permits in Sphera EHS in real time, including isolation and gas-test prerequisites.",
    "Notifies the area supervisor and EHS manager the moment work is detected against a missing, expired, or mismatched permit.",
    "Generates the complete permit compliance evidence pack on demand and logs every exception to BigQuery for trend review."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Sphera EHS",
        "description": "safety incidents, permit records, emissions readings records"
      },
      {
        "system": "ServiceNow",
        "description": "tickets, change requests, incidents records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query safety incidents and permit records from Sphera EHS and correlate with ServiceNow for the Permit-to-Work Compliance Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the EHS Manager's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Permit-to-Work Compliance Monitor Standard Operating Procedure and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the generate step in Sphera EHS with a full audit trail, and escalate exceptions to the EHS Manager."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Permit-to-Work Compliance Monitor so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
