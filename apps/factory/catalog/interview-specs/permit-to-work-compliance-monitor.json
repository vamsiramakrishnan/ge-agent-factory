    "anomalies": [
      {
        "id": "permit-to-work-compliance-monitor-baseline-gap",
        "description": "Seed a realistic gap where High-risk work performed without valid permit sits between 6 events per quarter and 0 events per quarter, so the agent can detect, narrate, and recommend remediation.",
        "affectedEntities": [
          "safety_incidents",
          "permit_records"
        ],
        "discoveryPath": [
          "Inspect Sphera EHS records for the affected entities",
          "Compare against ServiceNow historical baseline",
          "Generate a citation-backed recommendation"
        ],
        "expectedEvidence": [
          "source-system record",
          "historical baseline metric",
          "generated audit trail"
        ],
        "expectedRecommendation": "Explain the gap, cite supporting evidence, and propose the next EHS Manager action."
      }
