{
  "id": "inbound-po-eta-monitor",
  "title": "Inbound PO ETA Monitor",
  "department": "retail",
  "sourcePath": "catalog/interview-specs/inbound-po-eta-monitor.json",
  "subtitle": "R-1203 • Supply Chain & Fulfillment",
  "persona": "Inventory Control Analyst",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-12",
  "systems": [
    "Manhattan Active WM",
    "Oracle Retail MFCS",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "Late-PO detection lead time",
      "before": "2 days after due",
      "after": "9 days before due"
    },
    {
      "label": "Expedite freight spend",
      "before": "$620K/qtr",
      "after": "$210K/qtr"
    },
    {
      "label": "Receiving dock schedule adherence",
      "before": "74%",
      "after": "92%"
    }
  ],
  "statusQuo": [
    "Analysts chase carrier portals and vendor emails one PO at a time to learn a shipment slipped.",
    "Late inbound is discovered at the dock, blowing up appointment schedules for the whole day.",
    "Downstream allocation plans assume on-time arrival because nobody updates ETAs in the system."
  ],
  "agentification": [
    "Ingests ASN, carrier tracking, and port milestone events to predict arrival slippage per PO.",
    "Updates ETAs in Manhattan Active WM and rebalances dock appointments when a delay is confirmed.",
    "Escalates at-risk POs feeding promotions or ad items to the Inventory Control Analyst with expedite options."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Manhattan Active WM",
        "description": "warehouse orders, pick tasks, inventory snapshots records"
      },
      {
        "system": "Oracle Retail MFCS",
        "description": "item master, merchandise hierarchy, cost changes records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query warehouse orders and pick tasks from Manhattan Active WM and correlate with Oracle Retail MFCS for the Inbound PO ETA Monitor workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Inventory Control Analyst's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the Inbound PO ETA Monitor Retail Execution Playbook and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the escalate step in Manhattan Active WM with a full audit trail, and escalate exceptions to the Inventory Control Analyst."
      }
    ]
  },
  "generationSpec": {
    "version": 1,
    "rowPolicy": {
      "defaultRowsPerEntity": 50,
      "minimumRowsPerEntity": 25,
      "seed": 42,
      "rationale": "Row counts sized for Inbound PO ETA Monitor so the agent can demonstrate the workflow against realistic transactional volume without simulating a production warehouse."
    },
