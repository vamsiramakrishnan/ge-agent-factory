  "id": "fnol-triage-routing-agent",
  "title": "FNOL Triage & Routing Agent",
  "department": "insurance",
  "sourcePath": "catalog/interview-specs/fnol-triage-routing-agent.json",
  "subtitle": "I-3201 • Claims",
  "persona": "Claims Intake Specialist",
  "layer": "Layer 3: Custom ADK",
  "triggerType": "event-driven",
  "domainId": "domain-32",
  "systems": [
    "Guidewire ClaimCenter",
    "Zendesk",
    "BigQuery",
    "Vertex AI"
  ],
  "kpis": [
    {
      "label": "FNOL-to-assignment time",
      "before": "26 hours",
      "after": "35 min"
    },
    {
      "label": "Misrouted claims requiring reassignment",
      "before": "18%",
      "after": "4%"
    },
    {
      "label": "Same-day contact rate with claimant",
      "before": "42%",
      "after": "89%"
    }
  ],
  "statusQuo": [
    "First notice of loss arrives through phone, portal, and email and sits in a shared queue until an intake specialist manually reads it.",
    "Complexity and severity are judged from a quick skim, so injury claims sometimes land with adjusters licensed only for property damage.",
    "Claimants wait a full business day just to learn who their adjuster is."
  ],
  "agentification": [
    "Reads every inbound FNOL, extracts loss facts, and scores severity and complexity at the moment of receipt.",
    "Routes each claim to the best-fit adjuster based on line, severity, licensing, jurisdiction, and current workload in ClaimCenter.",
    "Notifies the claimant immediately via Zendesk with their adjuster assignment, claim number, and next steps."
  ],
  "architecture": {
    "connections": [
      {
        "system": "Guidewire ClaimCenter",
        "description": "claims, claim exposures, reserve lines records"
      },
      {
        "system": "Zendesk",
        "description": "tickets, macros, satisfaction scores records"
      },
      {
        "system": "BigQuery",
        "description": "Historical baselines, analytics events, and KPI aggregates"
      },
      {
        "system": "Vertex AI",
        "description": "Grounded reasoning, narrative generation, and evidence-cited recommendations"
      }
    ],
    "pipeline": [
      {
        "label": "Retrieve Records",
        "description": "Query claims and claim exposures from Guidewire ClaimCenter and correlate with Zendesk for the FNOL Triage & Routing Agent workflow."
      },
      {
        "label": "Analyze & Detect",
        "description": "Compare current state against historical baselines and analytics events in BigQuery to detect gaps, score exceptions, and prioritize the Claims Intake Specialist's queue."
      },
      {
        "label": "Validate Evidence",
        "description": "Cross-check every finding against the FNOL Triage & Routing Agent Authority & Referral Guide and cite the governing sections before any recommendation is issued."
      },
      {
        "label": "Act & Audit",
        "description": "Execute the route step in Guidewire ClaimCenter with a full audit trail, and escalate exceptions to the Claims Intake Specialist."
      }
    ]
  },
