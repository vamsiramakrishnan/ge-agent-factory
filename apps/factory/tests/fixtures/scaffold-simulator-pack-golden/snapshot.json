    "apps/factory/simulator-systems/demo_pack/projection.json": "{\n  \"id\": \"demo_pack_projection\",\n  \"version\": 1,\n  \"materialization\": \"Project scenario graph concepts into demo_pack collections; Snowfakery realizes large row sets from the same graph.\",\n  \"collectionMappings\": [\n    {\n      \"graphKinds\": [\n        \"supplier\"\n      ],\n      \"realizedObjects\": [\n        \"suppliers\"\n      ],\n      \"simulatorCollection\": \"suppliers\",\n      \"mergeMode\": \"merge-records-by-primary-key\"\n    },\n    {\n      \"graphKinds\": [\n        \"purchase_order\"\n      ],\n      \"realizedObjects\": [\n        \"purchase_orders\",\n        \"requisitions\"\n      ],\n      \"simulatorCollection\": \"purchase_orders\",\n      \"mergeMode\": \"merge-records-by-primary-key\"\n    },\n    {\n      \"graphKinds\": [\n        \"contract\"\n      ],\n      \"realizedObjects\": [\n        \"contracts\"\n      ],\n      \"simulatorCollection\": \"contracts\",\n      \"mergeMode\": \"merge-records-by-primary-key\"\n    },\n    {\n      \"graphKinds\": [\n        \"approval\"\n      ],\n      \"realizedObjects\": [\n        \"approvals\"\n      ],\n      \"simulatorCollection\": \"approvals\",\n      \"mergeMode\": \"merge-records-by-primary-key\"\n    }\n  ]\n}\n",
