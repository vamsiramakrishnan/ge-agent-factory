    "apps/factory/simulator-systems/demo_pack/seed.json": "{\n  \"suppliers\": [\n    {\n      \"supplier_id\": \"SUPPLIER-001\",\n      \"name\": \"Name 1\",\n      \"status\": \"active\",\n      \"risk_tier\": \"tier_2\",\n      \"country\": \"US\",\n      \"category\": \"Indirect Materials\"\n    }\n  ],\n  \"purchase_orders\": [\n    {\n      \"po_id\": \"PO-001\",\n      \"supplier_id\": \"SUPPLIER-001\",\n      \"status\": \"active\",\n      \"amount\": 125000,\n      \"currency\": \"USD\",\n      \"requester\": \"Taylor Brooks\"\n    }\n  ],\n  \"requisitions\": [\n    {\n      \"requisition_id\": \"REQUISITION-001\",\n      \"supplier_id\": \"SUPPLIER-001\",\n      \"status\": \"active\",\n      \"amount\": 125000,\n      \"cost_center\": \"CC-4100\"\n    }\n  ],\n  \"contracts\": [\n    {\n      \"contract_id\": \"CONTRACT-001\",\n      \"supplier_id\": \"SUPPLIER-001\",\n      \"status\": \"active\",\n      \"effective_date\": \"2026-03-15\",\n      \"expiration_date\": \"2026-03-15\"\n    }\n  ],\n  \"approvals\": [\n    {\n      \"approval_id\": \"APPROVAL-001\",\n      \"source_record_id\": \"SOURCE-RECORD-001\",\n      \"approver\": \"Approver 1\",\n      \"state\": \"active\",\n      \"reason\": \"Quarterly business review\"\n    }\n  ],\n  \"audit_events\": []\n}\n",
    "apps/factory/simulator-systems/demo_pack/tools.json": "{\n  \"id\": \"demo_pack_tools\",\n  \"version\": 1,\n  \"tools\": [\n    {\n      \"name\": \"search_suppliers\",\n      \"description\": \"Search suppliers in demo_pack.\",\n      \"inputSchema\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"query\": {\n            \"type\": \"string\"\n          },\n          \"status\": {\n            \"type\": \"string\"\n          },\n          \"limit\": {\n            \"type\": \"integer\"\n          }\n        }\n      }\n    },\n    {\n      \"name\": \"get_supplier\",\n      \"description\": \"Get one supplier in demo_pack.\",\n      \"inputSchema\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"supplier_id\": {\n            \"type\": \"string\"\n          }\n        },\n        \"required\": [\n          \"supplier_id\"\n        ]\n      }\n    },\n    {\n      \"name\": \"list_pending_approvals\",\n      \"description\": \"List pending demo_pack approvals.\",\n      \"inputSchema\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"source_record_id\": {\n            \"type\": \"string\"\n          }\n        }\n      }\n    },\n    {\n      \"name\": \"submit_supplier_update\",\n      \"description\": \"Submit an update to one supplier in demo_pack.\",\n      \"inputSchema\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"supplier_id\": {\n            \"type\": \"string\"\n          },\n          \"status\": {\n            \"type\": \"string\"\n          },\n          \"note\": {\n            \"type\": \"string\"\n          },\n          \"role\": {\n            \"type\": \"string\"\n          }\n        },\n        \"required\": [\n          \"supplier_id\"\n        ]\n      }\n    },\n    {\n      \"name\": \"list_audit_events\",\n      \"description\": \"List demo_pack simulator audit events.\",\n      \"inputSchema\": {\n        \"type\": \"object\",\n   