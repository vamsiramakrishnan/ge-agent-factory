    "apps/factory/simulator-systems/demo_pack/materialization.json": "{\n  \"id\": \"demo_pack_materialization\",\n  \"version\": 1,\n  \"collections\": {\n    \"suppliers\": {\n      \"primaryKey\": \"supplier_id\",\n      \"fieldAliases\": {\n        \"supplier_id\": [\n          \"supplier_id\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"name\": [\n          \"name\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"status\": [\n          \"status\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"risk_tier\": [\n          \"risk_tier\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"country\": [\n          \"country\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"category\": [\n          \"category\",\n          \"id\",\n          \"source_record_id\"\n        ]\n      },\n      \"defaults\": {\n        \"status\": \"active\"\n      }\n    },\n    \"purchase_orders\": {\n      \"primaryKey\": \"po_id\",\n      \"fieldAliases\": {\n        \"po_id\": [\n          \"po_id\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"supplier_id\": [\n          \"supplier_id\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"status\": [\n          \"status\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"amount\": [\n          \"amount\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"currency\": [\n          \"currency\",\n          \"id\",\n          \"source_record_id\"\n        ],\n        \"requester\": [\n          \"requester\",\n          \"id\",\n          \"source_record_id\"\n        ]\n      },\n      \"defaults\": {\n        \"status\": \"active\"\n      }\n    },\n    \"requisitions\": {\n      \"primaryKey\": \"requisition_id\",\n      \"fieldAliases\": {\n        \"requisition_id\": [\n          \"requisition_id\",\n   