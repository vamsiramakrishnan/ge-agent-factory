{
  "id": "oracle_retail_mfcs_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_suppliers",
      "description": "Search suppliers in oracle_retail_mfcs.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_supplier",
      "description": "Get one supplier in oracle_retail_mfcs.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "supplier_id": {
            "type": "string"
          }
        },
        "required": [
          "supplier_id"
        ]
      }
    },
    {
      "name": "submit_supplier_update",
      "description": "Submit an update to one supplier in oracle_retail_mfcs.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "supplier_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "supplier_id"
        ]
      }
    },
    {
      "name": "list_audit_events",
      "description": "List oracle_retail_mfcs simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  ]
}
