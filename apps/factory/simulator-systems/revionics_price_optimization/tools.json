{
  "id": "revionics_price_optimization_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_planning_models",
      "description": "Search planning_models in revionics_price_optimization.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_planning_model",
      "description": "Get one planning_model in revionics_price_optimization.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "model_id": {
            "type": "string"
          }
        },
        "required": [
          "model_id"
        ]
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List pending revionics_price_optimization approvals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "submit_planning_model_update",
      "description": "Submit an update to one planning_model in revionics_price_optimization.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "model_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "model_id"
        ]
      }
    },
    {
      "name": "list_audit_events",
      "description": "List revionics_price_optimization simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  ]
}
