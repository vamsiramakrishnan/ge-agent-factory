{
  "id": "ptc_windchill_plm_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_projects",
      "description": "Search projects in ptc_windchill_plm.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_project",
      "description": "Get one project in ptc_windchill_plm.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List pending ptc_windchill_plm approvals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "submit_project_update",
      "description": "Submit an update to one project in ptc_windchill_plm.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "name": "list_audit_events",
      "description": "List ptc_windchill_plm simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  ]
}
