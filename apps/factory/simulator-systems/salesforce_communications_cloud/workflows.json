{
  "id": "salesforce_communications_cloud_workflows",
  "version": 1,
  "primitives": [
    "role_permission_gate",
    "state_machine",
    "approval_blocker",
    "audit_trail"
  ],
  "toolHandlers": {
    "submit_account_update": {
      "primitive": "state_machine_update",
      "collection": "accounts",
      "primaryKey": "account_id",
      "roleArg": "role",
      "allowedRoles": [
        "seller",
        "sales_manager",
        "marketing_ops",
        "revops"
      ],
      "stateField": "status",
      "targetStateArg": "status",
      "noteArg": "note",
      "transitions": {
        "*": [
          "active",
          "pending_approval",
          "inactive",
          "cancelled",
          "closed",
          "approved",
          "rejected"
        ],
        "active": [
          "pending_approval",
          "inactive",
          "cancelled",
          "closed"
        ],
        "pending_approval": [
          "active",
          "approved",
          "rejected",
          "cancelled"
        ],
        "approved": [
          "closed",
          "inactive"
        ]
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    }
  }
,
  "mutationModel": "ge.mutation-model.v1"
}
