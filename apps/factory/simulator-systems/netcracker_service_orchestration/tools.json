{
  "id": "netcracker_service_orchestration_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_tickets",
      "description": "Search tickets in netcracker_service_orchestration.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_ticket",
      "description": "Get one ticket in netcracker_service_orchestration.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "ticket_id": {
            "type": "string"
          }
        },
        "required": [
          "ticket_id"
        ]
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List pending netcracker_service_orchestration approvals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "submit_ticket_update",
      "description": "Submit an update to one ticket in netcracker_service_orchestration.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "ticket_id": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "ticket_id"
        ]
      }
    },
    {
      "name": "list_audit_events",
      "description": "List netcracker_service_orchestration simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  ]
}
