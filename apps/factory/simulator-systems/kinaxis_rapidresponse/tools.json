{
  "id": "kinaxis_rapidresponse_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_planning_models",
      "description": "Search planning_models in kinaxis_rapidresponse.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_planning_model",
      "description": "Get one planning_model in kinaxis_rapidresponse.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "model_id": {
            "type": "string"
          }
        },
        "required": [
          "model_id"
        ]
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List pending kinaxis_rapidresponse approvals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "submit_planning_model_update",
      "description": "Submit an update to one planning_model in kinaxis_rapidresponse.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "model_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "model_id"
        ]
      }
    },
    {
      "name": "list_audit_events",
      "description": "List kinaxis_rapidresponse simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  ]
}
