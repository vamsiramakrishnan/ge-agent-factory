        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "period": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        }
      }
    },
    "scenarios": {
      "primaryKey": "scenario_id",
      "fields": {
        "scenario_id": {
          "type": "string"
        },
        "model_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        }
      }
    },
    "forecast_lines": {
      "primaryKey": "forecast_line_id",
      "fields": {
        "forecast_line_id": {
          "type": "string"
        },
        "scenario_id": {
          "type": "string"
        },
        "cost_center": {
          "type": "string"
        },
        "account": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "budget_owners": {
      "primaryKey": "owner_id",
      "fields": {
        "owner_id": {
          "type": "string"
        },
