{
  "id": "submit_expense_report_update_workflow",
  "version": 1,
  "primitives": [
    "role_permission_gate",
    "state_machine",
    "approval_blocker",
    "audit_trail"
  ],
  "toolHandlers": {
    "submit_expense_report_update": {
      "primitive": "state_machine_update",
      "collection": "expense_reports",
      "primaryKey": "report_id",
      "roleArg": "role",
      "allowedRoles": [
        "employee",
        "manager",
        "expense_auditor",
        "finance_partner"
      ],
      "stateField": "status",
      "targetStateArg": "status",
      "noteArg": "note",
      "transitions": {
        "*": [
          "not_submitted",
          "submitted",
          "sent_back",
          "approved",
          "audit_required",
          "paid",
          "closed",
          "cancelled"
        ],
        "not_submitted": [
          "submitted",
          "cancelled"
        ],
        "submitted": [
          "approved",
          "sent_back",
          "audit_required",
          "cancelled"
        ],
        "audit_required": [
          "approved",
          "sent_back"
        ],
        "approved": [
          "paid",
          "closed"
        ],
        "sent_back": [
          "submitted",
          "cancelled"
        ],
        "paid": [
          "closed"
        ]
      },
      "approvalBlockers": [
        {
          "collection": "approvals",
          "sourceRecordField": "source_record_id",
          "states": [
            "requested",
            "pending",
            "pending_approval"
          ],
          "blockedTargetStates": [
            "closed",
            "cancelled",
            "paid",
            "posted",
            "released",
            "awarded"
          ]
        }
      ]
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    }
  }
,
  "mutationModel": "ge.mutation-model.v1"
}
