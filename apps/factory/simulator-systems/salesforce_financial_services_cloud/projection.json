{
  "id": "salesforce_financial_services_cloud_projection",
  "version": 1,
  "materialization": "Project scenario graph concepts into salesforce_financial_services_cloud collections; Snowfakery realizes large row sets from the same graph.",
  "collectionMappings": [
    {
      "graphKinds": [
        "account"
      ],
      "realizedObjects": [
        "accounts",
        "contacts"
      ],
      "simulatorCollection": "accounts",
      "mergeMode": "merge-records-by-primary-key"
    },
    {
      "graphKinds": [
        "opportunity"
      ],
      "realizedObjects": [
        "opportunities"
      ],
      "simulatorCollection": "opportunities",
      "mergeMode": "merge-records-by-primary-key"
    },
    {
      "graphKinds": [
        "activity"
      ],
      "realizedObjects": [
        "activities"
      ],
      "simulatorCollection": "activities",
      "mergeMode": "merge-records-by-primary-key"
    }
  ]
}
