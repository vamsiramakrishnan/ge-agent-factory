{
  "id": "kubernetes_workflows",
  "version": 2,
  "primitives": [
    "role_permission_gate",
    "state_machine_update",
    "approval_blocker",
    "audit_trail",
    "failure_injection",
    "idempotency",
    "rate_limit"
  ],
  "toolHandlers": {
    "submit_pod_update": {
      "primitive": "state_machine_update",
      "collection": "pods",
      "primaryKey": "pod_id",
      "roleArg": "role",
      "allowedRoles": [
        "sre",
        "cluster_admin"
      ],
      "stateField": "phase",
      "targetStateArg": "phase",
      "noteArg": "note",
      "transitions": {
        "*": [
          "Pending",
          "Running",
          "Succeeded",
          "Failed"
        ],
        "Running": [
          "Succeeded",
          "Failed"
        ],
        "Pending": [
          "Running",
          "Failed"
        ],
        "Succeeded": [],
        "Failed": []
      },
      "rateLimit": {
        "capacity": 12,
        "refillPerSecond": 0.5,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 15,
        "max_ms": 70
      },
      "failureModes": {
        "permission_denied": 0.08,
        "conflict": 0.06,
        "validation_error": 0.04,
        "rate_limited": 0.04,
        "timeout": 0.02
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    },
    "submit_deployment_update": {
      "primitive": "state_machine_update",
      "collection": "deployments",
      "primaryKey": "deployment_id",
      "roleArg": "role",
      "allowedRoles": [
        "sre",
        "cluster_admin",
        "release_manager"
      ],
      "stateField": "phase",
      "targetStateArg": "phase",
      "noteArg": "note",
      "transitions": {
        "*": [
          "Progressing",
          "Available",
          "ReplicaFailure"
        ],
        "Progressing": [
          "Available",
          "ReplicaFailure"
        ],
        "Available": [
          "Progressing"
        ],
        "ReplicaFailure": [
          "Progressing"
        ]
      },
      "rateLimit": {
        "capacity": 8,
        "refillPerSecond": 0.3,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 20,
        "max_ms": 85
      },
      "failureModes": {
        "permission_denied": 0.08,
        "conflict": 0.06,
        "validation_error": 0.03,
        "rate_limited": 0.04,
        "timeout": 0.02
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    }
  }
,
  "mutationModel": "ge.mutation-model.v1"
}
