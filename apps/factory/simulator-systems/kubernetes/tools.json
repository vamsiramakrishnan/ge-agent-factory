{
  "id": "kubernetes_tools",
  "version": 3,
  "tools": [
    {
      "name": "search_pods",
      "description": "[GET /api/v1/namespaces/{namespace}/pods] list or watch objects of kind Pod",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Free-text query across pod name, namespace, node, phase, and image."
          },
          "namespace": {
            "type": "string",
            "description": "Namespace containing the pods."
          },
          "phase": {
            "type": "string",
            "description": "Pod phase filter."
          },
          "node": {
            "type": "string",
            "description": "Node name filter."
          },
          "fieldSelector": {
            "type": "string",
            "description": "Kubernetes field selector, e.g. metadata.name=mcp-service-5f1 or status.phase=Running."
          },
          "labelSelector": {
            "type": "string",
            "description": "Kubernetes label selector; simulated against name, namespace, and image text."
          },
          "watch": {
            "type": "boolean",
            "description": "Whether to watch changes."
          },
          "continue": {
            "type": "string",
            "description": "Continue token from a previous list call."
          },
          "limit": {
            "type": "integer",
            "description": "Max rows to return."
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "pods",
        "query": {
          "textFields": [
            "pod_id",
            "name",
            "namespace",
            "node",
            "phase",
            "image"
          ],
          "filters": {
            "namespace": {
              "field": "namespace",
              "op": "eq_ci"
            },
            "phase": {
              "field": "phase",
              "op": "eq_ci"
            },
            "node": {
              "field": "node",
              "op": "eq_ci"
            },
            "fieldSelector": {
              "field": "name",
              "op": "contains"
            },
            "labelSelector": {
              "field": "image",
              "op": "contains"
            }
          },
          "cursorFields": [
            "pod_id",
            "name"
          ],
          "defaultSort": [
            {
              "field": "name",
              "direction": "asc"
            }
          ],
          "pagination": {
            "style": "continue-token",
            "defaultLimit": 50,
            "maxLimit": 500
          }
        }
      }
    },
    {
      "name": "get_pod",
      "description": "[GET /api/v1/namespaces/{namespace}/pods/{name}] read the specified Pod",
      "inputSchema": {
        "type": "object",
        "properties": {
          "pod_id": {
            "type": "string",
            "description": "pod primary key"
          },
          "namespace": {
            "type": "string",
            "description": "Namespace containing the pod."
          },
          "name": {
            "type": "string",
            "description": "name of the Pod"
          }
        },
        "required": [
          "pod_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "pods",
        "primaryKey": "pod_id"
      }
    },
    {
      "name": "submit_pod_update",
      "description": "[PATCH /api/v1/namespaces/{namespace}/pods/{name}] partially update the specified Pod",
      "inputSchema": {
        "type": "object",
        "properties": {
          "pod_id": {
            "type": "string",
            "description": "pod primary key"
          },
          "phase": {
            "type": "string",
            "description": "Target phase."
          },
          "note": {
            "type": "string",
            "description": "Reviewer note recorded on the change."
          },
          "role": {
            "type": "string",
            "description": "Acting role; gated by allowedRoles."
          },
          "idempotency_key": {
            "type": "string",
            "description": "Replays return the original result."
          },
          "namespace": {
            "type": "string",
            "description": "Namespace containing the pod."
          },
          "name": {
            "type": "string",
            "description": "name of the Pod"
          },
          "dryRun": {
            "type": "string",
            "description": "When present, modifications should not be persisted."
          },
          "fieldValidation": {
            "type": "string",
            "description": "Server handling for unknown or duplicate fields."
          }
        },
        "required": [
          "pod_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "pods",
        "primaryKey": "pod_id"
      }
    },
