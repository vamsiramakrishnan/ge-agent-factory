{
  "id": "lexisnexis_risk_solutions_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_companies",
      "description": "Search companies in lexisnexis_risk_solutions.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_company",
      "description": "Get one company in lexisnexis_risk_solutions.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "company_id": {
            "type": "string"
          }
        },
        "required": [
          "company_id"
        ]
      }
    },
    {
      "name": "submit_company_update",
      "description": "Submit an update to one company in lexisnexis_risk_solutions.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "company_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "company_id"
        ]
      }
    },
    {
      "name": "list_audit_events",
      "description": "List lexisnexis_risk_solutions simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  ]
}
