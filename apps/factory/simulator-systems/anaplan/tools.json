{
  "id": "anaplan_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_planning_models",
      "description": "Search planning_models in anaplan.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "planning_models"
      }
    },
    {
      "name": "get_planning_model",
      "description": "Get one planning_model in anaplan.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "model_id": {
            "type": "string"
          }
        },
        "required": [
          "model_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "planning_models",
        "primaryKey": "model_id"
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List pending anaplan approvals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          }
        }
      },
      "binding": {
        "op": "list_pending_approvals",
        "collection": "approvals"
      }
    },
    {
      "name": "submit_planning_model_update",
      "description": "Submit an update to one planning_model in anaplan.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "model_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "model_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "planning_models",
        "primaryKey": "model_id"
      }
    },
    {
      "name": "list_audit_events",
      "description": "List anaplan simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "list_audit_events"
      }
    }
  ]
}
