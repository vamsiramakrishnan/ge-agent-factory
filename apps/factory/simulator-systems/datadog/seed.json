  "monitors": [
    {
      "monitor_id": "mon-payments-latency",
      "service_id": "svc-payments-api",
      "name": "payments-api p95 latency",
      "type": "metric_alert",
      "status": "alert",
      "severity": "p1",
      "query": "avg(last_5m):p95:trace.http.request.duration{service:payments-api,env:prod} > 900",
      "tags": [
        "service:payments-api",
        "env:prod",
        "team:payments-platform"
      ],
      "notification_channels": [
        "#payments-oncall",
        "@pagerduty-payments"
      ],
      "evaluation_delay": 60,
      "last_triggered_at": "2026-06-19T01:54:00Z"
    },
    {
      "monitor_id": "mon-workday-sync-errors",
      "service_id": "svc-workday-sync",
      "name": "workday-sync integration error rate",
      "type": "query_alert",
      "status": "ok",
      "severity": "p2",
      "query": "sum(last_15m):sum:workday.sync.errors{env:prod}.as_count() > 10",
      "tags": [
        "service:workday-sync",
        "env:prod",
        "team:enterprise-integrations"
      ],
      "notification_channels": [
        "#enterprise-integrations"
      ],
      "evaluation_delay": 120,
      "last_triggered_at": "2026-06-12T09:17:00Z"
