{
  "id": "okta_workflows",
  "version": 2,
  "primitives": [
    "role_permission_gate",
    "state_machine_update",
    "approval_blocker",
    "audit_trail",
    "failure_injection",
    "idempotency",
    "rate_limit"
  ],
  "toolHandlers": {
    "submit_user_update": {
      "primitive": "state_machine_update",
      "collection": "users",
      "primaryKey": "user_id",
      "roleArg": "role",
      "allowedRoles": [
        "identity_admin",
        "security_reviewer"
      ],
      "stateField": "status",
      "targetStateArg": "status",
      "noteArg": "note",
      "transitions": {
        "*": [
          "ACTIVE",
          "SUSPENDED",
          "DEPROVISIONED"
        ],
        "ACTIVE": [
          "SUSPENDED",
          "DEPROVISIONED"
        ],
        "SUSPENDED": [
          "ACTIVE",
          "DEPROVISIONED"
        ],
        "STAGED": [
          "PROVISIONED",
          "ACTIVE"
        ],
        "PROVISIONED": [
          "ACTIVE"
        ],
        "DEPROVISIONED": []
      },
      "approvalBlockers": [
        {
          "collection": "approvals",
          "sourceRecordField": "source_record_id",
          "states": [
            "requested",
            "pending"
          ],
          "blockedTargetStates": [
            "DEPROVISIONED"
          ]
        }
      ],
      "rateLimit": {
        "capacity": 10,
        "refillPerSecond": 0.35,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 20,
        "max_ms": 85
      },
      "failureModes": {
        "permission_denied": 0.12,
        "validation_error": 0.08,
        "rate_limited": 0.06,
        "conflict": 0.03,
        "timeout": 0.02
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    }
  }
,
  "mutationModel": "ge.mutation-model.v1"
}
