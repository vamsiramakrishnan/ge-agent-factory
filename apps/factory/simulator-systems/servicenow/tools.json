      "binding": {
        "op": "search",
        "collection": "service_requests"
      }
    },
    {
      "name": "get_service_request",
      "description": "Get one ServiceNow service request by request_id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "request_id": {
            "type": "string"
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string"
