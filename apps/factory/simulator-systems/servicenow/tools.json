{
  "id": "servicenow_tools",
  "version": 2,
  "tools": [
    {
      "name": "search_incidents",
      "description": "Search ServiceNow incidents by free text plus ITIL filters (state, priority, impact, urgency, assignment group, CI, escalation, SLA state).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "urgency": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "assignment_group_id": {
            "type": "string"
          },
          "configuration_item_id": {
            "type": "string"
          },
          "escalation": {
            "type": "string"
          },
          "sla_state": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "incidents"
      }
    },
    {
      "name": "get_incident",
      "description": "Get one ServiceNow incident by incident_id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "incident_id": {
            "type": "string"
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "incident_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "incidents",
        "primaryKey": "incident_id"
      }
    },
    {
      "name": "search_problems",
      "description": "Search ServiceNow problem records by free text and state/priority/assignment-group filters.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "known_error": {
            "type": "string"
          },
          "assignment_group_id": {
            "type": "string"
          },
          "configuration_item_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "problems"
      }
    },
    {
      "name": "get_problem",
      "description": "Get one ServiceNow problem by problem_id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "problem_id": {
            "type": "string"
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "problem_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "problems",
        "primaryKey": "problem_id"
      }
    },
    {
      "name": "search_change_requests",
