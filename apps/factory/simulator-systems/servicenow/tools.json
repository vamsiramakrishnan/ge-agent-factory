    {
      "name": "submit_incident_update",
      "description": "Advance a ServiceNow incident through its lifecycle (new -> in_progress -> on_hold -> resolved -> closed). Requires a resolver/itil role.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "incident_id": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          }
        },
        "required": [
          "incident_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "incidents",
        "primaryKey": "incident_id"
      }
    },
    {
      "name": "submit_problem_update",
      "description": "Advance a ServiceNow problem through investigation (new -> assess -> root_cause_analysis -> fix_in_progress -> resolved -> closed). Requires a problem-manager/itil role.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "problem_id": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          }
        },
        "required": [
          "problem_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "problems",
        "primaryKey": "problem_id"
      }
    },
    {
      "name": "submit_change_request_update",
      "description": "Advance a ServiceNow change request (draft -> assess -> authorize -> scheduled -> implemented -> review -> closed). The transition to scheduled is blocked until CAB approval is granted. Requires a change-manager role.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "change_id": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          }
        },
        "required": [
          "change_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "change_requests",
        "primaryKey": "change_id"
      }
    },
    {
      "name": "submit_service_request_update",
      "description": "Advance a ServiceNow service request through fulfillment (draft -> requested -> approval -> in_progress -> fulfilled -> closed). Blocked from in_progress while a manager approval is pending. Requires a fulfiller/itil role.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "request_id": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          }
        },
        "required": [
          "request_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "service_requests",
        "primaryKey": "request_id"
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List requested (pending) ServiceNow approvals, optionally scoped to one source record.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "list_pending_approvals",
        "collection": "approvals"
      }
    },
    {
      "name": "list_audit_events",
      "description": "List ServiceNow simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "list_audit_events"
      }
    }
  ]
