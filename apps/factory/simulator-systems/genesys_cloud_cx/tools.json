{
  "id": "genesys_cloud_cx_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_accounts",
      "description": "Search accounts in genesys_cloud_cx.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_account",
      "description": "Get one account in genesys_cloud_cx.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "string"
          }
        },
        "required": [
          "account_id"
        ]
      }
    },
    {
      "name": "submit_account_update",
      "description": "Submit an update to one account in genesys_cloud_cx.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "account_id"
        ]
      }
    },
    {
      "name": "list_audit_events",
      "description": "List genesys_cloud_cx simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  ]
}
