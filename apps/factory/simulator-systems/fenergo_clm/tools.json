{
  "id": "fenergo_clm_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_agreements",
      "description": "Search agreements in fenergo_clm.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_agreement",
      "description": "Get one agreement in fenergo_clm.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "agreement_id": {
            "type": "string"
          }
        },
        "required": [
          "agreement_id"
        ]
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List pending fenergo_clm approvals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "submit_agreement_update",
      "description": "Submit an update to one agreement in fenergo_clm.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "agreement_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "agreement_id"
        ]
      }
    },
    {
      "name": "list_audit_events",
      "description": "List fenergo_clm simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  ]
}
