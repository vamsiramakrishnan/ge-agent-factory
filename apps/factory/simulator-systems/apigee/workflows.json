{
  "id": "apigee_workflows",
  "version": 2,
  "primitives": [
    "role_permission_gate",
    "state_machine_update",
    "approval_blocker",
    "audit_trail",
    "failure_injection",
    "idempotency",
    "rate_limit"
  ],
  "toolHandlers": {
    "submit_developer_update": {
      "primitive": "state_machine_update",
      "collection": "developers",
      "primaryKey": "developer_id",
      "roleArg": "role",
      "allowedRoles": [
        "api_admin",
        "org_admin"
      ],
      "stateField": "status",
      "targetStateArg": "status",
      "noteArg": "note",
      "transitions": {
        "*": [
          "active",
          "inactive"
        ],
        "active": [
          "inactive"
        ],
        "inactive": [
          "active"
        ]
      },
      "rateLimit": {
        "capacity": 10,
        "refillPerSecond": 0.35,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 20,
        "max_ms": 90
      },
      "failureModes": {
        "permission_denied": 0.08,
        "validation_error": 0.05,
        "rate_limited": 0.05,
        "conflict": 0.03,
        "timeout": 0.02
      }
    }
  }
}
