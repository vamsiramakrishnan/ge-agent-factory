        },
        "status": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        }
      }
    },
    "signals": {
      "primaryKey": "signal_id",
      "fields": {
        "signal_id": {
          "type": "string"
        },
        "company_id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "signal_type": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "detected_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "watchlists": {
      "primaryKey": "watchlist_id",
      "fields": {
        "watchlist_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        }
      }
