{
  "id": "github_workflows",
  "version": 2,
  "primitives": [
    "role_permission_gate",
    "state_machine_update",
    "approval_blocker",
    "audit_trail",
    "failure_injection",
    "idempotency",
    "rate_limit"
  ],
  "toolHandlers": {
    "submit_issue_update": {
      "primitive": "state_machine_update",
      "collection": "issues",
      "primaryKey": "issue_id",
      "roleArg": "role",
      "allowedRoles": [
        "engineer",
        "project_manager",
        "maintainer"
      ],
      "stateField": "state",
      "targetStateArg": "state",
      "noteArg": "note",
      "transitions": {
        "*": [
          "open",
          "closed"
        ],
        "open": [
          "closed"
        ],
        "closed": [
          "open"
        ]
      },
      "rateLimit": {
        "capacity": 12,
        "refillPerSecond": 0.5,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 15,
        "max_ms": 70
      },
      "failureModes": {
        "permission_denied": 0.08,
        "validation_error": 0.06,
        "rate_limited": 0.05,
        "conflict": 0.04,
        "timeout": 0.02
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    },
    "submit_pull_update": {
      "primitive": "state_machine_update",
      "collection": "pulls",
      "primaryKey": "pull_id",
      "roleArg": "role",
      "allowedRoles": [
        "engineer",
        "maintainer",
        "release_manager"
      ],
      "stateField": "state",
      "targetStateArg": "state",
      "noteArg": "note",
      "transitions": {
        "*": [
          "open",
          "closed"
        ],
        "open": [
          "closed"
        ],
        "closed": [
          "open"
        ]
      },
      "rateLimit": {
        "capacity": 10,
        "refillPerSecond": 0.4,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 20,
        "max_ms": 80
      },
      "failureModes": {
        "permission_denied": 0.08,
        "conflict": 0.06,
        "validation_error": 0.05,
        "rate_limited": 0.04,
        "timeout": 0.02
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    }
  }
,
  "mutationModel": "ge.mutation-model.v1"
}
