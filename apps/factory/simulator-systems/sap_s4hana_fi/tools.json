    {
      "name": "submit_invoice_update",
      "description": "Advance a supplier invoice through its lifecycle (parked -> matched -> pending_approval -> approved -> posted -> paid -> cleared). Posting is gated by three-way match and by any pending approval; payment is gated by the payment block. role: ap_analyst | controller | finance_manager.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "invoice_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          }
        },
        "required": [
          "invoice_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "invoices",
        "primaryKey": "invoice_id"
      }
    },
    {
      "name": "submit_journal_entry_update",
      "description": "Post or reverse a GL journal entry (parked -> pending_approval -> posted -> reversed). Posting is blocked when the posting period is closed. role: gl_accountant | controller | finance_manager.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "journal_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
