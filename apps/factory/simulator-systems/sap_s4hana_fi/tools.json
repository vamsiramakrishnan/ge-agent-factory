{
  "id": "sap_s4hana_fi_tools",
  "version": 3,
  "tools": [
    {
      "name": "search_company_codes",
      "description": "Search SAP company codes (legal entities) with currency, chart of accounts, and open posting period.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "company_codes"
      }
    },
    {
      "name": "get_company_code",
      "description": "Get one company code, including its currently open posting period range.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "company_code": {
            "type": "string"
          }
        },
        "required": [
          "company_code"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "company_codes",
        "primaryKey": "company_code"
      }
    },
