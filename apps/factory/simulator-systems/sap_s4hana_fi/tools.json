        "required": [
          "journal_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "journal_entries",
        "primaryKey": "journal_id"
      }
    },
    {
      "name": "submit_payment_run_update",
      "description": "Execute the automatic payment program: created -> proposed -> released -> executed. Release requires a controller/finance_manager and clears any pending approval. role: ap_analyst | controller | finance_manager.",
      "inputSchema": {
        "type": "object",
        "properties": {
