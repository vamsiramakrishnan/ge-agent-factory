{
  "id": "oracle_field_service_workflows",
  "version": 1,
  "primitives": [
    "role_permission_gate",
    "state_machine",
    "approval_blocker",
    "audit_trail"
  ],
  "toolHandlers": {
    "submit_ticket_update": {
      "primitive": "state_machine_update",
      "collection": "tickets",
      "primaryKey": "ticket_id",
      "roleArg": "role",
      "allowedRoles": [
        "requester",
        "resolver",
        "change_manager",
        "service_owner"
      ],
      "stateField": "state",
      "targetStateArg": "state",
      "noteArg": "note",
      "transitions": {
        "*": [
          "active",
          "pending_approval",
          "inactive",
          "cancelled",
          "closed",
          "approved",
          "rejected"
        ],
        "active": [
          "pending_approval",
          "inactive",
          "cancelled",
          "closed"
        ],
        "pending_approval": [
          "active",
          "approved",
          "rejected",
          "cancelled"
        ],
        "approved": [
          "closed",
          "inactive"
        ]
      },
      "approvalBlockers": [
        {
          "collection": "approvals",
          "sourceRecordField": "source_record_id",
          "states": [
            "requested",
            "pending",
            "pending_approval"
          ],
          "blockedTargetStates": [
            "closed",
            "inactive",
            "cancelled"
          ]
        }
      ]
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    }
  }
,
  "mutationModel": "ge.mutation-model.v1"
}
