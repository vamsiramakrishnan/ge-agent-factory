{
  "id": "jira_workflows",
  "version": 2,
  "primitives": [
    "role_permission_gate",
    "board_state_machine",
    "approval_blocker",
    "audit_trail",
    "failure_injection",
    "idempotency",
    "rate_limit"
  ],
  "toolHandlers": {
    "submit_issue_update": {
      "primitive": "board_state_machine",
      "collection": "issues",
      "primaryKey": "issue_id",
      "roleArg": "role",
      "allowedRoles": ["developer", "lead", "qa", "scrum_master"],
      "stateField": "status",
      "targetStateArg": "status",
      "noteArg": "note",
      "transitions": {
        "*": ["to_do", "in_progress", "in_review", "done", "blocked"],
        "to_do": ["in_progress", "blocked"],
        "in_progress": ["in_review", "blocked", "to_do"],
        "in_review": ["done", "in_progress", "blocked"],
        "blocked": ["to_do", "in_progress"],
        "done": ["in_progress"]
      },
      "approvalBlockers": [
        {
          "collection": "approvals",
          "sourceRecordField": "source_record_id",
          "states": ["requested", "pending", "pending_approval"],
          "blockedTargetStates": ["done"]
        }
      ],
      "rateLimit": {
        "capacity": 12,
        "refillPerSecond": 0.5,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 20,
        "max_ms": 80
      },
      "failureModes": {
        "rate_limited": 0.04,
        "conflict": 0.03,
        "timeout": 0.02,
        "validation_error": 0.02
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    },
    "submit_subtask_update": {
      "primitive": "board_state_machine",
      "collection": "subtasks",
      "primaryKey": "subtask_id",
      "roleArg": "role",
      "allowedRoles": ["developer", "lead", "qa"],
      "stateField": "status",
      "targetStateArg": "status",
      "noteArg": "note",
      "transitions": {
        "*": ["to_do", "in_progress", "in_review", "done"],
        "to_do": ["in_progress"],
        "in_progress": ["in_review", "to_do"],
        "in_review": ["done", "in_progress"],
        "done": ["in_progress"]
      },
      "rateLimit": {
        "capacity": 14,
        "refillPerSecond": 0.6,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 15,
        "max_ms": 65
      },
      "failureModes": {
        "rate_limited": 0.03,
        "conflict": 0.03,
        "timeout": 0.02
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    },
    "submit_sprint_update": {
      "primitive": "board_state_machine",
      "collection": "sprints",
      "primaryKey": "sprint_id",
      "roleArg": "role",
      "allowedRoles": ["scrum_master", "lead"],
      "stateField": "state",
      "targetStateArg": "state",
      "noteArg": "note",
      "transitions": {
        "*": ["future", "active", "closed"],
        "future": ["active"],
        "active": ["closed"],
        "closed": []
      },
      "rateLimit": {
        "capacity": 8,
        "refillPerSecond": 0.25,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 25,
        "max_ms": 90
      },
      "failureModes": {
        "rate_limited": 0.03,
        "validation_error": 0.02
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    },
    "submit_release_update": {
      "primitive": "board_state_machine",
      "collection": "releases",
      "primaryKey": "release_id",
      "roleArg": "role",
      "allowedRoles": ["release_manager", "lead"],
      "stateField": "status",
      "targetStateArg": "status",
      "noteArg": "note",
      "transitions": {
        "*": ["unreleased", "released", "archived"],
        "unreleased": ["released", "archived"],
        "released": ["archived"],
        "archived": []
      },
      "approvalBlockers": [
        {
          "collection": "approvals",
          "sourceRecordField": "source_record_id",
          "states": ["requested", "pending", "pending_approval"],
          "blockedTargetStates": ["released"]
        }
      ],
      "rateLimit": {
        "capacity": 6,
        "refillPerSecond": 0.2,
        "key": "agent:system"
      },
      "latency": {
        "distribution": "uniform",
        "min_ms": 30,
        "max_ms": 100
      },
      "failureModes": {
        "missing_approval": 0.05,
        "rate_limited": 0.03,
        "conflict": 0.03,
        "timeout": 0.02
      }
    ,
      "semantics": "state_transition",
      "compensation": "manual"
    }
  }
,
  "mutationModel": "ge.mutation-model.v1"
}
