    {
      "name": "submit_issue_update",
      "description": "Transition a Jira issue across the board workflow (to_do -> in_progress -> in_review -> done, with blocked). Role-gated to developer/lead/qa; gated by approval blockers when a sign-off is pending. This is the issue-transition write tool.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "issue_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          }
        },
        "required": [
          "issue_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "issues",
        "primaryKey": "issue_id"
      }
    },
