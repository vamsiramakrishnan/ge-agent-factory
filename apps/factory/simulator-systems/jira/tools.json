{
  "id": "jira_tools",
  "version": 2,
  "tools": [
    {
      "name": "search_projects",
      "description": "Search Jira projects by free text and domain filters (project type, status, category).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "project_type_key": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "projects"
      }
    },
    {
      "name": "get_project",
      "description": "Get one Jira project by project_id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "project_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "projects",
        "primaryKey": "project_id"
      }
    },
    {
      "name": "search_components",
      "description": "Search Jira project components by free text and domain filters (project, assignee type).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "assignee_type": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "components"
      }
    },
    {
      "name": "get_component",
      "description": "Get one Jira component by component_id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "component_id": {
            "type": "string"
          }
        },
        "required": [
          "component_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "components",
        "primaryKey": "component_id"
      }
    },
    {
      "name": "search_epics",
      "description": "Search Jira epics by free text and domain filters (project, status, assignee).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "assignee_account_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "epics"
      }
    },
    {
      "name": "get_epic",
      "description": "Get one Jira epic by epic_id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "epic_id": {
            "type": "string"
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "epic_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "epics",
        "primaryKey": "epic_id"
      }
    },
    {
      "name": "search_issues",
      "description": "Search Jira issues (stories, tasks, bugs) by free text and domain filters (project, epic, sprint, type, status, priority, assignee, fix version).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "epic_id": {
            "type": "string"
          },
          "sprint_id": {
            "type": "string"
          },
          "component_id": {
            "type": "string"
          },
          "issue_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "assignee_account_id": {
            "type": "string"
          },
          "fix_version_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "issues",
        "query": {
          "textFields": [
            "key",
            "summary",
            "description",
            "assignee",
            "reporter",
            "labels",
            "status",
            "priority"
          ],
          "filters": {
            "project_id": {
              "field": "project_id",
              "op": "eq"
            },
            "epic_id": {
              "field": "epic_id",
              "op": "eq"
            },
            "sprint_id": {
              "field": "sprint_id",
              "op": "eq"
            },
            "component_id": {
              "field": "component_id",
              "op": "eq"
            },
            "issue_type": {
              "field": "issue_type",
              "op": "eq_ci"
            },
            "status": {
              "field": "status",
              "op": "eq_ci"
            },
            "priority": {
              "field": "priority",
              "op": "eq_ci"
            },
            "assignee_account_id": {
              "field": "assignee_account_id",
              "op": "eq"
            },
            "fix_version_id": {
              "field": "fix_version_id",
              "op": "eq"
            }
          },
          "defaultSort": [
            {
              "field": "updated_at",
              "direction": "desc"
            }
          ],
          "pagination": {
            "style": "offset",
            "defaultLimit": 50,
            "maxLimit": 100
          }
        }
      }
    },
    {
      "name": "get_issue",
