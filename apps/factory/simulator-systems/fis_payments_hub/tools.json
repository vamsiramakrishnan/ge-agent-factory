{
  "id": "fis_payments_hub_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_vendors",
      "description": "Search vendors in fis_payments_hub.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_vendor",
      "description": "Get one vendor in fis_payments_hub.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "vendor_id": {
            "type": "string"
          }
        },
        "required": [
          "vendor_id"
        ]
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List pending fis_payments_hub approvals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "name": "submit_vendor_update",
      "description": "Submit an update to one vendor in fis_payments_hub.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "vendor_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "vendor_id"
        ]
      }
    },
    {
      "name": "list_audit_events",
      "description": "List fis_payments_hub simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  ]
}
