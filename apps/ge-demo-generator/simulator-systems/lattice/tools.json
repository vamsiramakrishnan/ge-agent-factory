{
  "id": "lattice_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_workers",
      "description": "Search workers in lattice.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "workers"
      }
    },
    {
      "name": "get_worker",
      "description": "Get one worker in lattice.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "worker_id": {
            "type": "string"
          }
        },
        "required": [
          "worker_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "workers",
        "primaryKey": "worker_id"
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List pending lattice approvals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          }
        }
      },
      "binding": {
        "op": "list_pending_approvals",
        "collection": "approvals"
      }
    },
    {
      "name": "submit_worker_update",
      "description": "Submit an update to one worker in lattice.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "worker_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "worker_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "workers",
        "primaryKey": "worker_id"
      }
    },
    {
      "name": "list_audit_events",
      "description": "List lattice simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "list_audit_events"
      }
    }
  ]
}
