        "worker_type": "string",
        "position_id": "string",
        "manager_id": "string",
        "supervisory_org_id": "string",
        "cost_center": "string",
        "location": "string",
        "country": "string"
      }
    },
    "positions": {
      "primaryKey": "position_id",
      "fields": {
        "position_id": "string",
