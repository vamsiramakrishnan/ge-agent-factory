{
  "id": "greenhouse_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_candidates",
      "description": "Search candidates in greenhouse.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "candidates"
      }
    },
    {
      "name": "get_candidate",
      "description": "Get one candidate in greenhouse.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "candidate_id": {
            "type": "string"
          }
        },
        "required": [
          "candidate_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "candidates",
        "primaryKey": "candidate_id"
      }
    },
    {
      "name": "list_pending_approvals",
      "description": "List pending greenhouse approvals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_record_id": {
            "type": "string"
          }
        }
      },
      "binding": {
        "op": "list_pending_approvals",
        "collection": "approvals"
      }
    },
    {
      "name": "submit_candidate_update",
      "description": "Submit an update to one candidate in greenhouse.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "candidate_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "candidates",
        "primaryKey": "candidate_id"
      }
    },
    {
      "name": "list_audit_events",
      "description": "List greenhouse simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "list_audit_events"
      }
    }
  ]
}
