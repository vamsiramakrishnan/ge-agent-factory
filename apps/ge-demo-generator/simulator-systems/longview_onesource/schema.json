{
  "id": "longview_onesource_schema",
  "version": 1,
  "collections": {
    "planning_models": {
      "primaryKey": "model_id",
      "fields": {
        "model_id": "string",
        "name": "string",
        "status": "string",
        "period": "string",
        "currency": "string"
      }
    },
    "scenarios": {
      "primaryKey": "scenario_id",
