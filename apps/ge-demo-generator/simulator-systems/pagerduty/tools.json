          },
          "include[]": {
            "type": "string",
            "description": "Array of additional models to include."
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Simulator include aliases such as services or oncalls."
          }
        },
        "required": [
          "policy_id"
        ]
      },
      "binding": {
        "op": "get",
