          },
          "Accept": {
            "type": "string",
            "description": "The `Accept` header is used as a versioning header."
          },
          "Content-Type": {
            "type": "string"
          },
          "user_ids[]": {
            "type": "string",
            "description": "Filters to policies where users are targets."
          },
          "team_ids[]": {
            "type": "string",
