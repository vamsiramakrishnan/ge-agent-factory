    {
      "name": "search_oncalls",
      "description": "[GET /oncalls] List all of the on-calls",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Free-text query across on-call users and policies."
          },
          "Accept": {
            "type": "string",
            "description": "The `Accept` header is used as a versioning header."
          },
          "Content-Type": {
            "type": "string"
          },
          "time_zone": {
            "type": "string",
            "description": "Time zone in which results are rendered."
          },
          "offset": {
            "type": "integer",
            "description": "Offset to start pagination search results."
          },
          "total": {
            "type": "boolean",
            "description": "Set to true to request a populated total count."
          },
          "include[]": {
            "type": "string",
            "description": "Array of additional details to include."
          },
          "user_ids[]": {
            "type": "string",
            "description": "Filters to on-calls for the specified user IDs."
          },
          "escalation_policy_ids[]": {
            "type": "string",
            "description": "Filters to on-calls for the specified escalation policy IDs."
          },
          "schedule_ids[]": {
            "type": "string",
            "description": "Filters to on-calls for the specified schedule IDs."
          },
          "since": {
            "type": "string",
            "description": "Start of the time range."
          },
          "until": {
            "type": "string",
            "description": "End of the time range."
          },
          "earliest": {
            "type": "boolean",
            "description": "Only the earliest on-call for each policy, level, and user."
          },
          "limit": {
            "type": "integer",
            "description": "Max rows to return."
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "oncalls",
        "query": {
          "textFields": [
            "oncall_id",
            "policy_id",
            "user"
          ],
          "filters": {
            "user_ids[]": {
              "field": "user",
              "op": "in"
            },
            "escalation_policy_ids[]": {
              "field": "policy_id",
              "op": "in"
            },
            "since": {
              "field": "end",
              "op": "gte"
            },
