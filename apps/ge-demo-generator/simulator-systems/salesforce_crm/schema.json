{
  "id": "salesforce_crm_schema",
  "version": 1,
  "collections": {
    "accounts": {
      "primaryKey": "account_id",
      "fields": {
        "account_id": "string",
        "name": "string",
        "industry": "string",
        "segment": "string",
        "status": "string"
      }
    },
    "contacts": {
      "primaryKey": "contact_id",
      "fields": {
        "contact_id": "string",
        "account_id": "string",
        "name": "string",
        "email": "string",
        "role": "string"
      }
    },
    "opportunities": {
      "primaryKey": "opportunity_id",
      "fields": {
        "opportunity_id": "string",
        "account_id": "string",
        "stage": "string",
        "amount": "string",
        "close_date": "string"
      }
    },
    "activities": {
      "primaryKey": "activity_id",
      "fields": {
        "activity_id": "string",
        "account_id": "string",
        "type": "string",
        "status": "string",
        "created_at": "string"
      }
    },
    "audit_events": {
      "primaryKey": "event_id",
      "fields": {
        "event_id": "string",
        "action": "string",
        "entity": "string",
        "entity_id": "string",
        "outcome": "string"
      }
    }
  }
}
