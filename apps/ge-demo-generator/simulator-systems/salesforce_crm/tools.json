{
  "id": "salesforce_crm_tools",
  "version": 1,
  "tools": [
    {
      "name": "search_accounts",
      "description": "Search accounts in salesforce_crm.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "accounts"
      }
    },
    {
      "name": "get_account",
      "description": "Get one account in salesforce_crm.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "string"
          }
        },
        "required": [
          "account_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "accounts",
        "primaryKey": "account_id"
      }
    },
    {
      "name": "submit_account_update",
      "description": "Submit an update to one account in salesforce_crm.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "account_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "accounts",
        "primaryKey": "account_id"
      }
    },
    {
      "name": "list_audit_events",
      "description": "List salesforce_crm simulator audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "list_audit_events"
      }
    }
  ]
}
