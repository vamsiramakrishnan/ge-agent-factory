{
  "id": "hubspot_schema",
  "version": 1,
  "collections": {
    "leads": {
      "primaryKey": "lead_id",
      "fields": {
        "lead_id": "string",
        "name": "string",
        "email": "string",
        "status": "string",
        "score": "string",
        "source": "string",
        "account_id": "string"
      }
    },
    "accounts": {
      "primaryKey": "account_id",
