{
  "id": "manageengine_schema",
  "version": 1,
  "collections": {
    "tickets": {
      "primaryKey": "ticket_id",
      "fields": {
        "ticket_id": "string",
        "type": "string",
        "short_description": "string",
        "state": "string",
        "priority": "string",
        "assignment_group": "string",
        "requester": "string",
        "configuration_item": "string",
        "sla": "string"
      }
    },
    "cmdb_items": {
      "primaryKey": "ci_id",
      "fields": {
        "ci_id": "string",
        "name": "string",
        "type": "string",
        "status": "string",
        "owner": "string",
        "criticality": "string"
      }
    },
    "changes": {
      "primaryKey": "change_id",
      "fields": {
        "change_id": "string",
        "ticket_id": "string",
        "state": "string",
        "risk": "string",
        "planned_start": "string",
        "planned_end": "string"
      }
    },
    "slas": {
