    {
      "name": "get_statement_of_work",
      "description": "Get one statement of work.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sow_id": {
            "type": "string"
          }
        },
        "required": [
          "sow_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "statement_of_works",
        "primaryKey": "sow_id"
      }
    },
    {
