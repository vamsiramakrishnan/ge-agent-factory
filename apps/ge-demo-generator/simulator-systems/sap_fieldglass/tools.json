        ]
      },
      "binding": {
        "op": "get",
        "collection": "time_sheets",
        "primaryKey": "time_sheet_id"
      }
    },
    {
      "name": "search_statement_of_works",
      "description": "Search Fieldglass SOWs.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "supplier_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
