      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "worker_id": {
            "type": "string"
          },
          "invoice_status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
