{
  "id": "sap_fieldglass_tools",
  "version": 2,
  "tools": [
    {
      "name": "search_workers",
      "description": "Search Fieldglass workers.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "supplier_id": {
            "type": "string"
          },
          "cost_center": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "workers"
      }
    },
    {
      "name": "get_worker",
      "description": "Get one worker.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "worker_id": {
            "type": "string"
          }
        },
        "required": [
          "worker_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "workers",
        "primaryKey": "worker_id"
      }
    },
    {
      "name": "search_work_orders",
      "description": "Search Fieldglass work orders.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "supplier_id": {
            "type": "string"
          },
          "manager_id": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "work_orders"
      }
    },
    {
      "name": "get_work_order",
      "description": "Get one work order.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "work_order_id": {
            "type": "string"
          }
        },
        "required": [
          "work_order_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "work_orders",
        "primaryKey": "work_order_id"
      }
    },
    {
      "name": "search_job_postings",
