      },
      "binding": {
        "op": "search",
        "collection": "job_postings"
      }
    },
    {
      "name": "get_job_posting",
      "description": "Get one job posting.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "job_posting_id": {
            "type": "string"
          }
        },
