        "primaryKey": "work_order_id"
      }
    },
    {
      "name": "list_audit_events",
      "description": "List Fieldglass audit events.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
