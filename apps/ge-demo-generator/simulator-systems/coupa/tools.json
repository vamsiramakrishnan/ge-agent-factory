{
  "id": "coupa_tools",
  "version": 2,
  "tools": [
    {
      "name": "search_suppliers",
      "description": "Search Coupa suppliers by name, status, risk tier, category, or country.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "risk_tier": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "preferred": {
            "type": "boolean"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "suppliers"
      }
    },
    {
      "name": "get_supplier",
      "description": "Get one Coupa supplier, optionally including scorecards and contracts.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "supplier_id": {
            "type": "string"
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "supplier_id"
        ]
      },
      "binding": {
        "op": "get",
        "collection": "suppliers",
        "primaryKey": "supplier_id"
      }
    },
    {
      "name": "search_supplier_scorecards",
      "description": "Search supplier performance scorecards by supplier, period, rating, or status.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "supplier_id": {
            "type": "string"
          },
          "rating": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "binding": {
        "op": "search",
        "collection": "supplier_scorecards"
      }
    },
    {
      "name": "get_supplier_scorecard",
      "description": "Get one supplier scorecard.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "scorecard_id": {
            "type": "string"
          }
