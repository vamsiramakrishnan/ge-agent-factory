    {
      "name": "submit_requisition_update",
      "description": "Advance a requisition through its approval and PO-creation lifecycle (draft->submitted->manager_approved->procurement_approved->po_created). Blocked while approvals are pending.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "requisition_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "idempotency_key": {
            "type": "string"
          }
        },
        "required": [
          "requisition_id"
        ]
      },
      "binding": {
        "op": "submit",
        "collection": "requisitions",
        "primaryKey": "requisition_id"
      }
    },
    {
      "name": "submit_purchase_order_update",
