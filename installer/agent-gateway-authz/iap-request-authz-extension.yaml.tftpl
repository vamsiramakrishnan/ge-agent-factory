# IAP-based authorization extension for the GE Agent Factory Agent Gateway.
# GENERATED by Terraform from var.agent_gateway_authz_action — DO NOT EDIT BY HAND.
# (Source template: installer/agent-gateway-authz/iap-request-authz-extension.yaml.tftpl)
#
# iamEnforcementMode: DRY_RUN → audit-only (logs decisions, blocks nothing). ENFORCED →
# denies unauthorized calls. failOpen means a verifier error allows traffic. Flip via a
# single var: `terraform apply -var agent_gateway_authz_action=ENFORCED` re-renders this
# file; then re-import it with gcloud (see installer/AGENT-GATEWAY.md). Rollback = set the
# var back to DRY_RUN, apply, re-import.
name: ge-agent-factory-iap-authz-ext
service: iap.googleapis.com
failOpen: true
timeout: 1s
metadata:
  iamEnforcementMode: "${authz_action}"
  iapPolicyVersion: "V1"
