          "kind": "action",
          "sourceSystemId": "sap_s_4hana_fi",
          "description": "Execute the close step in SAP S/4HANA FI after the agent has gathered evidence and validated escalation gates.",
          "requiredInputs": [
            "target_id",
            "rationale"
          ],
          "produces": [
