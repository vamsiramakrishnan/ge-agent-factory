      "method": "POST",
      "path": "/api/sap_s_4hana_sd/match",
      "description": "Synchronous endpoint the agent calls to match in SAP S/4HANA SD after evidence gating.",
      "requestSchema": {
        "target_id": "string",
        "rationale": "string",
        "metadata": "object"
      },
      "responseSchema": {
        "action_id": "string",
        "status": "string",
        "audit_record_id": "string"
      },
      "idempotencyKey": "target_id+rationale"
    }
  ],
