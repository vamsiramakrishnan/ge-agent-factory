    "apis": [
      {
        "id": "kyriba_match_api",
        "sourceSystemId": "kyriba",
        "method": "POST",
        "path": "/api/kyriba/match",
        "description": "Synchronous endpoint the agent calls to match in Kyriba after evidence gating.",
        "requestSchema": {
          "target_id": "string",
          "rationale": "string",
          "metadata": "object"
        },
        "responseSchema": {
          "action_id": "string",
          "status": "string",
          "audit_record_id": "string"
        },
        "idempotencyKey": "target_id+rationale"
      }
    ],
