# Tooling state (don't commit any of this) — EXCEPT .claude/settings.json,
# the repo-shared Claude Code config (hooks installed by `ge harness hooks
# install`); personal overrides belong in .claude/settings.local.json, which
# stays ignored with the rest of the directory.
.claude/*
?*.claude/
!.claude/settings.json
.superpowers/
.antigravitycli/
.codex/
.agents/
.harness/
.ge/
.ge-daemon/
.ge-harness/
.ge-missions/
.ge-docs-shots/
.factory-runs.json

# Generated design tokens (presentation app)
apps/presentation/src/styles/tokens.generated.css
apps/presentation/customer/types.generated.ts

# factory runtime state — ephemeral, never commit
apps/factory/.harness/
apps/factory/.harness-test/
apps/factory/.harness-test-service/
apps/factory/.worktrees/
apps/factory/.e2e-sample/
apps/factory/runs/
apps/factory/.ge-harness/
apps/factory/simulator-systems/_openapi/

# Legacy scratch symlinks
tmp/

# Bulk-provision / generated-agent sync runtime state — ephemeral, never commit.
# NOTE: generated-agents/ and agents-batch.json ARE tracked on purpose.
.bulk-provision-state.json
.generated-agents-sync-state.json
canary-batch.json
.tmp/

# Local env files — per-environment, may hold project ids / endpoints.
# Keep the .env.example templates tracked.
.env
**/.env
!**/.env.example

# ge CLI config + state (per-environment; regenerate with `ge init`)
.ge.json
.ge-state.json

# generated terraform vars (per-environment)
installer/values.tfvars
installer/terraform/.terraform/
installer/terraform/*.tfstate*
installer/terraform/.terraform.lock.hcl

# ge cutover: generated terraform import blocks (project-specific, one-shot)
installer/terraform/imports.generated.tf

# ge sync --local: working clone of the dedicated agents repo
.agents-repo/

apps/factory/.harness/uv-cache/

# repo-local Python venv for the Antigravity harness driver (uv; `make deps`)
.venv/

# Relocated use-case catalog — generated build artifact (regen with `npm run use-cases:sync`)
apps/factory/generated/

# Python bytecode
__pycache__/
*.pyc

# Python editable-install / build artifacts
*.egg-info/
.eggs/
build/
dist/
