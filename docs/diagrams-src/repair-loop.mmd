flowchart TD
    SURVEY(["ge fleet status"]) --> LOGS["ge agents logs\nread failing stage"]
    LOGS --> REPAIR{{"ge fleet repair\nobserve → repair → retry"}}
    REPAIR -->|converged| PROVE(["re-prove"])
    REPAIR -->|attempts exhausted| BLOCKED["blocked"]
    BLOCKED -.->|fix contract or simulation| LOGS
    SURVEY -.->|interrupted, not blocked| RESUME["ge runs resume /\nge agents resume"]
    RESUME --> PROVE

    classDef pass fill:#dfeadf,stroke:#2e7a47,color:#1a1a18
    classDef blocked fill:#fce8e5,stroke:#b3231c,color:#1a1a18
    class PROVE pass
    class BLOCKED blocked
