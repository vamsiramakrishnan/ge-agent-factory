# Regenerate: vhs docs/tapes/ge-status.tape (writes docs/assets/tapes/ge-status.gif)
# Run from the repo root with `ge` on PATH (see SETUP.md).
# Theme derived from packages/design/src/palette.mjs (see docs/DESIGN.md) so
# terminal captures match the console/docs visual system.
Output docs/assets/tapes/ge-status.gif

Set FontFamily "Geist Mono"
Set FontSize 22
Set Width 1200
Set Height 480
Set Padding 24
Set Theme {"name": "ge", "black": "#202124", "red": "#c5221f", "green": "#34a853", "yellow": "#f9ab00", "blue": "#4285f4", "magenta": "#a142f4", "cyan": "#1a73e8", "white": "#f8fafd", "brightBlack": "#5f6368", "brightRed": "#c5221f", "brightGreen": "#34a853", "brightYellow": "#f9ab00", "brightBlue": "#4285f4", "brightMagenta": "#a142f4", "brightCyan": "#1a73e8", "brightWhite": "#ffffff", "background": "#202124", "foreground": "#f8fafd", "cursor": "#1a73e8", "selection": "#3c4043"}

Type "ge"
Enter
Sleep 10s
